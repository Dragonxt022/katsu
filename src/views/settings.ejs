<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Configurações</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'settings' }) %>
  <main x-data="settingsPage()" x-init="load()">
    <% var canEditVar = user.permissions.has('settings.edit'); %>
    <h1>Configurações</h1>

    <% if (user.permissions.has('license.view')) { %>
    <section class="panel">
      <h2>Licença</h2>
      <table>
        <tbody>
          <tr><th>Status</th><td><span class="badge" :class="license.status === 'valida' ? 'ok' : 'off'" x-text="license.message"></span></td></tr>
          <tr><th>Empresa (UUID)</th><td class="muted" x-text="license.companyUuid ?? 'não configurada'"></td></tr>
          <tr><th>Machine ID</th><td class="muted" x-text="license.machineId"></td></tr>
          <tr><th>Plano</th><td x-text="license.plan ?? '—'"></td></tr>
          <tr>
            <th>Módulos</th>
            <td>
              <template x-if="license.modules">
                <template x-for="m in license.modules" :key="m"><span class="badge module" x-text="m"></span></template>
              </template>
              <span x-show="!license.modules" class="muted">sem restrição</span>
            </td>
          </tr>
          <tr><th>Válida até</th><td x-text="license.validUntil ?? '—'"></td></tr>
        </tbody>
      </table>

      <% if (user.permissions.has('license.edit')) { %>
      <h3>Ativar / trocar licença</h3>
      <div class="field">
        <label>Empresa (UUID)</label>
        <input class="input" type="text" x-model="licenseForm.companyUuid" placeholder="uuid fornecido na ativação">
      </div>
      <div class="field">
        <label>Chave de licença</label>
        <input class="input" type="text" x-model="licenseForm.licenseKey" placeholder="chave fornecida na ativação">
      </div>
      <div class="toolbar">
        <button class="btn" @click="saveLicense()" x-text="savingLicense ? 'Salvando…' : 'Salvar licença'"></button>
        <% if (user.permissions.has('sync.run')) { %>
        <button class="btn secondary" @click="syncNow()" x-text="syncing ? 'Sincronizando…' : 'Sincronizar agora'"></button>
        <% } %>
        <span class="error" x-text="licenseError"></span>
      </div>
      <% } %>

      <% if (user.permissions.has('settings.edit')) { %>
      <h3>Servidor de sincronização (cloud)</h3>
      <div class="field">
        <label>URL do servidor</label>
        <input class="input" type="text" x-model="cloudUrlForm.value" placeholder="https://katsu.buscamais.org (padrão do instalador)">
        <p class="hint">Deixe em branco para usar o padrão do instalador. Muda na hora — não precisa gerar novo instalador.</p>
      </div>
      <div class="toolbar">
        <button class="btn secondary" @click="saveCloudUrl()" x-text="savingCloudUrl ? 'Salvando…' : 'Salvar servidor'"></button>
      </div>
      <% } %>
    </section>
    <% } %>

    <% if (canEditVar) { %>
    <details class="advanced">
      <summary>Configurações avançadas (técnicas)</summary>
      <div class="advanced-body">
        <div class="toolbar" x-show="canEdit">
          <button class="btn secondary small" @click="openNew()">Nova configuração</button>
          <span class="error" x-text="error"></span>
        </div>
        <table>
          <thead><tr><th>Chave</th><th>Valor</th><th>Atualizada</th><th></th></tr></thead>
          <tbody>
            <template x-for="s in settings" :key="s.key">
              <tr>
                <td x-text="s.key"></td>
                <td x-text="s.value ?? '—'"></td>
                <td class="muted" x-text="s.updated_at"></td>
                <td style="text-align:right">
                  <button class="btn secondary small" x-show="canEdit" @click="openEdit(s)">Editar</button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </details>
    <% } %>

    <dialog x-ref="dlg">
      <h1>Configuração</h1>
      <label>Chave</label><input type="text" x-model="form.key" :disabled="form.locked" />
      <label>Valor</label><input type="text" x-model="form.value" />
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()">Salvar</button>
      </div>
    </dialog>
  </main>
  <script>
    function settingsPage() {
      return {
        settings: [], license: {}, form: {}, error: '',
        licenseForm: { companyUuid: '', licenseKey: '' }, licenseError: '', savingLicense: false, syncing: false,
        cloudUrlForm: { value: '' }, savingCloudUrl: false,
        canEdit: <%= canEditVar ? 'true' : 'false' %>,
        async load() {
          const r = await fetch('/api/settings');
          if (r.ok) {
            this.settings = await r.json();
            const cu = this.settings.find((s) => s.key === 'sync.server_url');
            this.cloudUrlForm.value = cu?.value ?? '';
          }
          <% if (user.permissions.has('license.view')) { %>
          const l = await fetch('/api/license');
          if (l.ok) this.license = await l.json();
          <% } %>
        },
        <% if (user.permissions.has('license.edit')) { %>
        async saveLicense() {
          if (!this.licenseForm.companyUuid || !this.licenseForm.licenseKey) {
            this.licenseError = 'Preencha empresa e chave de licença.'; return;
          }
          this.savingLicense = true; this.licenseError = '';
          const r = await fetch('/api/license', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyUuid: this.licenseForm.companyUuid, licenseKey: this.licenseForm.licenseKey }),
          });
          this.savingLicense = false;
          if (r.ok) { this.license = await r.json(); this.licenseForm = { companyUuid: '', licenseKey: '' }; }
          else this.licenseError = (await r.json()).error ?? 'Falha ao salvar licença.';
        },
        <% } %>
        <% if (user.permissions.has('sync.run')) { %>
        async syncNow() {
          this.syncing = true; this.licenseError = '';
          const r = await fetch('/api/sync/run', { method: 'POST' });
          this.syncing = false;
          if (r.ok) {
            const l = await fetch('/api/license');
            if (l.ok) this.license = await l.json();
          } else this.licenseError = (await r.json()).error ?? 'Falha ao sincronizar.';
        },
        <% } %>
        <% if (user.permissions.has('settings.edit')) { %>
        async saveCloudUrl() {
          this.savingCloudUrl = true;
          const r = await fetch('/api/settings/sync.server_url', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.cloudUrlForm.value || null }),
          });
          this.savingCloudUrl = false;
          if (r.ok) this.load();
        },
        <% } %>
        openNew() { this.form = { locked: false }; this.$refs.dlg.showModal(); },
        openEdit(s) { this.form = { key: s.key, value: s.value ?? '', locked: true }; this.$refs.dlg.showModal(); },
        async save() {
          if (!this.form.key) return;
          const r = await fetch(`/api/settings/${encodeURIComponent(this.form.key)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.form.value }),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); }
          else this.error = (await r.json()).error ?? 'Erro ao salvar.';
        },
      };
    }
  </script>
</body>
</html>
