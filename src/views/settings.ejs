<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Configurações</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'settings' }) %>
  <main x-data="settingsPage()" x-init="load()">
    <h1>Configurações</h1>

    <div class="tabs">
      <button :class="{ active: tab === 'license' }" @click="tab = 'license'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/></svg>
        Licença
      </button>
      <button :class="{ active: tab === 'empresa' }" @click="tab = 'empresa'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"/></svg>
        Empresa
      </button>
      <button :class="{ active: tab === 'stock' }" @click="tab = 'stock'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>
        Estoque
      </button>
      <button :class="{ active: tab === 'sales' }" @click="tab = 'sales'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Vendas
      </button>
      <button :class="{ active: tab === 'financeiro' }" @click="tab = 'financeiro'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Financeiro
      </button>
      <button :class="{ active: tab === 'fidelidade' }" @click="tab = 'fidelidade'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 8 8 12 8c4 0 5-4 7.5-4a2.5 2.5 0 0 1 0 5H18"/><path d="M12 9v10M18 9v10"/></svg>
        Fidelidade
      </button>
      <% if (user.permissions.has('settings.edit')) { %>
      <button :class="{ active: tab === 'rede' }" @click="tab = 'rede'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="18" x2="6.01" y2="18"/><line x1="10" y1="18" x2="10.01" y2="18"/><path d="M6 14V7a6 6 0 0 1 12 0v7"/></svg>
        Rede local
      </button>
      <% } %>
      <% if (user.permissions.has('settings.edit')) { %>
      <button :class="{ active: tab === 'cardapio' }" @click="tab = 'cardapio'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Cardápio online
      </button>
      <% } %>
      <% if (user.permissions.has('settings.edit') || user.permissions.has('security.pin.manage')) { %>
      <button :class="{ active: tab === 'security' }" @click="tab = 'security'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Segurança
      </button>
      <% } %>
      <% if (user.permissions.has('settings.edit')) { %>
      <button :class="{ active: tab === 'advanced' }" @click="tab = 'advanced'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Avançado
      </button>
      <% } %>
    </div>

    <!-- ═══════ ABA: LICENÇA ═══════ -->
    <div x-show="tab === 'license'">
      <% if (user.permissions.has('license.view')) { %>
      <section class="panel">
        <h2>Status da licença</h2>
        <table>
          <tbody>
            <tr><th>Status</th><td><span class="badge" :class="license.status === 'valida' ? 'ok' : 'off'" x-text="license.message"></span></td></tr>
            <tr><th>Empresa (UUID)</th><td class="muted" x-text="license.companyUuid ?? 'não configurada'"></td></tr>
            <tr><th>Machine ID</th><td class="muted" x-text="license.machineId"></td></tr>
            <tr><th>Plano</th><td x-text="license.plan ?? '—'"></td></tr>
            <tr><th>Atualizações automáticas</th><td><span class="badge" :class="license.canAutoUpdate ? 'ok' : 'off'" x-text="license.canAutoUpdate ? 'Incluídas' : 'Não incluídas neste plano'"></span></td></tr>
            <tr><th>Sincronização/backup em nuvem</th><td><span class="badge" :class="license.canSaveToCloud ? 'ok' : 'off'" x-text="license.canSaveToCloud ? 'Incluído' : 'Não incluído neste plano'"></span></td></tr>
            <tr>
              <th>Módulos</th>
              <td>
                <template x-if="license.modules">
                  <template x-for="m in license.modules" :key="m"><span class="badge module" x-text="m"></span></template>
                </template>
                <span x-show="!license.modules" class="muted">sem restrição</span>
              </td>
            </tr>
            <tr><th>Válida até</th><td x-text="license.validUntil ?? '—'"></td></tr>
            <tr x-show="license.supportPhone || license.supportEmail"><th>Suporte</th><td>
              <span x-show="license.supportPhone" x-text="license.supportPhone"></span>
              <span x-show="license.supportPhone && license.supportEmail"> · </span>
              <span x-show="license.supportEmail" x-text="license.supportEmail"></span>
            </td></tr>
          </tbody>
        </table>
        <% if (user.permissions.has('license.edit')) { %>
        <div class="actions" style="margin-top:1rem">
          <button class="btn" @click="openLicenseDlg()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            Ativar / trocar licença
          </button>
          <% if (user.permissions.has('sync.run')) { %>
           <button class="btn secondary" @click="syncNow()" :disabled="!license.canSaveToCloud" :title="!license.canSaveToCloud ? 'Não incluído no plano atual' : ''" x-text="syncing ? 'Sincronizando…' : 'Sincronizar agora'">
             <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
           </button>
          <% } %>
          <span class="error" x-text="licenseError"></span>
        </div>
        <% } %>
      </section>
      <% } %>
    </div>

    <!-- ═══════ ABA: EMPRESA ═══════ -->
    <div x-show="tab === 'empresa'" x-cloak>
      <section class="panel">
        <h2>Dados da empresa</h2>
        <p class="hint mt-0">Usados no cabeçalho dos cupons de venda e orçamentos impressos.</p>
        <div class="field">
          <label>Nome da empresa</label>
          <input class="input" type="text" x-model="empresa.nome" placeholder="Nome que aparece no cupom/orçamento">
        </div>
        <div class="field">
          <label>CNPJ ou CPF</label>
          <input class="input" type="text" x-model="empresa.documento" placeholder="00.000.000/0000-00">
        </div>
        <div class="field">
          <label>Endereço</label>
          <input class="input" type="text" x-model="empresa.endereco" placeholder="Rua, número, bairro, cidade — UF">
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveEmpresa()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingEmpresa ? 'Salvando…' : 'Salvar dados da empresa'"></span>
          </button>
          <span class="muted" x-show="empresaSaved" x-text="empresaSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: ESTOQUE ═══════ -->
    <div x-show="tab === 'stock'" x-cloak>
      <section class="panel">
        <h2>Configurações de estoque</h2>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="stock.autoSku" />
            Gerar SKU automaticamente ao cadastrar produto
          </label>
        </div>
        <div class="field">
          <label>Valor padrão para estoque mínimo</label>
          <input class="input input-narrow" type="number" min="0" x-model="stock.minStockPadrao" placeholder="0" />
          <p class="hint">Todo produto novo será cadastrado com este valor como estoque mínimo.</p>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveStock()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingStock ? 'Salvando…' : 'Salvar configurações'"></span>
          </button>
          <span class="muted" x-show="stockSaved" x-text="stockSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: VENDAS ═══════ -->
    <div x-show="tab === 'sales'" x-cloak>
      <section class="panel">
        <h2>Configurações de vendas</h2>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="sales.exibirCupom" />
            Exibir mensagem "Imprimir cupom fiscal" ao finalizar venda
          </label>
        </div>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="sales.lembreteCaixa24h" />
            Lembrar de fechar o caixa quando ficar aberto por mais de 24h
          </label>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveSales()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingSales ? 'Salvando…' : 'Salvar configurações'"></span>
          </button>
          <span class="muted" x-show="salesSaved" x-text="salesSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: FINANCEIRO ═══════ -->
    <div x-show="tab === 'financeiro'" x-cloak>
      <section class="panel">
        <h2>Multa e juros por atraso</h2>
        <p class="hint mt-0">
          Aplicados sobre contas a pagar/receber vencidas. A multa é cobrada uma única vez
          quando a conta atrasa; os juros correm por dia de atraso.
        </p>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="financeiro.multaAtiva" />
            Cobrar multa por atraso
          </label>
        </div>
        <div class="field" x-show="financeiro.multaAtiva">
          <label>Percentual da multa (%)</label>
          <input class="input input-narrow" type="text" x-model="financeiro.multaPercentual" placeholder="2,00" />
          <p class="hint">Aplicado uma vez sobre o valor da conta assim que ela vence.</p>
        </div>
        <div class="field" style="margin-top:1.25rem">
          <label class="label-checkbox">
            <input type="checkbox" x-model="financeiro.jurosAtivo" />
            Cobrar juros por atraso (juros de mora)
          </label>
        </div>
        <div class="field" x-show="financeiro.jurosAtivo">
          <label>Percentual de juros ao dia (%)</label>
          <input class="input input-narrow" type="text" x-model="financeiro.jurosPercentualDia" placeholder="0,033" />
          <p class="hint">Juros corridos: incide a cada dia de atraso sobre o valor da conta (ex.: 0,033%/dia ≈ 1%/mês).</p>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveFinanceiro()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingFinanceiro ? 'Salvando…' : 'Salvar configurações'"></span>
          </button>
          <span class="muted" x-show="financeiroSaved" x-text="financeiroSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: FIDELIDADE ═══════ -->
    <div x-show="tab === 'fidelidade'" x-cloak>
      <section class="panel">
        <h2>Clube de fidelidade</h2>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="fidelidade.ativo" />
            Ativar acúmulo de pontos por venda
          </label>
          <p class="hint">Desativado por padrão. Quando ativado, toda venda com cliente identificado acumula pontos automaticamente.</p>
        </div>
        <div class="field">
          <label>Pontos por real gasto</label>
          <input class="input input-narrow" type="number" min="0" step="1" x-model.number="fidelidade.pontosPorReal" />
        </div>
        <div class="field">
          <label>Pontos necessários para resgate</label>
          <input class="input input-narrow" type="number" min="1" x-model.number="fidelidade.pontosResgate" />
        </div>
        <div class="field">
          <label>Valor do resgate (R$)</label>
          <input class="input input-narrow" type="text" x-model="fidelidade.valorResgate" placeholder="0,00" @input="fidelidade.valorResgate = maskMoney(fidelidade.valorResgate)" />
          <p class="hint">Ex.: 100 pontos = R$5,00 — o cliente resgata 100 pontos e ganha R$5,00 de desconto na compra.</p>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveFidelidade()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingFidelidade ? 'Salvando…' : 'Salvar configurações'"></span>
          </button>
          <span class="muted" x-show="fidelidadeSaved" x-text="fidelidadeSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: REDE LOCAL ═══════ -->
    <% if (user.permissions.has('settings.edit')) { %>
    <div x-show="tab === 'rede'" x-cloak>
      <section class="panel">
        <h2>Acesso pela rede local (Wi-Fi/cabo)</h2>
        <p class="hint mt-0">
          Permite abrir o Katsu no navegador de outro aparelho — celular do garçom pra
          lançar pedidos nas comandas, tablet fixo na cozinha pro painel de produção —
          desde que esteja na mesma rede local (Wi-Fi ou cabo) desta máquina. Nenhum dado
          sai da rede local; não é acesso pela internet.
        </p>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="rede.acessoLocal" />
            Permitir acesso pela rede local
          </label>
          <p class="hint">Desligado por padrão. <strong>Requer reiniciar o Katsu</strong> depois de salvar para valer.</p>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveRede()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingRede ? 'Salvando…' : 'Salvar'"></span>
          </button>
          <span class="muted" x-show="redeSaved" x-text="redeSaved"></span>
        </div>
        <% } %>
        <div x-show="networkInfo.urls && networkInfo.urls.length" style="margin-top:1.25rem">
          <p class="hint mt-0">Endereço(s) desta máquina na rede local — acesse pelo navegador do celular/tablet, ou aponte a câmera para o QR:</p>
          <template x-for="u in networkInfo.urls" :key="u.url">
            <div class="flex-row" style="align-items:center;gap:.75rem;margin-bottom:.75rem">
              <img :src="u.qr" width="80" height="80" alt="QR code do endereço" style="border-radius:6px;background:#fff;padding:4px" />
              <div class="flex-row" style="align-items:center;gap:.5rem">
                <code x-text="u.url" style="font-size:1rem;padding:.3rem .6rem;background:var(--surface-hover);border-radius:6px"></code>
                <button type="button" class="btn secondary small" @click="copyUrl(u.url)" x-text="copiedUrl === u.url ? 'Copiado!' : 'Copiar'"></button>
              </div>
            </div>
          </template>
        </div>
        <p class="hint" x-show="rede.acessoLocal && networkInfo.urls && !networkInfo.urls.length">
          Nenhuma interface de rede local detectada — verifique se o cabo/Wi-Fi está conectado.
        </p>
        <p class="hint" style="margin-top:1rem">
          Recomendado: crie usuários com os cargos <strong>Garçom</strong> (só vê Mesas/Comandas) ou
          <strong>Cozinha (KDS)</strong> (só vê o painel de produção) em vez de compartilhar o login de
          administrador nesses aparelhos — veja <a href="/admin/usuarios">Usuários</a> e
          <a href="/admin/cargos">Cargos</a>.
        </p>
      </section>
    </div>
    <% } %>

    <!-- ═══════ ABA: CARDÁPIO ONLINE ═══════ -->
    <% if (user.permissions.has('settings.edit')) { %>
    <div x-show="tab === 'cardapio'" x-cloak>
      <section class="panel">
        <h2>Cardápio online</h2>
        <p class="hint mt-0">
          Página pública, sem login, com os produtos que você escolher — pra clientes verem o
          cardápio pelo celular antes de vir na loja. Fica hospedada na nuvem do Katsu, separada
          do app (não depende do computador estar ligado).
        </p>
        <p class="hint">
          Requer o recurso <strong>"Cardápio online"</strong> ligado em
          <a href="/admin/recursos">Configurações → Recursos</a> e um plano com salvamento em
          nuvem. Depois de ligado, marque os produtos em
          <a href="/app/commercial/produtos">Produtos</a> usando o ícone de globo em cada linha —
          só os marcados aparecem na página pública.
        </p>

        <div x-show="cardapio.loading" class="hint">Carregando…</div>

        <div x-show="!cardapio.loading && cardapio.url" style="margin-top:1rem">
          <div class="flex-row" style="align-items:center;gap:.75rem">
            <img :src="cardapio.qr" width="120" height="120" alt="QR code do cardápio" style="border-radius:6px;background:#fff;padding:6px" />
            <div>
              <code x-text="cardapio.url" style="font-size:.95rem;padding:.3rem .6rem;background:var(--surface-hover);border-radius:6px;word-break:break-all;display:inline-block"></code>
              <div style="margin-top:.5rem">
                <button type="button" class="btn secondary small" @click="copyCardapioUrl()" x-text="cardapio.copied ? 'Copiado!' : 'Copiar link'"></button>
                <a :href="cardapio.url" target="_blank" rel="noopener" class="btn secondary small">Abrir</a>
              </div>
            </div>
          </div>
        </div>

        <p class="hint" x-show="!cardapio.loading && !cardapio.url" style="margin-top:1rem">
          Ainda não é possível gerar o link: é preciso ativar a licença (Configurações → Licença)
          com um plano que inclua salvamento em nuvem.
        </p>
      </section>
    </div>
    <% } %>

    <!-- ═══════ ABA: SEGURANÇA ═══════ -->
    <% if (user.permissions.has('settings.edit') || user.permissions.has('security.pin.manage')) { %>
    <div x-show="tab === 'security'" x-cloak>
      <% if (user.permissions.has('settings.edit')) { %>
      <section class="panel">
        <h2>Confirmação por PIN</h2>
        <div class="field">
          <label class="label-checkbox">
            <input type="checkbox" x-model="security.pinRemoverItem" />
            Exigir PIN de administrador para remover item já lançado no carrinho do PDV
          </label>
          <p class="hint">Desativado por padrão. Quando ativado, o operador do caixa precisa digitar o PIN para confirmar a remoção.</p>
        </div>
        <div class="toolbar">
          <button class="btn" @click="saveSecurity()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span x-text="savingSecurity ? 'Salvando…' : 'Salvar configurações'"></span>
          </button>
          <span class="muted" x-show="securitySaved" x-text="securitySaved"></span>
        </div>
      </section>
      <% } %>
      <% if (user.permissions.has('security.pin.manage')) { %>
      <section class="panel">
        <h2>PIN de administrador</h2>
        <p class="hint mt-0">
          <span x-show="pinConfigured">PIN configurado nesta máquina.</span>
          <span x-show="!pinConfigured">Nenhum PIN configurado ainda nesta máquina.</span>
        </p>
        <div class="field">
          <label>Novo PIN (4 a 6 dígitos)</label>
          <input class="input input-narrow-lg" type="password" inputmode="numeric" maxlength="6" x-model="pinForm.pin">
        </div>
        <div class="field">
          <label>Confirmar PIN</label>
          <input class="input input-narrow-lg" type="password" inputmode="numeric" maxlength="6" x-model="pinForm.confirm">
        </div>
        <div class="toolbar">
          <button class="btn" @click="savePin()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            <span x-text="savingPin ? 'Salvando…' : 'Salvar PIN'"></span>
          </button>
          <span class="error" x-text="pinError"></span>
          <span class="muted" x-show="pinSaved" x-text="pinSaved"></span>
        </div>
      </section>
      <% } %>
    </div>
    <% } %>

    <!-- ═══════ ABA: AVANÇADO ═══════ -->
    <% if (user.permissions.has('settings.edit')) { %>
    <div x-show="tab === 'advanced'" x-cloak>
      <section class="panel">
        <h2>Servidor de sincronização (cloud)</h2>
        <div class="field">
          <label>URL do servidor</label>
          <input class="input" type="text" x-model="cloudUrlForm.value" placeholder="https://katsu.buscamais.org (padrão do instalador)">
          <p class="hint">Deixe em branco para usar o padrão do instalador. Muda na hora — não precisa gerar novo instalador.</p>
        </div>
        <div class="toolbar">
          <button class="btn secondary" @click="saveCloudUrl()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span x-text="savingCloudUrl ? 'Salvando…' : 'Salvar servidor'"></span>
          </button>
        </div>
      </section>
      <div class="toolbar">
        <button class="btn secondary small" @click="openNew()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nova configuração
        </button>
        <span class="error" x-text="error"></span>
      </div>
      <table>
        <thead><tr><th>Chave</th><th>Valor</th><th>Atualizada</th><th></th></tr></thead>
        <tbody>
          <template x-for="s in settings" :key="s.key">
            <tr>
              <td x-text="s.key"></td>
              <td x-text="s.value ?? '—'"></td>
              <td class="muted" x-text="s.updated_at"></td>
              <td class="text-right">
                <button class="btn secondary small" @click="openEdit(s)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  Editar
                </button>
              </td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- ─── MODAL: Ativar / trocar licença ─── -->
    <% if (user.permissions.has('license.edit')) { %>
    <dialog x-ref="licenseDlg">
      <h1>Ativar / trocar licença</h1>
      <label>Empresa (UUID)</label>
      <input type="text" x-model="licenseForm.companyUuid" placeholder="uuid fornecido na ativação" />
      <label>Chave de licença</label>
      <input type="text" x-model="licenseForm.licenseKey" placeholder="chave fornecida na ativação" />
      <div class="error" x-text="licenseError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.licenseDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="saveLicense()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          <span x-text="savingLicense ? 'Salvando…' : 'Salvar licença'"></span>
        </button>
      </div>
    </dialog>
    <% } %>

    <!-- ─── MODAL: Licença ativada com sucesso ─── -->
    <% if (user.permissions.has('license.edit')) { %>
    <dialog x-ref="licenseThanksDlg" style="max-width:400px">
      <div class="dialog-body-center" style="padding:1.5rem 1.5rem .5rem">
        <div class="dialog-icon dialog-icon-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <h2 class="dialog-heading-md">Licença ativada!</h2>
        <p class="dialog-text">Obrigado — já sincronizamos com a nuvem.</p>
        <table style="text-align:left;margin-bottom:.5rem" x-show="licenseThanks.sync && !licenseThanks.sync.skipped">
          <tbody>
            <tr><th>Enviado</th><td x-text="licenseThanks.sync ? licenseThanks.sync.pushed : 0"></td></tr>
            <tr><th>Recebido</th><td x-text="licenseThanks.sync ? licenseThanks.sync.pulled : 0"></td></tr>
          </tbody>
        </table>
        <p class="muted muted-sm" x-show="licenseThanks.sync && licenseThanks.sync.skipped">
          Sincronização em nuvem não incluída no plano atual — os dados continuam só nesta máquina.
        </p>
        <p class="error muted-sm" x-show="licenseThanks.syncError" x-text="'Não deu pra sincronizar agora (' + licenseThanks.syncError + ') — tente de novo em Sincronizar agora.'"></p>
      </div>
      <div class="actions actions-center" style="padding-bottom:1.5rem">
        <button class="btn" @click="$refs.licenseThanksDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Ok
        </button>
      </div>
    </dialog>
    <% } %>

    <!-- ─── MODAL: Configuração avulsa (aba Avançado) ─── -->
    <dialog x-ref="dlg">
      <h1>Configuração</h1>
      <label>Chave</label><input type="text" x-model="form.key" :disabled="form.locked" />
      <label>Valor</label><input type="text" x-model="form.value" />
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="save()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script>
    function settingsPage() {
      return {
        tab: 'license',
        settings: [], license: {}, form: {}, error: '',
        licenseForm: { companyUuid: '', licenseKey: '' }, licenseError: '', savingLicense: false, syncing: false,
        licenseThanks: { sync: null, syncError: null },
        stock: { autoSku: true, minStockPadrao: 0 }, savingStock: false, stockSaved: '',
        sales: { exibirCupom: true, lembreteCaixa24h: true }, savingSales: false, salesSaved: '',
        financeiro: { multaAtiva: false, multaPercentual: '2,00', jurosAtivo: false, jurosPercentualDia: '0,033' },
        savingFinanceiro: false, financeiroSaved: '',
        empresa: { nome: '', documento: '', endereco: '' }, savingEmpresa: false, empresaSaved: '',
        cloudUrlForm: { value: '' }, savingCloudUrl: false,
        security: { pinRemoverItem: false }, savingSecurity: false, securitySaved: '',
        pinConfigured: false, pinForm: { pin: '', confirm: '' }, savingPin: false, pinError: '', pinSaved: '',
        fidelidade: { ativo: false, pontosPorReal: 1, pontosResgate: 100, valorResgate: '5,00' }, savingFidelidade: false, fidelidadeSaved: '',
        rede: { acessoLocal: false }, savingRede: false, redeSaved: '', networkInfo: { urls: [], port: null }, copiedUrl: '',
        cardapio: { url: '', qr: '', loading: true, copied: false },

        async load() {
          const r = await fetch('/api/settings');
          if (r.ok) {
            this.settings = await r.json();
            this.syncSettings();
          }
          <% if (user.permissions.has('license.view')) { %>
          const l = await fetch('/api/license');
          if (l.ok) this.license = await l.json();
          <% } %>
          <% if (user.permissions.has('security.pin.manage')) { %>
          const p = await fetch('/api/security/pin/status');
          if (p.ok) this.pinConfigured = (await p.json()).configured;
          <% } %>
          <% if (user.permissions.has('settings.edit')) { %>
          const n = await fetch('/api/settings/network-info');
          if (n.ok) this.networkInfo = await n.json();
          const c = await fetch('/api/settings/cardapio-info');
          if (c.ok) this.cardapio = { ...(await c.json()), loading: false, copied: false };
          else this.cardapio.loading = false;
          <% } %>
        },
        syncSettings() {
          const auto = this.settings.find(s => s.key === 'estoque.auto_sku');
          this.stock.autoSku = auto?.value !== '0';
          const minStock = this.settings.find(s => s.key === 'estoque.min_stock_padrao');
          this.stock.minStockPadrao = minStock?.value ? Number(minStock.value) : 0;
          const cupom = this.settings.find(s => s.key === 'vendas.exibir_cupom_fiscal');
          this.sales.exibirCupom = cupom?.value !== '0';
          const lembrete = this.settings.find(s => s.key === 'caixa.lembrete_24h');
          this.sales.lembreteCaixa24h = lembrete?.value !== '0';
          this.financeiro.multaAtiva = this.settings.find(s => s.key === 'financeiro.multa_atraso.ativa')?.value === '1';
          const multaPct = this.settings.find(s => s.key === 'financeiro.multa_atraso.percentual')?.value;
          this.financeiro.multaPercentual = (multaPct != null ? Number(multaPct) : 2).toFixed(2).replace('.', ',');
          this.financeiro.jurosAtivo = this.settings.find(s => s.key === 'financeiro.juros_atraso.ativo')?.value === '1';
          const jurosPct = this.settings.find(s => s.key === 'financeiro.juros_atraso.percentual_dia')?.value;
          this.financeiro.jurosPercentualDia = (jurosPct != null ? Number(jurosPct) : 0.033).toString().replace('.', ',');
          const pinRemove = this.settings.find(s => s.key === 'seguranca.pin_remover_item');
          this.security.pinRemoverItem = pinRemove?.value === '1';
          this.fidelidade.ativo = this.settings.find(s => s.key === 'fidelidade.ativo')?.value === '1';
          this.fidelidade.pontosPorReal = Number(this.settings.find(s => s.key === 'fidelidade.pontos_por_real')?.value ?? 1);
          this.fidelidade.pontosResgate = Number(this.settings.find(s => s.key === 'fidelidade.pontos_resgate')?.value ?? 100);
          const valorResgateCents = Number(this.settings.find(s => s.key === 'fidelidade.valor_resgate_cents')?.value ?? 500);
          this.fidelidade.valorResgate = (valorResgateCents / 100).toFixed(2).replace('.', ',');
          const cu = this.settings.find(s => s.key === 'sync.server_url');
          this.cloudUrlForm.value = cu?.value ?? '';
          this.empresa.nome = this.settings.find(s => s.key === 'empresa.nome')?.value ?? '';
          this.empresa.documento = this.settings.find(s => s.key === 'empresa.documento')?.value ?? '';
          this.empresa.endereco = this.settings.find(s => s.key === 'empresa.endereco')?.value ?? '';
          this.rede.acessoLocal = this.settings.find(s => s.key === 'rede.acesso_local')?.value === '1';
        },
        openLicenseDlg() {
          this.licenseForm = { companyUuid: '', licenseKey: '' };
          this.licenseError = '';
          this.$refs.licenseDlg.showModal();
        },
        <% if (user.permissions.has('license.edit')) { %>
        async saveLicense() {
          if (!this.licenseForm.companyUuid || !this.licenseForm.licenseKey) {
            this.licenseError = 'Preencha empresa e chave de licença.'; return;
          }
          this.savingLicense = true; this.licenseError = '';
          const r = await fetch('/api/license', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyUuid: this.licenseForm.companyUuid, licenseKey: this.licenseForm.licenseKey }),
          });
          this.savingLicense = false;
          if (r.ok) {
            const body = await r.json();
            this.license = body;
            this.licenseThanks = { sync: body.sync, syncError: body.syncError };
            this.$refs.licenseDlg.close();
            this.$refs.licenseThanksDlg.showModal();
          } else this.licenseError = (await r.json()).error ?? 'Falha ao salvar licença.';
        },
        <% } %>
        <% if (user.permissions.has('sync.run')) { %>
        async syncNow() {
          this.syncing = true; this.licenseError = '';
          const r = await fetch('/api/sync/run', { method: 'POST' });
          this.syncing = false;
          if (r.ok) {
            const l = await fetch('/api/license');
            if (l.ok) this.license = await l.json();
          } else this.licenseError = (await r.json()).error ?? 'Falha ao sincronizar.';
        },
        <% } %>
        <% if (user.permissions.has('settings.edit')) { %>
        async saveCloudUrl() {
          this.savingCloudUrl = true;
          const r = await fetch('/api/settings/sync.server_url', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.cloudUrlForm.value || null }),
          });
          this.savingCloudUrl = false;
          if (r.ok) await this.load();
        },
        <% } %>
        async saveStock() {
          this.savingStock = true; this.stockSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('estoque.auto_sku', this.stock.autoSku ? '1' : '0'),
            upsert('estoque.min_stock_padrao', String(this.stock.minStockPadrao)),
          ]);
          this.savingStock = false;
          this.stockSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveSales() {
          this.savingSales = true; this.salesSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('vendas.exibir_cupom_fiscal', this.sales.exibirCupom ? '1' : '0'),
            upsert('caixa.lembrete_24h', this.sales.lembreteCaixa24h ? '1' : '0'),
          ]);
          this.savingSales = false;
          this.salesSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveFinanceiro() {
          this.savingFinanceiro = true; this.financeiroSaved = '';
          const pct = (s) => { const n = parseFloat(String(s || '0').replace(',', '.')); return isNaN(n) ? 0 : n; };
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('financeiro.multa_atraso.ativa', this.financeiro.multaAtiva ? '1' : '0'),
            upsert('financeiro.multa_atraso.percentual', String(pct(this.financeiro.multaPercentual))),
            upsert('financeiro.juros_atraso.ativo', this.financeiro.jurosAtivo ? '1' : '0'),
            upsert('financeiro.juros_atraso.percentual_dia', String(pct(this.financeiro.jurosPercentualDia))),
          ]);
          this.savingFinanceiro = false;
          this.financeiroSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const s = await fetch('/api/settings');
          if (s.ok) { this.settings = await s.json(); this.syncSettings(); }
        },
        async saveEmpresa() {
          this.savingEmpresa = true; this.empresaSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: value || null }),
          });
          const results = await Promise.all([
            upsert('empresa.nome', this.empresa.nome),
            upsert('empresa.documento', this.empresa.documento),
            upsert('empresa.endereco', this.empresa.endereco),
          ]);
          this.savingEmpresa = false;
          this.empresaSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveFidelidade() {
          this.savingFidelidade = true; this.fidelidadeSaved = '';
          const valorCents = Math.round(parseFloat(String(this.fidelidade.valorResgate || '0').replace(/\./g, '').replace(',', '.')) * 100);
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('fidelidade.ativo', this.fidelidade.ativo ? '1' : '0'),
            upsert('fidelidade.pontos_por_real', String(this.fidelidade.pontosPorReal)),
            upsert('fidelidade.pontos_resgate', String(this.fidelidade.pontosResgate)),
            upsert('fidelidade.valor_resgate_cents', String(valorCents)),
          ]);
          this.savingFidelidade = false;
          this.fidelidadeSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const s = await fetch('/api/settings');
          if (s.ok) { this.settings = await s.json(); this.syncSettings(); }
        },
        async saveRede() {
          this.savingRede = true; this.redeSaved = '';
          const r = await fetch('/api/settings/rede.acesso_local', {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.rede.acessoLocal ? '1' : '0' }),
          });
          this.savingRede = false;
          this.redeSaved = r.ok ? 'Salvo — reinicie o Katsu para aplicar.' : 'Falha ao salvar.';
        },
        copyUrl(u) {
          navigator.clipboard?.writeText(u).then(() => {
            this.copiedUrl = u;
            setTimeout(() => { if (this.copiedUrl === u) this.copiedUrl = ''; }, 1500);
          });
        },
        copyCardapioUrl() {
          navigator.clipboard?.writeText(this.cardapio.url).then(() => {
            this.cardapio.copied = true;
            setTimeout(() => { this.cardapio.copied = false; }, 1500);
          });
        },
        async saveSecurity() {
          this.savingSecurity = true; this.securitySaved = '';
          const r = await fetch('/api/settings/seguranca.pin_remover_item', {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.security.pinRemoverItem ? '1' : '0' }),
          });
          this.savingSecurity = false;
          this.securitySaved = r.ok ? 'Salvo.' : 'Falha ao salvar.';
          const s = await fetch('/api/settings');
          if (s.ok) { this.settings = await s.json(); this.syncSettings(); }
        },
        async savePin() {
          this.pinError = ''; this.pinSaved = '';
          if (!this.pinForm.pin || this.pinForm.pin !== this.pinForm.confirm) {
            this.pinError = 'Os PINs não conferem.'; return;
          }
          this.savingPin = true;
          const r = await fetch('/api/security/pin', {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pin: this.pinForm.pin }),
          });
          this.savingPin = false;
          if (r.ok) {
            this.pinConfigured = true; this.pinSaved = 'PIN salvo.'; this.pinForm = { pin: '', confirm: '' };
          } else this.pinError = (await r.json()).error ?? 'Falha ao salvar PIN.';
        },
        openNew() { this.form = { locked: false }; this.$refs.dlg.showModal(); },
        openEdit(s) { this.form = { key: s.key, value: s.value ?? '', locked: true }; this.$refs.dlg.showModal(); },
        async save() {
          if (!this.form.key) return;
          const r = await fetch(`/api/settings/${encodeURIComponent(this.form.key)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.form.value }),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); }
          else this.error = (await r.json()).error ?? 'Erro ao salvar.';
        },
      };
    }
  </script>
</body>
</html>
