<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Configurações</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'settings' }) %>
  <main x-data="settingsPage()" x-init="load()">
    <h1>Configurações</h1>

    <div class="tabs">
      <button :class="{ active: tab === 'license' }" @click="tab = 'license'">Licença</button>
      <button :class="{ active: tab === 'empresa' }" @click="tab = 'empresa'">Empresa</button>
      <button :class="{ active: tab === 'stock' }" @click="tab = 'stock'">Estoque</button>
      <button :class="{ active: tab === 'sales' }" @click="tab = 'sales'">Vendas</button>
      <% if (user.permissions.has('settings.edit') || user.permissions.has('security.pin.manage')) { %>
      <button :class="{ active: tab === 'security' }" @click="tab = 'security'">Segurança</button>
      <% } %>
      <% if (user.permissions.has('settings.edit')) { %>
      <button :class="{ active: tab === 'advanced' }" @click="tab = 'advanced'">Avançado</button>
      <% } %>
    </div>

    <!-- ═══════ ABA: LICENÇA ═══════ -->
    <div x-show="tab === 'license'">
      <% if (user.permissions.has('license.view')) { %>
      <section class="panel">
        <h2>Status da licença</h2>
        <table>
          <tbody>
            <tr><th>Status</th><td><span class="badge" :class="license.status === 'valida' ? 'ok' : 'off'" x-text="license.message"></span></td></tr>
            <tr><th>Empresa (UUID)</th><td class="muted" x-text="license.companyUuid ?? 'não configurada'"></td></tr>
            <tr><th>Machine ID</th><td class="muted" x-text="license.machineId"></td></tr>
            <tr><th>Plano</th><td x-text="license.plan ?? '—'"></td></tr>
            <tr><th>Atualizações automáticas</th><td><span class="badge" :class="license.canAutoUpdate ? 'ok' : 'off'" x-text="license.canAutoUpdate ? 'Incluídas' : 'Não incluídas neste plano'"></span></td></tr>
            <tr><th>Sincronização/backup em nuvem</th><td><span class="badge" :class="license.canSaveToCloud ? 'ok' : 'off'" x-text="license.canSaveToCloud ? 'Incluído' : 'Não incluído neste plano'"></span></td></tr>
            <tr>
              <th>Módulos</th>
              <td>
                <template x-if="license.modules">
                  <template x-for="m in license.modules" :key="m"><span class="badge module" x-text="m"></span></template>
                </template>
                <span x-show="!license.modules" class="muted">sem restrição</span>
              </td>
            </tr>
            <tr><th>Válida até</th><td x-text="license.validUntil ?? '—'"></td></tr>
            <tr x-show="license.supportPhone || license.supportEmail"><th>Suporte</th><td>
              <span x-show="license.supportPhone" x-text="license.supportPhone"></span>
              <span x-show="license.supportPhone && license.supportEmail"> · </span>
              <span x-show="license.supportEmail" x-text="license.supportEmail"></span>
            </td></tr>
          </tbody>
        </table>
        <% if (user.permissions.has('license.edit')) { %>
        <div class="actions" style="margin-top:1rem">
          <button class="btn" @click="openLicenseDlg()">Ativar / trocar licença</button>
          <% if (user.permissions.has('sync.run')) { %>
          <button class="btn secondary" @click="syncNow()" :disabled="!license.canSaveToCloud" :title="!license.canSaveToCloud ? 'Não incluído no plano atual' : ''" x-text="syncing ? 'Sincronizando…' : 'Sincronizar agora'"></button>
          <% } %>
          <span class="error" x-text="licenseError"></span>
        </div>
        <% } %>
      </section>
      <% } %>
    </div>

    <!-- ═══════ ABA: EMPRESA ═══════ -->
    <div x-show="tab === 'empresa'" x-cloak>
      <section class="panel">
        <h2>Dados da empresa</h2>
        <p class="hint" style="margin-top:0">Usados no cabeçalho dos cupons de venda e orçamentos impressos.</p>
        <div class="field">
          <label>Nome da empresa</label>
          <input class="input" type="text" x-model="empresa.nome" placeholder="Nome que aparece no cupom/orçamento">
        </div>
        <div class="field">
          <label>CNPJ ou CPF</label>
          <input class="input" type="text" x-model="empresa.documento" placeholder="00.000.000/0000-00">
        </div>
        <div class="field">
          <label>Endereço</label>
          <input class="input" type="text" x-model="empresa.endereco" placeholder="Rua, número, bairro, cidade — UF">
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveEmpresa()" x-text="savingEmpresa ? 'Salvando…' : 'Salvar dados da empresa'"></button>
          <span class="muted" x-show="empresaSaved" x-text="empresaSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: ESTOQUE ═══════ -->
    <div x-show="tab === 'stock'" x-cloak>
      <section class="panel">
        <h2>Configurações de estoque</h2>
        <div class="field">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" x-model="stock.autoSku" />
            Gerar SKU automaticamente ao cadastrar produto
          </label>
        </div>
        <div class="field">
          <label>Valor padrão para estoque mínimo</label>
          <input class="input" type="number" min="0" x-model="stock.minStockPadrao" placeholder="0" style="max-width:120px" />
          <p class="hint">Todo produto novo será cadastrado com este valor como estoque mínimo.</p>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveStock()" x-text="savingStock ? 'Salvando…' : 'Salvar configurações'"></button>
          <span class="muted" x-show="stockSaved" x-text="stockSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: VENDAS ═══════ -->
    <div x-show="tab === 'sales'" x-cloak>
      <section class="panel">
        <h2>Configurações de vendas</h2>
        <div class="field">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" x-model="sales.exibirCupom" />
            Exibir mensagem "Imprimir cupom fiscal" ao finalizar venda
          </label>
        </div>
        <div class="field">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" x-model="sales.lembreteCaixa24h" />
            Lembrar de fechar o caixa quando ficar aberto por mais de 24h
          </label>
        </div>
        <% if (user.permissions.has('settings.edit')) { %>
        <div class="toolbar">
          <button class="btn" @click="saveSales()" x-text="savingSales ? 'Salvando…' : 'Salvar configurações'"></button>
          <span class="muted" x-show="salesSaved" x-text="salesSaved"></span>
        </div>
        <% } %>
      </section>
    </div>

    <!-- ═══════ ABA: SEGURANÇA ═══════ -->
    <% if (user.permissions.has('settings.edit') || user.permissions.has('security.pin.manage')) { %>
    <div x-show="tab === 'security'" x-cloak>
      <% if (user.permissions.has('settings.edit')) { %>
      <section class="panel">
        <h2>Confirmação por PIN</h2>
        <div class="field">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" x-model="security.pinRemoverItem" />
            Exigir PIN de administrador para remover item já lançado no carrinho do PDV
          </label>
          <p class="hint">Desativado por padrão. Quando ativado, o operador do caixa precisa digitar o PIN para confirmar a remoção.</p>
        </div>
        <div class="toolbar">
          <button class="btn" @click="saveSecurity()" x-text="savingSecurity ? 'Salvando…' : 'Salvar configurações'"></button>
          <span class="muted" x-show="securitySaved" x-text="securitySaved"></span>
        </div>
      </section>
      <% } %>
      <% if (user.permissions.has('security.pin.manage')) { %>
      <section class="panel">
        <h2>PIN de administrador</h2>
        <p class="hint" style="margin-top:0">
          <span x-show="pinConfigured">PIN configurado nesta máquina.</span>
          <span x-show="!pinConfigured">Nenhum PIN configurado ainda nesta máquina.</span>
        </p>
        <div class="field">
          <label>Novo PIN (4 a 6 dígitos)</label>
          <input class="input" type="password" inputmode="numeric" maxlength="6" x-model="pinForm.pin" style="max-width:160px">
        </div>
        <div class="field">
          <label>Confirmar PIN</label>
          <input class="input" type="password" inputmode="numeric" maxlength="6" x-model="pinForm.confirm" style="max-width:160px">
        </div>
        <div class="toolbar">
          <button class="btn" @click="savePin()" x-text="savingPin ? 'Salvando…' : 'Salvar PIN'"></button>
          <span class="error" x-text="pinError"></span>
          <span class="muted" x-show="pinSaved" x-text="pinSaved"></span>
        </div>
      </section>
      <% } %>
    </div>
    <% } %>

    <!-- ═══════ ABA: AVANÇADO ═══════ -->
    <% if (user.permissions.has('settings.edit')) { %>
    <div x-show="tab === 'advanced'" x-cloak>
      <section class="panel">
        <h2>Servidor de sincronização (cloud)</h2>
        <div class="field">
          <label>URL do servidor</label>
          <input class="input" type="text" x-model="cloudUrlForm.value" placeholder="https://katsu.buscamais.org (padrão do instalador)">
          <p class="hint">Deixe em branco para usar o padrão do instalador. Muda na hora — não precisa gerar novo instalador.</p>
        </div>
        <div class="toolbar">
          <button class="btn secondary" @click="saveCloudUrl()" x-text="savingCloudUrl ? 'Salvando…' : 'Salvar servidor'"></button>
        </div>
      </section>
      <div class="toolbar">
        <button class="btn secondary small" @click="openNew()">Nova configuração</button>
        <span class="error" x-text="error"></span>
      </div>
      <table>
        <thead><tr><th>Chave</th><th>Valor</th><th>Atualizada</th><th></th></tr></thead>
        <tbody>
          <template x-for="s in settings" :key="s.key">
            <tr>
              <td x-text="s.key"></td>
              <td x-text="s.value ?? '—'"></td>
              <td class="muted" x-text="s.updated_at"></td>
              <td style="text-align:right">
                <button class="btn secondary small" @click="openEdit(s)">Editar</button>
              </td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- ─── MODAL: Ativar / trocar licença ─── -->
    <% if (user.permissions.has('license.edit')) { %>
    <dialog x-ref="licenseDlg">
      <h1>Ativar / trocar licença</h1>
      <label>Empresa (UUID)</label>
      <input type="text" x-model="licenseForm.companyUuid" placeholder="uuid fornecido na ativação" />
      <label>Chave de licença</label>
      <input type="text" x-model="licenseForm.licenseKey" placeholder="chave fornecida na ativação" />
      <div class="error" x-text="licenseError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.licenseDlg.close()">Cancelar</button>
        <button class="btn" @click="saveLicense()" x-text="savingLicense ? 'Salvando…' : 'Salvar licença'"></button>
      </div>
    </dialog>
    <% } %>

    <!-- ─── MODAL: Licença ativada com sucesso ─── -->
    <% if (user.permissions.has('license.edit')) { %>
    <dialog x-ref="licenseThanksDlg" style="max-width:400px">
      <div style="text-align:center;padding:1.5rem 1.5rem .5rem">
        <div style="width:48px;height:48px;border-radius:50%;background:var(--primary-bg, #eef0fe);display:grid;place-items:center;margin:0 auto 1rem">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <h2 style="font-size:1.05rem;font-weight:600;margin-bottom:.5rem">Licença ativada!</h2>
        <p style="color:var(--text-secondary);font-size:.9rem;margin-bottom:1rem">Obrigado — já sincronizamos com a nuvem.</p>
        <table style="text-align:left;margin-bottom:.5rem" x-show="licenseThanks.sync && !licenseThanks.sync.skipped">
          <tbody>
            <tr><th>Enviado</th><td x-text="licenseThanks.sync ? licenseThanks.sync.pushed : 0"></td></tr>
            <tr><th>Recebido</th><td x-text="licenseThanks.sync ? licenseThanks.sync.pulled : 0"></td></tr>
          </tbody>
        </table>
        <p class="muted" style="font-size:.85rem" x-show="licenseThanks.sync && licenseThanks.sync.skipped">
          Sincronização em nuvem não incluída no plano atual — os dados continuam só nesta máquina.
        </p>
        <p class="error" style="font-size:.85rem" x-show="licenseThanks.syncError" x-text="'Não deu pra sincronizar agora (' + licenseThanks.syncError + ') — tente de novo em Sincronizar agora.'"></p>
      </div>
      <div class="actions" style="justify-content:center;padding-bottom:1.5rem">
        <button class="btn" @click="$refs.licenseThanksDlg.close()">Ok</button>
      </div>
    </dialog>
    <% } %>

    <!-- ─── MODAL: Configuração avulsa (aba Avançado) ─── -->
    <dialog x-ref="dlg">
      <h1>Configuração</h1>
      <label>Chave</label><input type="text" x-model="form.key" :disabled="form.locked" />
      <label>Valor</label><input type="text" x-model="form.value" />
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()">Salvar</button>
      </div>
    </dialog>
  </main>
  <script>
    function settingsPage() {
      return {
        tab: 'license',
        settings: [], license: {}, form: {}, error: '',
        licenseForm: { companyUuid: '', licenseKey: '' }, licenseError: '', savingLicense: false, syncing: false,
        licenseThanks: { sync: null, syncError: null },
        stock: { autoSku: true, minStockPadrao: 0 }, savingStock: false, stockSaved: '',
        sales: { exibirCupom: true, lembreteCaixa24h: true }, savingSales: false, salesSaved: '',
        empresa: { nome: '', documento: '', endereco: '' }, savingEmpresa: false, empresaSaved: '',
        cloudUrlForm: { value: '' }, savingCloudUrl: false,
        security: { pinRemoverItem: false }, savingSecurity: false, securitySaved: '',
        pinConfigured: false, pinForm: { pin: '', confirm: '' }, savingPin: false, pinError: '', pinSaved: '',

        async load() {
          const r = await fetch('/api/settings');
          if (r.ok) {
            this.settings = await r.json();
            this.syncSettings();
          }
          <% if (user.permissions.has('license.view')) { %>
          const l = await fetch('/api/license');
          if (l.ok) this.license = await l.json();
          <% } %>
          <% if (user.permissions.has('security.pin.manage')) { %>
          const p = await fetch('/api/security/pin/status');
          if (p.ok) this.pinConfigured = (await p.json()).configured;
          <% } %>
        },
        syncSettings() {
          const auto = this.settings.find(s => s.key === 'estoque.auto_sku');
          this.stock.autoSku = auto?.value !== '0';
          const minStock = this.settings.find(s => s.key === 'estoque.min_stock_padrao');
          this.stock.minStockPadrao = minStock?.value ? Number(minStock.value) : 0;
          const cupom = this.settings.find(s => s.key === 'vendas.exibir_cupom_fiscal');
          this.sales.exibirCupom = cupom?.value !== '0';
          const lembrete = this.settings.find(s => s.key === 'caixa.lembrete_24h');
          this.sales.lembreteCaixa24h = lembrete?.value !== '0';
          const pinRemove = this.settings.find(s => s.key === 'seguranca.pin_remover_item');
          this.security.pinRemoverItem = pinRemove?.value === '1';
          const cu = this.settings.find(s => s.key === 'sync.server_url');
          this.cloudUrlForm.value = cu?.value ?? '';
          this.empresa.nome = this.settings.find(s => s.key === 'empresa.nome')?.value ?? '';
          this.empresa.documento = this.settings.find(s => s.key === 'empresa.documento')?.value ?? '';
          this.empresa.endereco = this.settings.find(s => s.key === 'empresa.endereco')?.value ?? '';
        },
        openLicenseDlg() {
          this.licenseForm = { companyUuid: '', licenseKey: '' };
          this.licenseError = '';
          this.$refs.licenseDlg.showModal();
        },
        <% if (user.permissions.has('license.edit')) { %>
        async saveLicense() {
          if (!this.licenseForm.companyUuid || !this.licenseForm.licenseKey) {
            this.licenseError = 'Preencha empresa e chave de licença.'; return;
          }
          this.savingLicense = true; this.licenseError = '';
          const r = await fetch('/api/license', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyUuid: this.licenseForm.companyUuid, licenseKey: this.licenseForm.licenseKey }),
          });
          this.savingLicense = false;
          if (r.ok) {
            const body = await r.json();
            this.license = body;
            this.licenseThanks = { sync: body.sync, syncError: body.syncError };
            this.$refs.licenseDlg.close();
            this.$refs.licenseThanksDlg.showModal();
          } else this.licenseError = (await r.json()).error ?? 'Falha ao salvar licença.';
        },
        <% } %>
        <% if (user.permissions.has('sync.run')) { %>
        async syncNow() {
          this.syncing = true; this.licenseError = '';
          const r = await fetch('/api/sync/run', { method: 'POST' });
          this.syncing = false;
          if (r.ok) {
            const l = await fetch('/api/license');
            if (l.ok) this.license = await l.json();
          } else this.licenseError = (await r.json()).error ?? 'Falha ao sincronizar.';
        },
        <% } %>
        <% if (user.permissions.has('settings.edit')) { %>
        async saveCloudUrl() {
          this.savingCloudUrl = true;
          const r = await fetch('/api/settings/sync.server_url', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.cloudUrlForm.value || null }),
          });
          this.savingCloudUrl = false;
          if (r.ok) await this.load();
        },
        <% } %>
        async saveStock() {
          this.savingStock = true; this.stockSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('estoque.auto_sku', this.stock.autoSku ? '1' : '0'),
            upsert('estoque.min_stock_padrao', String(this.stock.minStockPadrao)),
          ]);
          this.savingStock = false;
          this.stockSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveSales() {
          this.savingSales = true; this.salesSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value }),
          });
          const results = await Promise.all([
            upsert('vendas.exibir_cupom_fiscal', this.sales.exibirCupom ? '1' : '0'),
            upsert('caixa.lembrete_24h', this.sales.lembreteCaixa24h ? '1' : '0'),
          ]);
          this.savingSales = false;
          this.salesSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveEmpresa() {
          this.savingEmpresa = true; this.empresaSaved = '';
          const upsert = (key, value) => fetch(`/api/settings/${encodeURIComponent(key)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: value || null }),
          });
          const results = await Promise.all([
            upsert('empresa.nome', this.empresa.nome),
            upsert('empresa.documento', this.empresa.documento),
            upsert('empresa.endereco', this.empresa.endereco),
          ]);
          this.savingEmpresa = false;
          this.empresaSaved = results.every((r) => r.ok) ? 'Salvo.' : 'Falha ao salvar.';
          const r = await fetch('/api/settings');
          if (r.ok) { this.settings = await r.json(); this.syncSettings(); }
        },
        async saveSecurity() {
          this.savingSecurity = true; this.securitySaved = '';
          const r = await fetch('/api/settings/seguranca.pin_remover_item', {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.security.pinRemoverItem ? '1' : '0' }),
          });
          this.savingSecurity = false;
          this.securitySaved = r.ok ? 'Salvo.' : 'Falha ao salvar.';
          const s = await fetch('/api/settings');
          if (s.ok) { this.settings = await s.json(); this.syncSettings(); }
        },
        async savePin() {
          this.pinError = ''; this.pinSaved = '';
          if (!this.pinForm.pin || this.pinForm.pin !== this.pinForm.confirm) {
            this.pinError = 'Os PINs não conferem.'; return;
          }
          this.savingPin = true;
          const r = await fetch('/api/security/pin', {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pin: this.pinForm.pin }),
          });
          this.savingPin = false;
          if (r.ok) {
            this.pinConfigured = true; this.pinSaved = 'PIN salvo.'; this.pinForm = { pin: '', confirm: '' };
          } else this.pinError = (await r.json()).error ?? 'Falha ao salvar PIN.';
        },
        openNew() { this.form = { locked: false }; this.$refs.dlg.showModal(); },
        openEdit(s) { this.form = { key: s.key, value: s.value ?? '', locked: true }; this.$refs.dlg.showModal(); },
        async save() {
          if (!this.form.key) return;
          const r = await fetch(`/api/settings/${encodeURIComponent(this.form.key)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.form.value }),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); }
          else this.error = (await r.json()).error ?? 'Erro ao salvar.';
        },
      };
    }
  </script>
</body>
</html>
