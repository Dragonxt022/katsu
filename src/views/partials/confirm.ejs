<dialog id="confirm-dlg">
  <div style="text-align:center;padding:.5rem 0">
    <div style="width:48px;height:48px;border-radius:50%;background:var(--danger-bg);display:grid;place-items:center;margin:0 auto 1rem">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <h2 style="font-size:1.05rem;font-weight:600;margin-bottom:.25rem">Confirmar</h2>
    <p id="confirm-msg" style="color:var(--text-muted);font-size:.9rem;margin-bottom:1.25rem"></p>
    <div class="actions" style="justify-content:center">
      <button class="btn secondary" onclick="__confirm(false)">Cancelar</button>
      <button class="btn" onclick="__confirm(true)">Confirmar</button>
    </div>
  </div>
</dialog>
<script>
var __confirmResolve = null;
function __confirm(val) {
  var dlg = document.getElementById('confirm-dlg');
  if (val) dlg.setAttribute('data-result', 'confirmed');
  dlg.close();
  if (__confirmResolve) { __confirmResolve(val); __confirmResolve = null; }
}
window.confirmDlg = function (msg) {
  document.getElementById('confirm-msg').textContent = msg;
  var dlg = document.getElementById('confirm-dlg');
  dlg.removeAttribute('data-result');
  dlg.showModal();
  return new Promise(function (resolve) { __confirmResolve = resolve; });
};
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    var dlg = document.getElementById('confirm-dlg');
    if (dlg && dlg.open) __confirm(false);
  }
});
</script>