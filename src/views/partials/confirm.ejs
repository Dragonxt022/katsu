<dialog id="confirm-dlg">
  <div class="dialog-body-center">
    <div class="dialog-icon dialog-icon-danger">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <h2 class="dialog-heading-sm">Confirmar</h2>
    <p id="confirm-msg" class="dialog-muted"></p>
    <div class="actions actions-center">
      <button class="btn secondary" onclick="__confirm(false)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        Cancelar
      </button>
      <button class="btn" onclick="__confirm(true)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Confirmar
      </button>
    </div>
  </div>
</dialog>
<script>
var __confirmResolve = null;
function __confirm(val) {
  var dlg = document.getElementById('confirm-dlg');
  if (val) dlg.setAttribute('data-result', 'confirmed');
  dlg.close();
  if (__confirmResolve) { __confirmResolve(val); __confirmResolve = null; }
}
window.confirmDlg = function (msg) {
  document.getElementById('confirm-msg').textContent = msg;
  var dlg = document.getElementById('confirm-dlg');
  dlg.removeAttribute('data-result');
  dlg.showModal();
  return new Promise(function (resolve) { __confirmResolve = resolve; });
};
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    var dlg = document.getElementById('confirm-dlg');
    if (dlg && dlg.open) __confirm(false);
  }
});
</script>