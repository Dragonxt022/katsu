<header class="nav" x-data="{ menuOpen: false, userOpen: false }">
  <a href="/" class="brand">
    <img class="logo" src="/favicon.png" alt="Katsu" />
  </a>

  <div class="nav-links">
    <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Início</a>
    <% if (page !== 'home') { %>
    <% (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) { %>
      <% if (!item.permission || user.permissions.has(item.permission)) { %>
        <a href="<%= item.href %>" class="<%= page === item.href ? 'active' : '' %>"><%= item.label %></a>
      <% } %>
    <% }) %>
    <% } %>
  </div>

  <div class="spacer"></div>

  <% if (user) { %>
  <div class="nav-end">
    <button class="user" @click="userOpen = true" style="cursor:pointer;border:0;background:none;padding:0;color:inherit;font-size:inherit;line-height:inherit;text-align:left">
      <span class="name"><%= user.name %></span>
      <span class="role"><%= user.roleSlug %></span>
    </button>

    <dialog x-ref="userDlg" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:280px"
            x-init="$watch('userOpen', v => v ? $refs.userDlg.showModal() : $refs.userDlg.close())"
            @close.prevent="userOpen = false"
            @click.outside="userOpen = false">
      <div style="padding:1rem 1rem .5rem;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:.75rem">
        <div style="width:38px;height:38px;border-radius:50%;background:var(--primary);color:#fff;display:grid;place-items:center;font-weight:600;font-size:1rem"><%= user.name.charAt(0).toUpperCase() %></div>
        <div>
          <div style="font-weight:600;font-size:.95rem"><%= user.name %></div>
          <div style="font-size:.8rem;color:var(--text-muted)"><%= user.roleSlug %></div>
        </div>
      </div>
      <div style="padding:.4rem">
        <button @click="window.changePasswordDlg(); userOpen = false" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--text);cursor:pointer;font-size:.88rem"
                @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Trocar senha
        </button>
        <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/?login=1')" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--text);cursor:pointer;font-size:.88rem"
                @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Trocar usuário
        </button>
        <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/')" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--danger);cursor:pointer;font-size:.88rem"
                @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/>
          </svg>
          Sair
        </button>
      </div>
    </dialog>

    <div style="position:relative">
      <button class="btn-icon" @click="menuOpen = !menuOpen" title="Configurações">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
      <div x-show="menuOpen" @click.outside="menuOpen = false" style="position:absolute;top:100%;right:0;margin-top:6px;background:var(--surface);border:1px solid var(--border-light);border-radius:10px;box-shadow:var(--shadow);padding:.4rem;min-width:180px;z-index:200">
        <% if (user.permissions.has('users.view')) { %>
          <a href="/admin/usuarios" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'users' ? '› ' : '' %>Usuários</a>
        <% } %>
        <% if (user.permissions.has('roles.view')) { %>
          <a href="/admin/cargos" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'roles' ? '› ' : '' %>Cargos</a>
        <% } %>
        <% if (user.permissions.has('audit.view')) { %>
          <a href="/admin/auditoria" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'audit' ? '› ' : '' %>Auditoria</a>
        <% } %>
        <% if (user.permissions.has('backup.view')) { %>
          <a href="/admin/backup" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'backup' ? '› ' : '' %>Backup</a>
        <% } %>
        <% if (user.permissions.has('settings.view')) { %>
          <a href="/admin/configuracoes" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'settings' ? '› ' : '' %>Configurações</a>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</header>
<script>(function(){var c=HTMLDialogElement.prototype.close;HTMLDialogElement.prototype.close=function(){if(this.hasAttribute('open')){var d=this;d.style.animation='dialog-out 150ms ease forwards';d.addEventListener('animationend',function h(){d.removeEventListener('animationend',h);d.style.animation='';c.call(d)})}else c.call(this)}})()</script>
<%- include('confirm') %>
<%- include('password') %>
