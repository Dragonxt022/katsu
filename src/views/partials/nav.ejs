<header class="nav" x-data="{ menuOpen: false }">
  <a href="/" class="brand">
    <img class="logo" src="/favicon.png" alt="Katsu" />
  </a>

  <div class="nav-links">
    <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Início</a>
    <% if (page !== 'home') { %>
    <% (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) { %>
      <% if (!item.permission || user.permissions.has(item.permission)) { %>
        <a href="<%= item.href %>" class="<%= page === item.href ? 'active' : '' %>"><%= item.label %></a>
      <% } %>
    <% }) %>
    <% } %>
  </div>

  <div class="spacer"></div>

  <div class="nav-end">
    <div class="user">
      <span class="name"><%= user.name %></span>
      <span class="role"><%= user.roleSlug %></span>
    </div>

    <div style="position:relative">
      <button class="btn-icon" @click="menuOpen = !menuOpen" title="Configurações">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
      <div x-show="menuOpen" @click.outside="menuOpen = false" style="position:absolute;top:100%;right:0;margin-top:6px;background:var(--surface);border:1px solid var(--border-light);border-radius:10px;box-shadow:var(--shadow);padding:.4rem;min-width:180px;z-index:200">
        <% if (user.permissions.has('users.view')) { %>
          <a href="/admin/usuarios" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'users' ? '› ' : '' %>Usuários</a>
        <% } %>
        <% if (user.permissions.has('audit.view')) { %>
          <a href="/admin/auditoria" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'audit' ? '› ' : '' %>Auditoria</a>
        <% } %>
        <% if (user.permissions.has('backup.view')) { %>
          <a href="/admin/backup" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'backup' ? '› ' : '' %>Backup</a>
        <% } %>
        <% if (user.permissions.has('settings.view')) { %>
          <a href="/admin/configuracoes" style="display:block;padding:.45rem .7rem;border-radius:6px;color:var(--text);text-decoration:none;font-size:.85rem" @click="menuOpen = false"><%= page === 'settings' ? '› ' : '' %>Configurações</a>
        <% } %>
        <hr style="margin:.3rem 0;border:0;border-top:1px solid var(--border-light)" />
        <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/login')" style="display:block;width:100%;text-align:left;padding:.45rem .7rem;border:0;border-radius:6px;background:transparent;color:var(--danger);cursor:pointer;font-size:.85rem">Sair</button>
      </div>
    </div>
  </div>
</header>
