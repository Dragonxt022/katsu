<div x-data="{
  appsOpen: false, userOpen: false,
  now: new Date().toLocaleTimeString('pt-BR', { timeZone: 'America/Porto_Velho' }),
  billingAlert: null,
  licenseStatus: null,
  cashAlert: null,
  upcomingBills: null,
  notifOpen: false,
  cloudStatus: { configured: false, online: false },
  fmtDueDate(raw) {
    const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(String(raw || ''));
    return m ? `${m[3]}/${m[2]}/${m[1]}` : String(raw || '');
  },
  get notifications() {
    const list = [];
    if (this.upcomingBills) {
      for (const p of this.upcomingBills.payables || []) {
        list.push({ id: 'p' + p.id, message: `A pagar: ${p.description} — vence ${this.fmtDueDate(p.due_date)}`, link: '/app/finance/pagar' });
      }
      for (const r of this.upcomingBills.receivables || []) {
        list.push({ id: 'r' + r.id, message: `A receber: ${r.description} — vence ${this.fmtDueDate(r.due_date)}`, link: '/app/finance/receber' });
      }
    }
    if (this.cashAlert) list.push({ id: 'cash', message: 'Caixa aberto há mais de 24h', link: '/app/finance/caixa' });
    if (this.billingAlert && this.billingAlert.count) {
      list.push({ id: 'billing', message: `${this.billingAlert.count} cobrança(s) da licença vencendo`, link: '/admin/cobrancas' });
    }
    return list;
  },
  checkCloudStatus() {
    fetch('/api/sync/status').then((r) => r.ok ? r.json() : null).then((data) => { if (data) this.cloudStatus = data; }).catch(() => { this.cloudStatus = { configured: true, online: false }; });
  },
  init() {
    setInterval(() => { this.now = new Date().toLocaleTimeString('pt-BR', { timeZone: 'America/Porto_Velho' }); }, 1000);
    <% if (user && user.permissions.has('billing.view')) { %>
    fetch('/api/billing/alert').then((r) => r.ok ? r.json() : null).then((data) => { if (data && data.count) this.billingAlert = data; }).catch(() => {});
    <% } %>
    <% if (user) { %>
    fetch('/api/license/status').then((r) => r.ok ? r.json() : null).then((data) => { this.licenseStatus = data; }).catch(() => {});
    this.checkCloudStatus();
    setInterval(() => this.checkCloudStatus(), 25000);
    <% } %>
    <% if (user && user.permissions.has('finance.cash.view')) { %>
    fetch('/api/finance/cash/current').then((r) => r.ok ? r.json() : null).then((data) => { if (data && data.open && data.openTooLong) this.cashAlert = data; }).catch(() => {});
    <% } %>
    <% if (user && (user.permissions.has('finance.payables.view') || user.permissions.has('finance.receivables.view'))) { %>
    fetch('/api/finance/reports/upcoming-bills').then((r) => r.ok ? r.json() : null).then((data) => { if (data) this.upcomingBills = data; }).catch(() => {});
    <% } %>
  },
  theme: document.documentElement.getAttribute('data-theme') || 'light',
  toggleTheme() {
    this.theme = this.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', this.theme);
    try { localStorage.setItem('katsu-theme', this.theme); } catch (e) {}
  },
}">
<% if (user) { %>
<div x-show="licenseStatus && licenseStatus.plan === 'trial' && licenseStatus.status !== 'expirada'" x-cloak
     class="muted-block" style="background:var(--warning-bg);color:var(--warning-text);text-align:center;padding:.45rem 1rem;font-size:.85rem;font-weight:600">
  Período de teste —
  <span x-text="licenseStatus && licenseStatus.daysRemaining != null ? (licenseStatus.daysRemaining > 0 ? `faltam ${licenseStatus.daysRemaining} dia(s)` : 'expira hoje') : ''"></span>
</div>
<% } %>
<header class="nav">
  <div class="nav-left">
    <svg class="nav-clock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
    </svg>
    <span class="nav-clock" x-text="now"></span>
  </div>

  <a href="/" class="brand">
    <img class="logo" :src="theme === 'dark' ? '/favicon_branco.png' : '/favicon.png'" alt="Katsu" />
  </a>

  <% if (user) { %>
  <div class="nav-end">
    <span :title="!cloudStatus.configured ? 'Licença não configurada' : (cloudStatus.online ? 'Conectado à nuvem' : 'Sem conexão com a nuvem')"
          class="flex-center" style="padding:.3rem;color:var(--text-muted)"
          :style="{ color: !cloudStatus.configured ? 'var(--text-muted)' : (cloudStatus.online ? 'var(--primary)' : 'var(--danger)') }">
      <template x-if="cloudStatus.configured && cloudStatus.online">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="17" height="17">
          <path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>
        </svg>
      </template>
      <template x-if="!cloudStatus.configured || !cloudStatus.online">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="17" height="17">
          <line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/>
          <path d="M10.71 5.05A16 16 0 0 1 22.58 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>
        </svg>
      </template>
    </span>

    <div class="dropdown" style="position:relative">
      <button class="btn-icon" @click="notifOpen = !notifOpen" title="Notificações" aria-label="Notificações">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span x-show="notifications.length" x-cloak class="notif-badge" x-text="notifications.length"></span>
      </button>
      <div class="dropdown-menu" style="width:320px;max-height:340px;overflow-y:auto" x-show="notifOpen" x-cloak @click.outside="notifOpen = false">
        <template x-if="!notifications.length">
          <p class="muted text-xs" style="padding:.6rem">Nenhuma notificação no momento.</p>
        </template>
        <template x-for="n in notifications" :key="n.id">
          <a :href="n.link" class="menu-item" style="display:block;white-space:normal" @click="notifOpen = false" x-text="n.message"></a>
        </template>
      </div>
    </div>

    <button class="user btn-reset" @mousedown.prevent @click="userOpen = true">
      <span class="name"><%= user.name %></span>
      <span class="role"><%= user.roleSlug %></span>
    </button>

    <button class="btn-icon" @mousedown.prevent @click="userOpen = true" title="Sair / trocar usuário" aria-label="Sair ou trocar usuário">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </button>

    <button class="btn-icon" @click="appsOpen = true" title="Aplicações" aria-label="Aplicações">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/>
        <rect x="14" y="14" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/>
      </svg>
    </button>
  </div>
  <% } %>
</header>

<% if (user && user.permissions.has('billing.view')) { %>
<div x-show="billingAlert" x-cloak
     style="position:fixed;top:calc(var(--header-height) + 8px);left:50%;transform:translateX(-50%);z-index:40;
            background:var(--danger-bg);color:var(--danger-text);border-radius:10px;padding:.6rem 1rem;
            display:flex;align-items:center;gap:.75rem;font-size:.88rem;box-shadow:var(--shadow-sm);max-width:90vw">
  <span>⚠ <span x-text="billingAlert ? billingAlert.count : 0"></span> cobrança(s) vencendo em até 3 dias</span>
  <a href="/admin/cobrancas" style="color:inherit;font-weight:600;text-decoration:underline">ver</a>
  <button @click="billingAlert = null" class="btn-reset" style="font-size:1rem;line-height:1" aria-label="Fechar">&times;</button>
</div>
<% } %>

<% if (user) { %>
<dialog x-ref="licenseBlockDlg" closedby="none" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:340px;max-width:90vw"
        x-init="$watch('licenseStatus', v => (v && (v.status === 'expirada' || v.status === 'bloqueada')) ? $refs.licenseBlockDlg.showModal() : $refs.licenseBlockDlg.close())"
        @close.prevent="null">
  <div style="padding:1.25rem">
    <h2 class="dialog-heading-md" x-text="licenseStatus && licenseStatus.status === 'bloqueada' ? 'Licença bloqueada' : 'Licença expirada'"></h2>
    <p class="dialog-text" x-show="licenseStatus && licenseStatus.status === 'bloqueada'">
      Detectamos uma inconsistência nesta instalação (relógio do sistema, integridade dos dados de licença ou
      dispositivo). Conecte esta máquina à internet para revalidar. Se o problema continuar, contate o suporte.
    </p>
    <p class="dialog-text" x-show="!licenseStatus || licenseStatus.status !== 'bloqueada'">
      Entre em contato com o suporte para renovar sua licença e continuar usando o Katsu.
    </p>
    <p class="dialog-text-sm" x-show="licenseStatus && licenseStatus.supportPhone">
      Telefone: <strong x-text="licenseStatus && licenseStatus.supportPhone"></strong>
    </p>
    <p class="dialog-text-md" x-show="licenseStatus && licenseStatus.supportEmail">
      E-mail: <strong x-text="licenseStatus && licenseStatus.supportEmail"></strong>
    </p>
    <button class="btn secondary btn-full"
            @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sair
    </button>
  </div>
</dialog>
<% } %>

<% if (user && user.permissions.has('finance.cash.view')) { %>
<dialog x-ref="cashAlertDlg" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:360px;max-width:90vw"
        x-init="$watch('cashAlert', v => v ? $refs.cashAlertDlg.showModal() : null)">
  <div class="dialog-body-center" style="padding:1.25rem">
    <div class="dialog-icon-sm dialog-icon-warning">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>
    <h2 class="dialog-heading-md">Caixa aberto há mais de 24h</h2>
    <p class="dialog-muted-sm">
      Não esqueça de fechar o caixa. Deixá-lo aberto por muito tempo dificulta a conferência dos valores.
    </p>
    <div class="actions actions-center">
      <button class="btn secondary" @click="cashAlert = null; $refs.cashAlertDlg.close()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        Depois
      </button>
      <button class="btn" @click="location.href = '/app/finance/caixa?fechar=1'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="22" height="14" rx="2"/><path d="M1 10h22"/><circle cx="12" cy="14" r="2"/></svg>
        Fechar caixa
      </button>
    </div>
  </div>
</dialog>
<% } %>

<% if (user) { %>
<dialog x-ref="userDlg" closedby="none" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:280px"
        x-init="$watch('userOpen', v => v ? $refs.userDlg.showModal() : $refs.userDlg.close())"
        @close.prevent="userOpen = false"
        @click="$event.target === $el && (userOpen = false)">
  <div class="flex-center" style="padding:1rem 1rem .5rem;border-bottom:1px solid var(--border-light)">
    <div style="width:38px;height:38px;border-radius:50%;background:var(--primary);color:#fff;display:grid;place-items:center;font-weight:600;font-size:1rem"><%= user.name.charAt(0).toUpperCase() %></div>
    <div>
      <div style="font-weight:600;font-size:.95rem"><%= user.name %></div>
      <div class="text-xs" style="color:var(--text-muted)"><%= user.roleSlug %></div>
    </div>
  </div>
  <div style="padding:.4rem">
    <button @click="window.changePasswordDlg(); userOpen = false" class="menu-item"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      Trocar senha
    </button>
    <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/?login=1')" class="menu-item"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Trocar usuário
    </button>
    <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/')" class="menu-item" style="color:var(--danger)"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/>
      </svg>
      Sair
    </button>
  </div>
</dialog>
<% } %>

<% if (user) { %>
<div class="apps-backdrop" :class="{ open: appsOpen }" @click="appsOpen = false"></div>
<aside class="apps-drawer" :class="{ open: appsOpen }" @keydown.escape.window="appsOpen = false">
  <div class="apps-drawer-header">
    <span>Aplicações</span>
    <button class="btn-icon" @click="appsOpen = false" title="Fechar" aria-label="Fechar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="theme-row">
    <span>Tema</span>
    <button class="theme-switch" :class="{ dark: theme === 'dark' }" @click="toggleTheme()"
            :aria-label="theme === 'dark' ? 'Mudar para modo claro' : 'Mudar para modo escuro'">
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
      <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <span class="theme-switch-thumb"></span>
    </button>
  </div>
  <nav class="apps-drawer-list">
    <a href="/" class="apps-drawer-item <%= page === 'home' ? 'active' : '' %>" @click="appsOpen = false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>
      </svg>
      Início
    </a>
    <% (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) { %>
      <% if (!item.permission || user.permissions.has(item.permission)) { %>
      <a href="<%= item.href %>" class="apps-drawer-item" @click="appsOpen = false">
        <img src="/icons/<%= item.icon %>.svg" alt="" width="18" height="18" />
        <%= item.label %>
      </a>
      <% } %>
    <% }) %>

    <%
      var adminItems = [];
      if (user.permissions.has('users.view')) adminItems.push({ label: 'Usuários', href: '/admin/usuarios', icon: 'user-cog', page: 'users' });
      if (user.permissions.has('roles.view')) adminItems.push({ label: 'Cargos', href: '/admin/cargos', icon: 'key', page: 'roles' });
      if (user.permissions.has('audit.view')) adminItems.push({ label: 'Auditoria', href: '/admin/auditoria', icon: 'shield-check', page: 'audit' });
      if (user.permissions.has('backup.view')) adminItems.push({ label: 'Backup', href: '/admin/backup', icon: 'database', page: 'backup' });
      if (user.permissions.has('settings.view')) adminItems.push({ label: 'Configurações', href: '/admin/configuracoes', icon: 'settings', page: 'settings' });
      if (user.permissions.has('settings.capabilities.edit')) adminItems.push({ label: 'Recursos', href: '/admin/recursos', icon: 'sparkles', page: 'recursos' });
      if (user.permissions.has('billing.view')) adminItems.push({ label: 'Cobranças', href: '/admin/cobrancas', icon: 'receipt', page: 'billing' });
    %>
    <% if (adminItems.length) { %>
    <div class="apps-drawer-divider"></div>
    <% adminItems.forEach(function (item) { %>
      <a href="<%= item.href %>" class="apps-drawer-item <%= page === item.page ? 'active' : '' %>" @click="appsOpen = false">
        <img src="/icons/<%= item.icon %>.svg" alt="" width="18" height="18" />
        <%= item.label %>
      </a>
    <% }) %>
    <% } %>

    <div class="apps-drawer-divider"></div>
    <a :href="(cloudStatus.url || 'https://katsu.buscamais.org') + '/wiki'" target="_blank" class="apps-drawer-item" @click="appsOpen = false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      Wiki
    </a>
  </nav>
</aside>
<% } %>
</div>
<div id="toast-container"></div>
<script>
(function(){
  // Fechamento animado de dialog
  var c=HTMLDialogElement.prototype.close;HTMLDialogElement.prototype.close=function(){if(this.hasAttribute('open')){var d=this;d.style.animation='dialog-out 150ms ease forwards';d.addEventListener('animationend',function h(){d.removeEventListener('animationend',h);d.style.animation='';c.call(d)})}else c.call(this)};

  // Toast global
  window.showToast = function(msg, type) {
    type = type || 'error';
    var openDlg = document.querySelector('dialog[open]');
    var container = document.getElementById('toast-container');
    if (openDlg) {
      container = openDlg.querySelector('.toast-dlg-container');
      if (!container) {
        container = document.createElement('div');
        container.className = 'toast-dlg-container';
        openDlg.appendChild(container);
      }
    }
    if (!container) return;
    var icons = { error: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>', success: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', info: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>', warning: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' };
    var el = document.createElement('div');
    el.className = 'toast toast-' + type;
    el.innerHTML = (icons[type] || icons.error) + '<span class="toast-msg">' + String(msg).replace(/</g,'&lt;') + '</span><button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
    container.appendChild(el);
    setTimeout(function(){ el.style.opacity = '0'; el.style.transform = 'translateX(100%)'; setTimeout(function(){ if (el.parentElement) el.remove(); }, 250); }, 5000);
  };
})();
</script>
<%- include('confirm') %>
<%- include('password') %>
