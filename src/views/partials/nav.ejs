<div x-data="{ appsOpen: false, userOpen: false }">
<header class="nav">
  <div class="nav-left">
    <% if (user) { %>
    <button class="btn-icon" @click="appsOpen = true" title="Aplicações" aria-label="Aplicações">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/>
        <rect x="14" y="14" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/>
      </svg>
    </button>
    <% } %>
  </div>

  <a href="/" class="brand">
    <img class="logo" src="/favicon.png" alt="Katsu" />
  </a>

  <% if (user) { %>
  <div class="nav-end">
    <button class="user" @mousedown.prevent @click="userOpen = true" style="cursor:pointer;border:0;background:none;padding:0;color:inherit;font-size:inherit;line-height:inherit;text-align:left">
      <span class="name"><%= user.name %></span>
      <span class="role"><%= user.roleSlug %></span>
    </button>

    <button class="btn-icon" @mousedown.prevent @click="userOpen = true" title="Sair / trocar usuário" aria-label="Sair ou trocar usuário">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </button>
  </div>
  <% } %>
</header>

<% if (user) { %>
<dialog x-ref="userDlg" closedby="none" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:280px"
        x-init="$watch('userOpen', v => v ? $refs.userDlg.showModal() : $refs.userDlg.close())"
        @close.prevent="userOpen = false"
        @click="$event.target === $el && (userOpen = false)">
  <div style="padding:1rem 1rem .5rem;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:.75rem">
    <div style="width:38px;height:38px;border-radius:50%;background:var(--primary);color:#fff;display:grid;place-items:center;font-weight:600;font-size:1rem"><%= user.name.charAt(0).toUpperCase() %></div>
    <div>
      <div style="font-weight:600;font-size:.95rem"><%= user.name %></div>
      <div style="font-size:.8rem;color:var(--text-muted)"><%= user.roleSlug %></div>
    </div>
  </div>
  <div style="padding:.4rem">
    <button @click="window.changePasswordDlg(); userOpen = false" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--text);cursor:pointer;font-size:.88rem"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      Trocar senha
    </button>
    <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/?login=1')" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--text);cursor:pointer;font-size:.88rem"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Trocar usuário
    </button>
    <button @click="fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/')" style="display:flex;align-items:center;gap:.6rem;width:100%;padding:.5rem .65rem;border:0;border-radius:8px;background:transparent;color:var(--danger);cursor:pointer;font-size:.88rem"
            @mouseenter="$el.style.background='var(--surface-hover)'" @mouseleave="$el.style.background='transparent'">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/>
      </svg>
      Sair
    </button>
  </div>
</dialog>
<% } %>

<% if (user) { %>
<div class="apps-backdrop" :class="{ open: appsOpen }" @click="appsOpen = false"></div>
<aside class="apps-drawer" :class="{ open: appsOpen }" @keydown.escape.window="appsOpen = false">
  <div class="apps-drawer-header">
    <span>Aplicações</span>
    <button class="btn-icon" @click="appsOpen = false" title="Fechar" aria-label="Fechar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <nav class="apps-drawer-list">
    <a href="/" class="apps-drawer-item <%= page === 'home' ? 'active' : '' %>" @click="appsOpen = false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
        <path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>
      </svg>
      Início
    </a>
    <% (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) { %>
      <% if (!item.permission || user.permissions.has(item.permission)) { %>
      <a href="<%= item.href %>" class="apps-drawer-item" @click="appsOpen = false">
        <img src="/icons/<%= item.icon %>.svg" alt="" width="18" height="18" />
        <%= item.label %>
      </a>
      <% } %>
    <% }) %>

    <%
      var adminItems = [];
      if (user.permissions.has('users.view')) adminItems.push({ label: 'Usuários', href: '/admin/usuarios', icon: 'user-cog', page: 'users' });
      if (user.permissions.has('roles.view')) adminItems.push({ label: 'Cargos', href: '/admin/cargos', icon: 'key', page: 'roles' });
      if (user.permissions.has('audit.view')) adminItems.push({ label: 'Auditoria', href: '/admin/auditoria', icon: 'shield-check', page: 'audit' });
      if (user.permissions.has('backup.view')) adminItems.push({ label: 'Backup', href: '/admin/backup', icon: 'database', page: 'backup' });
      if (user.permissions.has('settings.view')) adminItems.push({ label: 'Configurações', href: '/admin/configuracoes', icon: 'settings', page: 'settings' });
    %>
    <% if (adminItems.length) { %>
    <div class="apps-drawer-divider"></div>
    <% adminItems.forEach(function (item) { %>
      <a href="<%= item.href %>" class="apps-drawer-item <%= page === item.page ? 'active' : '' %>" @click="appsOpen = false">
        <img src="/icons/<%= item.icon %>.svg" alt="" width="18" height="18" />
        <%= item.label %>
      </a>
    <% }) %>
    <% } %>
  </nav>
</aside>
<% } %>
</div>
<script>(function(){var c=HTMLDialogElement.prototype.close;HTMLDialogElement.prototype.close=function(){if(this.hasAttribute('open')){var d=this;d.style.animation='dialog-out 150ms ease forwards';d.addEventListener('animationend',function h(){d.removeEventListener('animationend',h);d.style.animation='';c.call(d)})}else c.call(this)}})()</script>
<%- include('confirm') %>
<%- include('password') %>
