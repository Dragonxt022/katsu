<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Auditoria</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'audit' }) %>
  <main x-data="auditPage()" x-init="load()">
    <h1>Auditoria</h1>
    <div class="toolbar">
      <input type="text" placeholder="Filtrar por usuário, ação ou entidade…" x-model="q"
             class="input-search-ghost" style="min-width:280px" />
      <span class="muted" x-text="filtered().length + ' registro(s)'"></span>
    </div>
    <table>
      <thead>
        <tr>
          <th @click="sortCycle('created_at')" class="sortable">Quando<span class="sort-arrow" x-text="sortArrow('created_at')"></span></th>
          <th @click="sortCycle('username')" class="sortable">Usuário<span class="sort-arrow" x-text="sortArrow('username')"></span></th>
          <th @click="sortCycle('action')" class="sortable">Ação<span class="sort-arrow" x-text="sortArrow('action')"></span></th>
          <th @click="sortCycle('entity')" class="sortable">Entidade<span class="sort-arrow" x-text="sortArrow('entity')"></span></th>
          <th>ID</th><th>IP</th><th>Máquina</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="l in displayRows" :key="l.id">
          <tr>
            <td class="muted" x-text="fmtDateTime(l.created_at)"></td>
            <td x-text="l.username ?? '—'"></td>
            <td x-text="l.action"></td>
            <td x-text="l.entity"></td>
            <td class="muted" x-text="l.entity_id ?? '—'"></td>
            <td class="muted" x-text="l.ip ?? '—'"></td>
            <td class="muted" x-text="l.machine ?? '—'"></td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="7"><%- include('partials/empty-state', { message: 'Nenhum registro de auditoria encontrado.' }) %></td></tr>
      </tbody>
    </table>
  </main>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function auditPage() {
      return {
        ...tableToolkit(),
        logs: [], q: '',
        sortGetters: {
          created_at: (l) => l.created_at ?? '', username: (l) => l.username ?? '',
          action: (l) => l.action ?? '', entity: (l) => l.entity ?? '',
        },
        filtered() {
          if (!this.q.trim()) return this.logs;
          const t = this.q.toLowerCase();
          return this.logs.filter((l) =>
            (l.username ?? '').toLowerCase().includes(t) ||
            (l.action ?? '').toLowerCase().includes(t) ||
            (l.entity ?? '').toLowerCase().includes(t));
        },
        get displayRows() { return this.sortedRows(this.filtered(), this.sortGetters); },
        async load() {
          const r = await fetch('/api/audit?limit=500');
          if (r.ok) this.logs = await r.json();
        },
      };
    }
  </script>
</body>
</html>

