<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Katsu — Auditoria</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'audit' }) %>
  <main x-data="auditPage()" x-init="load()">
    <h1>Auditoria</h1>
    <table>
      <thead>
        <tr><th>Quando</th><th>Usuário</th><th>Ação</th><th>Entidade</th><th>ID</th><th>IP</th><th>Máquina</th></tr>
      </thead>
      <tbody>
        <template x-for="l in logs" :key="l.id">
          <tr>
            <td class="muted" x-text="l.created_at"></td>
            <td x-text="l.username ?? '—'"></td>
            <td x-text="l.action"></td>
            <td x-text="l.entity"></td>
            <td class="muted" x-text="l.entity_id ?? '—'"></td>
            <td class="muted" x-text="l.ip ?? '—'"></td>
            <td class="muted" x-text="l.machine ?? '—'"></td>
          </tr>
        </template>
      </tbody>
    </table>
  </main>
  <script>
    function auditPage() {
      return {
        logs: [],
        async load() {
          const r = await fetch('/api/audit?limit=200');
          if (r.ok) this.logs = await r.json();
        },
      };
    }
  </script>
</body>
</html>

