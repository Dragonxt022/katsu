<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <style>
    .login-overlay {
      position: fixed; inset: 0; z-index: 200;
      display: grid; place-items: center;
      background: rgba(0,0,0,.45);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .login-card {
      background: var(--surface); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); padding: 2.5rem 2rem;
      width: 340px; text-align: center;
    }
    .login-card img.logo { width: 80px; margin-bottom: .75rem; }
    .login-card h1 { font-size: 1.2rem; font-weight: 600; margin-bottom: 1.25rem; }
    .login-card label { display: block; text-align: left; font-size: .82rem; color: var(--text-muted); margin-bottom: .25rem; }
    .login-card input[type="text"],
    .login-card input[type="password"] {
      width: 100%; padding: .6rem .75rem; border-radius: 10px;
      border: 1.5px solid var(--border-light); background: var(--surface-hover);
      color: var(--text); font-size: .95rem; margin-bottom: .85rem;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .login-card input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent);
    }
    .login-card .remember {
      display: flex; align-items: center; gap: .5rem;
      margin-bottom: 1rem; font-size: .85rem; color: var(--text-muted); cursor: pointer;
    }
    .login-card .remember input { width: 16px; height: 16px; cursor: pointer; }
    .login-card button[type="submit"] {
      width: 100%; padding: .7rem; border: 0; border-radius: 10px;
      background: var(--primary); color: #fff; font-size: .95rem; font-weight: 600;
      cursor: pointer; transition: background var(--transition), transform var(--transition);
    }
    .login-card button[type="submit"]:hover { background: var(--primary-hover); transform: translateY(-1px); }
    .login-card button[type="submit"]:active { transform: scale(.98); }
    .login-card .error { color: var(--danger); font-size: .85rem; margin-top: .75rem; min-height: 1.2em; }
    .login-card .version { color: var(--text-muted); font-size: .72rem; margin-top: 1.25rem; }

    .help-chat-contacts { display: flex; flex-direction: column; gap: .5rem; margin: .25rem 0 1.25rem; }
    .help-chat-contact {
      display: flex; align-items: center; gap: .55rem; padding: .6rem .8rem;
      border: 1.5px solid var(--border-light); border-radius: 10px; background: var(--surface-hover);
      color: var(--text); font-size: .88rem; font-weight: 500; text-decoration: none;
      transition: border-color var(--transition), color var(--transition);
    }
    .help-chat-contact:hover { border-color: var(--primary); color: var(--primary); text-decoration: none; }
    .help-chat-contact svg { color: var(--primary); flex-shrink: 0; }
  </style>
</head>
<body>
  <%- include('partials/nav', { user, page: 'home' }) %>

  <main x-data="homePage()" x-init="init()">
    <!-- ─── Overlay de login (quando não autenticado ou ?login=1) ─── -->
    <div class="login-overlay" x-show="showLogin" x-cloak>
      <div class="login-card">
        <img class="logo" :src="theme === 'dark' ? '/logo_marca_branco.png' : '/katsu_logo.png'" alt="Katsu" />
        <h1>Entrar no Katsu</h1>
        <form @submit.prevent="login">
          <label for="login-user">Usuário</label>
          <input id="login-user" type="text" x-model="loginUser" autocomplete="username"
                 x-ref="loginUser" @keydown.escape.prevent="handleLoginEsc()" />
          <label for="login-pass">Senha</label>
          <input id="login-pass" type="password" x-model="loginPass" autocomplete="current-password"
                 @keydown.escape.prevent="handleLoginEsc()" />
          <label class="remember">
            <input type="checkbox" x-model="loginRemember" /> Lembrar login
          </label>
          <button type="submit" x-text="loginLoading ? 'Entrando…' : 'Entrar'"
                  :disabled="loginLoading"></button>
          <div class="error" x-text="loginError"></div>
        </form>
        <p class="version">Versão <%= appVersion %></p>
      </div>
    </div>

    <% if (user) { %>
    <div class="greeting">
      <h1><span x-html="greetingIcon" style="vertical-align:-.3rem;margin-right:.4rem"></span><span x-text="greeting + ', '"></span><%= user.name %></h1>
      <p>Comida que alimenta, sistema que organiza.</p>
    </div>

    <div class="search-wrap">
      <img class="search-icon" src="/icons/search.svg" width="18" height="18" alt="" />
      <input type="text" placeholder="Buscar aplicativo…" x-model="q" @input="filter" />
    </div>

    <div class="app-grid" x-ref="grid">
      <template x-for="a in apps" :key="a.href">
        <a class="app-card drag-enabled" :href="a.href" :data-href="a.href" draggable="false"
           x-show="matches(a.label)"
           :class="[dragId === a.href ? 'dragging' : '', dropOverId === a.href ? 'drop-target' : '']"
           @pointerdown="onCardPointerDown($event, a)">
          <img class="card-icon" :src="'/icons/' + a.icon + '.svg'" alt="" width="40" height="40" />
          <span class="card-title" x-text="a.label"></span>
          <span class="card-desc" x-text="a.description"></span>
        </a>
      </template>
      <%
        var moduleItems = [];
        (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) {
          if (!item.permission || user.permissions.has(item.permission)) {
            moduleItems.push(item);
          }
        });
        var visibleItemsForAlpine = moduleItems.map(function (item) {
          return { label: item.label, href: item.href, icon: item.icon, description: item.description ?? '' };
        });
        var visibleItems = moduleItems.slice();
        var adminItems = [];
        if (user.permissions.has('users.view')) adminItems.push({ label: 'Usuários', href: '/admin/usuarios', icon: 'user-cog', description: 'Contas, cargos e acesso.' });
        if (user.permissions.has('roles.view')) adminItems.push({ label: 'Cargos', href: '/admin/cargos', icon: 'key', description: 'Permissões por cargo.' });
        if (user.permissions.has('audit.view')) adminItems.push({ label: 'Auditoria', href: '/admin/auditoria', icon: 'shield-check', description: 'Quem fez o quê, quando e de onde.' });
        if (user.permissions.has('backup.view')) adminItems.push({ label: 'Backup', href: '/admin/backup', icon: 'database', description: 'Cópias de segurança do banco.' });
        if (user.permissions.has('settings.view')) adminItems.push({ label: 'Configurações', href: '/admin/configuracoes', icon: 'settings', description: 'Parâmetros do sistema e licença.' });
        visibleItems = visibleItems.concat(adminItems);
      %>

      <% if (adminItems.length) { %>
      <button type="button" class="app-card" @click="showMore = !showMore" x-show="!q">
        <img class="card-icon" src="/icons/more.svg" alt="" width="40" height="40" />
        <span class="card-title" x-text="showMore ? 'Mostrar menos' : 'Mais'"></span>
        <span class="card-desc">Usuários, cargos, auditoria, backup e configurações.</span>
      </button>
      <% } %>

      <% adminItems.forEach(function (item) { %>
          <a class="app-card" href="<%= item.href %>" x-show="(showMore || q) && matches('<%= item.label %>')">
            <img class="card-icon" src="/icons/<%= item.icon %>.svg" alt="" width="40" height="40" />
            <span class="card-title"><%= item.label %></span>
            <span class="card-desc"><%= item.description %></span>
          </a>
      <% }) %>

      <%
        var rem = visibleItems.length % 6;
        if (rem > 0) {
          for (var i = 0; i < 6 - rem; i++) {
      %>
          <div class="app-card" style="visibility:hidden;border-color:transparent;box-shadow:none;cursor:default;pointer-events:none"></div>
      <%
          }
        }
      %>
    </div>
    <% } %>
  </main>

  <% if (user && user.permissions.has('settings.edit')) { %>
  <div x-data="onboardingWizard()" x-init="checkFirstRun()">
    <%- include('partials/onboarding') %>
  </div>
  <% } %>

  <div x-data="helpChat()">
    <button type="button" class="fab" title="Ajuda" @click="open()">
      <img src="/icons/chat.svg" width="22" height="22" alt="" />
    </button>

    <dialog x-ref="dlg" style="width:360px">
      <div class="dialog-body-center">
        <div class="dialog-icon dialog-icon-primary">
          <img src="/icons/chat.svg" width="22" height="22" alt="" />
        </div>
        <h2 class="dialog-heading-md">Oi! 👋</h2>
        <p class="dialog-muted">
          Nosso chat de suporte ainda está a caminho — em breve você vai poder falar com a
          gente direto por aqui. Por enquanto, é só chamar pelos contatos abaixo:
        </p>
        <div class="help-chat-contacts">
          <a :href="'mailto:' + email" class="help-chat-contact" x-show="email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
            <span x-text="email"></span>
          </a>
          <a :href="'tel:' + phone" class="help-chat-contact" x-show="phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span x-text="phone"></span>
          </a>
          <p class="muted text-xs" x-show="loaded && !email && !phone">Contato de suporte ainda não configurado.</p>
        </div>
        <div class="actions actions-center">
          <button type="button" class="btn" @click="$refs.dlg.close()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Entendi</button>
        </div>
      </div>
    </dialog>
  </div>

  <% if (user && user.permissions.has('settings.edit')) { %>
  <script src="/js/onboarding.js"></script>
  <% } %>
  <script>
    const HOME_APPS_SEED = <%- JSON.stringify(typeof visibleItemsForAlpine !== 'undefined' ? visibleItemsForAlpine : []) %>;
    const HOME_ORDER_KEY = 'katsu-home-order';
    const HOME_USAGE_KEY = 'katsu-home-usage';

    function homePage() {
      return {
        greeting: '',
        greetingIcon: '',
        theme: document.documentElement.getAttribute('data-theme') || 'light',
        q: '',
        showMore: false,
        showLogin: false,
        loginUser: '',
        loginPass: '',
        loginRemember: false,
        loginLoading: false,
        loginError: '',
        apps: [],
        dragId: null,
        dropOverId: null,

        loadOrder(items) {
          let saved = [];
          try { saved = JSON.parse(localStorage.getItem(HOME_ORDER_KEY) || '[]'); } catch {}
          if (!saved.length) return items;
          const byHref = new Map(items.map((i) => [i.href, i]));
          const ordered = [];
          saved.forEach((href) => {
            const it = byHref.get(href);
            if (it) { ordered.push(it); byHref.delete(href); }
          });
          byHref.forEach((it) => ordered.push(it));
          return ordered;
        },
        saveOrder() {
          localStorage.setItem(HOME_ORDER_KEY, JSON.stringify(this.apps.map((a) => a.href)));
        },

        // Aprende com o uso: cada clique normal (não-arrasto) soma 1 pro app, e se ele
        // passar a ter mais uso que o vizinho de cima, sobe uma posição. Uso repetido ao
        // longo de várias visitas vai levando o app mais usado pro topo, aos poucos.
        // Teto + decaimento: sem isso, um app com 100 cliques acumulados no passado
        // ficaria praticamente impossível de ultrapassar. O teto limita quantos cliques
        // bastam pra alcançar o topo, e o decaimento faz apps esquecidos perderem força
        // aos poucos, dando espaço pra quem você passou a usar mais agora.
        recordUsage(href) {
          const DECAY = 0.9, CAP = 20;
          let usage = {};
          try { usage = JSON.parse(localStorage.getItem(HOME_USAGE_KEY) || '{}'); } catch {}
          Object.keys(usage).forEach((h) => {
            if (h === href) return;
            const next = usage[h] * DECAY;
            if (next < 0.5) delete usage[h]; else usage[h] = next;
          });
          usage[href] = Math.min((usage[href] || 0) + 1, CAP);
          localStorage.setItem(HOME_USAGE_KEY, JSON.stringify(usage));

          // Não mexe no array reativo `apps` aqui: o clique está prestes a navegar pra
          // fora da página (link normal), e reordenar o DOM nesse instante podia fazer o
          // navegador cancelar o próprio clique (card "não entrava"). Só grava a nova
          // ordem no localStorage — ela aparece já reordenada na próxima visita à home.
          const order = this.apps.map((a) => a.href);
          const idx = order.indexOf(href);
          if (idx > 0) {
            const aboveHref = order[idx - 1];
            if (usage[href] > (usage[aboveHref] || 0)) {
              order[idx - 1] = href;
              order[idx] = aboveHref;
              localStorage.setItem(HOME_ORDER_KEY, JSON.stringify(order));
            }
          }
        },

        onCardPointerDown(e, a) {
          if (e.pointerType === 'mouse' && e.button !== 0) return;
          const card = e.currentTarget;
          const startX = e.clientX, startY = e.clientY;
          const rect = card.getBoundingClientRect();
          let dragging = false;

          const activate = () => {
            dragging = true;
            this.dragId = a.href;
            card.style.width = rect.width + 'px';
            card.style.height = rect.height + 'px';
            card.style.left = rect.left + 'px';
            card.style.top = rect.top + 'px';
            try { card.setPointerCapture(e.pointerId); } catch {}
            card.addEventListener('click', suppressClick, { capture: true, once: true });
            if (navigator.vibrate) navigator.vibrate(12);
          };
          const suppressClick = (ev) => { ev.preventDefault(); ev.stopPropagation(); };

          const timer = setTimeout(activate, 260);

          const onMove = (ev) => {
            const dx = ev.clientX - startX, dy = ev.clientY - startY;
            if (!dragging) {
              if (Math.hypot(dx, dy) > 8) cleanup();
              return;
            }
            ev.preventDefault();
            card.style.transform = `translate(${dx}px, ${dy}px) scale(1.04)`;
            const under = document.elementFromPoint(ev.clientX, ev.clientY)?.closest('.app-card');
            this.dropOverId = under && under !== card && under.dataset.href ? under.dataset.href : null;
          };
          const onUp = () => {
            cleanup();
            if (dragging) this.finishDrag(a, card);
            else this.recordUsage(a.href);
          };
          const cleanup = () => {
            clearTimeout(timer);
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup', onUp);
          };

          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup', onUp);
        },
        finishDrag(a, card) {
          card.removeAttribute('style');
          this.dragId = null;
          const overHref = this.dropOverId;
          this.dropOverId = null;
          const fromIdx = this.apps.findIndex((x) => x.href === a.href);
          const toIdx = overHref != null ? this.apps.findIndex((x) => x.href === overHref) : -1;
          if (fromIdx === -1 || toIdx === -1 || fromIdx === toIdx) return;
          this.reorder(fromIdx, toIdx);
        },
        async reorder(fromIdx, toIdx) {
          const grid = this.$refs.grid;
          const before = new Map();
          grid.querySelectorAll('.app-card').forEach((el) => before.set(el, el.getBoundingClientRect()));

          const [moved] = this.apps.splice(fromIdx, 1);
          this.apps.splice(toIdx, 0, moved);
          this.saveOrder();
          await this.$nextTick();

          grid.querySelectorAll('.app-card').forEach((el) => {
            const prev = before.get(el);
            if (!prev) return;
            const next = el.getBoundingClientRect();
            const dx = prev.left - next.left, dy = prev.top - next.top;
            if (!dx && !dy) return;
            el.style.transition = 'none';
            el.style.transform = `translate(${dx}px, ${dy}px)`;
            requestAnimationFrame(() => {
              el.style.transition = 'transform .32s cubic-bezier(.2,.8,.2,1)';
              el.style.transform = '';
            });
          });
        },

        init() {
          this.apps = this.loadOrder(HOME_APPS_SEED);
          const now = new Date();
          const h = now.getHours();
          const isWeekend = now.getDay() === 0 || now.getDay() === 6;

          if (isWeekend) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="var(--primary)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
            this.greeting = 'Bom fim de semana';
          } else if (h < 12) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
            this.greeting = 'Bom dia';
          } else if (h < 18) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18a5 5 0 0 0 .88-9.8A5.5 5.5 0 0 0 5.6 9.2 4 4 0 1 0 6 18Z"/><line x1="2" y1="2" x2="4" y2="4"/><line x1="20" y1="2" x2="22" y2="4"/><line x1="22" y1="20" x2="20" y2="22"/></svg>';
            this.greeting = 'Boa tarde';
          } else {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
            this.greeting = 'Boa noite';
          }

          const isAuthed = <%= user ? 'true' : 'false' %>;
          const hasLoginParam = window.location.search.includes('login=1');
          this.showLogin = !isAuthed || hasLoginParam;

          if (this.showLogin) {
            this.$nextTick(() => {
              const el = this.$refs.loginUser;
              if (el) el.focus();
            });
          }
        },

        matches(label) {
          if (!this.q) return true;
          return label.toLowerCase().includes(this.q.toLowerCase());
        },
        filter() {},

        async login() {
          if (this.loginLoading) return;
          if (!this.loginUser.trim() || !this.loginPass) {
            this.loginError = 'Informe usuário e senha.';
            return;
          }
          this.loginLoading = true;
          this.loginError = '';
          try {
            const r = await fetch('/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                username: this.loginUser.trim(),
                password: this.loginPass,
                remember: this.loginRemember,
              }),
            });
            if (r.ok) {
              window.location.href = '/';
            } else {
              const data = await r.json();
              this.loginError = data.error || 'Erro ao autenticar.';
            }
          } catch (e) {
            this.loginError = 'Erro de conexão.';
          } finally {
            this.loginLoading = false;
          }
        },

        handleLoginEsc() {
          if (this.loginUser || this.loginPass) {
            this.loginUser = '';
            this.loginPass = '';
          }
        },
      };
    }

    function helpChat() {
      return {
        email: '', phone: '', loaded: false,
        async open() {
          this.$refs.dlg.showModal();
          if (this.loaded) return;
          try {
            const r = await fetch('/api/license/status');
            if (r.ok) {
              const d = await r.json();
              this.email = d.supportEmail || '';
              this.phone = d.supportPhone || '';
            }
          } catch (e) {
            // sem sessão/rede — o modal segue com a mensagem amigável, só sem os contatos
          }
          this.loaded = true;
        },
      };
    }
  </script>
</body>
</html>
