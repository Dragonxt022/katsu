<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <style>
    .login-overlay {
      position: fixed; inset: 0; z-index: 200;
      display: grid; place-items: center;
      background: rgba(0,0,0,.45);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .login-card {
      background: var(--surface); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); padding: 2.5rem 2rem;
      width: 340px; text-align: center;
    }
    .login-card img.logo { width: 80px; margin-bottom: .75rem; }
    .login-card h1 { font-size: 1.2rem; font-weight: 600; margin-bottom: 1.25rem; }
    .login-card label { display: block; text-align: left; font-size: .82rem; color: var(--text-muted); margin-bottom: .25rem; }
    .login-card input[type="text"],
    .login-card input[type="password"] {
      width: 100%; padding: .6rem .75rem; border-radius: 10px;
      border: 1.5px solid var(--border-light); background: var(--surface-hover);
      color: var(--text); font-size: .95rem; margin-bottom: .85rem;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .login-card input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent);
    }
    .login-card .remember {
      display: flex; align-items: center; gap: .5rem;
      margin-bottom: 1rem; font-size: .85rem; color: var(--text-muted); cursor: pointer;
    }
    .login-card .remember input { width: 16px; height: 16px; cursor: pointer; }
    .login-card button[type="submit"] {
      width: 100%; padding: .7rem; border: 0; border-radius: 10px;
      background: var(--primary); color: #fff; font-size: .95rem; font-weight: 600;
      cursor: pointer; transition: background var(--transition), transform var(--transition);
    }
    .login-card button[type="submit"]:hover { background: var(--primary-hover); transform: translateY(-1px); }
    .login-card button[type="submit"]:active { transform: scale(.98); }
    .login-card .error { color: var(--danger); font-size: .85rem; margin-top: .75rem; min-height: 1.2em; }
    .login-card .version { color: var(--text-muted); font-size: .72rem; margin-top: 1.25rem; }

    .help-chat-contacts { display: flex; flex-direction: column; gap: .5rem; margin: .25rem 0 1.25rem; }
    .help-chat-contact {
      display: flex; align-items: center; gap: .55rem; padding: .6rem .8rem;
      border: 1.5px solid var(--border-light); border-radius: 10px; background: var(--surface-hover);
      color: var(--text); font-size: .88rem; font-weight: 500; text-decoration: none;
      transition: border-color var(--transition), color var(--transition);
      cursor: pointer; width: 100%; text-align: left; font-family: inherit;
    }
    .help-chat-contact:hover { border-color: var(--primary); color: var(--primary); text-decoration: none; }
    .help-chat-contact svg { color: var(--primary); flex-shrink: 0; }

    /* ─── Chat de suporte ─── */
    .fab-unread {
      position: absolute; top: -3px; right: -3px; min-width: 18px; height: 18px;
      border-radius: 999px; background: var(--danger); color: #fff;
      font-size: .68rem; font-weight: 700; display: flex; align-items: center; justify-content: center;
      padding: 0 5px; border: 2px solid var(--surface);
    }
    .support-dlg { width: min(420px, 94vw); padding: 0; overflow: hidden; }
    .support-head {
      background: var(--primary); color: #fff; padding: 1.1rem 1.25rem;
      display: flex; align-items: center; gap: .75rem;
    }
    .support-head h2 { margin: 0; font-size: 1.05rem; line-height: 1.3; }
    .support-head .sub { font-size: .78rem; opacity: .9; }
    .support-head .back-btn, .support-head .close-btn {
      background: rgba(255,255,255,.18); border: none; color: #fff; cursor: pointer;
      width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
      flex: none;
    }
    .support-head .close-btn { margin-left: auto; }
    .support-body { padding: 1.1rem 1.25rem; max-height: 60vh; overflow-y: auto; }
    .support-ticket-item {
      display: flex; align-items: center; gap: .6rem; width: 100%; text-align: left;
      padding: .6rem .8rem; border: 1.5px solid var(--border-light); border-radius: 10px;
      background: var(--surface-hover); cursor: pointer; font-family: inherit; color: var(--text);
      margin-bottom: .5rem; font-size: .86rem;
    }
    .support-ticket-item:hover { border-color: var(--primary); }
    .support-ticket-item .t-subject { font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .support-badge { font-size: .68rem; font-weight: 700; padding: .15rem .55rem; border-radius: 999px; flex: none; }
    .support-badge.aberto { background: var(--warning-soft); color: var(--warning); }
    .support-badge.fechado { background: var(--success-soft); color: var(--success); }
    .support-badge.arquivado { background: var(--danger-soft); color: var(--danger); }
    .support-unread-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--danger); flex: none; }
    .support-thread { display: flex; flex-direction: column; gap: .6rem; }
    .support-bubble { max-width: 82%; padding: .55rem .85rem; border-radius: 12px; font-size: .88rem; white-space: pre-wrap; }
    .support-bubble .meta { font-size: .68rem; color: var(--text-muted); margin-top: .25rem; }
    .support-bubble.cliente { align-self: flex-end; background: color-mix(in srgb, var(--primary) 14%, transparent); border-bottom-right-radius: 4px; }
    .support-bubble.suporte { align-self: flex-start; background: var(--surface-hover); border: 1px solid var(--border-light); border-bottom-left-radius: 4px; }
    .support-input-row { display: flex; gap: .5rem; padding: .85rem 1.25rem; border-top: 1px solid var(--border-light); }
    .support-input-row textarea {
      flex: 1; resize: none; min-height: 42px; max-height: 120px; padding: .55rem .8rem;
      border-radius: 10px; border: 1.5px solid var(--border-light); background: var(--surface-hover);
      color: var(--text); font-family: inherit; font-size: .9rem;
    }
    .support-input-row textarea:focus { outline: none; border-color: var(--primary); }
    .support-send-btn {
      background: var(--primary); border: none; color: #fff; cursor: pointer; flex: none;
      width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center;
    }
    .support-send-btn:disabled { opacity: .5; cursor: default; }
    .support-form label { display: block; font-weight: 600; font-size: .85rem; margin: 0 0 .3rem; }
    .support-form input, .support-form textarea {
      width: 100%; padding: .6rem .8rem; border-radius: 10px; margin-bottom: .85rem;
      border: 1.5px solid var(--border-light); background: var(--surface-hover);
      color: var(--text); font-family: inherit; font-size: .9rem;
    }
    .support-form input:focus, .support-form textarea:focus { outline: none; border-color: var(--primary); }
    .support-form textarea { resize: vertical; min-height: 90px; }
    .support-note { font-size: .8rem; color: var(--text-muted); text-align: center; padding: .6rem 1.25rem .9rem; }
    .support-closed-note {
      text-align: center; font-size: .82rem; color: var(--text-muted);
      padding: .6rem; border-top: 1px solid var(--border-light);
    }
    .support-error { color: var(--danger); font-size: .82rem; margin-top: .4rem; white-space: pre-wrap; }
    .support-attach-btn {
      background: var(--surface-hover); border: 1.5px solid var(--border-light); color: var(--text-muted); cursor: pointer; flex: none;
      width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center;
    }
    .support-attach-btn:hover { border-color: var(--primary); color: var(--primary); }
    .support-attach-preview { display: flex; align-items: center; gap: .5rem; margin: -.4rem 0 .85rem; }
    .support-attach-preview img { width: 44px; height: 44px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-light); }
    .support-attach-preview button { background: none; border: none; color: var(--danger); font-size: .8rem; cursor: pointer; padding: 0; }
    .support-bubble img.attachment { max-width: 100%; border-radius: 8px; display: block; margin-top: .35rem; cursor: pointer; }
  </style>
</head>
<body>
  <%- include('partials/nav', { user, page: 'home' }) %>

  <main x-data="homePage()" x-init="init()">
    <!-- ─── Overlay de login (quando não autenticado ou ?login=1) ─── -->
    <div class="login-overlay" x-show="showLogin" x-cloak>
      <div class="login-card">
        <img class="logo" :src="theme === 'dark' ? '/logo_kivo-horizontal_branco.svg' : '/logo_kivo-horizontal.svg'" alt="Kivo" />
        <h1>Entrar no Kivo</h1>
        <form @submit.prevent="login">
          <label for="login-user">Usuário</label>
          <input id="login-user" type="text" x-model="loginUser" autocomplete="username"
                 x-ref="loginUser" @keydown.escape.prevent="handleLoginEsc()" />
          <label for="login-pass">Senha</label>
          <input id="login-pass" type="password" x-model="loginPass" autocomplete="current-password"
                 @keydown.escape.prevent="handleLoginEsc()" />
          <label class="remember">
            <input type="checkbox" x-model="loginRemember" /> Lembrar login
          </label>
          <button type="submit" x-text="loginLoading ? 'Entrando…' : 'Entrar'"
                  :disabled="loginLoading"></button>
          <div class="error" x-text="loginError"></div>
        </form>
        <p class="version">Versão <%= appVersion %></p>
      </div>
    </div>

    <% if (user) { %>
    <div class="greeting">
      <h1><span x-html="greetingIcon" style="vertical-align:-.3rem;margin-right:.4rem"></span><span x-text="greeting + ', '"></span><%= user.name %></h1>
      <p>Comida que alimenta, sistema que organiza.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon"><%- svgIcon('search', 18, 18) %></span>
      <input type="text" placeholder="Buscar aplicativo…" x-model="q" @input="filter" />
    </div>

    <div class="app-grid" x-ref="grid">
      <template x-for="a in apps" :key="a.href">
        <a class="app-card drag-enabled" :href="a.href" :data-href="a.href" draggable="false"
           x-show="matches(a.label)"
           :class="[dragId === a.href ? 'dragging' : '', dropOverId === a.href ? 'drop-target' : '']"
           @pointerdown="onCardPointerDown($event, a)">
           <span class="card-icon" x-html="iconSvg(a.icon)"></span>
          <span class="card-title" x-text="a.label"></span>
          <span class="card-desc" x-text="a.description"></span>
        </a>
      </template>
      <%
        var moduleItems = [];
        (typeof moduleMenu !== 'undefined' ? moduleMenu : []).forEach(function (item) {
          if (!item.permission || user.permissions.has(item.permission)) {
            moduleItems.push(item);
          }
        });
        var visibleItemsForAlpine = moduleItems.map(function (item) {
          return { label: item.label, href: item.href, icon: item.icon, description: item.description ?? '' };
        });
        var visibleItems = moduleItems.slice();
        var adminItems = [];
        if (user.permissions.has('users.view')) adminItems.push({ label: 'Usuários', href: '/admin/usuarios', icon: 'user-cog', description: 'Contas, cargos e acesso.' });
        if (user.permissions.has('roles.view')) adminItems.push({ label: 'Cargos', href: '/admin/cargos', icon: 'key', description: 'Permissões por cargo.' });
        if (user.permissions.has('audit.view')) adminItems.push({ label: 'Auditoria', href: '/admin/auditoria', icon: 'shield-check', description: 'Quem fez o quê, quando e de onde.' });
        if (user.permissions.has('backup.view')) adminItems.push({ label: 'Backup', href: '/admin/backup', icon: 'database', description: 'Cópias de segurança do banco.' });
        if (user.permissions.has('settings.view')) adminItems.push({ label: 'Configurações', href: '/admin/configuracoes', icon: 'settings', description: 'Parâmetros do sistema e licença.' });
        visibleItems = visibleItems.concat(adminItems);
      %>

      <% if (adminItems.length) { %>
      <button type="button" class="app-card" @click="showMore = !showMore" x-show="!q">
        <span class="card-icon"><%- svgIcon('more', 40, 40) %></span>
        <span class="card-title" x-text="showMore ? 'Mostrar menos' : 'Mais'"></span>
        <span class="card-desc">Usuários, cargos, auditoria, backup e configurações.</span>
      </button>
      <% } %>

      <% adminItems.forEach(function (item) { %>
          <a class="app-card" href="<%= item.href %>" x-show="(showMore || q) && matches('<%= item.label %>')">
            <span class="card-icon"><%- svgIcon(item.icon, 40, 40) %></span>
            <span class="card-title"><%= item.label %></span>
            <span class="card-desc"><%= item.description %></span>
          </a>
      <% }) %>

      <%
        var rem = visibleItems.length % 6;
        if (rem > 0) {
          for (var i = 0; i < 6 - rem; i++) {
      %>
          <div class="app-card" style="visibility:hidden;border-color:transparent;box-shadow:none;cursor:default;pointer-events:none"></div>
      <%
          }
        }
      %>
    </div>
    <% } %>
  </main>

  <% if (user && user.permissions.has('settings.edit')) { %>
  <div x-data="onboardingWizard()" x-init="checkFirstRun()">
    <%- include('partials/onboarding') %>
  </div>
  <% } %>

  <% if (user) { %>
  <div x-data="helpChat()" x-init="init()">
    <button type="button" class="fab" title="Ajuda e suporte" @click="open()">
      <%- svgIcon('chat', 22, 22) %>
      <span class="fab-unread" x-show="unread > 0" x-text="unread > 9 ? '9+' : unread" x-cloak></span>
    </button>

    <dialog x-ref="dlg" class="support-dlg" @close="stopPolling()">
      <div class="support-head">
        <button type="button" class="back-btn" x-show="view !== 'home'" @click="goHome()" title="Voltar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div style="min-width:0">
          <h2 x-text="view === 'chat' ? ticket.subject : (view === 'new' ? novoTitulo() : 'Suporte Kivo')"></h2>
          <div class="sub" x-show="view === 'home'">Normalmente respondemos em poucas horas</div>
          <div class="sub" x-show="view === 'chat'" x-text="'Ticket #' + ticket.id + ' · ' + ticket.status"></div>
        </div>
        <button type="button" class="close-btn" @click="$refs.dlg.close()" title="Fechar">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- ─── Boas-vindas + atalhos ─── -->
      <div class="support-body" x-show="view === 'home'">
        <p style="margin:.1rem 0 1rem; font-size:.92rem">
          Oi<span x-text="userName ? ', ' + userName : ''"></span>! 👋 Como podemos ajudar hoje?
        </p>

        <div class="help-chat-contacts" style="margin-bottom:1rem">
          <button type="button" class="help-chat-contact" @click="newTicket('suporte')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span><strong>Ajuda e suporte</strong><br /><span class="muted text-xs">Dúvida ou problema? Abra um chamado.</span></span>
          </button>
          <button type="button" class="help-chat-contact" @click="newTicket('sugestao')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"/><line x1="9" y1="22" x2="15" y2="22"/></svg>
            <span><strong>Sugestões e melhorias</strong><br /><span class="muted text-xs">Sua ideia pode virar recurso do Kivo.</span></span>
          </button>
          <button type="button" class="help-chat-contact" @click="shareWithFriend()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span><strong x-text="shared ? 'Link copiado! ✔' : 'Compartilhar com um amigo'"></strong><br /><span class="muted text-xs">Indique o Kivo para quem você gosta.</span></span>
          </button>
        </div>

        <template x-if="tickets.length">
          <div>
            <p class="muted text-xs" style="margin:.25rem 0 .5rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em">Meus atendimentos</p>
            <template x-for="t in tickets" :key="t.id">
              <button type="button" class="support-ticket-item" @click="openTicket(t.id)">
                <span class="support-unread-dot" x-show="t.client_unread > 0"></span>
                <span class="t-subject" x-text="t.subject"></span>
                <span class="support-badge" :class="t.status" x-text="t.status"></span>
              </button>
            </template>
          </div>
        </template>

        <div class="help-chat-contacts" x-show="email || phone" style="margin-top:1rem">
          <p class="muted text-xs" style="margin:0 0 .25rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em">Outros canais</p>
          <a :href="'mailto:' + email" class="help-chat-contact" x-show="email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
            <span x-text="email"></span>
          </a>
          <a :href="'tel:' + phone" class="help-chat-contact" x-show="phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span x-text="phone"></span>
          </a>
        </div>
        <div class="support-error" x-text="error"></div>
      </div>

      <!-- ─── Novo ticket ─── -->
      <div class="support-body" x-show="view === 'new'">
        <form class="support-form" @submit.prevent="createTicket()">
          <label for="sup-subject">Assunto</label>
          <input id="sup-subject" type="text" x-model="form.subject" maxlength="160" required
                 :placeholder="form.category === 'sugestao' ? 'Ex.: Sugestão para o PDV' : 'Ex.: Dúvida no fechamento do caixa'" />
          <label for="sup-message">Como podemos ajudar?</label>
          <textarea id="sup-message" x-model="form.message" maxlength="4000" required
                    placeholder="Descreva com detalhes — quanto mais contexto, mais rápido resolvemos."></textarea>

          <input type="file" accept="image/png,image/jpeg,image/webp" x-ref="formFile" class="sr-only" style="display:none"
                 @change="onPickAttachment($event, 'form')">
          <template x-if="!form.attachment">
            <button type="button" class="btn secondary" style="width:100%; justify-content:center; margin-bottom:.4rem"
                    @click="$refs.formFile.click()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05 12.25 20.24a5.5 5.5 0 0 1-7.78-7.78l9.19-9.19a3.5 3.5 0 0 1 4.95 4.95L9.41 17.41a1.5 1.5 0 0 1-2.12-2.12l8.49-8.48"/></svg>
              Anexar print do erro
            </button>
          </template>
          <p class="support-error" x-show="attachError && !form.attachment" x-text="attachError" style="margin-top:0"></p>
          <div class="support-attach-preview" x-show="form.attachment">
            <img :src="form.attachment" alt="Print anexado">
            <span class="muted text-xs" style="flex:1">Print anexado</span>
            <button type="button" @click="form.attachment = ''; $refs.formFile.value = ''">Remover</button>
          </div>

          <button type="submit" class="btn" style="width:100%; justify-content:center" :disabled="sending">
            <span x-text="sending ? 'Abrindo chamado…' : 'Abrir chamado'"></span>
          </button>
          <div class="support-error" x-text="error"></div>
        </form>
      </div>

      <!-- ─── Conversa ─── -->
      <div x-show="view === 'chat'">
        <div class="support-body support-thread" x-ref="thread">
          <template x-for="m in messages" :key="m.id">
            <div class="support-bubble" :class="m.sender === 'cliente' ? 'cliente' : 'suporte'">
              <div x-text="m.body" x-show="m.body"></div>
              <img class="attachment" x-show="m.attachment" :src="m.attachment" alt="Print anexado" @click="window.open(m.attachment, '_blank')">
              <div class="meta" x-text="(m.sender === 'suporte' ? 'Suporte Kivo' : (m.sender_name || 'Você')) + ' · ' + String(m.created_at).slice(0, 16).replace('T', ' ')"></div>
            </div>
          </template>
          <p class="muted text-xs" x-show="!messages.length" style="text-align:center">Carregando conversa…</p>
        </div>
        <p class="support-error" x-show="attachError && !draftAttachment" x-text="attachError" style="padding:0 1.25rem"></p>
        <div class="support-attach-preview" x-show="draftAttachment" style="padding:0 1.25rem">
          <img :src="draftAttachment" alt="Print anexado">
          <span class="muted text-xs" style="flex:1">Print anexado</span>
          <button type="button" @click="draftAttachment = ''; $refs.draftFile.value = ''">Remover</button>
        </div>
        <div class="support-input-row" x-show="ticket.status === 'aberto'">
          <input type="file" accept="image/png,image/jpeg,image/webp" x-ref="draftFile" style="display:none"
                 @change="onPickAttachment($event, 'draft')">
          <button type="button" class="support-attach-btn" @click="$refs.draftFile.click()" title="Anexar print">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05 12.25 20.24a5.5 5.5 0 0 1-7.78-7.78l9.19-9.19a3.5 3.5 0 0 1 4.95 4.95L9.41 17.41a1.5 1.5 0 0 1-2.12-2.12l8.49-8.48"/></svg>
          </button>
          <textarea x-model="draft" x-ref="draftBox" placeholder="Escreva sua mensagem…" maxlength="4000"
                    @keydown.enter.prevent="if (!$event.shiftKey) sendMessage(); else draft += '\n'"></textarea>
          <button type="button" class="support-send-btn" @click="sendMessage()" :disabled="sending || (!draft.trim() && !draftAttachment)" title="Enviar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </button>
        </div>
        <div class="support-note" x-show="ticket.status === 'aberto'">
          <button type="button" class="btn secondary small" @click="closeTicket()">Encerrar atendimento</button>
        </div>
        <div class="support-closed-note" x-show="ticket.status !== 'aberto'">
          Este atendimento foi encerrado. Precisa de mais ajuda?
          <a href="#" @click.prevent="newTicket('suporte')">Abra um novo chamado</a>.
        </div>
        <div class="support-error" x-text="error" style="padding:0 1.25rem .75rem"></div>
      </div>
    </dialog>
  </div>
  <% } %>

  <% if (user && user.permissions.has('settings.edit')) { %>
  <script src="/js/onboarding.js"></script>
  <% } %>
  <script>
    const HOME_APPS_SEED = <%- JSON.stringify(typeof visibleItemsForAlpine !== 'undefined' ? visibleItemsForAlpine : []) %>;
    const HOME_ORDER_KEY = 'kivo-home-order';
    const SVG_ICONS = <%- typeof svgIconMapJson !== 'undefined' ? svgIconMapJson : '{}' %>;

    function homePage() {
      return {
        greeting: '',
        greetingIcon: '',
        theme: document.documentElement.getAttribute('data-theme') || 'light',
        q: '',
        showMore: false,
        showLogin: false,
        loginUser: '',
        loginPass: '',
        loginRemember: false,
        loginLoading: false,
        loginError: '',
        apps: [],
        dragId: null,
        dropOverId: null,
        iconSvg(name) { return SVG_ICONS[name] || ''; },

        loadOrder(items) {
          let saved = [];
          try { saved = JSON.parse(localStorage.getItem(HOME_ORDER_KEY) || '[]'); } catch {}
          if (!saved.length) return items;
          const byHref = new Map(items.map((i) => [i.href, i]));
          const ordered = [];
          saved.forEach((href) => {
            const it = byHref.get(href);
            if (it) { ordered.push(it); byHref.delete(href); }
          });
          byHref.forEach((it) => ordered.push(it));
          return ordered;
        },
        saveOrder() {
          localStorage.setItem(HOME_ORDER_KEY, JSON.stringify(this.apps.map((a) => a.href)));
        },

        onCardPointerDown(e, a) {
          if (e.pointerType === 'mouse' && e.button !== 0) return;
          const card = e.currentTarget;
          const startX = e.clientX, startY = e.clientY;
          const rect = card.getBoundingClientRect();
          let dragging = false;

          const activate = () => {
            dragging = true;
            this.dragId = a.href;
            card.style.width = rect.width + 'px';
            card.style.height = rect.height + 'px';
            card.style.left = rect.left + 'px';
            card.style.top = rect.top + 'px';
            try { card.setPointerCapture(e.pointerId); } catch {}
            card.addEventListener('click', suppressClick, { capture: true, once: true });
            if (navigator.vibrate) navigator.vibrate(12);
          };
          const suppressClick = (ev) => { ev.preventDefault(); ev.stopPropagation(); };

          const timer = setTimeout(activate, 260);

          const onMove = (ev) => {
            const dx = ev.clientX - startX, dy = ev.clientY - startY;
            if (!dragging) {
              if (Math.hypot(dx, dy) > 8) cleanup();
              return;
            }
            ev.preventDefault();
            card.style.transform = `translate(${dx}px, ${dy}px) scale(1.04)`;
            const under = document.elementFromPoint(ev.clientX, ev.clientY)?.closest('.app-card');
            this.dropOverId = under && under !== card && under.dataset.href ? under.dataset.href : null;
          };
          const onUp = () => {
            cleanup();
            if (dragging) this.finishDrag(a, card);
            else {}
          };
          const cleanup = () => {
            clearTimeout(timer);
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup', onUp);
          };

          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup', onUp);
        },
        finishDrag(a, card) {
          card.removeAttribute('style');
          this.dragId = null;
          const overHref = this.dropOverId;
          this.dropOverId = null;
          const fromIdx = this.apps.findIndex((x) => x.href === a.href);
          const toIdx = overHref != null ? this.apps.findIndex((x) => x.href === overHref) : -1;
          if (fromIdx === -1 || toIdx === -1 || fromIdx === toIdx) return;
          this.reorder(fromIdx, toIdx);
        },
        async reorder(fromIdx, toIdx) {
          const grid = this.$refs.grid;
          const before = new Map();
          grid.querySelectorAll('.app-card').forEach((el) => before.set(el, el.getBoundingClientRect()));

          const [moved] = this.apps.splice(fromIdx, 1);
          this.apps.splice(toIdx, 0, moved);
          this.saveOrder();
          await this.$nextTick();

          grid.querySelectorAll('.app-card').forEach((el) => {
            const prev = before.get(el);
            if (!prev) return;
            const next = el.getBoundingClientRect();
            const dx = prev.left - next.left, dy = prev.top - next.top;
            if (!dx && !dy) return;
            el.style.transition = 'none';
            el.style.transform = `translate(${dx}px, ${dy}px)`;
            requestAnimationFrame(() => {
              el.style.transition = 'transform .32s cubic-bezier(.2,.8,.2,1)';
              el.style.transform = '';
            });
          });
        },

        init() {
          this.apps = this.loadOrder(HOME_APPS_SEED);
          const now = new Date();
          const h = now.getHours();
          const isWeekend = now.getDay() === 0 || now.getDay() === 6;

          if (isWeekend) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="var(--primary)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
            this.greeting = 'Bom fim de semana';
          } else if (h < 12) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
            this.greeting = 'Bom dia';
          } else if (h < 18) {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18a5 5 0 0 0 .88-9.8A5.5 5.5 0 0 0 5.6 9.2 4 4 0 1 0 6 18Z"/><line x1="2" y1="2" x2="4" y2="4"/><line x1="20" y1="2" x2="22" y2="4"/><line x1="22" y1="20" x2="20" y2="22"/></svg>';
            this.greeting = 'Boa tarde';
          } else {
            this.greetingIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
            this.greeting = 'Boa noite';
          }

          const isAuthed = <%= user ? 'true' : 'false' %>;
          const hasLoginParam = window.location.search.includes('login=1');
          this.showLogin = !isAuthed || hasLoginParam;

          if (this.showLogin) {
            this.$nextTick(() => {
              const el = this.$refs.loginUser;
              if (el) el.focus();
            });
          }
        },

        matches(label) {
          if (!this.q) return true;
          return label.toLowerCase().includes(this.q.toLowerCase());
        },
        filter() {},

        async login() {
          if (this.loginLoading) return;
          if (!this.loginUser.trim() || !this.loginPass) {
            this.loginError = 'Informe usuário e senha.';
            return;
          }
          this.loginLoading = true;
          this.loginError = '';
          try {
            const r = await fetch('/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                username: this.loginUser.trim(),
                password: this.loginPass,
                remember: this.loginRemember,
              }),
            });
            if (r.ok) {
              window.location.href = '/';
            } else {
              const data = await r.json();
              this.loginError = data.error || 'Erro ao autenticar.';
            }
          } catch (e) {
            this.loginError = 'Erro de conexão.';
          } finally {
            this.loginLoading = false;
          }
        },

        handleLoginEsc() {
          if (this.loginUser || this.loginPass) {
            this.loginUser = '';
            this.loginPass = '';
          }
        },
      };
    }

    function helpChat() {
      return {
        view: 'home',
        userName: <%- JSON.stringify(typeof user !== 'undefined' && user ? (user.name || '').split(' ')[0] : '') %>,
        tickets: [], unread: 0,
        ticket: { id: 0, subject: '', status: '' }, messages: [],
        form: { subject: '', message: '', category: 'suporte', attachment: '' },
        draft: '', draftAttachment: '', attachError: '', sending: false, error: '', shared: false,
        email: '', phone: '', contactsLoaded: false,
        pollTimer: null,
        bgTimer: null,

        async api(path, opts) {
          const r = await fetch('/api/support' + path, opts ? {
            method: opts.method || 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: opts.body !== undefined ? JSON.stringify(opts.body) : undefined,
          } : undefined);
          const j = await r.json().catch(() => ({}));
          if (!r.ok || j.success === false) throw new Error(j.error || 'Falha ao falar com o suporte.');
          return j.data !== undefined ? j.data : j;
        },

        async init() {
          // Badge de não-lidas no botão flutuante; silencioso se offline/sem licença.
          try { await this.refreshTickets(); } catch (e) {}
          // Atualiza o badge a cada 30s mesmo com o chat fechado.
          this.bgTimer = setInterval(() => {
            this.refreshTickets().catch(() => {});
          }, 30000);
        },
        async refreshTickets() {
          const d = await this.api('/tickets');
          this.tickets = d.tickets || [];
          this.unread = this.tickets.reduce((n, t) => n + (t.client_unread || 0), 0);
        },

        async open() {
          this.error = '';
          this.$refs.dlg.showModal();
          try { await this.refreshTickets(); } catch (e) { this.error = e.message; }
          if (!this.contactsLoaded) {
            try {
              const r = await fetch('/api/license/status');
              if (r.ok) {
                const d = await r.json();
                const s = d.data !== undefined ? d.data : d;
                this.email = s.supportEmail || '';
                this.phone = s.supportPhone || '';
              }
            } catch (e) { /* sem contatos, segue o jogo */ }
            this.contactsLoaded = true;
          }
        },

        goHome() {
          this.stopPolling();
          this.view = 'home';
          this.error = '';
          this.refreshTickets().catch(() => {});
        },
        novoTitulo() {
          return this.form.category === 'sugestao' ? 'Sugestões e melhorias' : 'Ajuda e suporte';
        },

        newTicket(category) {
          this.form = { subject: '', message: '', category, attachment: '' };
          this.attachError = '';
          this.error = '';
          this.view = 'new';
        },
        /** Converte o print escolhido em data URI e guarda no form (novo ticket) ou no
         * rascunho da conversa — sem upload/storage à parte, cabe direto na mensagem. */
        onPickAttachment(event, target) {
          const file = event.target.files && event.target.files[0];
          event.target.value = '';
          if (!file) return;
          this.attachError = '';
          if (file.size > 4 * 1024 * 1024) {
            this.attachError = 'Imagem muito grande (máx. 4MB).';
            return;
          }
          const reader = new FileReader();
          reader.onload = () => {
            if (target === 'form') this.form.attachment = reader.result;
            else this.draftAttachment = reader.result;
          };
          reader.readAsDataURL(file);
        },
        async createTicket() {
          if (this.sending) return;
          this.sending = true; this.error = '';
          try {
            const d = await this.api('/tickets', { body: this.form });
            await this.openTicket(d.id);
          } catch (e) { this.error = e.message; }
          this.sending = false;
        },

        async openTicket(id) {
          this.error = '';
          this.attachError = '';
          this.draftAttachment = '';
          this.view = 'chat';
          this.messages = [];
          this.ticket = { id, subject: '…', status: '' };
          try {
            await this.loadMessages(id);
            this.startPolling();
            this.$nextTick(() => this.$refs.draftBox && this.$refs.draftBox.focus());
          } catch (e) { this.error = e.message; }
        },
        async loadMessages(id) {
          const d = await this.api('/tickets/' + id + '/messages');
          this.ticket = d.ticket;
          const atBottom = this.isThreadAtBottom();
          const grew = (d.messages || []).length !== this.messages.length;
          this.messages = d.messages || [];
          if (grew && atBottom) this.$nextTick(() => this.scrollThread());
        },
        async sendMessage() {
          const body = this.draft.trim();
          const attachment = this.draftAttachment;
          if ((!body && !attachment) || this.sending) return;
          this.sending = true; this.error = '';
          try {
            await this.api('/tickets/' + this.ticket.id + '/messages', { body: { body, attachment } });
            this.draft = '';
            this.draftAttachment = '';
            await this.loadMessages(this.ticket.id);
            this.scrollThread();
          } catch (e) { this.error = e.message; }
          this.sending = false;
        },
        async closeTicket() {
          if (!confirm('Encerrar este atendimento? Você pode abrir um novo chamado quando quiser.')) return;
          try {
            await this.api('/tickets/' + this.ticket.id + '/close', { body: {} });
            this.stopPolling();
            this.view = 'home';
            this.error = '';
            await this.refreshTickets();
          } catch (e) { this.error = e.message; }
        },

        startPolling() {
          this.stopPolling();
          // Novas respostas do suporte aparecem sem recarregar; só enquanto a conversa está aberta.
          this.pollTimer = setInterval(() => {
            if (this.view === 'chat' && this.$refs.dlg.open) this.loadMessages(this.ticket.id).catch(() => {});
          }, 5000);
        },
        stopPolling() {
          if (this.pollTimer) { clearInterval(this.pollTimer); this.pollTimer = null; }
        },
        isThreadAtBottom() {
          const el = this.$refs.thread;
          return !el || el.scrollHeight - el.scrollTop - el.clientHeight < 60;
        },
        scrollThread() {
          const el = this.$refs.thread;
          if (el) el.scrollTop = el.scrollHeight;
        },

        destroy() {
          this.stopPolling();
          if (this.bgTimer) { clearInterval(this.bgTimer); this.bgTimer = null; }
        },

        async shareWithFriend() {
          try {
            const d = await this.api('/share-link');
            await navigator.clipboard.writeText(
              'Conhece o Kivo? É o sistema que eu uso para PDV, estoque e financeiro — funciona até sem internet. Dá uma olhada: ' + d.url,
            );
            this.shared = true;
            setTimeout(() => { this.shared = false; }, 2500);
          } catch (e) { this.error = 'Não consegui copiar o link.'; }
        },
      };
    }
  </script>
</body>
</html>
