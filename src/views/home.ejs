<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Katsu</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/katsu_logo.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: 'home' }) %>
  <main>
    <h1>Bem-vindo, <%= user.name %></h1>
    <div class="cards">
      <% if (user.permissions.has('users.view')) { %>
        <a class="card" href="/admin/usuarios"><h2>Usuários</h2><p>Contas, cargos e acesso ao sistema.</p></a>
      <% } %>
      <% if (user.permissions.has('audit.view')) { %>
        <a class="card" href="/admin/auditoria"><h2>Auditoria</h2><p>Quem fez o quê, quando e de onde.</p></a>
      <% } %>
      <% if (user.permissions.has('backup.view')) { %>
        <a class="card" href="/admin/backup"><h2>Backup</h2><p>Cópias de segurança do banco local.</p></a>
      <% } %>
      <% if (user.permissions.has('settings.view')) { %>
        <a class="card" href="/admin/configuracoes"><h2>Configurações</h2><p>Parâmetros do sistema e licença.</p></a>
      <% } %>
    </div>
    <p class="muted" style="margin-top:2rem">Os módulos (Apps) instalados aparecerão aqui.</p>
  </main>
</body>
</html>
