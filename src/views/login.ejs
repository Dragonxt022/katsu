<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Kivo — Entrar</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <script defer src="/vendor/alpine.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; }
    body { font-family: system-ui, sans-serif; background: #0f1115; color: #e6e6e6;
           display: grid; place-items: center; min-height: 100vh; }
    .card { background: #1a1d24; padding: 2.5rem; border-radius: 12px; width: 340px;
            box-shadow: 0 8px 32px rgba(0,0,0,.4); }
    .logo { display: block; margin: 0 auto 1.5rem; width: 96px; }
    h1 { font-size: 1.1rem; text-align: center; margin-bottom: 1.5rem; font-weight: 500; }
    label { display: block; font-size: .85rem; margin: .8rem 0 .3rem; color: #9aa0aa; }
    input[type=text], input[type=password] { width: 100%; padding: .6rem .8rem; border-radius: 8px;
            border: 1px solid #2c313c; background: #12141a; color: #e6e6e6; font-size: 1rem; }
    .remember { display: flex; align-items: center; gap: .5rem; margin: 1rem 0; font-size: .85rem; color: #9aa0aa; }
    button { width: 100%; padding: .7rem; border: 0; border-radius: 8px; background: #e5484d;
             color: #fff; font-size: 1rem; font-weight: 600; cursor: pointer;
             display: inline-flex; align-items: center; justify-content: center; gap: .5rem; }
    button:hover { background: #d93a40; }
    button svg { flex-shrink: 0; }
    .error { color: #ff8589; font-size: .85rem; margin-top: .8rem; text-align: center; min-height: 1.2em; }
  </style>
</head>
<body>
  <div class="card" x-data="loginForm()">
    <img class="logo" src="/logo_kivo-horizontal.svg" alt="Kivo" />
    <h1>Entrar no Kivo</h1>
    <form @submit.prevent="submit">
      <label for="username">Usuário</label>
      <input id="username" type="text" x-model="username" autocomplete="username" autofocus />
      <label for="password">Senha</label>
      <input id="password" type="password" x-model="password" autocomplete="current-password" />
      <label class="remember">
        <input type="checkbox" x-model="remember" /> Lembrar login
      </label>
      <button type="submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        <span x-text="loading ? 'Entrando…' : 'Entrar'"></span>
      </button>
      <div class="error" x-text="error"></div>
    </form>
  </div>
  <script>
    function loginForm() {
      return {
        username: '', password: '', remember: false, error: '', loading: false,
        async submit() {
          this.loading = true; this.error = '';
          const r = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: this.username, password: this.password, remember: this.remember }),
          });
          this.loading = false;
          if (r.ok) { window.location.href = '/'; }
          else { this.error = (await r.json()).error ?? 'Falha no login.'; }
        },
      };
    }
  </script>
</body>
</html>

