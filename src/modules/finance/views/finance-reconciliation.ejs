<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Reconciliação</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/finance/reconciliacao' }) %>
  <main x-data="reconciliationPage()" x-init="load()">
    <h1>Reconciliação de saldos</h1>
    <p class="muted">
      Crédito de troca e pontos de fidelidade podem ficar negativos quando duas máquinas offline usam o mesmo saldo
      ao mesmo tempo, antes de sincronizar entre si. A lista abaixo aponta esses casos para resolução manual com o cliente.
    </p>
    <table>
      <thead><tr><th>Cliente</th><th class="text-right">Crédito de troca</th><th class="text-right">Pontos</th><th></th></tr></thead>
      <tbody>
        <template x-for="c in rows" :key="c.id">
          <tr>
            <td x-text="c.name"></td>
            <td class="text-right" :style="c.store_credit_cents < 0 ? 'color:var(--danger);font-weight:700' : ''" x-text="brl(c.store_credit_cents)"></td>
            <td class="text-right" :style="c.loyalty_points < 0 ? 'color:var(--danger);font-weight:700' : ''" x-text="c.loyalty_points"></td>
            <td class="text-right"><a :href="'/app/commercial/clientes/' + c.id" class="btn secondary small">Ver ficha</a></td>
          </tr>
        </template>
        <tr x-show="!rows.length"><td colspan="4"><%- include('partials/empty-state', { message: 'Nenhum saldo negativo encontrado — tudo certo.' }) %></td></tr>
      </tbody>
    </table>
  </main>
  <script>
    function reconciliationPage() {
      return {
        rows: [],
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        async load() {
          const r = await fetch('/api/finance/reconciliation/negative-balances');
          if (r.ok) this.rows = await r.json();
        },
      };
    }
  </script>
</body>
</html>
