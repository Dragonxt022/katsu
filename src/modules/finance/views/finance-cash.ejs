<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo — Caixa</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/finance/caixa' }) %>
  <main x-data="cashPage()" x-init="load()" @apply-filter.window="filter=$event.detail">
    <h1>Caixa</h1>

    <template x-if="!open">
      <div>
        <p class="muted muted-block">Nenhum caixa aberto.</p>
        <% if (user.permissions.has('finance.cash.open')) { %>
        <div class="toolbar">
          <button class="btn" @click="openOpenDlg()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="22" height="14" rx="2"/><path d="M1 10h22"/><path d="M6 4h12"/></svg>
            Abrir caixa
          </button>
          <span class="error" x-text="error"></span>
        </div>
        <% } %>
      </div>
    </template>

    <template x-if="open">
      <div>
        <div class="toolbar">
          <span class="badge ok">aberto</span>
          <span>Esperado na gaveta: <strong x-text="brl(expected)"></strong></span>
          <% if (user.permissions.has('finance.cash.move')) { %>
            <button class="btn secondary" @click="openMove('suprimento')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Suprimento
            </button>
            <button class="btn secondary" @click="openMove('sangria')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Sangria
            </button>
          <% } %>
          <% if (user.permissions.has('finance.cash.close')) { %>
            <button class="btn" @click="$refs.close.showModal()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="22" height="14" rx="2"/><path d="M1 10h22"/><circle cx="12" cy="14" r="2"/></svg>
              Fechar caixa
            </button>
          <% } %>
          <span class="error" x-text="error"></span>
        </div>
        <table>
          <thead><tr><th>Quando</th><th>Tipo</th><th>Direção</th><th>Valor</th><th>Descrição</th><th>Usuário</th></tr></thead>
          <tbody>
            <template x-for="m in movements" :key="m.id">
              <tr>
                <td class="muted" x-text="fmtDateTime(m.created_at)"></td>
                <td x-text="m.type"></td>
                <td><span class="badge" :class="m.direction === 'entrada' ? 'ok' : 'off'" x-text="m.direction"></span></td>
                <td x-text="brl(m.amount_cents)"></td>
                <td class="muted" x-text="m.description ?? '—'"></td>
                <td class="muted" x-text="m.username ?? '—'"></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </template>

    <dialog x-ref="openDlg">
      <h1>Abrir caixa</h1>
      <label>Fundo de troco (R$)</label>
      <input type="text" x-model="opening" placeholder="0,00" @input="opening = maskMoney(opening)" autofocus />
      <div class="error" x-text="error"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.openDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="openCash()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Abrir
        </button>
      </div>
    </dialog>

    <dialog x-ref="mv">
      <h1 x-text="move.type === 'suprimento' ? 'Suprimento (entrada)' : 'Sangria (saída)'"></h1>
      <label>Valor (R$)</label><input type="text" x-model="move.amount" placeholder="0,00" @input="move.amount = maskMoney(move.amount)" />
      <label>Descrição</label><input type="text" x-model="move.description" />
      <div class="error" x-text="mvError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.mv.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="saveMove()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Confirmar
        </button>
      </div>
    </dialog>

    <dialog x-ref="close" class="dialog-fixed">
      <h1>Fechar caixa</h1>
      <div class="dialog-body">
        <p class="muted">Esperado: <strong x-text="brl(expected)"></strong></p>

        <label class="label-checkbox-sm" style="margin:.6rem 0">
          <input type="checkbox" x-model="countMode" @change="counts = {}" /> Contar notas e moedas
        </label>

        <template x-if="!countMode">
          <div>
            <label>Valor contado na gaveta (R$)</label>
            <input type="text" x-model="counted" placeholder="0,00" @input="counted = maskMoney(counted)" />
          </div>
        </template>

        <template x-if="countMode">
          <div>
            <table>
              <thead><tr><th>Denominação</th><th style="width:80px">Qtd.</th><th class="text-right">Subtotal</th></tr></thead>
              <tbody>
                <template x-for="d in denominations" :key="d.cents">
                  <tr>
                    <td x-text="d.label"></td>
                    <td><input type="number" min="0" step="1" x-model.number="counts[d.cents]" style="width:70px" /></td>
                    <td class="muted text-right" x-text="brl((counts[d.cents] || 0) * d.cents)"></td>
                  </tr>
                </template>
              </tbody>
            </table>
            <p class="text-right" style="margin-top:.5rem">Total contado: <strong x-text="brl(countTotal)"></strong></p>
          </div>
        </template>

        <label>Observações</label><input type="text" x-model="closeNotes" />
        <div class="error" x-text="closeError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.close.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="closeCash()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Fechar
        </button>
      </div>
    </dialog>

    <template x-if="history.length">
      <div class="mt-2">
        <h2>Histórico de fechamentos</h2>
        <div class="toolbar">
          <%- include('partials/search-filter', { statusOptions: [
            { value: 'aberto', label: 'Aberto', color: '#eab308' },
            { value: 'fechado', label: 'Fechado', color: '#16a34a' },
          ], placeholder: 'Buscar por observação' }) %>
          <span class="muted" x-text="pageTotal + ' registro(s)'"></span>
        </div>
        <table>
          <thead><tr>
            <th @click="sortCycle('opened_at')" class="sortable">Aberto em<span class="sort-arrow" x-text="sortArrow('opened_at')"></span></th>
            <th @click="sortCycle('closed_at')" class="sortable">Fechado em<span class="sort-arrow" x-text="sortArrow('closed_at')"></span></th>
            <th @click="sortCycle('expected_cents')" class="sortable">Esperado<span class="sort-arrow" x-text="sortArrow('expected_cents')"></span></th>
            <th @click="sortCycle('counted_cents')" class="sortable">Contado<span class="sort-arrow" x-text="sortArrow('counted_cents')"></span></th>
            <th @click="sortCycle('difference_cents')" class="sortable">Diferença<span class="sort-arrow" x-text="sortArrow('difference_cents')"></span></th>
            <th @click="sortCycle('status')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
            <th></th>
          </tr></thead>
          <tbody>
            <template x-for="r in pageRows" :key="r.id">
              <tr>
                <td class="muted" x-text="fmtDateTime(r.opened_at)"></td>
                <td class="muted" x-text="r.closed_at ? fmtDateTime(r.closed_at) : '—'"></td>
                <td x-text="brl(r.expected_cents)"></td>
                <td x-text="brl(r.counted_cents)"></td>
                <td>
                  <span :style="{ color: r.difference_cents < 0 ? 'var(--danger)' : r.difference_cents > 0 ? 'var(--success-text)' : '', fontWeight: r.difference_cents !== 0 ? 700 : 400 }"
                        x-text="(r.difference_cents >= 0 ? '+' : '') + (r.difference_cents / 100).toFixed(2).replace('.', ',')"></span>
                </td>
                <td>
                  <span class="badge" :class="r.status === 'aberto' ? 'off' : 'ok'" x-text="r.status"></span>
                  <span class="badge badge-info badge-ml" x-show="r.edited_at"
                        :title="'Editado por ' + (r.edited_by_name ?? '—') + ' em ' + fmtDateTime(r.edited_at)">editado</span>
                </td>
                <td class="text-right">
                  <button class="btn secondary small" x-show="r.status === 'fechado'" @click="printReport(r.id)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 17v-3"/><path d="M14 17v-2"/><path d="M10 17v-5"/><path d="M6 17v-1"/></svg>
                    Relatório
                  </button>
                  <% if (user.permissions.has('finance.cash.edit')) { %>
                    <button class="btn secondary small" x-show="r.status === 'fechado'" @click="openEditReg(r)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                      Editar
                    </button>
                  <% } %>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
        <%- include('partials/pager') %>
      </div>
    </template>

    <dialog x-ref="closeResultDlg" style="width:360px">
      <div class="dialog-body-center">
        <div :style="'width:44px;height:44px;border-radius:50%;display:grid;place-items:center;margin:0 auto .75rem;background:' + (closeResult.difference === 0 ? 'var(--success-bg)' : (closeResult.difference < 0 ? 'var(--danger-bg)' : 'var(--warning-bg)'))">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"
               :stroke="closeResult.difference === 0 ? 'var(--success-text)' : (closeResult.difference < 0 ? 'var(--danger)' : 'var(--warning-text)')">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <h2 class="dialog-heading">Caixa fechado</h2>
        <table style="width:100%;margin-bottom:.5rem">
          <tbody>
            <tr><td class="muted">Esperado</td><td class="text-right"><strong x-text="brl(closeResult.expected)"></strong></td></tr>
            <tr><td class="muted">Contado</td><td class="text-right"><strong x-text="brl(closeResult.counted)"></strong></td></tr>
            <tr>
              <td class="muted">Diferença</td>
              <td class="text-right">
                <strong :style="{ color: closeResult.difference < 0 ? 'var(--danger)' : closeResult.difference > 0 ? 'var(--success-text)' : '' }"
                        x-text="(closeResult.difference >= 0 ? '+' : '') + brl(closeResult.difference)"></strong>
              </td>
            </tr>
          </tbody>
        </table>
        <div class="actions actions-center">
          <button class="btn secondary" @click="printReport(closeResult.id)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Imprimir relatório completo
          </button>
          <button class="btn" @click="$refs.closeResultDlg.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            OK
          </button>
        </div>
      </div>
    </dialog>

    <dialog x-ref="editReg" @click="$event.target === $el && $refs.editReg.close()">
      <h1>Editar fechamento</h1>
      <label>Valor contado na gaveta (R$)</label>
      <input type="text" x-model="editReg.counted" placeholder="0,00" @input="editReg.counted = maskMoney(editReg.counted)" />
      <label>Observações</label>
      <input type="text" x-model="editReg.notes" />
      <div class="error" x-text="editRegError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.editReg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="saveEditReg()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/table-toolkit.js"></script>
  <script src="/js/masks.js"></script>
  <script>
    function cashPage() {
      return {
        ...tableToolkit(),
        open: false, expected: 0, movements: [], opening: '', counted: '', closeNotes: '',
        countMode: false, counts: {}, filter: {},
        denominations: [
          { cents: 20000, label: 'R$ 200' }, { cents: 10000, label: 'R$ 100' }, { cents: 5000, label: 'R$ 50' },
          { cents: 2000, label: 'R$ 20' }, { cents: 1000, label: 'R$ 10' }, { cents: 500, label: 'R$ 5' },
          { cents: 200, label: 'R$ 2' }, { cents: 100, label: 'R$ 1' }, { cents: 50, label: 'R$ 0,50' },
          { cents: 25, label: 'R$ 0,25' }, { cents: 10, label: 'R$ 0,10' }, { cents: 5, label: 'R$ 0,05' },
        ],
        move: {}, history: [], editReg: {}, closeResult: {}, error: '', mvError: '', closeError: '', editRegError: '',
        sortGetters: {
          opened_at: (r) => r.opened_at ?? '', closed_at: (r) => r.closed_at ?? '',
          expected_cents: (r) => r.expected_cents, counted_cents: (r) => r.counted_cents,
          difference_cents: (r) => r.difference_cents, status: (r) => r.status ?? '',
        },
        get displayRows() { return this.sortedRows(filterRows(this.history, this.filter), this.sortGetters); },
        get pageTotal() { return this.displayRows.length; },
        get pageRows() { return this.pagedRows(this.displayRows); },
        get countTotal() {
          return this.denominations.reduce((sum, d) => sum + (Number(this.counts[d.cents]) || 0) * d.cents, 0);
        },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        printReport(id) { if (id) window.open(`/app/finance/caixa/${id}/relatorio`, '_blank', 'width=800,height=900'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return Math.round(n * 100); },
        openOpenDlg() { this.opening = ''; this.error = ''; this.$refs.openDlg.showModal(); },
        async load() {
          const r = await fetch('/api/finance/cash/current');
          if (!r.ok) return;
          const data = await r.json();
          this.open = data.open; this.expected = data.expectedCents ?? 0;
          if (this.open) {
            const m = await fetch('/api/finance/cash/movements');
            if (m.ok) this.movements = await m.json();
          }
          const h = await fetch('/api/finance/cash/history');
          if (h.ok) this.history = await h.json();
          // Vindo do aviso de "caixa aberto há mais de 24h" (nav.ejs) — abre direto o fechamento,
          // sem exigir mais um clique na tela do Caixa.
          const params = new URLSearchParams(location.search);
          if (params.get('fechar') === '1' && this.open) {
            history.replaceState(null, '', location.pathname);
            this.$refs.close.showModal();
          }
        },
        openEditReg(r) {
          this.editReg = { id: r.id, counted: (r.counted_cents / 100).toFixed(2).replace('.', ','), notes: r.notes ?? '' };
          this.editRegError = '';
          this.$refs.editReg.showModal();
        },
        async saveEditReg() {
          const r = await fetch(`/api/finance/cash/${this.editReg.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ countedCents: this.cents(this.editReg.counted), notes: this.editReg.notes || undefined }),
          });
          if (r.ok) {
            const d = await r.json();
            this.$refs.editReg.close();
            this.closeResult = d;
            this.$refs.closeResultDlg.showModal();
            this.load();
          } else this.editRegError = (await r.json()).error;
        },
        async openCash() {
          const r = await fetch('/api/finance/cash/open', { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ openingCents: this.cents(this.opening) }) });
          if (r.ok) { this.$refs.openDlg.close(); this.load(); showToast('Caixa aberto.', 'success'); } else showToast((await r.json()).error, 'error');
        },
        openMove(type) { this.move = { type, amount: '', description: '' }; this.mvError = ''; this.$refs.mv.showModal(); },
        async saveMove() {
          const r = await fetch('/api/finance/cash/movement', { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: this.move.type, amountCents: this.cents(this.move.amount), description: this.move.description || undefined }) });
          if (r.ok) { this.$refs.mv.close(); this.load(); } else this.mvError = (await r.json()).error;
        },
        async closeCash() {
          const countedCents = this.countMode ? this.countTotal : this.cents(this.counted);
          const body = { countedCents, notes: this.closeNotes || undefined };
          if (this.countMode) {
            body.countBreakdown = Object.fromEntries(
              Object.entries(this.counts).filter(([, qty]) => Number(qty) > 0),
            );
          }
          const r = await fetch('/api/finance/cash/close', { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body) });
          if (r.ok) {
            const d = await r.json();
            this.$refs.close.close();
            this.counted = ''; this.closeNotes = ''; this.countMode = false; this.counts = {};
            this.closeResult = d;
            this.$refs.closeResultDlg.showModal();
            this.load();
          } else this.closeError = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>

