<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — <%= bills.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: bills.api }) %>
  <%
    var _billStatusOpts = [
      { value: 'aberta', label: 'Abertas', color: '#dc2626' },
      { value: bills.settledStatus, label: 'Liquidadas', color: '#16a34a' },
      { value: 'cancelada', label: 'Canceladas', color: '#6b7280' }
    ];
    var _billPlaceholder = 'Buscar por descricao ou ' + bills.partyLabel.toLowerCase();
  %>
  <main x-data="billsPage('<%= bills.api %>', <%= !!bills.categoryField %>)" x-init="load(); <% if (bills.categoryField) { %>loadCategories()<% } %>" @apply-filter.window="filter=$event.detail; load()">
    <h1><%= bills.title %></h1>
    <div class="toolbar">
      <% if (user.permissions.has(bills.createPerm)) { %>
        <button class="btn" @click="openNew()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nova conta
        </button>
      <% } %>
      <%- include('partials/search-filter', { statusOptions: _billStatusOpts, placeholder: _billPlaceholder }) %>
      <span class="muted" x-text="pageTotal + ' registro(s)'"></span>
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr>
        <th @click="sortCycle('description')" class="sortable">Descrição<span class="sort-arrow" x-text="sortArrow('description')"></span></th>
        <th @click="sortCycle('party')" class="sortable"><%= bills.partyLabel %><span class="sort-arrow" x-text="sortArrow('party')"></span></th>
        <th @click="sortCycle('amount_cents')" class="sortable">Valor<span class="sort-arrow" x-text="sortArrow('amount_cents')"></span></th>
        <th @click="sortCycle('issue_date')" class="sortable">Emissão<span class="sort-arrow" x-text="sortArrow('issue_date')"></span></th>
        <th @click="sortCycle('due_date')" class="sortable">Vencimento<span class="sort-arrow" x-text="sortArrow('due_date')"></span></th>
        <th @click="sortCycle('status')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
        <% if (bills.categoryField) { %><th>Categoria</th><% } %>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="b in pageRows" :key="b.id">
          <tr>
            <td>
              <span x-text="b.description"></span>
              <span class="badge neutral" x-show="b.installment_count > 1" style="margin-left:.4rem" x-text="b.installment_no + '/' + b.installment_count"></span>
            </td>
            <td class="muted" x-text="b.party ?? '—'"></td>
            <td x-text="brl(b.amount_cents)"></td>
            <td class="muted" x-text="b.issue_date ? fmtDate(b.issue_date) : '—'"></td>
            <td class="muted" x-text="fmtDate(b.due_date)"></td>
            <td><span class="badge" :class="b.status === 'aberta' ? 'off' : (b.status === 'cancelada' ? 'neutral' : 'ok')" x-text="b.status"></span></td>
            <% if (bills.categoryField) { %><td class="muted" x-text="b.dre_category_label ?? '—'"></td><% } %>
            <td class="text-right" @click.stop>
              <div class="dropdown" x-show="b.status === 'aberta'">
                <button class="icon-btn" @click="openMenu = openMenu === b.id ? null : b.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === b.id" x-cloak @click.outside="openMenu = null">
                  <% if (user.permissions.has(bills.settlePerm)) { %>
                  <button @click="openMenu = null; openSettle(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    <%= bills.settleLabel %>
                  </button>
                  <% } %>
                  <% if (user.permissions.has(bills.editPerm)) { %>
                  <button @click="openMenu = null; openEdit(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                    Editar
                  </button>
                  <button class="danger" @click="openMenu = null; cancel(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    Cancelar
                  </button>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="<%= bills.categoryField ? 8 : 7 %>"><%- include('partials/empty-state', { message: 'Nenhuma conta registrada ainda.' }) %></td></tr>
      </tbody>
    </table>
    <%- include('partials/pager') %>

    <dialog x-ref="dlg">
      <h1 x-text="form.id ? 'Editar conta' : 'Nova conta'"></h1>
      <label>Descrição</label><input type="text" x-model="form.description" />
      <label>Valor (R$)</label><input type="text" x-model="form.amount" placeholder="0,00" @input="form.amount = maskMoney(form.amount)" />
      <label>Vencimento (1ª parcela)</label><input type="date" x-model="form.dueDate" />
      <label>Emissão</label><input type="date" x-model="form.issueDate" />
      <template x-if="!form.id">
        <div>
          <label>Parcelas</label>
          <input class="input-narrow" type="number" min="1" max="24" step="1" x-model.number="form.installments" />
          <p class="hint" x-show="form.installments > 1">
            <span x-text="form.installments"></span> parcelas de
            <strong x-text="brl(Math.round(cents(form.amount) / form.installments))"></strong> cada, vencendo a
            cada 30 dias a partir do vencimento acima.
          </p>
        </div>
      </template>
      <% if (bills.categoryField) { %>
      <label>Categoria (DRE)</label>
      <div class="combo-wrap" @click.outside="catResults = []">
        <input type="text" placeholder="Buscar categoria…" x-model="catQ"
               @focus="searchCategories()" @input="searchCategories()"
               @keydown.enter.prevent="quickPickCategory()"
               @keydown.down.prevent="catIdx = Math.min(catIdx + 1, catResults.length - 1)"
               @keydown.up.prevent="catIdx = Math.max(catIdx - 1, 0)" />
        <div class="combo-results" x-show="catResults.length" x-cloak>
          <template x-for="(c, idx) in catResults" :key="c.id">
            <button type="button" class="combo-result" :class="{ active: idx === catIdx }" @click="pickCategory(c)">
              <span x-text="c.label"></span>
            </button>
          </template>
        </div>
      </div>
      <% } %>
      <label>Observações</label><input type="text" x-model="form.notes" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()">Salvar</button>
      </div>
    </dialog>

    <dialog x-ref="settleDlg" class="dialog-fixed" style="width:min(480px,calc(100vw - 2rem))">
      <h1><%= bills.settleLabel %></h1>
      <div class="dialog-body">
        <p class="muted" x-text="settleForm.description"></p>
        <p>Valor devido: <strong x-text="brl(settleForm.amountCents)"></strong></p>
        <p x-show="settleForm.diasAtraso > 0" class="muted text-xs">
          Vencida há <strong x-text="settleForm.diasAtraso"></strong> dia(s) —
          com multa/juros: <strong x-text="brl(settleOwedCents())"></strong>
        </p>

        <label style="margin-top:.6rem">Formas de pagamento</label>
        <template x-for="(p, idx) in settleForm.payments" :key="idx">
          <div class="form-grid" style="grid-template-columns:1fr 110px 32px;margin-bottom:.4rem">
            <select x-model.number="p.methodId">
              <option value="">Selecione…</option>
              <template x-for="m in settleMethods" :key="m.id">
                <option :value="m.id" x-text="m.name"></option>
              </template>
            </select>
            <input type="text" x-model="p.amount" placeholder="0,00" @input="p.amount = maskMoney(p.amount)" />
            <button type="button" class="btn secondary small" @click="removeSettlePaymentRow(idx)" x-show="settleForm.payments.length > 1">×</button>
          </div>
        </template>
        <button type="button" class="btn secondary small" @click="addSettlePaymentRow()">+ Adicionar forma</button>

        <p class="hint" style="margin-top:.6rem">
          Total informado: <strong x-text="brl(settleTotalCents())"></strong>
        </p>
        <p class="hint" style="color:var(--warning-text)" x-show="settleTotalCents() > 0 && settleTotalCents() < settleOwedCents()">
          Faltam <strong x-text="brl(settleOwedCents() - settleTotalCents())"></strong> —
          serão transferidos automaticamente pra próxima parcela em aberto, ou uma parcela nova será criada se não houver uma.
        </p>

        <label style="margin-top:.6rem">Data do pagamento</label>
        <input type="date" x-model="settleForm.settledAt" />
        <p class="hint">Pagamento adiantado? Ajuste a data acima — o padrão é hoje.</p>
        <div class="error" x-text="settleError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.settleDlg.close()">Cancelar</button>
        <button class="btn" @click="confirmSettle()"><%= bills.settleLabel %></button>
      </div>
    </dialog>

    <dialog x-ref="noRegisterDlg" style="border:0;border-radius:12px;padding:0;box-shadow:var(--shadow-lg);width:340px;max-width:90vw">
      <div class="dialog-body-center" style="padding:1.25rem">
        <div class="dialog-icon-sm dialog-icon-warning">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h2 class="dialog-heading-md">Nenhum caixa aberto</h2>
        <p class="dialog-muted-sm">
          Liquidar em dinheiro exige um caixa aberto, pra esse valor entrar na conferência da
          gaveta. Abra o caixa e tente de novo.
        </p>
        <div class="actions actions-center">
          <button class="btn secondary" @click="$refs.noRegisterDlg.close()">Cancelar</button>
          <button class="btn" @click="location.href = '/app/finance/caixa'">Abrir caixa</button>
        </div>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function billsPage(api, hasCategory) {
      return {
        ...tableToolkit(),
        rows: [], categories: [], form: {}, error: '', dlgError: '', filter: {},
        catQ: '', catResults: [], catIdx: -1,
        settleForm: { id: null, description: '', amountCents: 0, settledAt: '', diasAtraso: 0, suggestedSettleCents: 0, payments: [] },
        settleError: '', settleMethods: [],
        sortGetters: {
          description: (b) => b.description ?? '', party: (b) => b.party ?? '', amount_cents: (b) => b.amount_cents,
          issue_date: (b) => b.issue_date ?? '', due_date: (b) => b.due_date ?? '', status: (b) => b.status ?? '',
        },
        get displayRows() { return this.sortedRows(filterRows(this.rows, this.filter), this.sortGetters); },
        get pageTotal() { return this.displayRows.length; },
        get pageRows() { return this.pagedRows(this.displayRows); },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return Math.round(n * 100); },
        async load() {
          const r = await fetch(api);
          if (r.ok) this.rows = await r.json(); else this.error = (await r.json()).error;
        },
        async loadCategories() {
          const r = await fetch('/api/dre/categories?manualOnly=1');
          if (r.ok) this.categories = await r.json();
        },
        searchCategories() {
          const q = (this.catQ || '').trim().toLowerCase();
          this.catResults = (q ? this.categories.filter((c) => c.label.toLowerCase().includes(q)) : this.categories).slice(0, 8);
          this.catIdx = this.catResults.length ? 0 : -1;
        },
        pickCategory(c) {
          this.form.dreCategoryId = c.id; this.catQ = c.label;
          this.catResults = []; this.catIdx = -1;
        },
        quickPickCategory() {
          if (this.catIdx >= 0 && this.catResults[this.catIdx]) this.pickCategory(this.catResults[this.catIdx]);
        },
        openNew() {
          const def = hasCategory ? this.categories.find((c) => c.key === 'outras_despesas_operacionais') : null;
          this.form = hasCategory
            ? { issueDate: todayLocal(), dreCategoryId: def?.id ?? null, installments: 1 }
            : { issueDate: todayLocal(), installments: 1 };
          this.catQ = def?.label ?? ''; this.catResults = [];
          this.dlgError = ''; this.$refs.dlg.showModal();
        },
        openEdit(b) {
          this.form = { id: b.id, description: b.description, amount: (b.amount_cents / 100).toFixed(2).replace('.', ','),
            issueDate: b.issue_date ?? '', dueDate: b.due_date, notes: b.notes ?? '', dreCategoryId: b.dre_category_id ?? null };
          this.catQ = b.dre_category_label ?? ''; this.catResults = [];
          this.dlgError = ''; this.$refs.dlg.showModal();
        },
        async save() {
          if (this.form.id) {
            const r = await fetch(`${api}/${this.form.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ description: this.form.description, amountCents: this.cents(this.form.amount),
                issueDate: this.form.issueDate || undefined, dueDate: this.form.dueDate, notes: this.form.notes || undefined,
                dreCategoryId: hasCategory ? this.form.dreCategoryId : undefined }) });
            if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
            return;
          }
          const r = await fetch(api, { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: this.form.description, amountCents: this.cents(this.form.amount),
              issueDate: this.form.issueDate || undefined, dueDate: this.form.dueDate, notes: this.form.notes || undefined,
              dreCategoryId: hasCategory ? this.form.dreCategoryId : undefined, installments: this.form.installments || 1 }) });
          if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
        },
        settleOwedCents() { return this.settleForm.suggestedSettleCents || this.settleForm.amountCents; },
        settleTotalCents() { return (this.settleForm.payments || []).reduce((s, p) => s + this.cents(p.amount), 0); },
        addSettlePaymentRow() { this.settleForm.payments.push({ methodId: '', amount: '' }); },
        removeSettlePaymentRow(idx) { this.settleForm.payments.splice(idx, 1); },
        async openSettle(b) {
          const owed = b.suggestedSettleCents ?? b.amount_cents;
          this.settleForm = {
            id: b.id, description: b.description, amountCents: b.amount_cents, settledAt: todayLocal(),
            diasAtraso: b.diasAtraso || 0, suggestedSettleCents: owed,
            payments: [{ methodId: '', amount: (owed / 100).toFixed(2).replace('.', ',') }],
          };
          this.settleError = '';
          if (!this.settleMethods.length) {
            const r = await fetch('/api/finance/payment-methods/active');
            if (r.ok) this.settleMethods = await r.json();
          }
          if (this.settleMethods.length === 1) this.settleForm.payments[0].methodId = this.settleMethods[0].id;
          this.$refs.settleDlg.showModal();
        },
        async confirmSettle() {
          const payments = this.settleForm.payments.map((p) => ({ paymentMethodId: p.methodId, amountCents: this.cents(p.amount) }));
          if (!payments.length || payments.some((p) => !p.paymentMethodId || !(p.amountCents > 0))) {
            this.settleError = 'Preencha forma de pagamento e valor em cada linha.';
            return;
          }
          const r = await fetch(`${api}/${this.settleForm.id}/settle`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ settledAt: this.settleForm.settledAt, payments }),
          });
          if (r.ok) {
            this.$refs.settleDlg.close();
            this.load();
            return;
          }
          const data = await r.json();
          if (data.code === 'no_register') {
            this.$refs.settleDlg.close();
            this.$refs.noRegisterDlg.showModal();
            return;
          }
          this.settleError = data.error;
        },
        async cancel(b) {
          if (!await window.confirmDlg(`Cancelar "${b.description}"?`)) return;
          const r = await fetch(`${api}/${b.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'cancelada' }) });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>

