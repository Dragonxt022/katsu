<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — <%= bills.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: bills.api }) %>
  <%
    var _billStatusOpts = [
      { value: 'aberta', label: 'Abertas' },
      { value: bills.settledStatus, label: 'Liquidadas' },
      { value: 'cancelada', label: 'Canceladas' }
    ];
    var _billPlaceholder = 'Buscar por descricao ou ' + bills.partyLabel.toLowerCase();
  %>
  <main x-data="billsPage('<%= bills.api %>')" x-init="load()" @apply-filter.window="filter=$event.detail; load()">
    <h1><%= bills.title %></h1>
    <div class="toolbar">
      <% if (user.permissions.has(bills.createPerm)) { %>
        <button class="btn" @click="openNew()">Nova conta</button>
      <% } %>
      <%- include('partials/search-filter', { statusOptions: _billStatusOpts, placeholder: _billPlaceholder }) %>
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr>
        <th @click="sortCycle('description')" class="sortable">Descrição<span class="sort-arrow" x-text="sortArrow('description')"></span></th>
        <th @click="sortCycle('party')" class="sortable"><%= bills.partyLabel %><span class="sort-arrow" x-text="sortArrow('party')"></span></th>
        <th @click="sortCycle('amount_cents')" class="sortable">Valor<span class="sort-arrow" x-text="sortArrow('amount_cents')"></span></th>
        <th @click="sortCycle('due_date')" class="sortable">Vencimento<span class="sort-arrow" x-text="sortArrow('due_date')"></span></th>
        <th @click="sortCycle('status')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="b in displayRows" :key="b.id">
          <tr>
            <td x-text="b.description"></td>
            <td class="muted" x-text="b.party ?? '—'"></td>
            <td x-text="brl(b.amount_cents)"></td>
            <td class="muted" x-text="fmtDate(b.due_date)"></td>
            <td><span class="badge" :class="b.status === 'aberta' ? 'off' : 'ok'" x-text="b.status"></span></td>
            <td class="text-right" @click.stop>
              <div class="dropdown" x-show="b.status === 'aberta'">
                <button class="icon-btn" @click="openMenu = openMenu === b.id ? null : b.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === b.id" x-cloak @click.outside="openMenu = null">
                  <% if (user.permissions.has(bills.settlePerm)) { %>
                  <button @click="openMenu = null; openSettle(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    <%= bills.settleLabel %>
                  </button>
                  <% } %>
                  <% if (user.permissions.has(bills.editPerm)) { %>
                  <button @click="openMenu = null; openEdit(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                    Editar
                  </button>
                  <button class="danger" @click="openMenu = null; cancel(b)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    Cancelar
                  </button>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="6"><%- include('partials/empty-state', { message: 'Nenhuma conta registrada ainda.' }) %></td></tr>
      </tbody>
    </table>

    <dialog x-ref="dlg">
      <h1 x-text="form.id ? 'Editar conta' : 'Nova conta'"></h1>
      <label>Descrição</label><input type="text" x-model="form.description" />
      <label>Valor (R$)</label><input type="text" x-model="form.amount" placeholder="0,00" @input="form.amount = maskMoney(form.amount)" />
      <label>Vencimento</label><input type="date" x-model="form.dueDate" />
      <label>Observações</label><input type="text" x-model="form.notes" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()">Salvar</button>
      </div>
    </dialog>

    <dialog x-ref="settleDlg">
      <h1><%= bills.settleLabel %></h1>
      <p class="muted" x-text="settleForm.description + ' — ' + brl(settleForm.amountCents)"></p>
      <label>Data do pagamento</label>
      <input type="date" x-model="settleForm.settledAt" />
      <p class="hint">Pagamento adiantado? Ajuste a data acima — o padrão é hoje.</p>
      <div class="error" x-text="settleError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.settleDlg.close()">Cancelar</button>
        <button class="btn" @click="confirmSettle()"><%= bills.settleLabel %></button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function billsPage(api) {
      return {
        ...tableToolkit(),
        rows: [], form: {}, error: '', dlgError: '', filter: {},
        settleForm: { id: null, description: '', amountCents: 0, settledAt: '' }, settleError: '',
        sortGetters: {
          description: (b) => b.description ?? '', party: (b) => b.party ?? '', amount_cents: (b) => b.amount_cents,
          due_date: (b) => b.due_date ?? '', status: (b) => b.status ?? '',
        },
        get displayRows() { return this.sortedRows(filterRows(this.rows, this.filter), this.sortGetters); },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return Math.round(n * 100); },
        async load() {
          const r = await fetch(api);
          if (r.ok) this.rows = await r.json(); else this.error = (await r.json()).error;
        },
        openNew() { this.form = {}; this.dlgError = ''; this.$refs.dlg.showModal(); },
        openEdit(b) {
          this.form = { id: b.id, description: b.description, amount: (b.amount_cents / 100).toFixed(2).replace('.', ','),
            dueDate: b.due_date, notes: b.notes ?? '' };
          this.dlgError = ''; this.$refs.dlg.showModal();
        },
        async save() {
          if (this.form.id) {
            const r = await fetch(`${api}/${this.form.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ description: this.form.description, amountCents: this.cents(this.form.amount),
                dueDate: this.form.dueDate, notes: this.form.notes || undefined }) });
            if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
            return;
          }
          const r = await fetch(api, { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: this.form.description, amountCents: this.cents(this.form.amount),
              dueDate: this.form.dueDate, notes: this.form.notes || undefined }) });
          if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
        },
        openSettle(b) {
          this.settleForm = { id: b.id, description: b.description, amountCents: b.amount_cents, settledAt: todayLocal() };
          this.settleError = '';
          this.$refs.settleDlg.showModal();
        },
        async confirmSettle() {
          const r = await fetch(`${api}/${this.settleForm.id}/settle`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ settledAt: this.settleForm.settledAt }),
          });
          if (r.ok) {
            const d = await r.json();
            this.$refs.settleDlg.close();
            if (!d.registeredInCash) alert('Atenção: nenhum caixa aberto — o valor não entrou na gaveta.');
            this.load();
          } else this.settleError = (await r.json()).error;
        },
        async cancel(b) {
          if (!await window.confirmDlg(`Cancelar "${b.description}"?`)) return;
          const r = await fetch(`${api}/${b.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'cancelada' }) });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>

