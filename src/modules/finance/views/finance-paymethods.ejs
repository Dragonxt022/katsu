<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Formas de pagamento</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/finance/formas-pagamento' }) %>
  <main x-data="payMethodsPage()" x-init="load()">
    <h1>Formas de pagamento</h1>
    <p class="muted muted-block">Cadastre cada maquininha/condição com a taxa real (ex.: "Débito — Stone" com 1,60%). A taxa é descontada nos relatórios de venda.</p>
    <div class="toolbar">
      <% if (user.permissions.has('finance.paymethods.edit')) { %>
        <button class="btn" @click="openNew()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nova forma
        </button>
      <% } %>
      <input type="text" placeholder="Buscar por nome…" x-model="q" class="input-search" style="min-width:220px" />
      <span class="muted" x-text="pageTotal + ' registro(s)'"></span>
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr>
        <th @click="sortCycle('name')" class="sortable">Nome<span class="sort-arrow" x-text="sortArrow('name')"></span></th>
        <th @click="sortCycle('type')" class="sortable">Tipo<span class="sort-arrow" x-text="sortArrow('type')"></span></th>
        <th @click="sortCycle('fee_bps')" class="sortable">Taxa<span class="sort-arrow" x-text="sortArrow('fee_bps')"></span></th>
        <th @click="sortCycle('active')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('active')"></span></th>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="m in pageRows" :key="m.id">
          <tr>
            <td x-text="m.name"></td>
            <td class="muted" x-text="labels[m.type] ?? m.type"></td>
            <td x-text="(m.fee_bps / 100).toFixed(2).replace('.', ',') + '%'"></td>
            <td><span class="badge" :class="m.active ? 'ok' : 'off'" x-text="m.active ? 'ativa' : 'inativa'"></span></td>
            <td class="text-right">
              <% if (user.permissions.has('finance.paymethods.edit')) { %>
                <button class="btn secondary small" @click="openEdit(m)">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  Editar
                </button>
                <button class="btn small" @click="toggle(m)">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                  <span x-text="m.active ? 'Desativar' : 'Ativar'"></span>
                </button>
              <% } %>
              <% if (user.permissions.has('finance.paymethods.delete')) { %>
                <button class="btn small" @click="del(m)">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  Excluir
                </button>
              <% } %>
            </td>
          </tr>
        </template>
        <tr x-show="!rows.length"><td colspan="5"><%- include('partials/empty-state', { message: 'Nenhuma forma de pagamento cadastrada.' }) %></td></tr>
      </tbody>
    </table>
    <%- include('partials/pager') %>

    <dialog x-ref="dlg">
      <h1 x-text="form.id ? 'Editar forma' : 'Nova forma de pagamento'"></h1>
      <label>Nome (ex.: Débito — Stone)</label><input type="text" x-model="form.name" />
      <template x-if="!form.id">
        <div>
          <label>Tipo</label>
          <select x-model="form.type">
            <option value="dinheiro">Dinheiro (passa pela gaveta, com troco)</option>
            <option value="debito">Cartão de débito</option>
            <option value="credito">Cartão de crédito</option>
            <option value="pix">PIX</option>
            <option value="prazo">A prazo (gera conta a receber)</option>
            <option value="outro">Outro</option>
          </select>
        </div>
      </template>
      <label>Taxa da operadora (%)</label>
      <input type="text" x-model="form.fee" placeholder="1,60" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="save()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function payMethodsPage() {
      return {
        ...tableToolkit(),
        rows: [], form: {}, error: '', dlgError: '', q: '',
        labels: { dinheiro: 'Dinheiro', debito: 'Débito', credito: 'Crédito', pix: 'PIX', prazo: 'A prazo', outro: 'Outro' },
        sortGetters: {
          name: (m) => m.name ?? '', type: (m) => m.type ?? '', fee_bps: (m) => m.fee_bps, active: (m) => (m.active ? 1 : 0),
        },
        get filteredRows() {
          if (!this.q.trim()) return this.rows;
          const t = this.q.toLowerCase();
          return this.rows.filter((m) => (m.name ?? '').toLowerCase().includes(t));
        },
        get displayRows() { return this.sortedRows(this.filteredRows, this.sortGetters); },
        get pageTotal() { return this.displayRows.length; },
        get pageRows() { return this.pagedRows(this.displayRows); },
        bps(s) { const n = parseFloat(String(s || '0').replace(',', '.')); return isNaN(n) ? 0 : Math.round(n * 100); },
        async load() {
          const r = await fetch('/api/finance/payment-methods?all=1');
          if (r.ok) this.rows = await r.json(); else this.error = (await r.json()).error;
        },
        openNew() { this.form = { type: 'debito', fee: '' }; this.dlgError = ''; this.$refs.dlg.showModal(); },
        openEdit(m) {
          this.form = { id: m.id, name: m.name, fee: (m.fee_bps / 100).toFixed(2).replace('.', ',') };
          this.dlgError = ''; this.$refs.dlg.showModal();
        },
        async save() {
          const isEdit = !!this.form.id;
          const body = isEdit
            ? { name: this.form.name, feeBps: this.bps(this.form.fee) }
            : { name: this.form.name, type: this.form.type, feeBps: this.bps(this.form.fee) };
          const r = await fetch(isEdit ? `/api/finance/payment-methods/${this.form.id}` : '/api/finance/payment-methods', {
            method: isEdit ? 'PUT' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
        },
        async toggle(m) {
          const r = await fetch(`/api/finance/payment-methods/${m.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ active: !m.active }),
          });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
        async del(m) {
          if (!await window.confirmDlg(`Excluir a forma de pagamento "${m.name}"?`)) return;
          const r = await fetch(`/api/finance/payment-methods/${m.id}`, { method: 'DELETE' });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>
