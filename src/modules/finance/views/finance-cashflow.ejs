<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Fluxo de caixa</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/finance/fluxo' }) %>
  <main x-data="flowPage()" x-init="load()">
    <h1>Fluxo de caixa</h1>
    <div class="toolbar">
      <input type="date" x-model="from" @change="load()"
             class="input-search" />
      <input type="date" x-model="to" @change="load()"
             class="input-search" />
      <span class="muted">Total: entradas <strong x-text="brl(totals.entradas)"></strong> ·
        saídas <strong x-text="brl(totals.saidas)"></strong> ·
        saldo <strong x-text="brl(totals.saldo)"></strong></span>
    </div>
    <table>
      <thead><tr><th>Dia</th><th>Entradas</th><th>Saídas</th><th>Saldo do dia</th></tr></thead>
      <tbody>
        <template x-for="d in days" :key="d.day">
          <tr>
            <td x-text="d.day"></td>
            <td x-text="brl(d.entradas)"></td>
            <td x-text="brl(d.saidas)"></td>
            <td :style="d.saldo < 0 ? 'color:#ff8589' : 'color:#4ade80'" x-text="brl(d.saldo)"></td>
          </tr>
        </template>
      </tbody>
    </table>
  </main>
  <script>
    function flowPage() {
      return {
        days: [], totals: { entradas: 0, saidas: 0, saldo: 0 }, from: '', to: '',
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        async load() {
          const params = new URLSearchParams();
          if (this.from) params.set('from', this.from);
          if (this.to) params.set('to', this.to);
          const r = await fetch('/api/finance/reports/cashflow?' + params);
          if (r.ok) { const d = await r.json(); this.days = d.days; this.totals = d.totals; }
        },
      };
    }
  </script>
</body>
</html>

