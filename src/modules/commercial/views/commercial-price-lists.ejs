<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Listas de preço</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/commercial/listas-de-preco' }) %>
  <main x-data="priceListsPage()" x-init="load()">
    <h1>Listas de preço</h1>
    <p class="muted">Atacado, varejo, revenda… cada lista pode ter um preço fixo ou faixas por quantidade mínima. A lista marcada como "padrão" vale para qualquer venda sem cliente com lista própria.</p>
    <div class="toolbar">
      <% if (user.permissions.has('commercial.pricelists.manage')) { %>
        <button class="btn" @click="openNew()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nova lista
        </button>
      <% } %>
      <span class="error" x-text="error"></span>
    </div>
    <% if (user.permissions.has('commercial.pricelists.manage')) { %>
    <div class="bulk-bar" x-show="selectedIds.length" x-cloak>
      <span class="bulk-count" x-text="selectedIds.length + ' selecionado(s)'"></span>
      <button class="btn danger small" @click="bulkDelete('/api/commercial/price-lists', { label: 'lista(s) de preço', onDone: () => load() })">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        Excluir selecionados
      </button>
      <button class="btn secondary small" @click="clearSelection()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        Cancelar
      </button>
    </div>
    <% } %>
    <table>
      <thead><tr>
        <% if (user.permissions.has('commercial.pricelists.manage')) { %>
        <th class="col-checkbox">
          <input type="checkbox" :checked="isAllSelected(displayRows)" @change="toggleSelectAll(displayRows)"
                 x-effect="$el.indeterminate = selectedIds.length > 0 && !isAllSelected(displayRows)" />
        </th>
        <% } %>
        <th @click="sortCycle('name')" class="sortable">Nome<span class="sort-arrow" x-text="sortArrow('name')"></span></th>
        <th @click="sortCycle('item_count')" class="sortable">Itens<span class="sort-arrow" x-text="sortArrow('item_count')"></span></th>
        <th>Padrão</th>
        <th>Situação</th>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="l in displayRows" :key="l.id">
          <tr>
            <% if (user.permissions.has('commercial.pricelists.manage')) { %>
            <td class="col-checkbox" @click.stop>
              <input type="checkbox" :checked="isSelected(l.id)" @change="toggleSelect(l.id)" />
            </td>
            <% } %>
            <td x-text="l.name"></td>
            <td class="muted" x-text="l.item_count"></td>
            <td><span class="badge" x-show="l.is_default">padrão</span></td>
            <td><span class="badge" :class="l.active ? '' : 'off'" x-text="l.active ? 'ativa' : 'inativa'"></span></td>
            <td class="text-right" @click.stop>
              <% if (user.permissions.has('commercial.pricelists.manage')) { %>
              <div class="dropdown">
                <button class="icon-btn" @click="openMenu = openMenu === l.id ? null : l.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === l.id" x-cloak @click.outside="openMenu = null">
                  <button @click="openMenu = null; openEdit(l)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                    Editar
                  </button>
                  <button class="danger" @click="openMenu = null; remove(l)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    Excluir
                  </button>
                </div>
              </div>
              <% } %>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="6"><%- include('partials/empty-state', { message: 'Nenhuma lista de preço cadastrada ainda.' }) %></td></tr>
      </tbody>
    </table>

    <dialog x-ref="dlg" class="dialog-fixed">
      <h1 x-text="form.id ? 'Editar lista' : 'Nova lista'"></h1>
      <div class="dialog-body">
        <label>Nome</label><input type="text" x-model="form.name" />
        <label class="label-checkbox-sm" style="margin-top:.4rem">
          <input type="checkbox" x-model="form.isDefault" /> Lista padrão (quando a venda não tem cliente com lista própria)
        </label>
        <template x-if="form.id">
          <label class="label-checkbox-sm">
            <input type="checkbox" x-model="form.active" /> Ativa
          </label>
        </template>

        <template x-if="form.id">
            <div class="section-divider-lg">
            <h2 style="font-size:.95rem;margin-bottom:.5rem">Itens</h2>
            <div class="flex-row" style="margin-bottom:.6rem">
              <input type="text" x-model="prodQ" placeholder="Buscar produto…" @input.debounce.300ms="searchProducts()" style="flex:1" />
            </div>
            <div x-show="prodResults.length" class="scroll-box-sm" style="border:1px solid var(--border-light);border-radius:8px;margin-bottom:.6rem">
              <template x-for="p in prodResults" :key="p.id">
                <div style="padding:.4rem .6rem;cursor:pointer" @click="addItem(p)" x-text="p.name + ' — ' + brl(p.price_cents)"></div>
              </template>
            </div>
            <table>
              <thead><tr><th>Produto</th><th>Qtd. mínima</th><th>Preço (R$)</th><th></th></tr></thead>
              <tbody>
                <template x-for="(it, idx) in items" :key="idx">
                  <tr>
                    <td x-text="it.product_name"></td>
                    <td><input type="number" min="1" step="1" x-model.number="it.min_qty" style="width:80px" /></td>
                    <td><input type="text" x-model="it.priceStr" @input="it.priceStr = maskMoney(it.priceStr)" style="width:100px" /></td>
                    <td><button class="icon-btn" @click="items.splice(idx, 1)" title="Remover">×</button></td>
                  </tr>
                </template>
              </tbody>
            </table>
            <div class="error" x-text="itemsError"></div>
            <div class="actions actions-inline">
              <button class="btn secondary small" @click="saveItems()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                Salvar itens
              </button>
            </div>
          </div>
        </template>
        <div class="error" x-text="dlgError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
        <button class="btn" @click="save()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function priceListsPage() {
      return {
        ...tableToolkit(),
        rows: [], form: {}, items: [], prodQ: '', prodResults: [], error: '', dlgError: '', itemsError: '',
        sortGetters: { name: (l) => l.name, item_count: (l) => l.item_count ?? 0 },
        get displayRows() { return this.sortedRows(this.rows, this.sortGetters); },
        brl(c) { return 'R$ ' + (c / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        toCents(s) { if (s == null || s === '') return null; return Math.round(parseFloat(String(s).replace(/\./g, '').replace(',', '.')) * 100); },
        async load() {
          const r = await fetch('/api/commercial/price-lists');
          if (r.ok) { this.rows = await r.json(); this.pruneSelection(this.rows); } else this.error = (await r.json()).error;
        },
        openNew() { this.form = { isDefault: false }; this.items = []; this.dlgError = ''; this.itemsError = ''; this.$refs.dlg.showModal(); },
        async openEdit(l) {
          const r = await fetch(`/api/commercial/price-lists/${l.id}`);
          if (!r.ok) { this.error = (await r.json()).error; return; }
          const data = await r.json();
          this.form = { id: data.id, name: data.name, isDefault: !!data.is_default, active: !!data.active };
          this.items = data.items.map((i) => ({ ...i, priceStr: (i.unit_price_cents / 100).toFixed(2).replace('.', ',') }));
          this.prodQ = ''; this.prodResults = []; this.dlgError = ''; this.itemsError = '';
          this.$refs.dlg.showModal();
        },
        async save() {
          const body = { name: this.form.name, isDefault: this.form.isDefault, active: this.form.id ? this.form.active : undefined };
          const isEdit = !!this.form.id;
          const r = await fetch(isEdit ? `/api/commercial/price-lists/${this.form.id}` : '/api/commercial/price-lists', {
            method: isEdit ? 'PUT' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
          });
          if (r.ok) {
            if (!isEdit) { const created = await r.json(); await this.load(); this.openEdit(created); }
            else { this.$refs.dlg.close(); this.load(); }
          } else this.dlgError = (await r.json()).error ?? 'Erro ao salvar.';
        },
        async remove(l) {
          if (!await window.confirmDlg(`Excluir "${l.name}"?`)) return;
          const r = await fetch(`/api/commercial/price-lists/${l.id}`, { method: 'DELETE' });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
        async searchProducts() {
          if (!this.prodQ.trim()) { this.prodResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.prodQ.trim()));
          if (r.ok) this.prodResults = await r.json();
        },
        addItem(p) {
          if (this.items.some((i) => i.product_id === p.id && i.min_qty === 1)) return;
          this.items.push({ product_id: p.id, product_name: p.name, min_qty: 1, priceStr: (p.price_cents / 100).toFixed(2).replace('.', ',') });
          this.prodQ = ''; this.prodResults = [];
        },
        async saveItems() {
          this.itemsError = '';
          const payload = this.items.map((i) => ({ productId: i.product_id, minQty: i.min_qty, unitPriceCents: this.toCents(i.priceStr) }));
          const r = await fetch(`/api/commercial/price-lists/${this.form.id}/items`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: payload }),
          });
          if (r.ok) { await this.openEdit({ id: this.form.id }); await this.load(); }
          else this.itemsError = (await r.json()).error ?? 'Erro ao salvar itens.';
        },
      };
    }
  </script>
</body>
</html>
