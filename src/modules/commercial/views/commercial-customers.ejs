<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Katsu — Clientes</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/commercial/clientes' }) %>
  <main x-data="crudPage('/api/commercial/customers')" x-init="load()">
    <h1>Clientes</h1>
    <div class="toolbar">
      <% if (user.permissions.has('commercial.customers.create')) { %>
        <button class="btn" @click="openNew()">Novo cliente</button>
      <% } %>
      <input type="text" placeholder="Buscar…" x-model="q" @input.debounce.400ms="load()"
             style="padding:.5rem .8rem;border-radius:8px;border:1px solid #2c313c;background:#12141a;color:#e6e6e6" />
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr><th>Nome</th><th>Documento</th><th>Telefone</th><th>E-mail</th><th></th></tr></thead>
      <tbody>
        <template x-for="r in rows" :key="r.id">
          <tr>
            <td x-text="r.name"></td>
            <td class="muted" x-text="r.document ?? '—'"></td>
            <td class="muted" x-text="r.phone ?? '—'"></td>
            <td class="muted" x-text="r.email ?? '—'"></td>
            <td style="text-align:right">
              <% if (user.permissions.has('commercial.customers.edit')) { %>
                <button class="btn secondary small" @click="openEdit(r)">Editar</button>
              <% } %>
              <% if (user.permissions.has('commercial.customers.delete')) { %>
                <button class="btn small" @click="remove(r)">Excluir</button>
              <% } %>
            </td>
          </tr>
        </template>
      </tbody>
    </table>

    <dialog x-ref="dlg">
      <h1 x-text="form.id ? 'Editar cliente' : 'Novo cliente'"></h1>
      <label>Nome</label><input type="text" x-model="form.name" />
      <label>CPF/CNPJ</label><input type="text" x-model="form.document" />
      <label>Telefone</label><input type="text" x-model="form.phone" />
      <label>E-mail</label><input type="text" x-model="form.email" />
      <label>Endereço</label><input type="text" x-model="form.address" />
      <label>Observações</label><input type="text" x-model="form.notes" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()">Salvar</button>
      </div>
    </dialog>
  </main>
  <script src="/js/crud-page.js"></script>
</body>
</html>

