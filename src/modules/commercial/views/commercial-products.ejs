<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Produtos</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/commercial/produtos' }) %>
  <main x-data="productsPage()" x-init="load()">
    <h1>Produtos</h1>
    <div class="toolbar">
      <% if (user.permissions.has('commercial.products.create')) { %>
        <button class="btn" @click="openNew()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Novo produto
        </button>
      <% } %>
      <input type="text" placeholder="Buscar nome, código de barras ou SKU…" x-model="q" @input.debounce.400ms="load()"
             class="input-search" style="min-width:280px" />
      <% if (user.permissions.has('commercial.products.edit')) { %>
      <input type="text" x-ref="scan" placeholder="Bipar código de barras (cadastro rápido)…"
             @keydown.enter.prevent="scanLookup($event.target.value); $event.target.value = ''"
             class="input-search" style="min-width:280px" />
      <% } %>
      <span class="muted" x-text="pageTotal + ' registro(s)'"></span>
      <span class="error" x-text="error"></span>
    </div>
    <div class="bulk-bar" x-show="selectedIds.length" x-cloak>
      <span class="bulk-count" x-text="selectedIds.length + ' selecionado(s)'"></span>
      <% if (user.permissions.has('commercial.products.delete')) { %>
      <button class="btn danger small" @click="bulkDelete('/api/commercial/products', { label: 'produto(s)', onDone: () => load() })">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        Excluir selecionados
      </button>
      <% } %>
      <button class="btn secondary small" @click="clearSelection()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        Cancelar
      </button>
    </div>
      <table>
        <thead><tr>
          <% if (user.permissions.has('commercial.products.delete')) { %>
          <th class="col-checkbox">
            <input type="checkbox" :checked="isAllSelected(displayRows)" @change="toggleSelectAll(displayRows)"
                   x-effect="$el.indeterminate = selectedIds.length > 0 && !isAllSelected(displayRows)" />
          </th>
          <% } %>
          <th></th>
          <th @click="sortCycle('name')" class="sortable">Produto<span class="sort-arrow" x-text="sortArrow('name')"></span></th>
          <th @click="sortCycle('category')" class="sortable">Categoria<span class="sort-arrow" x-text="sortArrow('category')"></span></th>
          <th @click="sortCycle('price')" class="sortable">Preço<span class="sort-arrow" x-text="sortArrow('price')"></span></th>
          <th @click="sortCycle('cost')" class="sortable">Custo<span class="sort-arrow" x-text="sortArrow('cost')"></span></th>
          <th @click="sortCycle('stock')" class="sortable">Estoque<span class="sort-arrow" x-text="sortArrow('stock')"></span></th>
          <th @click="sortCycle('unit')" class="sortable">Un<span class="sort-arrow" x-text="sortArrow('unit')"></span></th>
          <th></th>
          <th></th>
        </tr></thead>
      <tbody>
        <template x-for="p in pageRows" :key="p.id">
          <tr
            <% if (user.permissions.has('commercial.products.edit')) { %>
              @click="openEdit(p)" style="cursor:pointer"
            <% } %>
          >
            <% if (user.permissions.has('commercial.products.delete')) { %>
            <td class="col-checkbox" @click.stop>
              <input type="checkbox" :checked="isSelected(p.id)" @change="toggleSelect(p.id)" />
            </td>
            <% } %>
            <td style="width:1%">
              <div class="product-thumb">
                <img x-show="p.image_url" :src="p.image_url" alt="" />
                <template x-if="!p.image_url">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
                </template>
              </div>
            </td>
            <td>
              <span x-text="p.name"></span>
              <span class="badge off" x-show="p.track_stock && p.stock_qty < 0" style="margin-left:.4rem">estoque negativo</span>
              <span class="badge off" x-show="p.track_stock && p.stock_qty >= 0 && p.stock_qty <= p.min_stock" style="margin-left:.4rem">estoque baixo</span>
            </td>
            <td class="muted" x-text="p.category ?? '—'"></td>
            <td x-text="brl(p.price_cents)"></td>
            <td class="muted" x-text="brl(p.cost_cents)"></td>
            <td :style="p.track_stock && p.stock_qty < 0 ? 'color:var(--danger);font-weight:700' : ''" x-text="p.track_stock ? p.stock_qty : '—'"></td>
            <td class="muted" x-text="p.unit"></td>
            <td @click.stop style="width:1%">
              <% if (user.permissions.has('commercial.products.edit')) { %>
              <div class="flex-row">
                <button class="icon-btn" :class="{ active: p.favorite }" @click="toggleFavorite(p)"
                        :title="p.favorite ? 'Remover dos favoritos' : 'Marcar como favorito'">
                  <svg width="17" height="17" viewBox="0 0 24 24" :fill="p.favorite ? 'currentColor' : 'none'" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </button>
                <button class="icon-btn" :class="{ active: p.visivel_cardapio }" @click="toggleCardapio(p)"
                        :title="p.visivel_cardapio ? 'Remover do cardápio online' : 'Mostrar no cardápio online'">
                  <svg width="17" height="17" viewBox="0 0 24 24" :fill="p.visivel_cardapio ? 'currentColor' : 'none'" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/>
                  </svg>
                </button>
              </div>
              <% } %>
            </td>
            <td class="text-right" @click.stop>
              <div class="dropdown">
                <button class="icon-btn" @click="openMenu = openMenu === p.id ? null : p.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === p.id" x-cloak @click.outside="openMenu = null">
                  <% if (user.permissions.has('commercial.stock.move')) { %>
                    <button x-show="p.track_stock" @click="openMenu = null; openMove(p)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                      Estoque
                    </button>
                  <% } %>
                  <% if (user.permissions.has('commercial.products.edit')) { %>
                    <button @click="openMenu = null; openEdit(p)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                      Editar
                    </button>
                  <% } %>
                  <% if (user.permissions.has('commercial.products.create')) { %>
                    <button @click="openMenu = null; duplicate(p)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                      Duplicar
                    </button>
                  <% } %>
                  <% if (user.permissions.has('commercial.products.delete')) { %>
                    <button class="danger" @click="openMenu = null; remove(p)">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                      Excluir
                    </button>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="10"><%- include('partials/empty-state', { message: 'Nenhum produto cadastrado ainda.' }) %></td></tr>
      </tbody>
    </table>
    <%- include('partials/pager') %>

    <dialog x-ref="dlg" class="dialog-fixed product-modal">
      <h1 x-text="form.id ? 'Editar produto' : 'Novo produto'"></h1>
      <div class="dialog-body" :style="'grid-template-columns: 1fr 1fr' + (form.productType === 'fisico' ? '' : ' 1.2fr')">
        <div class="product-col">
          <label>Nome</label>
          <input type="text" x-model="form.name" @input.debounce.500ms="searchCatalogImages()" />

          <label>Descrição / Ingredientes (cardápio online)</label>
          <textarea x-model="form.description" rows="3" style="resize:vertical;min-height:80px"></textarea>

          <label>Tipo de produto</label>
          <select x-model="form.productType" :disabled="!!form.id">
            <option value="fisico">Produto simples</option>
            <option value="variante">Produto com variantes</option>
            <option value="kit">Kit</option>
            <option value="combo">Combo</option>
            <option value="produzido">Produzido (ficha técnica)</option>
          </select>

          <label>Código de barras</label>
          <div class="flex-row">
            <input type="text" x-model="form.barcode" style="flex:1" @input="barcodeHint = checkBarcode(form.barcode)" />
            <template x-if="form.id">
              <button class="btn secondary small" type="button" @click="genBarcode()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"/><path d="M6 4v16"/><path d="M10 4v4"/><path d="M10 16v4"/><path d="M14 4v8"/><path d="M14 16v4"/><path d="M18 4v4"/><path d="M18 12v8"/><path d="M22 4v16"/></svg>
                Gerar código interno
              </button>
            </template>
          </div>
          <span class="muted text-xs" x-show="barcodeHint" x-text="barcodeHint"></span>
          <label>SKU</label><input type="text" x-model="form.sku" />
          <label>Unidade (un, kg, l…)</label><input type="text" x-model="form.unit" />
          <label>Categoria</label>
          <select x-model.number="form.categoryId">
            <option value="">— sem categoria —</option>
            <template x-for="c in categories" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
          </select>
          <div class="flex-row" style="margin-top:.3rem">
            <input type="text" x-model="newCat" placeholder="Nova categoria…" style="flex:1" />
            <button class="btn secondary small" type="button" @click="addCategory()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Criar
            </button>
            <% if (user.permissions.has('commercial.products.edit') || user.permissions.has('commercial.products.delete')) { %>
            <button class="btn secondary small" type="button" @click="openCatMgr()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              Gerenciar
            </button>
            <% } %>
          </div>
          <% if (user.permissions.has('commercial.products.price')) { %>
            <label>Preço (R$)</label><input type="text" x-model="form.price" placeholder="0,00" @input="form.price = maskMoney(form.price)" />
          <% } %>
          <label>Custo (R$)</label><input type="text" x-model="form.cost" placeholder="0,00" @input="form.cost = maskMoney(form.cost)" />
          <label>Estoque mínimo</label><input type="text" x-model="form.minStock" />
          <template x-if="!form.id">
            <div>
              <label>Estoque inicial (opcional)</label>
              <input type="number" step="any" min="0" x-model="form.initialStock" placeholder="0" />
            </div>
          </template>
        </div>

        <div class="product-col">
          <label>Foto do produto</label>
          <div class="product-image-picker" @click="!(form.newImagePreview || form.imageUrl) && $refs.imageFile.click()">
            <input type="file" accept="image/jpeg,image/png,image/webp" x-ref="imageFile" class="hidden-file-input" @change="onImageFile($event)" />
            <template x-if="form.newImagePreview || form.imageUrl">
              <img :src="form.newImagePreview || form.imageUrl" alt="" />
            </template>
            <template x-if="!form.newImagePreview && !form.imageUrl">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
            </template>
            <div class="product-image-overlay" x-show="!form.newImagePreview && !form.imageUrl">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </div>
            <div class="product-image-overlay remove-overlay" x-show="form.newImagePreview || form.imageUrl" @click.stop="removeProductImage()" title="Remover imagem">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </div>
          </div>
          <label class="label-checkbox-sm" x-show="form.pendingImageBase64" style="margin-top:.2rem">
            <input type="checkbox" x-model="form.submitToCatalog" /> Contribuir esta foto com o banco de imagens do Katsu Cloud
          </label>

          <label style="margin-top:.9rem">Sugestões do banco de imagens</label>
          <p class="muted text-xs" x-show="!form.name || form.name.trim().length < 3">Digite o nome do produto para ver sugestões automáticas.</p>
          <p class="muted text-xs" x-show="imgSearchOffline">Banco de imagens indisponível agora (sem internet ou plano sem esse recurso).</p>
          <p class="muted text-xs" x-show="imgSearching">Buscando…</p>
          <p class="muted text-xs" x-show="!imgSearching && form.name && form.name.trim().length >= 3 && !imgSearchResults.length && !imgSearchOffline">Nenhuma sugestão encontrada — cadastre com sua própria foto.</p>
          <div class="product-image-suggestions" x-show="imgSearchResults.length">
            <template x-for="r in imgSearchResults" :key="r.id">
              <button type="button" class="product-image-suggestion" @click="pickCatalogImage(r)">
                <img :src="r.url" :alt="r.name" />
                <span x-text="r.name"></span>
              </button>
            </template>
          </div>
        </div>

        <div class="product-col-3" x-show="form.productType !== 'fisico'">
          <template x-if="form.id && form.productType === 'variante'">
            <div>
              <div class="flex-row" style="justify-content:space-between;align-items:center;margin-bottom:.6rem">
                <h2>Variantes</h2>
                <div class="flex-row" style="gap:.5rem">
                  <button class="btn secondary small" type="button" @click="openAttrMgr()">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Atributos
                  </button>
                  <button class="btn small" type="button" @click="openGenVariants()">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Gerar variantes
                  </button>
                </div>
              </div>
              <div style="max-height:400px;overflow-y:auto;border:1.5px solid var(--border-light);border-radius:var(--radius)">
                <table style="width:100%">
                  <thead><tr>
                    <th>Variante</th>
                    <th>Atributos</th>
                    <th>SKU</th>
                    <th>Preço</th>
                    <th>Est</th>
                    <th></th>
                  </tr></thead>
                  <tbody>
                    <template x-for="v in variants" :key="v.id">
                      <tr>
                        <td x-text="v.name" style="white-space:nowrap"></td>
                        <td class="muted text-xs" x-text="variantAttrsLabel(v)"></td>
                        <td><input type="text" x-model="v.sku" class="inline-edit" @change="updateVariantField(v, 'sku')" style="width:70px" /></td>
                        <td><input type="text" x-model="v.priceDisplay" class="inline-edit" @change="updateVariantPrice(v)" style="width:60px" /></td>
                        <td><input type="number" step="any" x-model="v.stock_qty" class="inline-edit" @change="updateVariantStock(v)" style="width:50px" :disabled="!v.track_stock" /></td>
                        <td @click.stop>
                          <button class="icon-btn" @click="deleteVariant(v)" title="Excluir variante">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                          </button>
                        </td>
                      </tr>
                    </template>
                    <tr x-show="!variants.length"><td colspan="6" class="muted text-xs" style="text-align:center;padding:.5rem">Nenhuma variante — use Atributos + Gerar variantes.</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </template>
          <template x-if="form.id && (form.productType === 'kit' || form.productType === 'combo')">
            <div>
              <div class="flex-row" style="justify-content:space-between;align-items:center;margin-bottom:.6rem">
                <h2>Componentes fixos</h2>
                <button class="btn small" type="button" @click="openAddComponent()">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Adicionar
                </button>
              </div>
              <div style="max-height:400px;overflow-y:auto;border:1.5px solid var(--border-light);border-radius:var(--radius)">
                <table style="width:100%">
                  <thead><tr>
                    <th>Componente</th>
                    <th>Qtd</th>
                    <th></th>
                  </tr></thead>
                  <tbody>
                    <template x-for="c in kitComponents" :key="c.id">
                      <tr>
                        <td x-text="c.component_name"></td>
                        <td><input type="number" step="any" x-model="c.qty" class="inline-edit" @change="updateKitComponent(c)" style="width:50px" /></td>
                        <td @click.stop>
                          <button class="icon-btn" @click="deleteKitComponent(c)" title="Remover">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                          </button>
                        </td>
                      </tr>
                    </template>
                    <tr x-show="!kitComponents.length"><td colspan="3" class="muted text-xs" style="text-align:center;padding:.5rem">Nenhum componente.</td></tr>
                  </tbody>
                </table>
              </div>
              <div style="margin-top:.75rem">
                <div class="flex-row" style="justify-content:space-between;align-items:center;margin-bottom:.4rem">
                  <h2 style="font-size:.95rem">Grupos de complementos</h2>
                  <button class="btn secondary small" type="button" @click="openAddComplementGroup()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Vincular
                  </button>
                </div>
                <template x-for="g in complementGroups" :key="g.id">
                  <div class="flex-row" style="justify-content:space-between;align-items:center;padding:.25rem 0;font-size:.85rem">
                    <span x-text="g.group_name"></span>
                    <span class="muted text-xs" x-text="`min ${g.min_select}, máx ${g.max_select ?? '∞'}`"></span>
                    <button class="icon-btn" @click="unlinkComplementGroup(g)" title="Desvincular">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </button>
                  </div>
                </template>
                <p x-show="!complementGroups.length" class="muted text-xs" style="margin:.2rem 0">Nenhum grupo vinculado.</p>
              </div>
            </div>
          </template>
          <template x-if="form.id && form.productType === 'produzido'">
            <div>
              <div class="flex-row" style="justify-content:space-between;align-items:center;margin-bottom:.6rem">
                <h2>Ficha técnica</h2>
                <button class="btn small" type="button" @click="openAddRecipeInput()">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Adicionar insumo
                </button>
              </div>
              <div style="max-height:400px;overflow-y:auto;border:1.5px solid var(--border-light);border-radius:var(--radius)">
                <table style="width:100%">
                  <thead><tr>
                    <th>Insumo</th>
                    <th>Qtd</th>
                    <th>Custo un.</th>
                    <th></th>
                  </tr></thead>
                  <tbody>
                    <template x-for="r in recipeComponents" :key="r.id">
                      <tr>
                        <td x-text="r.input_name"></td>
                        <td><input type="number" step="any" x-model="r.qty" class="inline-edit" @change="updateRecipeInput(r)" style="width:50px" /></td>
                        <td class="text-xs" x-text="brl(r.cost_cents ?? 0)"></td>
                        <td @click.stop>
                          <button class="icon-btn" @click="deleteRecipeInput(r)" title="Remover">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                          </button>
                        </td>
                      </tr>
                    </template>
                    <tr x-show="!recipeComponents.length"><td colspan="4" class="muted text-xs" style="text-align:center;padding:.5rem">Nenhum insumo.</td></tr>
                  </tbody>
                </table>
              </div>
              <p x-show="recipeComponents.length" class="muted text-xs" style="margin-top:.4rem;text-align:right">
                Custo total: <strong x-text="brl(recipeComponents.reduce((s, r) => s + (r.total_cost_cents ?? 0), 0))"></strong>
              </p>
            </div>
          </template>
          <p x-show="!form.id" class="muted text-xs" style="margin-top:1rem;text-align:center">Salve o produto primeiro para gerenciar variantes, componentes ou ficha técnica.</p>
        </div>

        <div class="error" x-text="dlgError" style="grid-column:1 / -1"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="save()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar
        </button>
      </div>
    </dialog>

    <dialog x-ref="mv">
      <h1>Movimentar estoque</h1>
      <p class="muted" x-text="`${move.name} — saldo atual: ${move.current}`"></p>
      <label>Tipo</label>
      <select x-model="move.type">
        <option value="entrada">Entrada</option>
        <option value="saida">Saída</option>
        <option value="ajuste">Ajuste (define o saldo)</option>
      </select>
      <label x-text="move.type === 'ajuste' ? 'Novo saldo' : 'Quantidade'"></label>
      <input type="number" step="any" x-model="move.qty" />
      <label>Motivo</label><input type="text" x-model="move.reason" />
      <div class="error" x-text="mvError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.mv.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="saveMove()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Confirmar
        </button>
      </div>
    </dialog>

    <dialog x-ref="catDlg" class="dialog-fixed">
      <h1>Gerenciar categorias</h1>
      <div class="dialog-body">
        <template x-for="c in categories" :key="c.id">
          <div class="flex-center" style="padding:.35rem 0">
            <template x-if="catEditId !== c.id">
              <span style="flex:1" x-text="c.name"></span>
            </template>
            <template x-if="catEditId === c.id">
              <input type="text" x-model="catEditName" style="flex:1" @keydown.enter="renameCategory(c.id)" />
            </template>
            <% if (user.permissions.has('commercial.products.edit')) { %>
            <template x-if="catEditId !== c.id">
              <button class="icon-btn" @click="catEditId = c.id; catEditName = c.name" title="Renomear">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
              </button>
            </template>
            <template x-if="catEditId === c.id">
              <button class="icon-btn" @click="renameCategory(c.id)" title="Salvar">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </template>
            <% } %>
            <% if (user.permissions.has('commercial.products.delete')) { %>
            <button class="icon-btn" @click="catDelId = c.id; catDelAction = 'unset'; catDelMigrateTo = null" title="Excluir">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
            <% } %>
          </div>
        </template>

        <template x-if="catDelId">
          <div style="margin-top:.8rem;padding-top:.8rem;border-top:1px solid var(--border-light)">
            <p style="margin-bottom:.8rem" x-text="'Excluir &quot;' + categories.find(c => c.id === catDelId)?.name + '&quot;?'"></p>
            <label class="label-checkbox-sm" style="margin-bottom:.5rem">
              <input type="radio" value="unset" x-model="catDelAction" /> Deixar produtos sem categoria
            </label>
            <label class="label-checkbox-sm" style="margin-bottom:.5rem">
              <input type="radio" value="migrate" x-model="catDelAction" /> Migrar produtos para:
            </label>
            <select x-show="catDelAction === 'migrate'" x-model.number="catDelMigrateTo" style="width:100%;margin-bottom:.8rem">
              <option value="">Selecione…</option>
              <template x-for="c in categories.filter(c => c.id !== catDelId)" :key="c.id">
                <option :value="c.id" x-text="c.name"></option>
              </template>
            </select>
            <div class="error" x-text="dlgError"></div>
            <div class="actions actions-inline">
              <button class="btn secondary" @click="catDelId = null; catDelAction = 'unset'; catDelMigrateTo = null">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                Cancelar
              </button>
              <button class="btn danger" @click="deleteCategory()" :disabled="catDelAction === 'migrate' && !catDelMigrateTo">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                Confirmar exclusão
              </button>
            </div>
          </div>
        </template>
      </div>

      <div class="actions">
        <button class="btn secondary" @click="$refs.catDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>

    <dialog x-ref="attrDlg" class="dialog-fixed">
      <h1>Gerenciar atributos</h1>
      <div class="dialog-body">
        <div class="flex-row" style="gap:.5rem;margin-bottom:.75rem">
          <input type="text" x-model="newAttrName" placeholder="Novo atributo…" style="flex:1" @keydown.enter="addAttribute()" />
          <button class="btn secondary small" type="button" @click="addAttribute()">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Adicionar
          </button>
        </div>
        <template x-for="attr in attributes" :key="attr.id">
          <div style="margin-bottom:.75rem;padding:.5rem;border:1px solid var(--border);border-radius:6px">
            <div class="flex-row" style="justify-content:space-between;align-items:center;margin-bottom:.35rem">
              <template x-if="attrEditId !== attr.id">
                <strong x-text="attr.name"></strong>
              </template>
              <template x-if="attrEditId === attr.id">
                <input type="text" x-model="attrEditName" style="flex:1" @keydown.enter="renameAttribute(attr.id)" />
              </template>
              <div class="flex-row" style="gap:.3rem">
                <template x-if="attrEditId !== attr.id">
                  <button class="icon-btn" @click="attrEditId = attr.id; attrEditName = attr.name" title="Renomear">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  </button>
                </template>
                <template x-if="attrEditId === attr.id">
                  <button class="icon-btn" @click="renameAttribute(attr.id)" title="Salvar">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </button>
                </template>
                <button class="icon-btn" @click="deleteAttribute(attr)" title="Excluir">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                </button>
              </div>
            </div>
            <div class="flex-row" style="flex-wrap:wrap;gap:.35rem">
              <template x-for="val in attrValues[attr.id] || []" :key="val.id">
                <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.15rem .5rem;background:var(--surface-hover);border-radius:4px;font-size:.85rem">
                  <template x-if="attrValEditId !== val.id">
                    <span x-text="val.value"></span>
                  </template>
                  <template x-if="attrValEditId === val.id">
                    <input type="text" x-model="attrValEditName" style="width:60px" @keydown.enter="renameAttrValue(attr.id, val.id)" @keydown.escape="attrValEditId = null" />
                  </template>
                  <button class="icon-btn" style="width:16px;height:16px" @click="attrValEditId = val.id; attrValEditName = val.value" title="Renomear">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  </button>
                  <button class="icon-btn" style="width:16px;height:16px" @click="deleteAttrValue(attr.id, val)" title="Excluir">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                  </button>
                </span>
              </template>
              <button class="btn-reset text-xs" style="color:var(--primary);padding:.15rem .4rem" @click="addAttrValId = attr.id; $nextTick(() => $refs['newAttrVal-' + attr.id]?.focus())">
                + valor
              </button>
              <input type="text" x-show="addAttrValId === attr.id" x-cloak :ref="'newAttrVal-' + attr.id"
                     style="width:70px;font-size:.85rem" placeholder="Valor…"
                     @keydown.enter="addAttrValue(attr.id, $event.target.value); $event.target.value = ''"
                     @keydown.escape="addAttrValId = null" />
            </div>
          </div>
        </template>
        <div class="error" x-text="attrDlgError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.attrDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>

    <dialog x-ref="genVarDlg">
      <h1>Gerar variantes</h1>
      <p class="muted">Selecione os valores de atributo para gerar as combinações.</p>
      <div class="dialog-body">
        <template x-if="!genGroups.length">
          <p class="muted text-xs">Nenhum atributo cadastrado. Crie atributos primeiro em "Atributos".</p>
        </template>
        <template x-for="(group, gi) in genGroups" :key="gi">
          <div style="margin-bottom:.75rem">
            <strong x-text="group.attribute_name"></strong>
            <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.3rem">
              <template x-for="val in group.values" :key="val.id">
                <label class="label-checkbox-sm" style="padding:.2rem .5rem;background:var(--surface-hover);border-radius:4px;cursor:pointer">
                  <input type="checkbox" :value="val.id" x-model="genSelectedValues" />
                  <span x-text="val.value"></span>
                </label>
              </template>
            </div>
          </div>
        </template>
        <div class="error" x-text="attrDlgError"></div>
        <template x-if="previewCombos.length">
          <div style="margin-top:1rem;border-top:1px solid var(--border);padding-top:.75rem">
            <p><strong>Pré-visualização: <span x-text="previewCombos.length"></span> combinação(ões)</strong></p>
            <div style="display:flex;flex-wrap:wrap;gap:.35rem">
              <template x-for="(combo, ci) in previewCombos" :key="ci">
                <span class="muted text-xs" style="padding:.2rem .5rem;background:var(--surface-hover);border-radius:4px" x-text="combo"></span>
              </template>
            </div>
          </div>
        </template>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.genVarDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="confirmGenerateVariants()" :disabled="!genSelectedValues.length">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Gerar <span x-text="previewCombos.length"></span>
        </button>
      </div>
    </dialog>

    <dialog x-ref="kitCompDlg">
      <h1>Adicionar componente</h1>
      <p class="muted">Busque por nome, código de barras ou SKU.</p>
      <input type="text" x-model="addCompSearch" placeholder="Buscar produto…" @input.debounce.300ms="searchComponents()" style="width:100%" />
      <div class="dialog-body" style="max-height:300px;overflow-y:auto">
        <template x-for="r in addCompResults" :key="r.id">
          <div class="flex-row" style="justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid var(--border-light)">
            <div>
              <span x-text="r.name"></span>
              <span class="muted text-xs" x-show="r.sku" x-text="` (${r.sku})`"></span>
            </div>
            <button class="btn secondary small" type="button" @click="addKitComponent(r.id)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Adicionar
            </button>
          </div>
        </template>
        <p x-show="!addCompResults.length && addCompSearch.trim().length >= 2" class="muted text-xs" style="text-align:center;padding:.75rem">Nenhum produto encontrado.</p>
        <p x-show="addCompSearch.trim().length < 2" class="muted text-xs" style="text-align:center;padding:.75rem">Digite ao menos 2 caracteres.</p>
        <div class="error" x-text="kitDlgError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.kitCompDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>

    <dialog x-ref="kitGroupDlg">
      <h1>Vincular grupo de complementos</h1>
      <p class="muted">Grupos disponíveis para vincular a este produto.</p>
      <div class="dialog-body" style="max-height:300px;overflow-y:auto">
        <template x-for="g in addCompResults" :key="g.id">
          <div class="flex-row" style="justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid var(--border-light)">
            <span x-text="g.name"></span>
            <button class="btn secondary small" type="button" @click="linkComplementGroup(g.id)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Vincular
            </button>
          </div>
        </template>
        <p x-show="!addCompResults.length" class="muted text-xs" style="text-align:center;padding:.75rem">Nenhum grupo disponível. Crie grupos de complemento em Configurações ou via API.</p>
        <div class="error" x-text="kitDlgError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.kitGroupDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>

    <dialog x-ref="recipeDlg">
      <h1>Adicionar insumo à ficha técnica</h1>
      <p class="muted">Busque por nome, código de barras ou SKU (apenas produtos simples).</p>
      <input type="text" x-model="recipeSearchQ" placeholder="Buscar produto…" @input.debounce.300ms="searchRecipeInputs()" style="width:100%" />
      <div class="dialog-body" style="max-height:300px;overflow-y:auto">
        <template x-for="r in recipeSearchResults" :key="r.id">
          <div class="flex-row" style="justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid var(--border-light)">
            <div>
              <span x-text="r.name"></span>
              <span class="muted text-xs" x-show="r.sku" x-text="` (${r.sku})`"></span>
            </div>
            <button class="btn secondary small" type="button" @click="addRecipeInput(r.id)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Adicionar
            </button>
          </div>
        </template>
        <p x-show="!recipeSearchResults.length && recipeSearchQ.trim().length >= 2" class="muted text-xs" style="text-align:center;padding:.75rem">Nenhum produto encontrado.</p>
        <p x-show="recipeSearchQ.trim().length < 2" class="muted text-xs" style="text-align:center;padding:.75rem">Digite ao menos 2 caracteres.</p>
        <div class="error" x-text="recipeDlgError"></div>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.recipeDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script src="/js/barcode.js"></script>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function productsPage() {
      return {
        ...tableToolkit(),
        rows: [], form: {}, move: {}, categories: [], newCat: '', q: '', error: '', dlgError: '', mvError: '',
        catEditId: null, catEditName: '', catDelId: null, catDelAction: 'unset', catDelMigrateTo: null, appSettings: [], barcodeHint: '',
        imgSearchResults: [], imgSearching: false, imgSearchOffline: false,
        // Variantes
        variants: [], attributes: [], attrValues: {}, attrEditId: null, attrEditName: '', attrValEditId: null, attrValEditName: '',
        attrDlgError: '', newAttrName: '', addAttrValId: null, genGroups: [], genSelectedValues: [],
        // Kits
        kitComponents: [], complementGroups: [], kitDlgError: '', addCompSearch: '', addCompResults: [],
        // Ficha técnica
        recipeComponents: [], recipeDlgError: '', recipeSearchResults: [], recipeSearchQ: '',
        sortGetters: {
          name: (p) => p.name, category: (p) => p.category ?? '',
          price: (p) => p.price_cents, cost: (p) => p.cost_cents,
          stock: (p) => (p.track_stock ? p.stock_qty : -Infinity), unit: (p) => p.unit,
        },
        get displayRows() { return this.sortedRows(this.rows, this.sortGetters); },
        get pageTotal() { return this.displayRows.length; },
        get pageRows() { return this.pagedRows(this.displayRows); },
        get previewCombos() {
          if (!this.genSelectedValues.length || !this.genGroups.length) return [];
          const groups = [];
          for (const g of this.genGroups) {
            const selected = g.values.filter(v => this.genSelectedValues.includes(v.id));
            if (selected.length) groups.push(selected.map(v => v.value));
          }
          if (!groups.length) return [];
          const cartesian = (arr) => arr.reduce((acc, a) => acc.flatMap(d => a.map(e => [...d, e])), [[]]);
          return cartesian(groups).map(c => c.join(', '));
        },
        brl(c) { return 'R$ ' + (c / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        toCents(s) { if (s == null || s === '') return null; return Math.round(parseFloat(String(s).replace(/\./g, '').replace(',', '.')) * 100); },
        async load() {
          const params = new URLSearchParams({ includeParents: 'true' });
          if (this.q) params.set('q', this.q);
          const r = await fetch('/api/commercial/products?' + params.toString());
          if (r.ok) { this.rows = await r.json(); this.pruneSelection(this.rows); }
          else showToast((await r.json()).error, 'error');
          const [c, s] = await Promise.all([
            fetch('/api/commercial/categories'),
            fetch('/api/settings'),
          ]);
          if (c.ok) this.categories = await c.json();
          if (s.ok) this.appSettings = await s.json();
        },
        openCatMgr() { this.dlgError = ''; this.$refs.catDlg.showModal(); },
        async renameCategory(id) {
          if (!this.catEditName.trim()) return;
          const r = await fetch(`/api/commercial/categories/${id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: this.catEditName.trim() }),
          });
          if (r.ok) {
            this.catEditId = null; this.catEditName = '';
            await this.load();
          } else { this.dlgError = (await r.json()).error; showToast(this.dlgError, 'error'); }
        },
        async deleteCategory() {
          const body = this.catDelAction === 'migrate' && this.catDelMigrateTo ? { migrateToId: this.catDelMigrateTo } : {};
          const r = await fetch(`/api/commercial/categories/${this.catDelId}`, {
            method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
          });
          if (r.ok) {
            this.catDelId = null; this.catDelAction = 'unset'; this.catDelMigrateTo = null;
            await this.load();
          } else { this.dlgError = (await r.json()).error; showToast(this.dlgError, 'error'); }
        },
        async addCategory() {
          if (!this.newCat.trim()) return;
          const r = await fetch('/api/commercial/categories', { method: 'POST',
            headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: this.newCat.trim() }) });
          if (r.ok) {
            const created = await r.json();
            const c = await fetch('/api/commercial/categories');
            if (c.ok) this.categories = await c.json();
            this.form.categoryId = created.id;
            this.newCat = '';
          } else { this.dlgError = (await r.json()).error; showToast(this.dlgError, 'error'); }
        },
        resetImageState() {
          this.form.imageUrl = null; this.form.newImagePreview = null;
          this.form.pendingImageBase64 = null; this.form.pendingImageUrl = null;
          this.form.removeImage = false; this.form.submitToCatalog = true;
          this.imgSearchResults = []; this.imgSearchOffline = false;
        },
        onImageFile(e) {
          const file = e.target.files[0];
          e.target.value = '';
          if (!file) return;
          if (file.size > 6 * 1024 * 1024) { this.dlgError = 'Imagem muito grande (máximo 6MB).'; return; }
          const reader = new FileReader();
          reader.onload = () => {
            const dataUrl = String(reader.result);
            this.form.newImagePreview = dataUrl;
            this.form.pendingImageBase64 = dataUrl.split(',')[1] ?? '';
            this.form.pendingImageUrl = null;
            this.form.removeImage = false;
          };
          reader.readAsDataURL(file);
        },
        removeProductImage() {
          this.form.newImagePreview = null; this.form.imageUrl = null;
          this.form.pendingImageBase64 = null; this.form.pendingImageUrl = null;
          this.form.removeImage = true;
        },
        async searchCatalogImages() {
          const q = (this.form.name || '').trim();
          if (q.length < 3) { this.imgSearchResults = []; return; }
          this.imgSearching = true;
          try {
            const r = await fetch('/api/commercial/products/image-search?q=' + encodeURIComponent(q));
            const data = r.ok ? await r.json() : { results: [] };
            this.imgSearchResults = data.results || [];
            this.imgSearchOffline = !!data.offline;
          } finally {
            this.imgSearching = false;
          }
        },
        async pickCatalogImage(r) {
          // Baixa os bytes agora (via proxy local) e trata como um upload comum: assim a
          // foto fica salva localmente e continua disponível offline depois de escolhida,
          // sem depender de acesso à nuvem toda vez que o produto for exibido.
          this.imgSearching = true; this.dlgError = '';
          try {
            const resp = await fetch(r.url);
            if (!resp.ok) { this.dlgError = 'Não foi possível baixar a imagem sugerida.'; return; }
            const blob = await resp.blob();
            const dataUrl = await new Promise((resolve, reject) => {
              const reader = new FileReader();
              reader.onload = () => resolve(String(reader.result));
              reader.onerror = reject;
              reader.readAsDataURL(blob);
            });
            this.form.newImagePreview = dataUrl;
            this.form.pendingImageBase64 = dataUrl.split(',')[1] ?? '';
            this.form.pendingImageUrl = null;
            this.form.removeImage = false;
            this.form.submitToCatalog = false; // já veio do catálogo — reenviar não tem sentido
          } finally {
            this.imgSearching = false;
          }
        },
        openNew() {
          this.form = { unit: 'un', productType: 'fisico' }; this.dlgError = ''; this.resetImageState();
          const autoSku = this.appSettings?.find(s => s.key === 'estoque.auto_sku')?.value;
          if (autoSku === '1') this.form.sku = 'SKU-' + String(Date.now()).slice(-8);
          const defMinStock = this.appSettings?.find(s => s.key === 'estoque.min_stock_padrao')?.value;
          if (defMinStock) this.form.minStock = Number(defMinStock);
          this.variants = [];
          this.kitComponents = [];
          this.complementGroups = [];
          this.recipeComponents = [];
          this.$refs.dlg.showModal();
        },
        openEdit(p) {
          this.form = { id: p.id, name: p.name, barcode: p.barcode ?? '', sku: p.sku ?? '', unit: p.unit,
            categoryId: p.category_id ?? '',
            price: (p.price_cents / 100).toFixed(2).replace('.', ','), cost: (p.cost_cents / 100).toFixed(2).replace('.', ','),
            minStock: p.min_stock, productType: p.product_type ?? 'fisico',
            description: p.description ?? '' };
          this.dlgError = ''; this.barcodeHint = ''; this.resetImageState();
          this.form.imageUrl = p.image_url ?? null;
          this.variants = [];
          this.kitComponents = [];
          this.complementGroups = [];
          this.$refs.dlg.showModal();
          if (!this.form.imageUrl) this.searchCatalogImages();
          if (p.product_type === 'variante') this.loadVariants(p.id);
          if (p.product_type === 'kit' || p.product_type === 'combo') {
            this.loadKitComponents(p.id);
            this.loadComplementGroups(p.id);
          }
          if (p.product_type === 'produzido') this.loadRecipeComponents(p.id);
        },
        checkBarcode(code) {
          if (!code) return '';
          return validateBarcodeClient(code) ? '' : 'Dígito verificador não confere.';
        },
        async scanLookup(code) {
          code = (code || '').trim();
          if (!code) return;
          const r = await fetch('/api/commercial/products/by-barcode/' + encodeURIComponent(code));
          if (r.ok) { this.openEdit(await r.json()); }
          else { this.openNew(); this.form.barcode = code; }
        },
        async genBarcode() {
          if (!this.form.id) return;
          const r = await fetch(`/api/commercial/products/${this.form.id}/barcode/generate`, { method: 'POST' });
          if (r.ok) { const p = await r.json(); this.form.barcode = p.barcode; this.barcodeHint = ''; }
          else { this.dlgError = (await r.json()).error ?? 'Erro ao gerar código.'; showToast(this.dlgError, 'error'); }
        },
        async save() {
          const body = { name: this.form.name, description: this.form.description || null,
            barcode: this.form.barcode || null, sku: this.form.sku || null,
            unit: this.form.unit || 'un', minStock: this.form.minStock ? Number(this.form.minStock) : undefined,
            categoryId: this.form.categoryId || null,
            productType: this.form.productType || 'fisico',
            initialStock: !this.form.id && this.form.initialStock ? Number(this.form.initialStock) : undefined };
          const price = this.toCents(this.form.price); if (price != null) body.priceCents = price;
          const cost = this.toCents(this.form.cost); if (cost != null) body.costCents = cost;
          if (this.form.removeImage) body.removeImage = true;
          else if (this.form.pendingImageBase64) { body.imageBase64 = this.form.pendingImageBase64; body.submitToCatalog = this.form.submitToCatalog !== false; }
          else if (this.form.pendingImageUrl) body.imageUrl = this.form.pendingImageUrl;
          const isEdit = !!this.form.id;
          const r = await fetch(isEdit ? `/api/commercial/products/${this.form.id}` : '/api/commercial/products', {
            method: isEdit ? 'PUT' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); showToast(isEdit ? 'Produto atualizado.' : 'Produto criado.', 'success'); }
          else { this.dlgError = (await r.json()).error ?? 'Erro ao salvar.'; showToast(this.dlgError, 'error'); }
        },
        async remove(p) {
          if (!await window.confirmDlg(`Excluir "${p.name}"?`)) return;
          const r = await fetch(`/api/commercial/products/${p.id}`, { method: 'DELETE' });
          if (r.ok) { this.load(); showToast(`"${p.name}" excluído.`, 'success'); } else showToast((await r.json()).error, 'error');
        },
        async toggleFavorite(p) {
          const r = await fetch(`/api/commercial/products/${p.id}/favorite`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ favorite: !p.favorite }),
          });
          if (r.ok) this.load(); else showToast((await r.json()).error, 'error');
        },
        async toggleCardapio(p) {
          const r = await fetch(`/api/commercial/products/${p.id}/cardapio-online`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ visivelCardapio: !p.visivel_cardapio }),
          });
          if (r.ok) this.load(); else showToast((await r.json()).error, 'error');
        },
        async duplicate(p) {
          const r = await fetch(`/api/commercial/products/${p.id}/duplicate`, { method: 'POST' });
          if (r.ok) { this.load(); showToast(`"${p.name}" duplicado.`, 'success'); } else showToast((await r.json()).error, 'error');
        },
        openMove(p) { this.move = { productId: p.id, name: p.name, current: p.stock_qty, type: 'entrada', qty: '', reason: '' }; this.mvError = ''; this.$refs.mv.showModal(); },
        async saveMove() {
          const r = await fetch('/api/commercial/stock/move', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: this.move.productId, type: this.move.type, qty: Number(this.move.qty), reason: this.move.reason || undefined }),
          });
          if (r.ok) { this.$refs.mv.close(); this.load(); }
          else this.mvError = (await r.json()).error ?? 'Erro na movimentação.';
        },
        // ---------- Variantes ----------
        async loadKitComponents(productId) {
          const r = await fetch(`/api/commercial/products/${productId}/kit-items`);
          if (r.ok) this.kitComponents = await r.json();
        },
        async loadComplementGroups(productId) {
          const r = await fetch(`/api/commercial/products/${productId}/complement-groups`);
          if (r.ok) this.complementGroups = await r.json();
        },
        async loadVariants(parentId) {
          const r = await fetch(`/api/commercial/products/${parentId}/variants`);
          if (r.ok) {
            const data = await r.json();
            this.variants = data.map(v => ({
              ...v,
              priceDisplay: (v.price_cents / 100).toFixed(2).replace('.', ','),
            }));
          }
        },
        variantAttrsLabel(v) {
          try {
            const attrs = typeof v.variant_attrs === 'string' ? JSON.parse(v.variant_attrs) : (v.variant_attrs || []);
            return attrs.map(a => `${a.attribute_name}: ${a.value}`).join(', ');
          } catch {
            return '';
          }
        },
        async updateVariantField(v, field) {
          const body = { [field]: v[field] || null };
          await fetch(`/api/commercial/products/${v.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
          });
        },
        async updateVariantPrice(v) {
          const cents = this.toCents(v.priceDisplay);
          if (cents == null) return;
          await fetch(`/api/commercial/products/${v.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ priceCents: cents }),
          });
        },
        async updateVariantStock(v) {
          if (v.stock_qty == null) return;
          await fetch('/api/commercial/stock/move', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: v.id, type: 'ajuste', qty: Number(v.stock_qty), reason: 'Ajuste inline de variante' }),
          });
        },
        async deleteVariant(v) {
          if (!await window.confirmDlg(`Excluir variante "${v.name}"?`)) return;
          const r = await fetch(`/api/commercial/products/${v.id}`, { method: 'DELETE' });
          if (r.ok) this.loadVariants(this.form.id);
          else showToast((await r.json()).error, 'error');
        },
        // ---------- Kits ----------
        async openAddComponent() {
          this.kitDlgError = ''; this.addCompSearch = ''; this.addCompResults = [];
          this.$refs.kitCompDlg.showModal();
        },
        async searchComponents() {
          const q = this.addCompSearch.trim();
          if (q.length < 2) { this.addCompResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(q));
          if (r.ok) {
            const all = await r.json();
            // Excluir o proprio kit e outros kits/combos dos resultados
            this.addCompResults = all.filter(p => p.id !== this.form.id && p.product_type !== 'kit' && p.product_type !== 'combo');
          }
        },
        async addKitComponent(compId) {
          const r = await fetch(`/api/commercial/products/${this.form.id}/kit-items`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ componentProductId: compId }),
          });
          if (r.ok) {
            this.$refs.kitCompDlg.close();
            this.loadKitComponents(this.form.id);
          } else this.kitDlgError = (await r.json()).error;
        },
        async updateKitComponent(c) {
          await fetch(`/api/commercial/kit-items/${c.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ qty: Number(c.qty) }),
          });
        },
        async deleteKitComponent(c) {
          if (!await window.confirmDlg(`Remover "${c.component_name}" dos componentes do kit?`)) return;
          const r = await fetch(`/api/commercial/kit-items/${c.id}`, { method: 'DELETE' });
          if (r.ok) this.loadKitComponents(this.form.id);
          else showToast((await r.json()).error, 'error');
        },
        async openAddComplementGroup() {
          this.kitDlgError = ''; this.addCompSearch = ''; this.addCompResults = [];
          // Carregar todos os grupos de complemento disponiveis
          const r = await fetch('/api/commercial/complement-groups');
          if (r.ok) {
            const all = await r.json();
            const linkedIds = new Set(this.complementGroups.map(g => g.group_id));
            this.addCompResults = all.filter(g => !linkedIds.has(g.id));
          }
          this.$refs.kitGroupDlg.showModal();
        },
        async linkComplementGroup(groupId) {
          const r = await fetch(`/api/commercial/products/${this.form.id}/complement-groups`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ groupId }),
          });
          if (r.ok) {
            this.$refs.kitGroupDlg.close();
            this.loadComplementGroups(this.form.id);
          } else this.kitDlgError = (await r.json()).error;
        },
        async unlinkComplementGroup(g) {
          if (!await window.confirmDlg(`Desvincular grupo "${g.group_name}"?`)) return;
          const r = await fetch(`/api/commercial/products/${this.form.id}/complement-groups/${g.id}`, { method: 'DELETE' });
          if (r.ok) this.loadComplementGroups(this.form.id);
          else showToast((await r.json()).error, 'error');
        },
        // ---------- Ficha técnica ----------
        async loadRecipeComponents(productId) {
          const r = await fetch(`/api/commercial/products/${productId}/recipe-items`);
          if (r.ok) this.recipeComponents = await r.json();
        },
        async openAddRecipeInput() {
          this.recipeDlgError = ''; this.recipeSearchQ = ''; this.recipeSearchResults = [];
          this.$refs.recipeDlg.showModal();
        },
        async searchRecipeInputs() {
          const q = this.recipeSearchQ.trim();
          if (q.length < 2) { this.recipeSearchResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(q));
          if (r.ok) {
            const all = await r.json();
            const linkedIds = new Set(this.recipeComponents.map(c => c.input_product_id));
            this.recipeSearchResults = all.filter(p =>
              p.id !== this.form.id && p.product_type !== 'kit' && p.product_type !== 'combo' && p.product_type !== 'produzido'
              && p.active && !linkedIds.has(p.id)
            );
          }
        },
        async addRecipeInput(inputId) {
          const r = await fetch(`/api/commercial/products/${this.form.id}/recipe-items`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ inputProductId: inputId }),
          });
          if (r.ok) {
            this.$refs.recipeDlg.close();
            this.loadRecipeComponents(this.form.id);
          } else this.recipeDlgError = (await r.json()).error;
        },
        async updateRecipeInput(r) {
          await fetch(`/api/commercial/recipe-items/${r.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ qty: Number(r.qty) }),
          });
          // Recalcular custo total da linha
          r.total_cost_cents = Math.round(Number(r.qty) * (r.cost_cents ?? 0));
        },
        async deleteRecipeInput(r) {
          if (!await window.confirmDlg(`Remover "${r.input_name}" da ficha técnica?`)) return;
          const resp = await fetch(`/api/commercial/recipe-items/${r.id}`, { method: 'DELETE' });
          if (resp.ok) this.loadRecipeComponents(this.form.id);
          else showToast((await resp.json()).error, 'error');
        },
        async openAttrMgr() {
          this.attrDlgError = ''; this.newAttrName = ''; this.attrEditId = null; this.addAttrValId = null;
          await this.loadAttributes();
          this.$refs.attrDlg.showModal();
        },
        async loadAttributes() {
          const r = await fetch('/api/commercial/attributes');
          if (r.ok) {
            this.attributes = await r.json();
            const vals = {};
            for (const attr of this.attributes) {
              const vr = await fetch(`/api/commercial/attributes/${attr.id}/values`);
              if (vr.ok) vals[attr.id] = await vr.json();
              else vals[attr.id] = [];
            }
            this.attrValues = vals;
          }
        },
        async addAttribute() {
          if (!this.newAttrName.trim()) return;
          const r = await fetch('/api/commercial/attributes', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: this.newAttrName.trim() }),
          });
          if (r.ok) { this.newAttrName = ''; await this.loadAttributes(); }
          else this.attrDlgError = (await r.json()).error;
        },
        async renameAttribute(id) {
          if (!this.attrEditName.trim()) return;
          const r = await fetch(`/api/commercial/attributes/${id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: this.attrEditName.trim() }),
          });
          if (r.ok) { this.attrEditId = null; await this.loadAttributes(); }
          else this.attrDlgError = (await r.json()).error;
        },
        async deleteAttribute(attr) {
          if (!await window.confirmDlg(`Excluir atributo "${attr.name}" e todos os seus valores?`)) return;
          const r = await fetch(`/api/commercial/attributes/${attr.id}`, { method: 'DELETE' });
          if (r.ok) await this.loadAttributes();
          else this.attrDlgError = (await r.json()).error;
        },
        async addAttrValue(attrId, value) {
          if (!value || !String(value).trim()) return;
          const r = await fetch(`/api/commercial/attributes/${attrId}/values`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: String(value).trim() }),
          });
          if (r.ok) { this.addAttrValId = null; await this.loadAttributes(); }
          else this.attrDlgError = (await r.json()).error;
        },
        async renameAttrValue(attrId, valId) {
          if (!this.attrValEditName.trim()) return;
          const r = await fetch(`/api/commercial/attributes/${attrId}/values/${valId}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ value: this.attrValEditName.trim() }),
          });
          if (r.ok) { this.attrValEditId = null; await this.loadAttributes(); }
          else this.attrDlgError = (await r.json()).error;
        },
        async deleteAttrValue(attrId, val) {
          if (!await window.confirmDlg(`Excluir valor "${val.value}"?`)) return;
          const r = await fetch(`/api/commercial/attributes/${attrId}/values/${val.id}`, { method: 'DELETE' });
          if (r.ok) await this.loadAttributes();
          else this.attrDlgError = (await r.json()).error;
        },
        async openGenVariants() {
          this.attrDlgError = ''; this.genSelectedValues = []; this.previewCombos = [];
          await this.loadAttributes();
          // Montar grupos de valores por atributo
          this.genGroups = this.attributes.map(a => ({
            attribute_id: a.id,
            attribute_name: a.name,
            values: (this.attrValues[a.id] || []).filter(v => !v.deleted_at),
          })).filter(g => g.values.length > 0);
          this.$refs.genVarDlg.showModal();
        },
        async confirmGenerateVariants() {
          if (!this.genSelectedValues.length) return;
          this.attrDlgError = '';
          const r = await fetch(`/api/commercial/products/${this.form.id}/attributes/generate-variants`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ attributeValueIds: this.genSelectedValues }),
          });
          if (r.ok) {
            this.$refs.genVarDlg.close();
            this.loadVariants(this.form.id);
          } else this.attrDlgError = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>

