<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Compras</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/commercial/compras' }) %>
  <main x-data="purchasesPage()" x-init="load()">
    <h1>Compras</h1>
    <div class="toolbar">
      <% if (user.permissions.has('commercial.purchases.create')) { %>
        <button class="btn" @click="openNew()">Nova compra</button>
      <% } %>
      <span class="muted">Receber uma compra dá entrada no estoque e atualiza o custo dos produtos.</span>
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr><th>#</th><th>Fornecedor</th><th>Status</th><th>Total</th><th>Recebida em</th><th></th></tr></thead>
      <tbody>
        <template x-for="p in rows" :key="p.id">
          <tr>
            <td x-text="p.id"></td>
            <td x-text="p.supplier"></td>
            <td><span class="badge" :class="p.status === 'cancelada' ? 'off' : 'ok'" x-text="p.status"></span></td>
            <td x-text="brl(p.total_cents)"></td>
            <td class="muted" x-text="p.received_at ?? '—'"></td>
            <td style="text-align:right">
              <% if (user.permissions.has('commercial.purchases.edit')) { %>
                <button class="btn secondary small" x-show="p.status !== 'cancelada'" @click="openEdit(p)">Editar</button>
              <% } %>
              <% if (user.permissions.has('commercial.purchases.cancel')) { %>
                <button class="btn small" x-show="p.status !== 'cancelada'" @click="cancelPurchase(p)">Cancelar</button>
              <% } %>
            </td>
          </tr>
        </template>
      </tbody>
    </table>

    <dialog x-ref="dlg" style="width:600px">
      <h1 x-text="form.id ? 'Editar compra #' + form.id : 'Nova compra'"></h1>
      <label>Fornecedor</label>
      <select x-model.number="form.supplierId">
        <option value="">Selecione…</option>
        <template x-for="s in suppliers" :key="s.id"><option :value="s.id" x-text="s.name"></option></template>
      </select>

      <template x-if="!form.id">
        <div>
          <label>Adicionar item</label>
          <div style="display:grid;grid-template-columns:1fr 80px 110px 70px;gap:.4rem;align-items:end">
            <select x-model.number="item.productId">
              <option value="">Produto…</option>
              <template x-for="p in products" :key="p.id"><option :value="p.id" x-text="p.name"></option></template>
            </select>
            <input type="number" step="any" min="0.001" placeholder="Qtd" x-model.number="item.qty" />
            <input type="text" placeholder="Custo un. R$" x-model="item.cost" @input="item.cost = maskMoney(item.cost)" />
            <button class="btn secondary" @click="addItem()">+</button>
          </div>

          <div style="margin-top:.8rem;max-height:180px;overflow-y:auto">
            <template x-for="(i, idx) in form.items" :key="idx">
              <div style="display:flex;justify-content:space-between;gap:.5rem;padding:.3rem 0;font-size:.9rem">
                <span x-text="`${i.name} — ${i.qty} × ${brl(i.unitCostCents)}`"></span>
                <span>
                  <strong x-text="brl(Math.round(i.qty * i.unitCostCents))"></strong>
                  <button class="btn small" style="margin-left:.5rem" @click="form.items.splice(idx, 1)">×</button>
                </span>
              </div>
            </template>
          </div>
          <p style="margin-top:.5rem;text-align:right">Total: <strong x-text="brl(total())"></strong></p>
        </div>
      </template>
      <label>Observações</label><input type="text" x-model="form.notes" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">Cancelar</button>
        <button class="btn" @click="save()" x-text="form.id ? 'Salvar' : 'Receber compra'"></button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script>
    function purchasesPage() {
      return {
        rows: [], suppliers: [], products: [], form: { items: [] }, item: {},
        error: '', dlgError: '',
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return isNaN(n) ? 0 : Math.round(n * 100); },
        async load() {
          const r = await fetch('/api/commercial/purchases');
          if (r.ok) this.rows = await r.json(); else this.error = (await r.json()).error;
        },
        async openNew() {
          this.form = { items: [], supplierId: '', notes: '' }; this.item = {}; this.dlgError = '';
          if (!this.suppliers.length) {
            const s = await fetch('/api/commercial/suppliers'); if (s.ok) this.suppliers = await s.json();
            const p = await fetch('/api/commercial/products'); if (p.ok) this.products = await p.json();
          }
          this.$refs.dlg.showModal();
        },
        async openEdit(p) {
          this.form = { id: p.id, supplierId: p.supplier_id, notes: p.notes ?? '', items: [] };
          this.dlgError = '';
          if (!this.suppliers.length) {
            const s = await fetch('/api/commercial/suppliers'); if (s.ok) this.suppliers = await s.json();
          }
          this.$refs.dlg.showModal();
        },
        async cancelPurchase(p) {
          if (!(await window.confirmDlg(`Cancelar a compra #${p.id}? O estoque recebido será estornado.`))) return;
          const r = await fetch(`/api/commercial/purchases/${p.id}/cancel`, { method: 'POST' });
          if (r.ok) this.load(); else this.error = (await r.json()).error;
        },
        addItem() {
          const p = this.products.find((x) => x.id === this.item.productId);
          const cost = this.cents(this.item.cost);
          if (!p || !(this.item.qty > 0) || cost <= 0) { this.dlgError = 'Escolha produto, quantidade e custo.'; return; }
          this.dlgError = '';
          this.form.items.push({ productId: p.id, name: p.name, qty: this.item.qty, unitCostCents: cost });
          this.item = {};
        },
        total() { return this.form.items.reduce((a, i) => a + Math.round(i.qty * i.unitCostCents), 0); },
        async save() {
          if (this.form.id) {
            const r = await fetch(`/api/commercial/purchases/${this.form.id}`, {
              method: 'PUT', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ supplierId: this.form.supplierId, notes: this.form.notes || undefined }),
            });
            if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
            return;
          }
          if (!this.form.supplierId || !this.form.items.length) { this.dlgError = 'Fornecedor e ao menos um item.'; return; }
          const r = await fetch('/api/commercial/purchases', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ supplierId: this.form.supplierId, notes: this.form.notes || undefined,
              items: this.form.items.map((i) => ({ productId: i.productId, qty: i.qty, unitCostCents: i.unitCostCents })) }),
          });
          if (r.ok) { this.$refs.dlg.close(); this.load(); } else this.dlgError = (await r.json()).error;
        },
      };
    }
  </script>
</body>
</html>
