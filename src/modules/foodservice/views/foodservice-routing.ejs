<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo — Roteamento para Cozinha</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/foodservice/roteamento' }) %>
  <main x-data="routingPage()" x-init="init()">
    <h1>Roteamento para cozinha</h1>
    <p class="muted muted-block">Defina quais produtos geram ticket na cozinha ao serem vendidos.</p>

    <table class="routing-table" x-show="list.length">
      <thead>
        <tr><th>Produto</th><th>SKU</th><th>Estação</th><th style="width:140px">Tempo estimado</th><th></th></tr>
      </thead>
      <tbody>
        <template x-for="r in list" :key="r.id">
          <tr>
            <td data-label="Produto" x-text="r.product_name"></td>
            <td data-label="SKU" class="muted" x-text="r.sku || '—'"></td>
            <td data-label="Estação"><input type="text" x-model="r.station" class="input input-narrow-lg" placeholder="Ex.: Chapa" /></td>
            <td data-label="Tempo estimado">
              <div class="flex-center" style="gap:.35rem">
                <input type="number" x-model="r.estimated_minutes" class="input input-narrow-sm" min="1" />
                <span class="muted text-xs">min</span>
              </div>
            </td>
            <td class="actions-cell">
              <button type="button" class="icon-btn" @click="update(r)" title="Salvar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="mobile-label">Salvar</span>
              </button>
              <button type="button" class="icon-btn active" @click="remove(r)" title="Remover">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                <span class="mobile-label">Remover</span>
              </button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>

    <div x-show="!list.length" x-cloak>
      <%- include('partials/empty-state', { message: 'Nenhum produto roteado para a cozinha ainda.' }) %>
    </div>

    <div class="panel mt-2">
      <h2>Adicionar produto</h2>
      <div class="combo-wrap">
        <input type="text" class="input" style="width:100%" x-model="searchQ"
               @input.debounce.300ms="searchProducts" placeholder="Buscar produto por nome ou SKU…" />
        <div class="combo-results" x-show="searchResults.length" x-cloak>
          <template x-for="p in searchResults" :key="p.id">
            <button type="button" class="combo-result" @click="addProduct(p)">
              <span x-text="p.name"></span>
              <span class="muted text-sm" x-text="p.sku || '—'"></span>
            </button>
          </template>
        </div>
      </div>
      <div class="error" x-text="error"></div>
    </div>
  </main>
  <style>
    .mobile-label { display: none; }
    /* ─── Celular: tabela vira lista de cards (tabela larga é ilegível em tela estreita) ─── */
    @media (max-width: 640px) {
      .routing-table, .routing-table tbody, .routing-table tr, .routing-table td { display: block; width: 100%; }
      .routing-table thead { display: none; }
      .routing-table { box-shadow: none; }
      .routing-table tr {
        margin-bottom: .85rem; background: var(--surface); border: 1.5px solid var(--border-light);
        border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-xs);
      }
      .routing-table td {
        display: flex; align-items: center; justify-content: space-between; gap: .75rem;
        padding: .65rem .9rem; border-bottom: 1px solid var(--border-light); border-radius: 0 !important;
      }
      .routing-table td:last-child { border-bottom: 0; }
      .routing-table td[data-label]::before {
        content: attr(data-label); flex-shrink: 0;
        font-size: .78rem; font-weight: 600; color: var(--text-muted);
      }
      .routing-table td .input { width: auto; flex: 1; max-width: 60%; }
      .routing-table td.actions-cell { justify-content: flex-end; gap: .25rem; }
      .routing-table .icon-btn {
        width: auto; height: 38px; padding: 0 .8rem; gap: .4rem;
        border: 1.5px solid var(--border-light); border-radius: 8px;
      }
      .routing-table .mobile-label { display: inline; font-size: .82rem; font-weight: 600; }
    }
  </style>
  <script>
    function routingPage() {
      return {
        list: [],
        searchQ: '',
        searchResults: [],
        error: '',
        async init() { await this.load(); },
        async load() {
          const r = await fetch('/api/foodservice/kitchen-routing');
          if (r.ok) this.list = await r.json();
        },
        async searchProducts() {
          if (!this.searchQ.trim()) { this.searchResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.searchQ.trim()));
          if (r.ok) {
            const all = await r.json();
            const routedIds = new Set(this.list.map((x) => x.product_id));
            this.searchResults = all.filter((p) => !routedIds.has(p.id) && !p.deleted_at);
          }
        },
        async addProduct(p) {
          const r = await fetch('/api/foodservice/kitchen-routing', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: p.id }),
          });
          if (r.ok) { this.searchQ = ''; this.searchResults = []; await this.load(); }
          else showToast((await r.json()).error ?? 'Erro ao adicionar produto.', 'error');
        },
        async update(r) {
          const res = await fetch(`/api/foodservice/kitchen-routing/${r.id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ station: r.station, estimatedMinutes: Number(r.estimated_minutes) || null }),
          });
          if (!res.ok) showToast((await res.json()).error ?? 'Erro ao salvar.', 'error');
        },
        async remove(r) {
          if (!await window.confirmDlg('Remover ' + r.product_name + ' do roteamento?')) return;
          const res = await fetch(`/api/foodservice/kitchen-routing/${r.id}`, { method: 'DELETE' });
          if (res.ok) await this.load();
          else showToast((await res.json()).error ?? 'Erro ao remover.', 'error');
        },
      };
    }
  </script>
</body>
</html>
