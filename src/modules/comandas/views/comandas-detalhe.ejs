<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo — Comanda</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/comandas/mesas' }) %>
  <main x-data="comandaDetalhePage()" x-init="init()">
    <div class="comanda-header">
      <div>
        <a href="/app/comandas/mesas" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Mesas
        </a>
        <h1 x-text="comanda ? 'Comanda #' + comanda.id + (comanda.table_label ? ' — ' + comanda.table_label : '') : 'Carregando…'"></h1>
        <p class="muted" x-show="comanda?.notes" x-text="'Obs.: ' + (comanda?.notes ?? '')"></p>
      </div>
      <div class="toolbar header-actions" x-show="isOpen" x-cloak>
        <button type="button" class="btn secondary" @click="openTransferDlg()" title="Transferir">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>
          <span class="btn-label">Transferir</span>
        </button>
        <button type="button" class="btn secondary" @click="openSplitDlg()" :disabled="items.length < 2" title="Dividir">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
          <span class="btn-label">Dividir</span>
        </button>
        <button type="button" class="btn secondary" @click="openMergeDlg()" title="Unir">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>
          <span class="btn-label">Unir</span>
        </button>
        <button type="button" class="btn danger" @click="cancelComanda()" title="Cancelar comanda">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/></svg>
          <span class="btn-label">Cancelar</span>
        </button>
      </div>
    </div>
    <div class="error" x-text="error"></div>

    <div class="panel comanda-panel">
      <div class="comanda-items" x-show="items.length">
        <template x-for="(item, idx) in items" :key="item.id">
          <div class="comanda-item">
            <div class="comanda-item-qty" x-text="(item.qty % 1 === 0 ? item.qty : item.qty.toFixed(3)) + 'x'"></div>
            <div class="comanda-item-info">
              <div class="comanda-item-name" x-text="item.product_name"></div>
              <div class="comanda-item-meta" x-show="item.notes" x-text="'Obs.: ' + item.notes"></div>
            </div>
            <div class="comanda-item-price" x-text="brl(item.unit_price_cents * item.qty)"></div>
            <button type="button" class="icon-btn active" @click="voidItem(item.id, idx)" :disabled="!isOpen" title="Remover item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
          </div>
        </template>
      </div>
      <div x-show="!items.length" x-cloak>
        <%- include('partials/empty-state', { message: 'Comanda vazia — busque um produto abaixo para adicionar.' }) %>
      </div>

      <div class="comanda-total" x-show="items.length">
        <span>Total</span>
        <strong x-text="brl(total())"></strong>
      </div>
    </div>

    <div class="panel" x-show="isOpen" x-cloak>
      <h2>Adicionar item</h2>
      <div class="combo-wrap">
        <div style="display:flex;gap:.5rem">
          <input type="text" class="input" style="flex:1" x-model="searchQ"
                 @input.debounce.300ms="searchProducts" @keydown.enter.prevent="quickAdd"
                 placeholder="Buscar produto por nome, SKU ou código de barras…" x-ref="searchInput" />
          <button type="button" class="btn secondary" @click="openBrowse()" title="Procurar produtos">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Procurar
          </button>
        </div>
        <div class="combo-results" x-show="searchResults.length" x-cloak>
          <template x-for="p in searchResults" :key="p.id">
            <button type="button" class="combo-result" @click="addItem(p)">
              <span x-text="p.name"></span>
              <span class="muted text-sm" x-text="brl(p.price_cents) + (p.sku ? ' · ' + p.sku : '')"></span>
            </button>
          </template>
        </div>
      </div>
    </div>

    <div class="toolbar close-bar" x-show="isOpen && items.length" x-cloak style="justify-content:flex-end">
      <button type="button" class="btn" @click="openCloseDlg()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Fechar comanda
      </button>
    </div>
    <div class="close-bar-spacer"></div>

    <!-- Dialog Transferir -->
    <dialog x-ref="transferDlg">
      <h1>Transferir para mesa</h1>
      <p class="dialog-text">Escolha a mesa de destino:</p>
      <div class="tables-mini-grid">
        <template x-for="t in availableTables" :key="t.id">
          <button type="button" class="mini-table" :class="{ selected: transferTarget === t.id }" @click="transferTarget = t.id">
            <span x-text="t.label"></span>
          </button>
        </template>
        <p class="muted text-sm" x-show="!availableTables.length">Nenhuma mesa livre no momento.</p>
      </div>
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button type="button" class="btn secondary" @click="$refs.transferDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button type="button" class="btn" :disabled="!transferTarget" @click="confirmTransfer()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Transferir
        </button>
      </div>
    </dialog>

    <!-- Dialog Dividir -->
    <dialog x-ref="splitDlg" class="dialog-fixed">
      <h1>Dividir comanda</h1>
      <div class="dialog-body">
        <p class="dialog-text">Selecione os itens que vão para uma nova comanda:</p>
        <template x-for="item in items" :key="item.id">
          <label class="split-item">
            <input type="checkbox" x-model="splitItemIds" :value="item.id" />
            <span x-text="item.qty + 'x ' + item.product_name"></span>
            <span class="muted text-sm" x-text="brl(item.unit_price_cents * item.qty)"></span>
          </label>
        </template>
        <div class="error" x-text="dlgError"></div>
      </div>
      <div class="actions">
        <button type="button" class="btn secondary" @click="$refs.splitDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button type="button" class="btn" :disabled="!splitItemIds.length" @click="confirmSplit()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Dividir
        </button>
      </div>
    </dialog>

    <!-- Dialog Unir -->
    <dialog x-ref="mergeDlg" class="dialog-fixed">
      <h1>Unir comanda</h1>
      <div class="dialog-body">
        <p class="dialog-text">Escolha a comanda que será unida a esta:</p>
        <template x-for="c in otherComandas" :key="c.id">
          <label class="split-item">
            <input type="radio" name="mergeComanda" x-model="mergeSourceId" :value="c.id" />
            <span x-text="'Comanda #' + c.id + (c.table_label ? ' — ' + c.table_label : '')"></span>
          </label>
        </template>
        <p class="muted text-sm" x-show="!otherComandas.length">Nenhuma outra comanda aberta.</p>
        <div class="error" x-text="dlgError"></div>
      </div>
      <div class="actions">
        <button type="button" class="btn secondary" @click="$refs.mergeDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button type="button" class="btn" :disabled="!mergeSourceId" @click="confirmMerge()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Unir
        </button>
      </div>
    </dialog>

    <!-- Dialog Fechar (encaminha para o PDV) -->
    <dialog x-ref="closeDlg" style="width:360px">
      <div class="dialog-body-center">
        <div class="dialog-icon dialog-icon-primary">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--primary)"><rect x="1" y="7" width="22" height="14" rx="2"/><path d="M1 10h22"/><circle cx="12" cy="14" r="2"/></svg>
        </div>
        <h2 class="dialog-heading-md">Fechar comanda</h2>
        <p class="dialog-muted">Você será encaminhado ao PDV para finalizar o pagamento.</p>
        <div class="actions actions-center">
          <button type="button" class="btn secondary" @click="$refs.closeDlg.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            Cancelar
          </button>
          <button type="button" class="btn" @click="confirmClose()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            Ir para o PDV
          </button>
        </div>
      </div>
    </dialog>

    <!-- ─── Modal: Procurar produtos ─── -->
    <dialog x-ref="browseDlg" style="width:min(960px, 94vw)">
      <h1>Procurar produtos</h1>
      <input type="text" x-ref="browseInput" x-model="browseQ"
             @input.debounce.250ms="searchBrowse()"
             placeholder="Buscar por nome, código de barras ou SKU…" />
      <div class="browse-cats" x-show="browseCategories.length">
        <button type="button" class="browse-cat-chip"
                :class="{ active: !browseCategoryId }"
                @click="browseCategoryId = ''">Todas</button>
        <template x-for="c in browseCategories" :key="c.id">
          <button type="button" class="browse-cat-chip"
                  :class="{ active: browseCategoryId === c.id }"
                  @click="browseCategoryId = browseCategoryId === c.id ? '' : c.id"
                  x-text="c.name"></button>
        </template>
      </div>
      <div class="browse-list">
        <template x-for="p in browseFiltered()" :key="p.id">
          <div class="browse-result" @click="addItem(p); $refs.browseDlg.close()">
            <span class="browse-result-thumb">
              <img x-show="p.image_url" :src="p.image_url" alt="" />
              <template x-if="!p.image_url">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </template>
            </span>
            <span class="browse-name" x-text="p.name"></span>
            <span class="browse-category muted text-sm" x-show="p.category" x-text="p.category"></span>
            <span class="browse-price" x-text="brl(p.price_cents)"></span>
            <span class="browse-stock"
                  :class="{ low: p.track_stock && p.stock_qty <= 3 && p.stock_qty >= 0, negative: p.track_stock && p.stock_qty < 0 }"
                  x-show="p.track_stock"
                  x-text="'Est: ' + p.stock_qty"></span>
          </div>
        </template>
        <p class="browse-empty" x-show="!browseFiltered().length">Nenhum produto encontrado.</p>
      </div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.browseDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar
        </button>
      </div>
    </dialog>
  </main>
  <style>
    .comanda-header {
      display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .comanda-header h1 { margin-bottom: .15rem; }
    .back-link {
      display: inline-flex; align-items: center; gap: .3rem;
      font-size: .8rem; color: var(--text-muted); text-decoration: none; margin-bottom: .4rem;
      transition: color var(--transition);
    }
    .back-link:hover { color: var(--primary); }
    .comanda-panel { padding: 0; overflow: hidden; }
    .comanda-items { display: flex; flex-direction: column; }
    .comanda-item {
      display: flex; align-items: center; gap: .85rem; padding: .85rem 1.25rem;
      border-bottom: 1px solid var(--border-light);
    }
    .comanda-item:last-child { border-bottom: 0; }
    .comanda-item-qty {
      font-weight: 700; min-width: 2.4rem; text-align: center; color: var(--primary);
      background: var(--primary-bg); border-radius: 8px; padding: .2rem 0; font-size: .85rem;
    }
    .comanda-item-info { flex: 1; min-width: 0; }
    .comanda-item-name { font-weight: 500; }
    .comanda-item-meta { font-size: .82rem; color: var(--text-muted); margin-top: .1rem; }
    .comanda-item-price { font-weight: 600; font-size: .92rem; white-space: nowrap; }
    .comanda-total {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1rem 1.25rem; background: var(--surface-hover); border-top: 1.5px solid var(--border-light);
      font-size: 1.05rem;
    }
    .comanda-total strong { color: var(--primary); font-size: 1.25rem; }

    .tables-mini-grid { display: flex; flex-wrap: wrap; gap: .5rem; margin: .5rem 0 1rem; }
    .mini-table {
      padding: .55rem 1.1rem; border-radius: 10px; border: 1.5px solid var(--border-light);
      background: var(--surface); color: var(--text); cursor: pointer; font-size: .88rem; font-weight: 600;
      transition: border-color var(--transition), background var(--transition), color var(--transition);
    }
    .mini-table:hover { border-color: var(--primary); }
    .mini-table.selected { border-color: var(--primary); background: var(--primary); color: #fff; }

    .split-item {
      display: flex; align-items: center; gap: .6rem; padding: .6rem .5rem; border-radius: 8px; cursor: pointer;
      font-size: .88rem;
    }
    .split-item:hover { background: var(--surface-hover); }
    .split-item span:nth-child(2) { flex: 1; }

    /* ─── Barra "Fechar comanda" fixa embaixo no celular (como o botão Finalizar do PDV) ─── */
    .close-bar-spacer { display: none; }
    @media (max-width: 720px) {
      .close-bar-spacer { display: block; height: 4.5rem; }
      .close-bar {
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 80;
        margin: 0; padding: .75rem 1rem calc(.75rem + env(safe-area-inset-bottom));
        background: color-mix(in srgb, var(--surface) 92%, transparent);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        border-top: 1px solid var(--border-light); box-shadow: 0 -4px 16px rgba(0,0,0,.06);
      }
      .close-bar .btn { flex: 1; padding: .8rem; font-size: 1rem; }
    }

    /* ─── Ações do cabeçalho: só ícone no celular (título vira o rótulo acessível) ─── */
    @media (max-width: 560px) {
      .comanda-header { flex-direction: column; }
      .header-actions .btn-label { display: none; }
      .header-actions .btn { width: 42px; height: 42px; padding: 0; justify-content: center; }
      .header-actions .btn svg { margin-right: 0; }
    }

    /* ─── Toque/mobile: alvos maiores nos itens da comanda ─── */
    @media (hover: none), (max-width: 560px) {
      .comanda-item { padding: .95rem 1rem; }
      .comanda-item .icon-btn { width: 40px; height: 40px; }
    }

    /* ─── Browse modal ─── */
    .browse-cats { display: flex; gap: .4rem; flex-wrap: wrap; margin-top: .7rem; }
    .browse-cat-chip {
      border: 1.5px solid var(--border-light); background: var(--surface-hover); color: var(--text-secondary);
      border-radius: 999px; padding: .35rem .85rem; font-size: .82rem; font-weight: 600; cursor: pointer;
      transition: border-color var(--transition), background var(--transition), color var(--transition);
    }
    .browse-cat-chip:hover { border-color: var(--primary); color: var(--primary); }
    .browse-cat-chip.active { border-color: var(--primary); background: var(--primary-bg); color: var(--primary); }
    .browse-list { max-height: min(64vh, 680px); overflow-y: auto; margin-top: .75rem; border: 1.5px solid var(--border-light); border-radius: var(--radius); }
    .browse-result {
      display: grid; grid-template-columns: 38px 1fr auto auto auto; gap: .75rem; align-items: center;
      padding: .7rem .9rem; cursor: pointer; border-bottom: 1px solid var(--border-light);
      transition: background var(--transition);
    }
    .browse-result:last-child { border-bottom: 0; }
    .browse-result:hover { background: color-mix(in srgb, var(--primary) 6%, transparent); }
    .browse-result-thumb {
      width: 36px; height: 36px; border-radius: 8px; overflow: hidden; flex-shrink: 0;
      background: var(--surface-hover); border: 1px solid var(--border-light);
      display: grid; place-items: center; color: var(--text-muted);
    }
    .browse-result-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .browse-name { font-weight: 600; font-size: .95rem; color: var(--text); }
    .browse-category { font-size: .8rem; }
    .browse-price { font-weight: 700; font-size: .95rem; color: var(--primary); white-space: nowrap; }
    .browse-stock {
      font-size: .78rem; color: var(--text-muted); white-space: nowrap; text-align: right;
    }
    .browse-stock.low { color: var(--danger); }
    .browse-stock.negative { color: var(--danger); }
    .browse-empty { padding: .9rem; text-align: center; color: var(--text-muted); font-size: .9rem; }
  </style>
  <script>
    function comandaDetalhePage() {
      return {
        comandaId: <%= comandaId %>,
        comanda: null,
        items: [],
        searchQ: '',
        searchResults: [],
        isOpen: false,
        error: '', dlgError: '',
        availableTables: [],
        transferTarget: null,
        splitItemIds: [],
        otherComandas: [],
        mergeSourceId: null,
        pollTimer: null,
        browseQ: '',
        browseResults: [],
        browseCategories: [],
        browseCategoryId: '',

        async init() {
          await this.load();
          this.pollTimer = setInterval(() => this.load(), 5000);
        },
        async load() {
          const r = await fetch('/api/comandas/comandas/' + this.comandaId);
          if (!r.ok) { showToast((await r.json()).error ?? 'Erro ao carregar comanda.', 'error'); return; }
          const data = await r.json();
          this.comanda = data;
          this.items = data.items || [];
          this.isOpen = data.status === 'aberta';
        },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        total() { return this.items.reduce((a, i) => a + i.unit_price_cents * i.qty, 0); },
        async searchProducts() {
          if (!this.searchQ.trim()) { this.searchResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.searchQ.trim()));
          if (r.ok) this.searchResults = await r.json();
        },
        quickAdd() {
          if (this.searchResults.length === 1) this.addItem(this.searchResults[0]);
        },
        async openBrowse() {
          this.browseQ = '';
          this.browseResults = [];
          this.browseCategoryId = '';
          this.$refs.browseDlg.showModal();
          this.$nextTick(() => this.$refs.browseInput?.focus());
          if (!this.browseCategories.length) {
            const c = await fetch('/api/commercial/categories');
            if (c.ok) this.browseCategories = await c.json();
          }
          this.searchBrowse();
        },
        async searchBrowse() {
          const r = await fetch('/api/commercial/products' + (this.browseQ.trim() ? '?q=' + encodeURIComponent(this.browseQ.trim()) : ''));
          if (r.ok) this.browseResults = await r.json();
        },
        browseFiltered() {
          if (!this.browseCategoryId) return this.browseResults;
          return this.browseResults.filter((p) => p.category_id === this.browseCategoryId);
        },
        async addItem(p) {
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/items', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: p.id, qty: 1 }),
          });
          if (r.ok) { this.searchQ = ''; this.searchResults = []; await this.load(); this.$refs.searchInput?.focus(); showToast('Item adicionado.', 'success'); }
          else showToast((await r.json()).error ?? 'Erro ao adicionar item.', 'error');
        },
        async voidItem(itemId, idx) {
          if (!await window.confirmDlg('Remover ' + this.items[idx].product_name + ' da comanda?')) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/items/' + itemId, { method: 'DELETE' });
          if (r.ok) { await this.load(); showToast('Item removido.', 'success'); }
          else showToast((await r.json()).error ?? 'Erro ao remover item.', 'error');
        },
        async openTransferDlg() {
          this.transferTarget = null; this.dlgError = '';
          const r = await fetch('/api/comandas/tables/status');
          if (r.ok) this.availableTables = (await r.json()).filter((t) => t.status === 'livre');
          this.$refs.transferDlg.showModal();
        },
        async confirmTransfer() {
          if (!this.transferTarget) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/transfer', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tableId: this.transferTarget }),
          });
          if (!r.ok) { this.dlgError = (await r.json()).error ?? 'Erro ao transferir.'; showToast(this.dlgError, 'error'); return; }
          this.$refs.transferDlg.close();
          await this.load();
        },
        openSplitDlg() {
          this.splitItemIds = []; this.dlgError = '';
          this.$refs.splitDlg.showModal();
        },
        async confirmSplit() {
          if (!this.splitItemIds.length) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/split', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemIds: this.splitItemIds }),
          });
          if (!r.ok) { this.dlgError = (await r.json()).error ?? 'Erro ao dividir.'; showToast(this.dlgError, 'error'); return; }
          const data = await r.json();
          this.$refs.splitDlg.close();
          window.location.href = '/app/comandas/mesas/' + data.newComandaId;
        },
        async openMergeDlg() {
          this.mergeSourceId = null; this.dlgError = '';
          const r = await fetch('/api/comandas/comandas?status=aberta');
          if (r.ok) this.otherComandas = (await r.json()).filter((c) => c.id !== this.comandaId);
          this.$refs.mergeDlg.showModal();
        },
        async confirmMerge() {
          if (!this.mergeSourceId) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/merge', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sourceComandaId: this.mergeSourceId }),
          });
          if (!r.ok) { this.dlgError = (await r.json()).error ?? 'Erro ao unir.'; showToast(this.dlgError, 'error'); return; }
          this.$refs.mergeDlg.close();
          await this.load();
        },
        openCloseDlg() { this.$refs.closeDlg.showModal(); },
        confirmClose() {
          this.$refs.closeDlg.close();
          window.location.href = '/app/store/pdv?comandaId=' + this.comandaId;
        },
        async cancelComanda() {
          if (!await window.confirmDlg('Cancelar esta comanda? Os itens serão perdidos.')) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/cancel', { method: 'POST' });
          if (r.ok) window.location.href = '/app/comandas/mesas';
          else showToast((await r.json()).error ?? 'Erro ao cancelar.', 'error');
        },
      };
    }
  </script>
</body>
</html>
