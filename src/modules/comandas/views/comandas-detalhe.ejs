<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('../../../store/views/partials/theme-init') %>
  <title>Katsu — Comanda</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('../../../store/views/partials/nav', { user, page: '/app/comandas/mesas' }) %>
  <main x-data="comandaDetalhePage()" x-init="init()">
    <div class="container">
      <div class="flex-row" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
        <div>
          <h1 x-text="comanda ? 'Comanda #' + comanda.id + (comanda.table_label ? ' — Mesa ' + comanda.table_label : '') : 'Carregando...'"></h1>
          <div x-show="comanda?.notes" class="text-muted" x-text="'Obs: ' + comanda.notes"></div>
        </div>
        <div class="btn-group">
          <button type="button" class="btn" @click="openTransferDlg()" :disabled="!isOpen">Transferir</button>
          <button type="button" class="btn" @click="openSplitDlg()" :disabled="!isOpen || (items.length < 2)">Dividir</button>
          <button type="button" class="btn" @click="openMergeDlg()" :disabled="!isOpen">Unir</button>
          <button type="button" class="btn btn-danger" @click="cancelComanda()" :disabled="!isOpen">Cancelar</button>
        </div>
      </div>

      <div class="comanda-items">
        <template x-for="(item, idx) in items" :key="item.id">
          <div class="comanda-item">
            <div class="comanda-item-qty" x-text="item.qty + 'x'"></div>
            <div class="comanda-item-info">
              <div class="comanda-item-name" x-text="item.product_name"></div>
              <div class="comanda-item-meta" x-show="item.notes" x-text="'Obs: ' + item.notes"></div>
              <div class="comanda-item-price" x-text="brl(item.unit_price_cents * item.qty)"></div>
            </div>
            <button type="button" class="btn btn-sm btn-danger" @click="voidItem(item.id, idx)" :disabled="!isOpen">Remover</button>
          </div>
        </template>
        <div x-show="!items.length" class="text-muted" style="text-align:center;padding:1rem">Comanda vazia.</div>
      </div>

      <div class="comanda-total" x-show="items.length">
        <strong>Total: <span x-text="brl(total())"></span></strong>
      </div>

      <div class="comanda-add" x-show="isOpen">
        <h2>Adicionar Item</h2>
        <div class="form-row">
          <input type="text" x-model="searchQ" @input.debounce.300ms="searchProducts" @keydown.enter.prevent="quickAdd" placeholder="Buscar produto..." class="form-input" x-ref="searchInput" />
        </div>
        <div class="search-results" x-show="searchResults.length">
          <template x-for="p in searchResults" :key="p.id">
            <div class="search-result" @click="addItem(p)">
              <span x-text="p.name"></span>
              <span class="text-muted" x-text="p.sku ? '(' + p.sku + ')' : ''"></span>
              <span class="text-muted" x-text="brl(p.price_cents)"></span>
            </div>
          </template>
        </div>
      </div>

      <div class="form-actions" x-show="isOpen && items.length">
        <button type="button" class="btn btn-success btn-lg" @click="openCloseDlg()">Fechar Comanda</button>
      </div>
    </div>

    <!-- Dialog Transferir -->
    <dialog x-ref="transferDlg">
      <form @submit.prevent="confirmTransfer" method="dialog">
        <h2>Transferir para Mesa</h2>
        <p>Mesa destino:</p>
        <div class="tables-mini-grid">
          <template x-for="t in availableTables" :key="t.id">
            <div class="mini-table" :class="{ selected: transferTarget === t.id }" @click="transferTarget = t.id">
              <span x-text="t.label"></span>
            </div>
          </template>
        </div>
        <div class="form-actions">
          <button type="button" class="btn secondary" @click="$refs.transferDlg.close()">Cancelar</button>
          <button type="submit" class="btn" :disabled="!transferTarget">Transferir</button>
        </div>
      </form>
    </dialog>

    <!-- Dialog Dividir -->
    <dialog x-ref="splitDlg">
      <form @submit.prevent="confirmSplit" method="dialog">
        <h2>Dividir Comanda</h2>
        <p>Selecione os itens para mover para uma nova comanda:</p>
        <template x-for="(item, idx) in items" :key="item.id">
          <label class="split-item">
            <input type="checkbox" x-model="splitItemIds" :value="item.id" />
            <span x-text="item.qty + 'x ' + item.product_name + ' — ' + brl(item.unit_price_cents * item.qty)"></span>
          </label>
        </template>
        <div class="form-actions">
          <button type="button" class="btn secondary" @click="$refs.splitDlg.close()">Cancelar</button>
          <button type="submit" class="btn" :disabled="!splitItemIds.length">Dividir</button>
        </div>
      </form>
    </dialog>

    <!-- Dialog Unir -->
    <dialog x-ref="mergeDlg">
      <form @submit.prevent="confirmMerge" method="dialog">
        <h2>Unir Comanda</h2>
        <p>Selecione a comanda para unir com esta:</p>
        <template x-for="c in otherComandas" :key="c.id">
          <label class="split-item">
            <input type="radio" name="mergeComanda" x-model="mergeSourceId" :value="c.id" />
            <span x-text="'Comanda #' + c.id + (c.table_label ? ' — Mesa ' + c.table_label : '')"></span>
          </label>
        </template>
        <div class="form-actions">
          <button type="button" class="btn secondary" @click="$refs.mergeDlg.close()">Cancelar</button>
          <button type="submit" class="btn" :disabled="!mergeSourceId">Unir</button>
        </div>
      </form>
    </dialog>

    <!-- Dialog Fechar (encaminha para o PDV) -->
    <dialog x-ref="closeDlg">
      <form @submit.prevent="confirmClose" method="dialog">
        <h2>Fechar Comanda</h2>
        <p>Você será redirecionado para o PDV para finalizar o pagamento.</p>
        <div class="form-actions">
          <button type="button" class="btn secondary" @click="$refs.closeDlg.close()">Cancelar</button>
          <button type="submit" class="btn btn-success">Ir para o PDV</button>
        </div>
      </form>
    </dialog>
  </main>
  <style>
    .comanda-items { border: 1px solid var(--border); border-radius: 8px; margin-bottom: 1rem; }
    .comanda-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-top: 1px solid var(--border); }
    .comanda-item:first-child { border-top: none; }
    .comanda-item-qty { font-weight: 700; min-width: 2rem; text-align: center; }
    .comanda-item-info { flex: 1; }
    .comanda-item-name { font-weight: 500; }
    .comanda-item-meta { font-size: 0.85rem; color: var(--muted); }
    .comanda-total { text-align: right; padding: 0.5rem 1rem; font-size: 1.2rem; margin-bottom: 1rem; }
    .comanda-add { margin-bottom: 1.5rem; }
    .search-results { border: 1px solid var(--border); border-radius: 6px; max-height: 200px; overflow-y: auto; }
    .search-result { padding: 0.5rem 0.75rem; cursor: pointer; display: flex; gap: 0.5rem; border-top: 1px solid var(--border); }
    .search-result:first-child { border-top: none; }
    .search-result:hover { background: var(--hover); }
    .tables-mini-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0.5rem 0; }
    .mini-table { padding: 0.5rem 1rem; border: 2px solid var(--border); border-radius: 8px; cursor: pointer; }
    .mini-table.selected { border-color: var(--primary); background: rgba(59,130,246,0.1); }
    .split-item { display: block; padding: 0.5rem; cursor: pointer; }
    .split-item:hover { background: var(--hover); }
  </style>
  <script>
    function comandaDetalhePage() {
      return {
        comandaId: <%= comandaId %>,
        comanda: null,
        items: [],
        searchQ: '',
        searchResults: [],
        isOpen: false,
        // Transfer
        availableTables: [],
        transferTarget: null,
        // Split
        splitItemIds: [],
        // Merge
        otherComandas: [],
        mergeSourceId: null,
        pollTimer: null,

        async init() {
          await this.load();
          this.pollTimer = setInterval(() => this.load(), 5000);
        },
        async load() {
          const r = await fetch('/api/comandas/comandas/' + this.comandaId);
          if (!r.ok) return;
          const data = await r.json();
          this.comanda = data;
          this.items = data.items || [];
          this.isOpen = data.status === 'aberta';
        },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        total() { return this.items.reduce((a, i) => a + i.unit_price_cents * i.qty, 0); },
        async searchProducts() {
          if (!this.searchQ.trim()) { this.searchResults = []; return; }
          const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.searchQ.trim()));
          if (r.ok) this.searchResults = await r.json();
        },
        quickAdd() {
          if (this.searchResults.length === 1) this.addItem(this.searchResults[0]);
        },
        async addItem(p) {
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/items', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: p.id, qty: 1 }),
          });
          if (r.ok) { this.searchQ = ''; this.searchResults = []; await this.load(); this.$refs.searchInput?.focus(); }
          else { const e = await r.json(); alert(e.error); }
        },
        async voidItem(itemId, idx) {
          if (!await window.confirmDlg('Remover ' + this.items[idx].product_name + ' da comanda?')) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/items/' + itemId, { method: 'DELETE' });
          if (r.ok) await this.load();
        },
        async openTransferDlg() {
          this.transferTarget = null;
          const r = await fetch('/api/comandas/tables/status');
          if (r.ok) this.availableTables = (await r.json()).filter((t) => t.status === 'livre');
          this.$refs.transferDlg.showModal();
        },
        async confirmTransfer() {
          if (!this.transferTarget) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/transfer', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tableId: this.transferTarget }),
          });
          if (!r.ok) { const e = await r.json(); alert(e.error); return; }
          this.$refs.transferDlg.close();
          await this.load();
        },
        openSplitDlg() {
          this.splitItemIds = [];
          this.$refs.splitDlg.showModal();
        },
        async confirmSplit() {
          if (!this.splitItemIds.length) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/split', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemIds: this.splitItemIds }),
          });
          if (!r.ok) { const e = await r.json(); alert(e.error); return; }
          const data = await r.json();
          this.$refs.splitDlg.close();
          window.location.href = '/app/comandas/mesas/' + data.newComandaId;
        },
        async openMergeDlg() {
          this.mergeSourceId = null;
          const r = await fetch('/api/comandas/comandas?status=aberta');
          if (r.ok) this.otherComandas = (await r.json()).filter((c) => c.id !== this.comandaId);
          this.$refs.mergeDlg.showModal();
        },
        async confirmMerge() {
          if (!this.mergeSourceId) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/merge', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sourceComandaId: this.mergeSourceId }),
          });
          if (!r.ok) { const e = await r.json(); alert(e.error); return; }
          this.$refs.mergeDlg.close();
          await this.load();
        },
        openCloseDlg() {
          this.$refs.closeDlg.showModal();
        },
        confirmClose() {
          this.$refs.closeDlg.close();
          window.location.href = '/app/store/pdv?comandaId=' + this.comandaId;
        },
        async cancelComanda() {
          if (!await window.confirmDlg('Cancelar esta comanda? Os itens serao perdidos.')) return;
          const r = await fetch('/api/comandas/comandas/' + this.comandaId + '/cancel', { method: 'POST' });
          if (r.ok) window.location.href = '/app/comandas/mesas';
          else { const e = await r.json(); alert(e.error); }
        },
      };
    }
  </script>
</body>
</html>
