<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — Mesas</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/comandas/mesas' }) %>
  <main x-data="mesasPage(<%- JSON.stringify(user.permissions.has('comandas.tables.manage')) %>)" x-init="init()">
    <h1>Mesas</h1>
    <div class="toolbar">
      <% if (user.permissions.has('comandas.tables.manage')) { %>
      <button class="btn" @click="openNew()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Nova mesa
      </button>
      <% } %>
      <span class="error" x-text="error"></span>
    </div>

    <div class="tables-grid" x-ref="grid" x-show="tables.length">
      <template x-for="t in tables" :key="t.id">
        <div class="table-card"
             :data-id="t.id"
             :class="[t.status === 'livre' ? 'table-livre' : 'table-ocupada', canManage ? 'drag-enabled' : '', dragId === t.id ? 'dragging' : '', dropOverId === t.id ? 'drop-target' : '']"
             @pointerdown="onCardPointerDown($event, t)">
          <% if (user.permissions.has('comandas.tables.manage')) { %>
          <button type="button" class="icon-btn table-remove" x-show="t.status === 'livre'"
                  @pointerdown.stop @click.stop="removeTable(t)" title="Remover mesa">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
          <% } %>
          <button type="button" class="table-card-body" @click="openTable(t)"
                  :title="t.label + ' — ' + (t.status === 'livre' ? 'Livre' : 'Ocupada')">
            <div class="table-icon">
              <template x-if="t.status === 'livre'">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
              </template>
              <template x-if="t.status === 'ocupada'">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </template>
            </div>
            <div class="table-label" x-text="t.label"></div>
            <span class="badge" :class="t.status === 'livre' ? 'ok' : 'off'" x-text="t.status === 'livre' ? 'Livre' : 'Ocupada'"></span>
          </button>
        </div>
      </template>
    </div>

    <div x-show="!tables.length" x-cloak>
      <%- include('partials/empty-state', { message: 'Nenhuma mesa cadastrada ainda.' }) %>
    </div>

    <dialog x-ref="addTableDlg">
      <h1>Nova mesa</h1>
      <label>Nome ou número</label>
      <input type="text" x-ref="tableInput" x-model="newTableLabel" placeholder="Ex.: Mesa 5"
             @keydown.enter.prevent="createTable" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button type="button" class="btn secondary" @click="$refs.addTableDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button type="button" class="btn" @click="createTable()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Criar
        </button>
      </div>
    </dialog>
  </main>
  <style>
    .tables-grid {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem;
    }
    @media (max-width: 1200px) { .tables-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (max-width: 900px)  { .tables-grid { grid-template-columns: repeat(3, 1fr); } }
    .table-card {
      position: relative;
      background: var(--surface); border: 1.5px solid var(--border-light); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xs);
      transition: border-color var(--transition), box-shadow var(--transition), transform .15s ease;
    }
    .table-card.drag-enabled { cursor: grab; touch-action: none; }
    .table-card.drag-enabled:active { cursor: grabbing; }
    .table-card.dragging {
      position: fixed; top: 0; left: 0; z-index: 60; margin: 0;
      cursor: grabbing; pointer-events: none;
      box-shadow: 0 20px 40px rgba(0,0,0,.28);
      transition: box-shadow .15s ease;
    }
    .table-card.drop-target {
      outline: 2px dashed var(--primary); outline-offset: 3px;
      transition: outline-color .15s ease;
    }
    .table-card.table-livre:hover { border-color: var(--primary); box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 16%, transparent); }
    .table-card.table-ocupada:hover { border-color: var(--danger); box-shadow: 0 8px 24px color-mix(in srgb, var(--danger) 16%, transparent); }
    .table-card.table-ocupada { background: var(--danger-bg); }
    .table-card-body {
      width: 100%; background: none; border: 0; cursor: pointer; font: inherit; color: inherit;
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      padding: 1.4rem 1rem 1.1rem;
      transition: transform var(--transition);
    }
    .table-card-body:active { transform: scale(.97); }
    .table-icon {
      width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center;
      color: var(--primary);
    }
    .table-livre .table-icon { background: var(--primary-bg); color: var(--primary); }
    .table-ocupada .table-icon { background: color-mix(in srgb, var(--danger) 16%, transparent); color: var(--danger); }
    .table-label { font-size: 1.05rem; font-weight: 700; }
    .table-remove {
      position: absolute; top: .4rem; right: .4rem; z-index: 1;
      width: 30px; height: 30px;
      background: var(--surface); box-shadow: var(--shadow-xs);
      opacity: 0; transition: opacity var(--transition), background var(--transition), color var(--transition);
    }
    .table-card:hover .table-remove { opacity: 1; }
    .table-remove:hover { background: var(--danger-bg); color: var(--danger); }

    /* ─── Toque/mobile: sem hover, o botão de remover precisa ficar sempre visível ─── */
    @media (hover: none), (max-width: 820px) {
      .table-remove { opacity: 1; }
      .tables-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: .75rem; }
      .table-card-body { padding: 1.15rem .75rem .95rem; }
    }
  </style>
  <script>
    function mesasPage(canManage) {
      return {
        tables: [],
        newTableLabel: '',
        error: '', dlgError: '',
        pollTimer: null,
        canManage: !!canManage,
        dragId: null,
        dropOverId: null,
        async init() {
          await this.load();
          this.pollTimer = setInterval(() => this.load(), 10000);
        },
        async load() {
          if (this.dragId !== null) return;
          const r = await fetch('/api/comandas/tables/status');
          if (r.ok) this.tables = await r.json();
          else showToast((await r.json()).error ?? 'Erro ao carregar mesas.', 'error');
        },
        onCardPointerDown(e, t) {
          if (!this.canManage || e.pointerType === 'mouse' && e.button !== 0) return;
          const card = e.currentTarget;
          const startX = e.clientX, startY = e.clientY;
          const rect = card.getBoundingClientRect();
          let dragging = false;

          const activate = () => {
            dragging = true;
            this.dragId = t.id;
            card.style.width = rect.width + 'px';
            card.style.height = rect.height + 'px';
            card.style.left = rect.left + 'px';
            card.style.top = rect.top + 'px';
            try { card.setPointerCapture(e.pointerId); } catch {}
            card.addEventListener('click', suppressClick, { capture: true, once: true });
            if (navigator.vibrate) navigator.vibrate(12);
          };
          const suppressClick = (ev) => { ev.preventDefault(); ev.stopPropagation(); };

          const timer = setTimeout(activate, 260);

          const onMove = (ev) => {
            const dx = ev.clientX - startX, dy = ev.clientY - startY;
            if (!dragging) {
              if (Math.hypot(dx, dy) > 8) cleanup();
              return;
            }
            ev.preventDefault();
            card.style.transform = `translate(${dx}px, ${dy}px) scale(1.04)`;
            const under = document.elementFromPoint(ev.clientX, ev.clientY)?.closest('.table-card');
            this.dropOverId = under && under !== card ? Number(under.dataset.id) : null;
          };
          const onUp = () => {
            cleanup();
            if (dragging) this.finishDrag(t, card);
          };
          const cleanup = () => {
            clearTimeout(timer);
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup', onUp);
          };

          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup', onUp);
        },
        finishDrag(t, card) {
          card.removeAttribute('style');
          this.dragId = null;
          const overId = this.dropOverId;
          this.dropOverId = null;
          const fromIdx = this.tables.findIndex((x) => x.id === t.id);
          const toIdx = overId != null ? this.tables.findIndex((x) => x.id === overId) : -1;
          if (fromIdx === -1 || toIdx === -1 || fromIdx === toIdx) return;
          this.reorder(fromIdx, toIdx);
        },
        async reorder(fromIdx, toIdx) {
          const grid = this.$refs.grid;
          const before = new Map();
          grid.querySelectorAll('.table-card').forEach((el) => before.set(el.dataset.id, el.getBoundingClientRect()));

          const [moved] = this.tables.splice(fromIdx, 1);
          this.tables.splice(toIdx, 0, moved);
          await this.$nextTick();

          grid.querySelectorAll('.table-card').forEach((el) => {
            const prev = before.get(el.dataset.id);
            if (!prev) return;
            const next = el.getBoundingClientRect();
            const dx = prev.left - next.left, dy = prev.top - next.top;
            if (!dx && !dy) return;
            el.style.transition = 'none';
            el.style.transform = `translate(${dx}px, ${dy}px)`;
            requestAnimationFrame(() => {
              el.style.transition = 'transform .32s cubic-bezier(.2,.8,.2,1)';
              el.style.transform = '';
            });
          });

          const updates = this.tables.map((tb, i) => ({ id: tb.id, sortOrder: i }));
          const results = await Promise.allSettled(updates.map((u) => fetch('/api/comandas/tables/' + u.id, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sortOrder: u.sortOrder }),
          })));
          if (results.some((r) => r.status === 'rejected' || !r.value.ok)) {
            showToast('Erro ao salvar nova ordem.', 'error');
          }
        },
        async openTable(t) {
          this.error = '';
          if (t.status === 'ocupada') {
            const r = await fetch('/api/comandas/comandas?status=aberta');
            if (!r.ok) return;
            const list = await r.json();
            const c = list.find((c) => c.table_id === t.id);
            if (c) window.location.href = '/app/comandas/mesas/' + c.id;
            return;
          }
          const r = await fetch('/api/comandas/comandas', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tableId: t.id }),
          });
          if (r.ok) {
            const c = await r.json();
            window.location.href = '/app/comandas/mesas/' + c.id;
          } else {
            showToast((await r.json()).error ?? 'Erro ao abrir comanda.', 'error');
          }
        },
        openNew() {
          this.newTableLabel = ''; this.dlgError = '';
          this.$refs.addTableDlg.showModal();
          this.$nextTick(() => this.$refs.tableInput?.focus());
        },
        async createTable() {
          if (!this.newTableLabel.trim()) { this.dlgError = 'Informe um nome ou número.'; return; }
          const r = await fetch('/api/comandas/tables', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ label: this.newTableLabel.trim() }),
          });
          if (r.ok) { this.$refs.addTableDlg.close(); await this.load(); showToast('Mesa criada.', 'success'); }
          else { this.dlgError = (await r.json()).error ?? 'Erro ao criar mesa.'; showToast(this.dlgError, 'error'); }
        },
        async removeTable(t) {
          if (!await window.confirmDlg(`Remover a mesa "${t.label}"?`)) return;
          const r = await fetch('/api/comandas/tables/' + t.id, { method: 'DELETE' });
          if (r.ok) { await this.load(); showToast('Mesa removida.', 'success'); }
          else showToast((await r.json()).error ?? 'Erro ao remover mesa.', 'error');
        },
      };
    }
  </script>
</body>
</html>
