<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>DRE — <%= report.from %> a <%= report.to %></title>
  <style>
    * { margin: 0; box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 13px; color: #000; background: #fff; max-width: 800px; margin: 0 auto; padding: 16px; }
    h1 { font-size: 18px; margin-bottom: 2px; }
    h2 { font-size: 14px; margin: 16px 0 6px; border-bottom: 1px solid #999; padding-bottom: 2px; }
    .center { text-align: center; }
    .right { text-align: right; }
    .muted { color: #555; font-size: 11px; }
    hr { border: 0; border-top: 1px solid #999; margin: 10px 0; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }
    th, td { padding: 3px 4px; text-align: left; border-bottom: 1px solid #ddd; }
    th { font-size: 11px; text-transform: uppercase; color: #555; }
    .total-row td { font-weight: bold; border-top: 2px solid #333; border-bottom: none; }
    .final-row td { font-weight: bold; border-top: 2px solid #000; border-bottom: none; font-size: 14px; }
    @media print { .no-print { display: none; } }
    .no-print { text-align: center; margin-top: 16px; }
    .no-print button { padding: 8px 16px; font-size: 13px; cursor: pointer; }
  </style>
</head>
<body>
  <div class="center">
    <h1><%= company.name %></h1>
    <% if (company.document) { %><p class="muted"><%= company.document %></p><% } %>
    <% if (company.address) { %><p class="muted"><%= company.address %></p><% } %>
  </div>
  <hr />

  <% function brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }
     function pct(bps) { return (bps === 0 ? '—' : (bps > 0 ? '+' : '') + (bps / 100).toFixed(2).replace('.', ',') + '%'); }
     var lineLabels = { receita_bruta: 'Receita Bruta', deducoes: 'Deduções da Receita', cmv: 'CMV',
       despesas_operacionais: 'Despesas Operacionais', despesas_financeiras: 'Despesas Financeiras' };
     var afterLine = {
       deducoes: { label: '= Receita Líquida', realCents: report.totals.receitaLiquidaReal, adjustedCents: report.totals.receitaLiquidaAjustada, cls: 'total-row' },
       cmv: { label: '= Lucro Bruto', realCents: report.totals.lucroBrutoReal, adjustedCents: report.totals.lucroBrutoAjustada, cls: 'total-row' },
       despesas_operacionais: { label: '= Resultado Operacional', realCents: report.totals.resultadoOperacionalReal, adjustedCents: report.totals.resultadoOperacionalAjustada, cls: 'total-row' },
       despesas_financeiras: { label: '= Resultado Líquido do Período', realCents: report.totals.resultadoLiquidoReal, adjustedCents: report.totals.resultadoLiquidoAjustada, cls: 'final-row' },
     };
  %>

  <h1 style="margin-top:8px">DRE — Demonstrativo de Resultado</h1>
  <p class="muted">Período: <%= report.from %> a <%= report.to %></p>

  <table>
    <thead><tr><th>Categoria</th><th class="right">Real</th><th class="right">Ajuste</th><th class="right">Projetado</th></tr></thead>
    <tbody>
      <% ['receita_bruta', 'deducoes', 'cmv', 'despesas_operacionais', 'despesas_financeiras'].forEach(function (line) {
           var group = report.lines[line]; %>
        <tr><td colspan="4"><strong><%= lineLabels[line] %></strong></td></tr>
        <% group.categories.forEach(function (c) { %>
          <tr>
            <td><%= c.label %></td>
            <td class="right"><%= brl(c.realCents) %></td>
            <td class="right"><%= pct(c.adjustmentBps) %></td>
            <td class="right"><%= brl(c.adjustedCents) %></td>
          </tr>
        <% }) %>
        <tr class="total-row">
          <td>Total <%= lineLabels[line] %></td>
          <td class="right"><%= brl(group.realCents) %></td>
          <td></td>
          <td class="right"><%= brl(group.adjustedCents) %></td>
        </tr>
        <% if (afterLine[line]) { var f = afterLine[line]; %>
          <tr class="<%= f.cls %>">
            <td><%= f.label %></td>
            <td class="right"><%= brl(f.realCents) %></td>
            <td></td>
            <td class="right"><%= brl(f.adjustedCents) %></td>
          </tr>
        <% } %>
      <% }) %>
    </tbody>
  </table>
  <p class="muted">O CMV usa o custo atual do produto (sem histórico de custo por venda) — valor aproximado se o custo mudou após a venda.</p>

  <div class="no-print">
    <button onclick="window.print()">Imprimir</button>
    <button onclick="window.close()">Fechar</button>
  </div>
  <script>window.addEventListener('load', function () { setTimeout(function () { window.print(); }, 300); });</script>
</body>
</html>
