<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo — Vendas</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/store/vendas' }) %>
  <%
    var _sfStatusOpts = [
      { value: 'concluida', label: 'Concluida', color: '#16a34a' },
      { value: 'cancelada', label: 'Cancelada', color: '#6b7280' }
    ];
  %>
  <main x-data="salesPage()" x-init="load()" @apply-filter.window="filter=$event.detail; load()">
    <h1>Vendas</h1>
    <div class="toolbar">
      <%- include('partials/search-filter', { statusOptions: _sfStatusOpts, placeholder: 'Buscar por cliente' }) %>
      <% if (user.permissions.has('store.reports.view')) { %>
        <span class="muted">Vendas: <strong x-text="filterRows(rows, filter).length"></strong> ·
          total <strong x-text="brl(filterRows(rows, filter).reduce((s, r) => s + r.total_cents, 0))"></strong></span>
      <% } %>
      <span class="error" x-text="error"></span>
    </div>

    <% if (user.permissions.has('store.reports.view')) { %>
    <div class="form-grid" style="grid-template-columns:1fr 1fr;margin-bottom:1.2rem">
      <section>
        <h2 class="muted" style="font-size:.95rem;margin-bottom:.5rem">Por forma de pagamento (hoje)</h2>
        <table>
          <tbody>
            <template x-for="p in report.byPayment" :key="p.payment_method">
              <tr><td x-text="label(p.payment_method)"></td><td x-text="p.vendas"></td><td x-text="brl(p.total_cents)"></td></tr>
            </template>
            <tr x-show="!report.byPayment || !report.byPayment.length"><td class="muted" style="padding:.75rem 0">Nenhuma venda hoje ainda.</td></tr>
          </tbody>
        </table>
      </section>
      <section>
        <h2 class="muted" style="font-size:.95rem;margin-bottom:.5rem">Mais vendidos (hoje)</h2>
        <table>
          <tbody>
            <template x-for="t in report.topProducts" :key="t.product_name">
              <tr><td x-text="t.product_name"></td><td x-text="t.qty"></td><td x-text="brl(t.total_cents)"></td></tr>
            </template>
            <tr x-show="!report.topProducts || !report.topProducts.length"><td class="muted" style="padding:.75rem 0">Nenhuma venda hoje ainda.</td></tr>
          </tbody>
        </table>
      </section>
    </div>
    <% } %>

    <table>
      <thead><tr>
        <th @click="sortCycle('id')" class="sortable">#<span class="sort-arrow" x-text="sortArrow('id')"></span></th>
        <th @click="sortCycle('created_at')" class="sortable">Hora<span class="sort-arrow" x-text="sortArrow('created_at')"></span></th>
        <th @click="sortCycle('customer')" class="sortable">Cliente<span class="sort-arrow" x-text="sortArrow('customer')"></span></th>
        <th @click="sortCycle('payment_method')" class="sortable">Pagamento<span class="sort-arrow" x-text="sortArrow('payment_method')"></span></th>
        <th @click="sortCycle('total_cents')" class="sortable">Total<span class="sort-arrow" x-text="sortArrow('total_cents')"></span></th>
        <th @click="sortCycle('status')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
        <th @click="sortCycle('username')" class="sortable">Vendedor<span class="sort-arrow" x-text="sortArrow('username')"></span></th>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="s in pageRows" :key="s.id">
          <tr>
            <td x-text="s.id"></td>
            <td class="muted" x-text="fmtDateTime(s.created_at)"></td>
            <td class="muted" x-text="s.customer ?? '—'"></td>
            <td x-text="label(s.payment_method)"></td>
            <td x-text="brl(s.total_cents)"></td>
            <td><span class="badge" :class="s.status === 'concluida' ? 'ok' : 'off'" x-text="s.status"></span></td>
            <td class="muted" x-text="s.username"></td>
            <td class="text-right" @click.stop>
              <div class="dropdown">
                <button class="icon-btn" @click="openMenu = openMenu === s.id ? null : s.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === s.id" x-cloak @click.outside="openMenu = null">
                  <button @click="openMenu = null; window.open(`/app/store/vendas/${s.id}/cupom`, '_blank', 'width=380,height=600')">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                    Cupom
                  </button>
                  <% if (user.permissions.has('store.sales.cancel')) { %>
                  <button class="danger" x-show="s.status === 'concluida'" @click="openMenu = null; cancel(s)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    Cancelar
                  </button>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="8"><%- include('partials/empty-state', { message: 'Nenhuma venda registrada ainda.' }) %></td></tr>
      </tbody>
    </table>
    <%- include('partials/pager') %>
  </main>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function salesPage() {
      return {
        ...tableToolkit(),
        rows: [], report: {}, day: todayLocal(), error: '', filter: {},
        labels: { dinheiro: 'Dinheiro', cartao_debito: 'Débito', cartao_credito: 'Crédito', pix: 'PIX', prazo: 'A prazo' },
        sortGetters: {
          id: (s) => s.id, created_at: (s) => s.created_at ?? '', customer: (s) => s.customer ?? '',
          payment_method: (s) => s.payment_method ?? '', total_cents: (s) => s.total_cents, status: (s) => s.status ?? '',
          username: (s) => s.username ?? '',
        },
        get displayRows() { return this.sortedRows(filterRows(this.rows, this.filter), this.sortGetters); },
        get pageTotal() { return this.displayRows.length; },
        get pageRows() { return this.pagedRows(this.displayRows); },
        label(k) { return this.labels[k] ?? k; },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        async load() {
          const r = await fetch('/api/store/sales');
          if (r.ok) this.rows = await r.json();
          const rep = await fetch('/api/store/reports/daily?day=' + this.day);
          if (rep.ok) this.report = await rep.json();
        },
        async cancel(s) {
          if (!await window.confirmDlg(`Cancelar a venda #${s.id} (${this.brl(s.total_cents)})? O estoque será devolvido` + (s.payment_method === 'dinheiro' ? ' e o dinheiro sairá da gaveta.' : '.'))) return;
          const r = await fetch(`/api/store/sales/${s.id}/cancel`, { method: 'POST' });
          if (r.ok) { this.load(); showToast('Venda cancelada.', 'success'); } else showToast((await r.json()).error, 'error');
        },
      };
    }
  </script>
</body>
</html>
