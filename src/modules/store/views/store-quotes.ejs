<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Kivo — Orçamentos</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <script src="/js/datetime.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/store/orcamentos' }) %>
  <%
    var _qfStatusOpts = [
      { value: 'aberto', label: 'Abertos' },
      { value: 'convertido', label: 'Convertidos' },
      { value: 'cancelado', label: 'Cancelados' }
    ];
  %>
  <main x-data="quotesPage()" x-init="load()" @apply-filter.window="filter=$event.detail; load()">
    <h1>Orcamentos</h1>
    <div class="toolbar">
      <% if (user.permissions.has('store.quotes.create')) { %>
        <button class="btn" @click="openNew()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Novo orcamento
        </button>
      <% } %>
      <%- include('partials/search-filter', { statusOptions: _qfStatusOpts, placeholder: 'Buscar por cliente' }) %>
      <span class="error" x-text="error"></span>
    </div>
    <table>
      <thead><tr>
        <th @click="sortCycle('id')" class="sortable">#<span class="sort-arrow" x-text="sortArrow('id')"></span></th>
        <th @click="sortCycle('customer')" class="sortable">Cliente<span class="sort-arrow" x-text="sortArrow('customer')"></span></th>
        <th @click="sortCycle('total_cents')" class="sortable">Total<span class="sort-arrow" x-text="sortArrow('total_cents')"></span></th>
        <th @click="sortCycle('valid_until')" class="sortable">Válido até<span class="sort-arrow" x-text="sortArrow('valid_until')"></span></th>
        <th @click="sortCycle('status')" class="sortable">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
        <th @click="sortCycle('username')" class="sortable">Vendedor<span class="sort-arrow" x-text="sortArrow('username')"></span></th>
        <th></th>
      </tr></thead>
      <tbody>
        <template x-for="q in displayRows" :key="q.id">
          <tr>
            <td x-text="q.id"></td>
            <td x-text="q.customer ?? q.customer_name ?? '—'"></td>
            <td x-text="brl(q.total_cents)"></td>
            <td class="muted" x-text="q.valid_until ?? '—'"></td>
            <td><span class="badge" :class="q.status === 'aberto' ? 'off' : 'ok'" x-text="q.status"></span></td>
            <td class="muted" x-text="q.username"></td>
            <td class="text-right" @click.stop>
              <div class="dropdown">
                <button class="icon-btn" @click="openMenu = openMenu === q.id ? null : q.id" title="Mais ações">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </button>
                <div class="dropdown-menu" x-show="openMenu === q.id" x-cloak @click.outside="openMenu = null">
                  <button @click="openMenu = null; window.open(`/app/store/orcamentos/${q.id}/imprimir`, '_blank', 'width=800,height=900')">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                    Imprimir
                  </button>
                  <% if (user.permissions.has('store.sales.create')) { %>
                  <button x-show="q.status === 'aberto'" @click="openMenu = null; openConvert(q)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.85.99 6.57 2.61"/><path d="M21 3v6h-6"/></svg>
                    Converter em venda
                  </button>
                  <% } %>
                  <% if (user.permissions.has('store.quotes.edit')) { %>
                  <button x-show="q.status === 'aberto'" @click="openMenu = null; openEdit(q)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                    Editar
                  </button>
                  <% } %>
                  <% if (user.permissions.has('store.quotes.create')) { %>
                  <button class="danger" x-show="q.status === 'aberto'" @click="openMenu = null; cancel(q)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    Cancelar
                  </button>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
        </template>
        <tr x-show="!displayRows.length"><td colspan="7"><%- include('partials/empty-state', { message: 'Nenhum orçamento registrado ainda.' }) %></td></tr>
      </tbody>
    </table>

    <dialog x-ref="dlg" style="width:600px">
      <h1 x-text="form.id ? 'Editar orçamento #' + form.id : 'Novo orçamento'"></h1>
      <label>Cliente (cadastrado)</label>
      <select x-model.number="form.customerId">
        <option value="">— sem cadastro —</option>
        <template x-for="c in customers" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
      </select>
      <label>Ou nome avulso</label><input type="text" x-model="form.customerName" placeholder="Cliente de balcão" />

      <template x-if="!form.id">
      <label>Adicionar item</label>
      <div class="form-grid" style="grid-template-columns:1fr 90px 70px">
        <select x-model.number="item.productId">
          <option value="">Produto…</option>
          <template x-for="p in products" :key="p.id"><option :value="p.id" x-text="`${p.name} — ${brl(p.price_cents)}`"></option></template>
        </select>
        <input type="number" step="any" min="0.001" placeholder="Qtd" x-model.number="item.qty" />
        <button class="btn secondary" @click="addItem()">+</button>
      </div>
      <div class="scroll-box-sm" style="margin-top:.8rem">
        <template x-for="(i, idx) in form.items" :key="idx">
          <div class="form-row">
            <span x-text="`${i.name} — ${i.qty} × ${brl(i.price_cents)}`"></span>
            <span><strong x-text="brl(Math.round(i.qty * i.price_cents))"></strong>
              <button class="btn small" style="margin-left:.5rem" @click="form.items.splice(idx, 1)">×</button></span>
          </div>
        </template>
      </div>
      <p class="text-right" style="margin-top:.5rem">Total: <strong x-text="brl(total())"></strong></p>
      </template>
      <% if (user.permissions.has('store.sales.discount')) { %>
        <label>Desconto (R$)</label><input type="text" x-model="form.discount" placeholder="0,00" @input="form.discount = maskMoney(form.discount)" />
      <% } %>
      <label>Válido até</label><input type="date" x-model="form.validUntil" />
      <label>Observações</label><input type="text" x-model="form.notes" />
      <div class="error" x-text="dlgError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.dlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="save()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Salvar orçamento
        </button>
      </div>
    </dialog>

    <dialog x-ref="conv">
      <h1>Converter orçamento #<span x-text="converting.id"></span></h1>
      <p class="muted">Total: <strong x-text="brl(converting.total_cents)"></strong> — preços cotados serão honrados.</p>
      <label>Forma de pagamento</label>
      <select x-model="conv.method">
        <option value="dinheiro">Dinheiro</option>
        <option value="cartao_debito">Cartão de débito</option>
        <option value="cartao_credito">Cartão de crédito</option>
        <option value="pix">PIX</option>
        <option value="prazo">A prazo (fiado)</option>
      </select>
      <template x-if="conv.method === 'dinheiro'">
        <div><label>Valor recebido (R$)</label><input type="text" x-model="conv.received" placeholder="0,00" @input="conv.received = maskMoney(conv.received)" /></div>
      </template>
      <template x-if="conv.method === 'prazo'">
        <div>
          <label>Cliente</label>
          <select x-model.number="conv.customerId">
            <option value="">Selecione…</option>
            <template x-for="c in customers" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
          </select>
          <label>Vencimento</label><input type="date" x-model="conv.dueDate" />
        </div>
      </template>
      <div class="error" x-text="convError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.conv.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Voltar
        </button>
        <button class="btn" @click="convert()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Confirmar venda
        </button>
      </div>
    </dialog>
  </main>
  <script src="/js/masks.js"></script>
  <script src="/js/table-toolkit.js"></script>
  <script>
    function quotesPage() {
      return {
        ...tableToolkit(),
        rows: [], customers: [], products: [], form: { items: [] }, item: {}, converting: {},
        conv: { method: 'dinheiro', received: '', customerId: '', dueDate: '' },
        status: 'aberto', error: '', dlgError: '', convError: '', filter: {},
        sortGetters: {
          id: (q) => q.id, customer: (q) => q.customer ?? q.customer_name ?? '', total_cents: (q) => q.total_cents,
          valid_until: (q) => q.valid_until ?? '', status: (q) => q.status ?? '', username: (q) => q.username ?? '',
        },
        get displayRows() { return this.sortedRows(filterRows(this.rows, this.filter), this.sortGetters); },
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return isNaN(n) ? 0 : Math.round(n * 100); },
        async load() {
          const r = await fetch('/api/store/quotes');
          if (r.ok) this.rows = await r.json(); else showToast((await r.json()).error, 'error');
        },
        async refs() {
          if (!this.customers.length) {
            const c = await fetch('/api/commercial/customers'); if (c.ok) this.customers = await c.json();
            const p = await fetch('/api/commercial/products'); if (p.ok) this.products = await p.json();
          }
        },
        async openNew() {
          this.form = { items: [], customerId: '', customerName: '', discount: '', validUntil: '', notes: '' };
          this.item = {}; this.dlgError = '';
          await this.refs();
          this.$refs.dlg.showModal();
        },
        async openEdit(q) {
          this.form = { id: q.id, customerId: q.customer_id ?? '', customerName: q.customer_name ?? '',
            discount: q.discount_cents ? (q.discount_cents / 100).toFixed(2).replace('.', ',') : '',
            validUntil: q.valid_until ?? '', notes: q.notes ?? '', items: [] };
          this.dlgError = '';
          await this.refs();
          this.$refs.dlg.showModal();
        },
        addItem() {
          const p = this.products.find((x) => x.id === this.item.productId);
          if (!p || !(this.item.qty > 0)) { this.dlgError = 'Escolha produto e quantidade.'; return; }
          this.dlgError = '';
          this.form.items.push({ productId: p.id, name: p.name, qty: this.item.qty, price_cents: p.price_cents });
          this.item = {};
        },
        total() { return Math.max(0, this.form.items.reduce((a, i) => a + Math.round(i.qty * i.price_cents), 0) - this.cents(this.form.discount)); },
        async save() {
          const body = {
            customerId: this.form.customerId || undefined,
            customerName: this.form.customerName || undefined,
            discountCents: this.cents(this.form.discount) || undefined,
            validUntil: this.form.validUntil || undefined,
            notes: this.form.notes || undefined,
          };
          if (this.form.id) {
            const r = await fetch(`/api/store/quotes/${this.form.id}`, {
              method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
            });
            if (r.ok) { this.$refs.dlg.close(); this.load(); } else { this.dlgError = (await r.json()).error; showToast(this.dlgError, 'error'); }
            return;
          }
          const r = await fetch('/api/store/quotes', { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...body, items: this.form.items.map((i) => ({ productId: i.productId, qty: i.qty })) }) });
          if (r.ok) { this.$refs.dlg.close(); this.load(); } else { this.dlgError = (await r.json()).error; showToast(this.dlgError, 'error'); }
        },
        async openConvert(q) {
          this.converting = q; this.convError = '';
          this.conv = { method: 'dinheiro', received: '', customerId: '', dueDate: '' };
          await this.refs();
          this.$refs.conv.showModal();
        },
        async convert() {
          const r = await fetch(`/api/store/quotes/${this.converting.id}/convert`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              paymentMethod: this.conv.method,
              paidCents: this.conv.method === 'dinheiro' ? this.cents(this.conv.received) || undefined : undefined,
              customerId: this.conv.method === 'prazo' ? this.conv.customerId || undefined : undefined,
              dueDate: this.conv.method === 'prazo' ? this.conv.dueDate || undefined : undefined,
            }) });
          if (r.ok) {
            const d = await r.json();
            this.$refs.conv.close();
            alert(`Venda #${d.id} gerada — ${this.brl(d.totalCents)}` + (d.changeCents ? `\nTroco: ${this.brl(d.changeCents)}` : ''));
            this.load();
          } else this.convError = (await r.json()).error;
        },
        async cancel(q) {
          if (!await window.confirmDlg(`Cancelar o orçamento #${q.id}?`)) return;
          const r = await fetch(`/api/store/quotes/${q.id}/cancel`, { method: 'POST' });
          if (r.ok) { this.load(); showToast('Orçamento cancelado.', 'success'); } else showToast((await r.json()).error, 'error');
        },
      };
    }
  </script>
</body>
</html>
