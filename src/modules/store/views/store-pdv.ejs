<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <%- include('partials/theme-init') %>
  <title>Katsu — PDV</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <link rel="stylesheet" href="/css/pdv.css" />
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/store/pdv' }) %>
  <main x-data="pdvPage()" x-init="init()">
    <div class="pdv">

      <!-- ─── COLUNA ESQUERDA (carrinho) ─── -->
      <div class="pdv-left">
        <div class="sale-tabs-bar">
          <div class="sale-tabs">
            <template x-for="(s, idx) in slots" :key="idx">
              <div class="sale-tab" :class="{ active: idx === activeSlot }" @click="switchSlot(idx)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                <span class="sale-tab-info">
                  <span class="sale-tab-name" x-text="'Venda ' + String(idx + 1).padStart(2, '0')"></span>
                  <span class="sale-tab-count" x-text="s.cart.length + (s.cart.length === 1 ? ' item' : ' itens')"></span>
                </span>
                <button type="button" class="close-tab" x-show="slots.length > 1" @click.stop="closeSlot(idx)" title="Fechar esta venda">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
            </template>
          </div>
          <button type="button" class="sale-tab-add-btn" @click="addSlot()" title="Nova venda simultânea" x-show="slots.length < 4">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nova venda
          </button>
        </div>

        <div class="pdv-comanda-banner" x-show="slots[activeSlot].comandaId" x-cloak style="display:flex;align-items:center;gap:.5rem;padding:.6rem .9rem;margin-bottom:.75rem;border-radius:var(--radius);background:var(--primary-light,#eafaf0);border:1.5px solid var(--primary)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span x-text="'Fechando Comanda #' + slots[activeSlot].comandaId + (slots[activeSlot].tableLabel ? (' — Mesa ' + slots[activeSlot].tableLabel) : '')" style="flex:1;font-weight:600"></span>
          <a href="/app/comandas/mesas" class="btn secondary small">Cancelar</a>
        </div>

        <div class="pdv-search" x-show="!slots[activeSlot].comandaId">
          <div class="pdv-search-box">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" x-ref="search" x-model="q"
                   @input.debounce.250ms="search()"
                   @keydown.enter.prevent="quickAdd()"
                   @keydown.down.prevent="highlightNext()"
                   @keydown.up.prevent="highlightPrev()"
                   @keydown.escape="results = []"
                   placeholder="Código de barras, SKU ou nome do produto…" autofocus />
            <button type="button" class="pdv-search-scan-btn" @click="openBrowse()" title="Consultar todos os produtos">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="5" width="18" height="14" rx="2"/><line x1="7" y1="5" x2="7" y2="19"/><line x1="11" y1="5" x2="11" y2="19"/><line x1="16" y1="5" x2="16" y2="19"/>
              </svg>
            </button>
          </div>

          <div class="pdv-results" x-show="results.length" x-cloak>
            <template x-for="(p, idx) in results" :key="p.id">
              <div class="pdv-result" :class="{ 'highlight': idx === highlightIdx }"
                   @click="add(p)" @mouseenter="highlightIdx = idx">
                <span class="pdv-result-thumb">
                  <img x-show="p.image_url" :src="p.image_url" alt="" />
                  <template x-if="!p.image_url"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg></template>
                </span>
                <span class="name" x-text="p.name"></span>
                <span class="price" x-text="brl(p.price_cents)"></span>
                <span class="stock" :class="{ low: p.track_stock && p.stock_qty <= 3 && p.stock_qty >= 0, negative: p.track_stock && p.stock_qty < 0 }"
                      x-show="p.track_stock" x-text="'Est: ' + p.stock_qty"></span>
              </div>
            </template>
          </div>
          <p class="pdv-empty" x-show="q && !results.length && !searching" x-cloak>Nenhum produto encontrado.</p>
        </div>

        <div class="cart-header">
          <h2>Carrinho <span class="count" x-text="'(' + cart.length + ')'"></span></h2>
          <select x-model.number="customerId" @change="repriceCart(); loadCustomerBalances()" class="select">
            <option value="">Cliente (preço normal)</option>
            <template x-for="c in customers" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
          </select>
        </div>

        <div class="cart-items">
          <template x-for="(i, idx) in cart" :key="idx">
            <div class="cart-line" :class="{ 'cart-line-complement': i.lineGroupUuid && idx > 0 && cart[idx - 1]?.lineGroupUuid === i.lineGroupUuid }">
              <div class="cart-line-thumb">
                <img x-show="i.image_url" :src="i.image_url" alt="" />
                <template x-if="!i.image_url">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
                </template>
              </div>
              <div>
                <div class="prod-name" x-text="i.name"></div>
                <div class="prod-unit" x-text="(i.sku ? ('SKU: ' + i.sku + ' · ') : '') + brl(i.price_cents) + ' un.'"></div>
                <div class="prod-notes" x-show="i.notes" x-text="i.notes"></div>
              </div>
              <div class="qty-wrap" x-show="!slots[activeSlot].comandaId">
                <button @click="qtyMinus(idx)" :disabled="i.qty <= 0.001">−</button>
                <input type="number" step="any" min="0.001" x-model.number="i.qty"
                       @focus="$event.target.select()" @change="repriceCart()" />
                <button @click="qtyPlus(idx)">+</button>
              </div>
              <span class="qty-wrap" x-show="slots[activeSlot].comandaId" x-text="i.qty"></span>
              <span class="prod-total" x-text="brl(Math.round(i.price_cents * i.qty))"></span>
              <button class="remove-btn" @click="removeItem(idx)" title="Remover" x-show="!slots[activeSlot].comandaId">×</button>
            </div>
          </template>

          <div class="cart-empty" x-show="!cart.length">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <p>Carrinho vazio — busque ou bipe um produto para começar.</p>
          </div>
        </div>

        <div class="cart-footer-note" x-show="cart.length" x-cloak>
          <span class="cart-added-note">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span x-text="cart.length + (cart.length === 1 ? ' item adicionado' : ' itens adicionados')"></span>
          </span>
          <button type="button" class="cart-clear-link" @click="clearCart()">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            Limpar carrinho
          </button>
        </div>
      </div>

      <!-- ─── COLUNA DA DIREITA (resumo) ─── -->
      <div class="pdv-right">
        <div class="pdv-card">
          <h2>Resumo da venda</h2>

          <div class="pdv-totals">
            <div class="pdv-total-row">
              <span class="label">Subtotal</span>
              <span class="value" x-text="brl(subtotal())"></span>
            </div>
            <div class="pdv-total-row discount" x-show="discountCents > 0">
              <span class="label">Desconto</span>
              <span class="value" x-text="'−' + brl(discountCents)"></span>
            </div>
            <div class="pdv-total-row surcharge" x-show="surchargeCents > 0">
              <span class="label">Acréscimo</span>
              <span class="value" x-text="'+' + brl(surchargeCents)"></span>
            </div>
            <div class="pdv-total-row final">
              <span class="label">Total</span>
              <span class="value" x-text="brl(total())"></span>
            </div>
          </div>

          <div class="pdv-actions">
            <button type="button" class="pdv-action" style="--action-color:#3DA5F4" @click="printLast()"
                    :disabled="!lastSaleId" title="Imprimir última venda (F11)">
              <span class="pdv-action-icon"><svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg></span>
              <span class="shortcut">F11</span>
            </button>
            <button type="button" class="pdv-action" style="--action-color:#F2542D" @click="clearCart()" title="Limpar carrinho (F9)">
              <span class="pdv-action-icon"><svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></span>
              <span class="shortcut">F9</span>
            </button>
            <% if (user.permissions.has('store.sales.discount')) { %>
            <button type="button" class="pdv-action" style="--action-color:#F5C344" @click="openValue('acrescimo')" title="Acréscimo (F7)">
              <span class="pdv-action-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
              <span class="shortcut">F7</span>
            </button>
            <button type="button" class="pdv-action" style="--action-color:#34D399" @click="openValue('desconto')" title="Desconto (F4)">
              <span class="pdv-action-icon"><svg viewBox="0 0 24 24"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg></span>
              <span class="shortcut">F4</span>
            </button>
            <% } %>
          </div>

          <div class="pdv-summary-pill" x-show="cart.length" x-cloak>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span x-text="cart.length + (cart.length === 1 ? ' item' : ' itens')"></span>
            <span class="sep">·</span>
            <span>Subtotal itens: <strong x-text="brl(subtotal())"></strong></span>
          </div>

          <div class="pdv-error" x-text="error"></div>

          <button class="btn-finalize" :disabled="!cart.length" @click="openPay()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Finalizar venda
            <span class="sub">F2</span>
          </button>
        </div>
      </div>
    </div>

    <div class="pdv-footer-bar">
      <div class="pdv-footer-shortcuts">
        <span><kbd>F2</kbd>Finalizar venda</span>
        <% if (user.permissions.has('store.sales.discount')) { %>
        <span><kbd>F4</kbd>Desconto</span>
        <span><kbd>F7</kbd>Acréscimo</span>
        <% } %>
        <span><kbd>F9</kbd>Limpar</span>
        <span><kbd>F11</kbd>Imprimir</span>
      </div>
      <div class="pdv-footer-status">
        <span class="pdv-status-dot" :class="{ online: cloudOnline }"></span>
        <span x-text="cloudOnline ? 'PDV Online' : 'PDV Offline'"></span>
        <span class="pdv-footer-sep">|</span>
        <span>Versão <%= appVersion %></span>
      </div>
    </div>

    <!-- ─── MODAL: Consultar produtos (sem adicionar ao carrinho) ─── -->
    <dialog x-ref="browse" style="width:min(1100px, 94vw)">
      <h1>Consultar produtos</h1>
      <input type="text" x-ref="browseInput" x-model="browseQ" @input.debounce.250ms="searchBrowse()"
             placeholder="Buscar por nome, código de barras ou SKU…" />

      <div class="pdv-browse-cats" x-show="browseCategories.length">
        <button type="button" class="pdv-cat-chip" :class="{ active: !browseCategoryId }" @click="browseCategoryId = ''">Todas</button>
        <template x-for="c in browseCategories" :key="c.id">
          <button type="button" class="pdv-cat-chip" :class="{ active: browseCategoryId === c.id }" @click="browseCategoryId = browseCategoryId === c.id ? '' : c.id" x-text="c.name"></button>
        </template>
      </div>

          <div class="pdv-browse-list" style="margin-top:.75rem;border:1.5px solid var(--border-light);border-radius:var(--radius)">
            <template x-for="p in browseFiltered()" :key="p.id">
              <div class="pdv-result" @click="add(p).then(() => $refs.browse.close())">
            <span class="pdv-result-thumb">
              <img x-show="p.image_url" :src="p.image_url" alt="" />
              <template x-if="!p.image_url"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg></template>
            </span>
            <span class="name" x-text="p.name"></span>
            <span class="price" x-text="brl(p.price_cents)"></span>
            <span class="stock" :class="{ low: p.track_stock && p.stock_qty <= 3 && p.stock_qty >= 0, negative: p.track_stock && p.stock_qty < 0 }"
                  x-show="p.track_stock" x-text="'Est: ' + p.stock_qty"></span>
          </div>
        </template>
        <p class="pdv-empty" x-show="!browseFiltered().length">Nenhum produto encontrado.</p>
      </div>
      <p class="muted text-xs" style="margin-top:.5rem">Clique num item para adicioná-lo ao carrinho, ou só consulte o preço/estoque aqui.</p>
      <div class="actions">
        <button class="btn secondary" @click="$refs.browse.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Fechar (Esc)
        </button>
      </div>
    </dialog>

    <!-- ─── MODAL: Desconto / Acréscimo ─── -->
    <dialog x-ref="value">
      <h1 x-text="valueDlg.kind === 'desconto' ? 'Desconto (F4)' : 'Acréscimo (F7)'"></h1>
      <div class="flex-row" style="margin-bottom:.6rem">
        <button type="button" class="btn secondary" :class="{ active: valueDlg.mode === 'valor' }" @click="setValueMode('valor')" style="flex:1">R$</button>
        <button type="button" class="btn secondary" :class="{ active: valueDlg.mode === 'percentual' }" @click="setValueMode('percentual')" style="flex:1">%</button>
      </div>
      <label x-text="valueDlg.mode === 'valor' ? 'Valor em R$' : 'Percentual (%)'"></label>
      <input type="text" x-ref="valueInput" x-model="valueDlg.amount"
             :placeholder="valueDlg.mode === 'valor' ? '0,00' : '0'"
             @input="valueDlg.amount = valueDlg.mode === 'valor' ? maskMoney(valueDlg.amount) : valueDlg.amount.replace(/[^0-9,]/g, '')"
             @keydown.enter.prevent="saveValue()" @keydown.escape.prevent="$refs.value.close()" />
      <p class="muted text-xs" x-show="valueDlg.mode === 'percentual' && valueDlg.amount" x-text="'≈ ' + brl(percentToCents(valueDlg.amount))"></p>
      <div class="error" x-text="valueDlg.error"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.value.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar (Esc)
        </button>
        <button class="btn" @click="saveValue()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Aplicar (Enter)
        </button>
      </div>
    </dialog>

    <!-- ─── MODAL: Limpar carrinho (F9) ─── -->
    <dialog x-ref="clearDlg">
      <div class="dialog-body-center">
        <div class="dialog-icon dialog-icon-danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
        </div>
        <h2 class="dialog-heading-md">Limpar carrinho?</h2>
        <p class="dialog-muted">
          Todos os itens, descontos e acréscimos serão removidos.
        </p>
        <div class="actions actions-center">
          <button class="btn secondary" @click="$refs.clearDlg.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            Não (Esc)
          </button>
          <button class="btn" @click="doClear()" x-ref="clearConfirm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Sim (Enter)
          </button>
        </div>
      </div>
    </dialog>

    <!-- ─── MODAL: Confirmação por PIN (remover item do carrinho) ─── -->
    <dialog x-ref="pinDlg">
      <h1>PIN de administrador</h1>
      <p class="muted" style="margin-top:-.3rem">Digite o PIN para confirmar a remoção do item.</p>
      <input type="password" inputmode="numeric" maxlength="6" x-model="pinInput" x-ref="pinInput"
             @keydown.enter.prevent="confirmPinRemove()" placeholder="PIN" />
      <div class="error" x-text="pinError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.pinDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="confirmPinRemove()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Confirmar
        </button>
      </div>
    </dialog>

    <!-- ─── MODAL: Pagamento ─── -->
    <dialog x-ref="pay" class="pay-modal">
      <div class="pay-left">
        <h1>Pagamento</h1>
        <div class="subtitle">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span x-text="cart.length + (cart.length === 1 ? ' item' : ' itens')"></span>
        </div>

        <span class="pay-label">Valor do pagamento</span>
        <div class="pay-value-box">
          <span class="prefix">R$</span>
          <input type="text" x-model="pay.amount" placeholder="0,00"
                 @input="pay.amount = maskMoney(pay.amount)"
                 @keydown.enter.prevent="remaining() === 0 ? finish() : addPayment()" />
        </div>

        <span class="pay-label">Forma de pagamento</span>
        <div class="pay-method-row">
          <select x-model.number="pay.methodId">
            <template x-for="m in methods" :key="m.id">
              <option :value="m.id" x-text="m.name + (m.fee_bps ? ` (taxa ${(m.fee_bps/100).toFixed(2).replace('.', ',')}%)` : '')"></option>
            </template>
          </select>
          <button class="btn secondary" @click="addPayment()">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:.3rem;vertical-align:-2px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Adicionar
          </button>
        </div>

        <div class="pay-quick-methods">
          <template x-for="(m, idx) in visibleQuickMethods()" :key="'q' + m.id">
            <button type="button" class="pay-quick-method" :class="{ selected: pay.methodId === m.id }" @click="selectQuickMethod(m)" x-html="methodIcon(m.type) + '<span>' + m.name + '</span>' + (idx < 9 ? '<span class=shortcut>F' + (idx+1) + '</span>' : '')"></button>
          </template>
        </div>

        <button type="button" class="btn secondary small" style="margin-bottom:.75rem" x-show="!showSplit" @click="showSplit = true">
          Dividir conta
        </button>
        <div class="flex-row" style="align-items:center;margin-bottom:.75rem" x-show="showSplit" x-cloak>
          <span class="muted text-xs">Dividir por</span>
          <input type="number" min="2" max="20" x-model.number="pay.split" style="width:55px;padding:.3rem .4rem" />
          <button class="btn secondary small" @click="splitEqual()">pessoas</button>
          <span class="muted text-xs" x-show="pay.split >= 2" x-text="'≈ ' + brl(Math.ceil(remaining() > 0 ? remaining() / (pay.split || 1) : total() / (pay.split || 1))) + '/pessoa'"></span>
        </div>

        <template x-if="needsCashReceived()">
          <div>
            <button type="button" class="btn secondary small" style="margin-bottom:.6rem" x-show="!showCashReceived" @click="showCashReceived = true">
              Cliente pagou com nota maior (calcular troco)
            </button>
            <div x-show="showCashReceived" x-cloak>
              <span class="pay-label">Recebido em dinheiro (R$)</span>
              <input type="text" x-model="pay.received" placeholder="0,00" style="margin-bottom:.6rem" @input="pay.received = maskMoney(pay.received); calcChange()" />
              <p class="muted text-sm" style="margin:-.3rem 0 .6rem">Troco: <strong x-text="brl(pay.changeCents)"></strong></p>
            </div>
          </div>
        </template>
        <button class="btn secondary" style="width:100%;margin-top:.5rem" @click="$refs.pay.close()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:.3rem;vertical-align:-2px"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>Voltar
        </button>
      </div>

      <div class="pay-right">
        <div class="pay-summary-card">
          <div class="title">Resumo do recebimento</div>
          <div class="pay-total-row"><span>Total da venda</span><strong x-text="brl(total())"></strong></div>

          <div class="pay-items-list">
            <template x-for="(p, idx) in pay.list" :key="idx">
              <div class="pay-item-card">
                <span x-html="methodIcon(methodType(p.methodId))"></span>
                <div class="info">
                  <div class="name" x-text="methodName(p.methodId)"></div>
                  <div class="amount" x-text="brl(p.amountCents)"></div>
                </div>
                <button @click="pay.list.splice(idx, 1)" title="Remover">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </template>
            <p class="muted" style="font-size:.82rem;text-align:center" x-show="!pay.list.length">Nenhum pagamento adicionado ainda.</p>
          </div>

          <hr class="hr-sep" />
          <div class="pay-recap-row"><span>Pago</span><span x-text="brl(paidSum())"></span></div>
          <div class="pay-recap-row remaining" :style="remaining() > 0 ? 'color:var(--danger)' : 'color:var(--primary)'">
            <span x-text="remaining() >= 0 ? 'Restante' : 'Excedente'"></span>
            <span x-text="brl(Math.abs(remaining()))"></span>
          </div>

          <div class="pay-ready-banner" x-show="remaining() === 0">Venda pronta para finalizar</div>
          <div class="pay-pending-banner" x-show="remaining() !== 0" x-text="remaining() > 0 ? 'Falta ' + brl(remaining()) : 'Excedente de ' + brl(Math.abs(remaining()))"></div>

          <div class="error" x-text="payError"<% if (user.permissions.has('finance.cash.open')) { %> x-show="!payError.includes('Abra o caixa')"<% } %>></div>

          <button class="pay-confirm-btn" :disabled="remaining() !== 0 || saving" @click="finish()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span x-text="saving ? 'Registrando…' : 'Confirmar venda'"></span>
          </button>
          <p class="pay-confirm-hint">Pressione <strong>ENTER</strong> para confirmar</p>
        </div>
      </div>
    </dialog>

    <!-- ─── MODAL: Venda a prazo (parcelamento) ─── -->
    <dialog x-ref="prazoDlg" class="dialog-fixed">
      <h1>Venda a prazo</h1>
      <div class="dialog-body">
        <label>Cliente</label>
        <select x-model.number="prazoForm.customerId">
          <option value="">Selecione…</option>
          <template x-for="c in customers" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
        </select>
        <label class="label-checkbox-sm" style="margin-top:.5rem">
          <input type="radio" value="avista" x-model="prazoForm.mode" /> À vista (1 vencimento)
        </label>
        <label class="label-checkbox-sm">
          <input type="radio" value="parcelado" x-model="prazoForm.mode" /> Parcelado
        </label>
        <template x-if="prazoForm.mode === 'parcelado'">
          <div>
            <label>Número de parcelas (2 a 12)</label>
            <input type="number" min="2" max="12" x-model.number="prazoForm.installments" class="input-narrow-sm" />
          </div>
