        <label>Primeiro vencimento</label>
        <input type="date" x-model="prazoForm.firstDueDate" />
        <table style="margin-top:.75rem">
          <thead><tr><th>Parcela</th><th>Vencimento</th>            <th class="text-right">Valor</th></tr></thead>
