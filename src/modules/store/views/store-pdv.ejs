<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Katsu — PDV</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.png" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/vendor/alpine.min.js"></script>
  <style>
    .pdv { display: grid; grid-template-columns: 68fr 32fr; gap: 1.25rem; align-items: start; min-height: calc(100vh - var(--header-height) - 48px); }

    /* ─── Coluna da Esquerda ─── */
    .pdv-left { display: flex; flex-direction: column; gap: .75rem; }

    /* ─── Busca ─── */
    .pdv-search { position: relative; z-index: 10; }
    .pdv-search input {
      width: 100%; font-size: 1.15rem; padding: .85rem 1.1rem;
      border-radius: var(--radius); border: 2px solid var(--border-light);
      background: var(--surface); color: var(--text);
      box-shadow: var(--shadow-xs);
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .pdv-search input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent), var(--shadow-sm);
    }
    .pdv-search input::placeholder { color: var(--text-muted); }

    /* ─── Dropdown de resultados ─── */
    .pdv-results {
      position: absolute; top: calc(100% + 4px); left: 0; right: 0;
      background: var(--surface); border: 1.5px solid var(--border-light);
      border-radius: var(--radius); box-shadow: var(--shadow-lg);
      max-height: 45vh; overflow-y: auto; z-index: 50;
    }
    .pdv-result {
      display: grid; grid-template-columns: 1fr auto auto; gap: .75rem; align-items: center;
      padding: .7rem .9rem; cursor: pointer; border-bottom: 1px solid var(--border-light);
      transition: background var(--transition);
    }
    .pdv-result:last-child { border-bottom: 0; }
    .pdv-result:hover { background: color-mix(in srgb, var(--primary) 6%, transparent); }
    .pdv-result .name { font-weight: 600; font-size: .95rem; color: var(--text); }
    .pdv-result .price { font-weight: 700; font-size: .95rem; color: var(--primary); white-space: nowrap; }
    .pdv-result .stock {
      font-size: .78rem; color: var(--text-muted); white-space: nowrap; text-align: right;
    }
    .pdv-result .stock.low { color: var(--danger); }
    .pdv-result.highlight { background: color-mix(in srgb, var(--primary) 10%, transparent); }
    .pdv-empty { padding: .9rem; text-align: center; color: var(--text-muted); font-size: .9rem; }
    [x-cloak] { display: none !important; }

    /* ─── Carrinho ─── */
    .cart-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: .25rem 0;
    }
    .cart-header h2 { font-size: 1.05rem; font-weight: 600; margin: 0; }
    .cart-header .count { color: var(--text-muted); font-size: .85rem; }
    .cart-items {
      flex: 1; overflow-y: auto; min-height: 120px;
      background: var(--surface); border-radius: var(--radius);
      border: 1.5px solid var(--border-light); box-shadow: var(--shadow-xs);
    }
    .cart-empty {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: .5rem; padding: 2.5rem 1rem; color: var(--text-muted);
    }
    .cart-empty svg { width: 48px; height: 48px; stroke: var(--border); fill: none; stroke-width: 1.5; }
    .cart-empty p { font-size: .9rem; }

    .cart-line {
      display: grid; grid-template-columns: 1fr 80px 120px 36px;
      gap: .5rem; align-items: center;
      padding: .55rem .75rem; border-bottom: 1px solid var(--border-light);
      font-size: .9rem; transition: background var(--transition);
    }
    .cart-line:last-child { border-bottom: 0; }
    .cart-line:hover { background: var(--surface-hover); }
    .cart-line .prod-name { font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cart-line .prod-unit { font-size: .8rem; color: var(--text-muted); white-space: nowrap; }
    .cart-line .qty-wrap {
      display: inline-flex; align-items: center; gap: 0;
      border: 1.5px solid var(--border-light); border-radius: 8px; overflow: hidden;
      background: var(--surface-hover);
    }
    .cart-line .qty-wrap button {
      border: 0; background: transparent; color: var(--text-secondary);
      width: 28px; height: 28px; cursor: pointer; font-size: 1rem; font-weight: 600;
      display: grid; place-items: center; transition: background var(--transition), color var(--transition);
      line-height: 1;
    }
    .cart-line .qty-wrap button:hover { background: var(--border-light); color: var(--text); }
    .cart-line .qty-wrap button:active { background: var(--border); }
    .cart-line .qty-wrap input {
      width: 40px; height: 28px; border: 0; text-align: center; font-size: .85rem; font-weight: 600;
      background: transparent; color: var(--text); padding: 0;
      -moz-appearance: textfield; appearance: textfield;
    }
    .cart-line .qty-wrap input::-webkit-inner-spin-button { display: none; }
    .cart-line .qty-wrap input:focus { outline: none; background: var(--surface); }
    .cart-line .prod-total { text-align: right; font-weight: 700; font-size: .95rem; white-space: nowrap; }
    .cart-line .remove-btn {
      border: 0; background: transparent; color: var(--text-muted); cursor: pointer;
      width: 28px; height: 28px; border-radius: 6px; display: grid; place-items: center;
      font-size: 1.1rem; transition: background var(--transition), color var(--transition);
    }
    .cart-line .remove-btn:hover { background: var(--danger-bg); color: var(--danger); }

    /* ─── Coluna da Direita ─── */
    .pdv-right { position: sticky; top: 1rem; }
    .pdv-card {
      background: var(--surface); border: 1.5px solid var(--border-light);
      border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);
      padding: 1.25rem; display: flex; flex-direction: column; gap: .85rem;
    }

    /* ─── Botões de ação rápida ─── */
    .pdv-actions { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
    .pdv-action {
      display: flex; flex-direction: column; align-items: center; gap: .3rem;
      background: var(--surface-hover); border: 1.5px solid var(--border-light); border-radius: 10px;
      padding: .65rem .4rem; cursor: pointer; color: var(--text-secondary);
      font-size: .72rem; font-weight: 500; line-height: 1.2;
      transition: border-color var(--transition), background var(--transition), color var(--transition), transform var(--transition);
    }
    .pdv-action:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-bg); transform: translateY(-1px); }
    .pdv-action:active { transform: scale(.97); }
    .pdv-action svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2.25; stroke-linecap: round; stroke-linejoin: round; }
    .pdv-action .shortcut {
      font-size: .62rem; color: var(--text-muted); font-weight: 400;
      background: var(--border-light); padding: .05rem .4rem; border-radius: 4px;
    }
    .pdv-action:disabled { opacity: .35; cursor: not-allowed; transform: none; }

    /* ─── Bloco de valores ─── */
    .pdv-totals { border-top: 1.5px solid var(--border-light); padding-top: .65rem; }
    .pdv-total-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: .2rem 0; font-size: .9rem;
    }
    .pdv-total-row .label { color: var(--text-muted); }
    .pdv-total-row .value { font-weight: 500; }
    .pdv-total-row.discount .value { color: #4ade80; }
    .pdv-total-row.surcharge .value { color: #ff8589; }
    .pdv-total-row.final { padding: .4rem 0; }
    .pdv-total-row.final .label { font-size: 1rem; font-weight: 600; color: var(--text); }
    .pdv-total-row.final .value { font-size: 1.6rem; font-weight: 800; color: var(--primary); letter-spacing: -.02em; }

    .btn-finalize {
      width: 100%; padding: .95rem; font-size: 1.1rem; font-weight: 700;
      background: var(--primary); color: #fff; border: 0; border-radius: 12px;
      cursor: pointer; letter-spacing: -.01em;
      transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    }
    .btn-finalize:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 4px 16px color-mix(in srgb, var(--primary) 30%, transparent); }
    .btn-finalize:active { transform: scale(.98); }
    .btn-finalize:disabled { opacity: .4; cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-finalize .sub {
      display: block; font-size: .7rem; font-weight: 400; opacity: .75; margin-top: .1rem;
    }
    .pdv-error { color: var(--danger); font-size: .82rem; min-height: 1.2em; text-align: center; }

    /* ─── Responsivo ─── */
    @media (max-width: 1080px) {
      .pdv { grid-template-columns: 1fr; gap: 1rem; }
      .pdv-right { position: static; }
      .pdv-actions { grid-template-columns: repeat(4, 1fr); }
    }
  </style>
</head>
<body>
  <%- include('partials/nav', { user, page: '/app/store/pdv' }) %>
  <main x-data="pdvPage()" x-init="init()" style="max-width:92%">
    <div class="pdv">

      <!-- ─── COLUNA ESQUERDA (68%) ─── -->
      <div class="pdv-left">
        <div class="pdv-search">
          <input type="text" x-ref="search" x-model="q"
                 @input.debounce.250ms="search()"
                 @keydown.enter.prevent="quickAdd()"
                 @keydown.down.prevent="highlightNext()"
                 @keydown.up.prevent="highlightPrev()"
                 @keydown.escape="results = []"
                 placeholder="Código de barras, SKU ou nome… (Enter adiciona)" autofocus />

          <div class="pdv-results" x-show="results.length" x-cloak>
            <template x-for="(p, idx) in results" :key="p.id">
              <div class="pdv-result" :class="{ 'highlight': idx === highlightIdx }"
                   @click="add(p)" @mouseenter="highlightIdx = idx">
                <span class="name" x-text="p.name"></span>
                <span class="price" x-text="brl(p.price_cents)"></span>
                <span class="stock" :class="{ low: p.track_stock && p.stock_qty <= 3 }"
                      x-show="p.track_stock" x-text="'Est: ' + p.stock_qty"></span>
              </div>
            </template>
          </div>
          <p class="pdv-empty" x-show="q && !results.length && !searching" x-cloak>Nenhum produto encontrado.</p>
        </div>

        <div class="cart-header">
          <h2>Carrinho <span class="count" x-text="'(' + cart.length + ')'"></span></h2>
        </div>

        <div class="cart-items">
          <template x-for="(i, idx) in cart" :key="idx">
            <div class="cart-line">
              <div>
                <div class="prod-name" x-text="i.name"></div>
                <div class="prod-unit" x-text="'R$ ' + (i.price_cents / 100).toFixed(2).replace('.', ',')"></div>
              </div>
              <div class="qty-wrap">
                <button @click="qtyMinus(idx)" :disabled="i.qty <= 0.001">−</button>
                <input type="number" step="any" min="0.001" x-model.number="i.qty"
                       @focus="$event.target.select()" />
                <button @click="qtyPlus(idx)">+</button>
              </div>
              <span class="prod-total" x-text="brl(Math.round(i.price_cents * i.qty))"></span>
              <button class="remove-btn" @click="removeItem(idx)" title="Remover">×</button>
            </div>
          </template>

          <div class="cart-empty" x-show="!cart.length">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <p>Carrinho vazio — busque ou bie um produto para começar.</p>
          </div>
        </div>
      </div>

      <!-- ─── COLUNA DIREITA (32%) ─── -->
      <div class="pdv-right">
        <div class="pdv-card">
          <div class="pdv-actions">
            <% if (user.permissions.has('store.sales.discount')) { %>
            <button class="pdv-action" @click="openValue('desconto')" title="Desconto">
              <svg viewBox="0 0 24 24"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
              % Desconto <span class="shortcut">F4</span>
            </button>
            <button class="pdv-action" @click="openValue('acrescimo')" title="Acréscimo">
              <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              + Acréscimo <span class="shortcut">F7</span>
            </button>
            <% } %>
            <button class="pdv-action" @click="clearCart()" title="Limpar carrinho">
              <svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              Limpar <span class="shortcut">F9</span>
            </button>
            <button class="pdv-action" @click="printLast()"
                    :disabled="!lastSaleId" title="Imprimir última venda">
              <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Imprimir <span class="shortcut">F11</span>
            </button>
          </div>

          <div class="pdv-totals">
            <div class="pdv-total-row">
              <span class="label">Subtotal</span>
              <span class="value" x-text="brl(subtotal())"></span>
            </div>
            <div class="pdv-total-row discount" x-show="discountCents > 0">
              <span class="label">Desconto</span>
              <span class="value" x-text="'−' + brl(discountCents)"></span>
            </div>
            <div class="pdv-total-row surcharge" x-show="surchargeCents > 0">
              <span class="label">Acréscimo</span>
              <span class="value" x-text="'+' + brl(surchargeCents)"></span>
            </div>
            <div class="pdv-total-row final">
              <span class="label">Total</span>
              <span class="value" x-text="brl(total())"></span>
            </div>
          </div>

          <div class="pdv-error" x-text="error"></div>

          <button class="btn-finalize" :disabled="!cart.length" @click="openPay()">
            Finalizar venda
            <span class="sub">F2</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ─── MODAL: Desconto / Acréscimo ─── -->
    <dialog x-ref="value">
      <h1 x-text="valueDlg.kind === 'desconto' ? 'Desconto (F4)' : 'Acréscimo (F7)'"></h1>
      <label>Valor em R$</label>
      <input type="text" x-ref="valueInput" x-model="valueDlg.amount" placeholder="0,00"
             @keydown.enter.prevent="saveValue()" @keydown.escape.prevent="$refs.value.close()" />
      <div class="error" x-text="valueDlg.error"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.value.close()">Cancelar (Esc)</button>
        <button class="btn" @click="saveValue()">Aplicar (Enter)</button>
      </div>
    </dialog>

    <!-- ─── MODAL: Limpar carrinho (F9) ─── -->
    <dialog x-ref="clearDlg">
      <div style="text-align:center;padding:.5rem 0">
        <div style="width:48px;height:48px;border-radius:50%;background:var(--danger-bg);display:grid;place-items:center;margin:0 auto 1rem">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
        </div>
        <h2 style="font-size:1.05rem;font-weight:600;margin-bottom:.5rem">Limpar carrinho?</h2>
        <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:1.25rem">
          Todos os itens, descontos e acréscimos serão removidos.
        </p>
        <div class="actions" style="justify-content:center">
          <button class="btn secondary" @click="$refs.clearDlg.close()">Não (Esc)</button>
          <button class="btn" @click="doClear()" x-ref="clearConfirm">Sim (Enter)</button>
        </div>
      </div>
    </dialog>

    <!-- ─── MODAL: Pagamento ─── -->
    <dialog x-ref="pay" style="width:540px">
      <h1>Pagamento — <span x-text="brl(total())"></span></h1>

      <div style="display:flex;gap:.4rem;align-items:end;margin-bottom:.6rem">
        <div style="flex:1">
          <label>Forma</label>
          <select x-model.number="pay.methodId">
            <template x-for="m in methods" :key="m.id">
              <option :value="m.id" x-text="m.name + (m.fee_bps ? ` (taxa ${(m.fee_bps/100).toFixed(2).replace('.', ',')}%)` : '')"></option>
            </template>
          </select>
        </div>
        <div style="width:110px">
          <label>Valor (R$)</label>
          <input type="text" x-model="pay.amount" placeholder="0,00"
                 @keydown.enter.prevent="addPayment()" />
        </div>
        <button class="btn secondary" @click="addPayment()">+</button>
      </div>
      <div style="display:flex;gap:.4rem;align-items:center;margin-bottom:.6rem">
        <span class="muted" style="font-size:.85rem">Dividir por</span>
        <input type="number" min="2" max="20" x-model.number="pay.split" style="width:60px;padding:.3rem .4rem" />
        <button class="btn secondary small" @click="splitEqual()">pessoas</button>
        <span class="muted" style="font-size:.85rem" x-show="pay.split >= 2" x-text="'≈ ' + brl(Math.ceil(remaining() > 0 ? remaining() / (pay.split || 1) : total() / (pay.split || 1)))"></span>
      </div>

      <div style="max-height:160px;overflow-y:auto">
        <template x-for="(p, idx) in pay.list" :key="idx">
          <div class="pay-line">
            <span x-text="methodName(p.methodId)"></span>
            <span style="text-align:right" x-text="brl(p.amountCents)"></span>
            <button class="btn small" @click="pay.list.splice(idx, 1)">×</button>
          </div>
        </template>
      </div>

      <hr style="margin:.5rem 0;border:0;border-top:1px solid var(--border-light, #2c313c)" />
      <div class="pay-summary"><span>Pago</span><span x-text="brl(paidSum())"></span></div>
      <div class="pay-summary" :style="remaining() > 0 ? 'color:#ff8589' : 'color:#4ade80'">
        <span x-text="remaining() >= 0 ? 'Restante' : 'Excedente'"></span>
        <span x-text="brl(Math.abs(remaining()))"></span>
      </div>

      <template x-if="needsCashReceived()">
        <div>
          <label>Recebido em dinheiro (R$)</label>
          <input type="text" x-model="pay.received" placeholder="0,00" @input="calcChange()" />
          <p style="margin-top:.4rem">Troco: <strong x-text="brl(pay.changeCents)"></strong></p>
        </div>
      </template>
      <template x-if="hasPrazo()">
        <div>
          <label>Cliente (obrigatório para a prazo)</label>
          <select x-model.number="pay.customerId">
            <option value="">Selecione…</option>
            <template x-for="c in customers" :key="c.id"><option :value="c.id" x-text="c.name"></option></template>
          </select>
          <label>Vencimento</label>
          <input type="date" x-model="pay.dueDate" />
        </div>
      </template>

      <div class="error" x-text="payError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.pay.close()">Voltar</button>
        <button class="btn" :disabled="remaining() !== 0 || saving" @click="finish()" x-text="saving ? 'Registrando…' : 'Confirmar venda'"></button>
      </div>
    </dialog>
  </main>

  <script>
    function pdvPage() {
      return {
        // ─── Estado ───
        q: '', results: [], cart: [], customers: [], methods: [],
        discountCents: 0, surchargeCents: 0, lastSaleId: null,
        highlightIdx: -1, searching: false,
        valueDlg: { kind: 'desconto', amount: '', error: '' },
        pay: { methodId: null, amount: '', list: [], split: 2, received: '', changeCents: 0, customerId: '', dueDate: '' },
        error: '', payError: '', saving: false,

        // ─── Utilitários ───
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return isNaN(n) ? 0 : Math.round(n * 100); },
        focusSearch() { this.$nextTick(() => { this.$refs.search.focus(); }); },

        // ─── Inicialização ───
        async init() {
          const m = await fetch('/api/store/payment-methods');
          if (m.ok) { this.methods = await m.json(); if (this.methods.length) this.pay.methodId = this.methods[0].id; }
          this.focusSearch();
          document.addEventListener('keydown', (e) => {
            const dialogsOpen = document.querySelectorAll('dialog[open]').length > 0;
            if (!dialogsOpen) {
              switch (e.key) {
                case 'F2': e.preventDefault(); if (this.cart.length) this.openPay(); return;
                case 'F4': e.preventDefault(); this.openValue('desconto'); return;
                case 'F7': e.preventDefault(); this.openValue('acrescimo'); return;
                case 'F9': e.preventDefault(); this.clearCart(); return;
                case 'F11': e.preventDefault(); this.printLast(); return;
              }
            }
            if (e.key === 'Enter') {
              const dlg = document.querySelector('dialog[open]');
              if (dlg && dlg.id === 'confirm-dlg') {
                const confirmBtn = dlg.querySelector('.btn:not(.secondary)');
                if (confirmBtn) confirmBtn.click();
              }
            }
          });
        },

        // ─── Busca ───
        async search() {
          if (!this.q.trim()) { this.results = []; this.highlightIdx = -1; return; }
          this.searching = true;
          this.highlightIdx = -1;
          try {
            const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.q.trim()));
            if (r.ok) this.results = await r.json();
          } finally {
            this.searching = false;
          }
        },
        highlightNext() {
          if (!this.results.length) return;
          this.highlightIdx = (this.highlightIdx + 1) % this.results.length;
          const el = document.querySelector('.pdv-result.highlight');
          if (el) el.scrollIntoView({ block: 'nearest' });
        },
        highlightPrev() {
          if (!this.results.length) return;
          this.highlightIdx = (this.highlightIdx - 1 + this.results.length) % this.results.length;
          const el = document.querySelector('.pdv-result.highlight');
          if (el) el.scrollIntoView({ block: 'nearest' });
        },
        quickAdd() {
          if (this.results.length === 1) { this.add(this.results[0]); }
          else if (this.results.length > 1) {
            if (this.highlightIdx >= 0) {
              this.add(this.results[this.highlightIdx]);
              return;
            }
            const exact = this.results.find((p) => p.barcode === this.q.trim() || p.sku === this.q.trim());
            if (exact) this.add(exact);
          }
        },
        add(p) {
          const existing = this.cart.find((i) => i.productId === p.id);
          if (existing) existing.qty += 1;
          else this.cart.push({ productId: p.id, name: p.name, price_cents: p.price_cents, qty: 1 });
          this.q = ''; this.results = []; this.highlightIdx = -1;
          this.focusSearch();
        },

        // ─── Carrinho ───
        qtyPlus(idx) {
          const i = this.cart[idx];
          if (i) i.qty = Math.round((i.qty + 0.5) * 2) / 2;
        },
        qtyMinus(idx) {
          const i = this.cart[idx];
          if (i && i.qty > 0.001) {
            const dec = i.qty <= 1 ? 0.5 : 1;
            i.qty = Math.max(0.001, Math.round((i.qty - dec) * 2) / 2);
          }
        },
        removeItem(idx) { this.cart.splice(idx, 1); },
        subtotal() { return this.cart.reduce((a, i) => a + Math.round(i.price_cents * i.qty), 0); },
        total() { return Math.max(0, this.subtotal() - this.discountCents + this.surchargeCents); },

        // ─── Desconto / Acréscimo ───
        openValue(kind) {
          this.valueDlg = { kind, amount: '', error: '' };
          this.$refs.value.showModal();
          this.$nextTick(() => this.$refs.valueInput.focus());
        },
        saveValue() {
          const v = this.cents(this.valueDlg.amount);
          if (v < 0) { this.valueDlg.error = 'Valor inválido.'; return; }
          if (this.valueDlg.kind === 'desconto') {
            if (v > this.subtotal() + this.surchargeCents) { this.valueDlg.error = 'Desconto maior que o total.'; return; }
            this.discountCents = v;
          } else {
            this.surchargeCents = v;
          }
          this.$refs.value.close();
          this.focusSearch();
        },

        // ─── Limpar carrinho ───
        clearCart() {
          if (!this.cart.length) return;
          this.$refs.clearDlg.showModal();
          this.$nextTick(() => this.$refs.clearConfirm.focus());
        },
        doClear() {
          this.cart = []; this.discountCents = 0; this.surchargeCents = 0;
          this.$refs.clearDlg.close();
          this.focusSearch();
        },

        // ─── Impressão ───
        printLast() {
          if (this.lastSaleId) window.open(`/app/store/vendas/${this.lastSaleId}/cupom`, '_blank', 'width=380,height=600');
        },

        // ─── Pagamento ───
        methodName(id) { const m = this.methods.find((x) => x.id === id); return m ? m.name : '?'; },
        methodType(id) { const m = this.methods.find((x) => x.id === id); return m ? m.type : ''; },
        paidSum() { return this.pay.list.reduce((a, p) => a + p.amountCents, 0); },
        remaining() { return this.total() - this.paidSum(); },
        needsCashReceived() { return this.pay.list.some((p) => this.methodType(p.methodId) === 'dinheiro'); },
        hasPrazo() { return this.pay.list.some((p) => this.methodType(p.methodId) === 'prazo'); },
        async openPay() {
          this.payError = '';
          this.pay.list = []; this.pay.received = ''; this.pay.changeCents = 0;
          this.pay.amount = (this.total() / 100).toFixed(2).replace('.', ',');
          if (!this.customers.length) {
            const r = await fetch('/api/commercial/customers');
            if (r.ok) this.customers = await r.json();
          }
          this.$refs.pay.showModal();
        },
        addPayment() {
          const amount = this.cents(this.pay.amount);
          if (!this.pay.methodId || amount <= 0) { this.payError = 'Escolha a forma e o valor.'; return; }
          if (amount > this.remaining()) { this.payError = 'Valor maior que o restante.'; return; }
          this.payError = '';
          this.pay.list.push({ methodId: this.pay.methodId, amountCents: amount });
          const rest = this.remaining();
          this.pay.amount = rest > 0 ? (rest / 100).toFixed(2).replace('.', ',') : '';
          this.calcChange();
        },
        splitEqual() {
          const n = this.pay.split;
          if (!n || n < 2) return;
          this.pay.list = [];
          const base = Math.floor(this.total() / n);
          for (let i = 0; i < n; i++) {
            const amount = i === 0 ? this.total() - base * (n - 1) : base;
            if (amount > 0) this.pay.list.push({ methodId: this.pay.methodId, amountCents: amount });
          }
          this.pay.amount = '';
          this.calcChange();
        },
        calcChange() {
          const cashDue = this.pay.list.filter((p) => this.methodType(p.methodId) === 'dinheiro')
            .reduce((a, p) => a + p.amountCents, 0);
          this.pay.changeCents = Math.max(0, this.cents(this.pay.received) - cashDue);
        },
        async finish() {
          if (this.saving || this.remaining() !== 0) return;
          this.saving = true; this.payError = '';
          let cashReceived = this.cents(this.pay.received);
          const payments = this.pay.list.map((p) => {
            const out = { methodId: p.methodId, amountCents: p.amountCents };
            if (this.methodType(p.methodId) === 'dinheiro') {
              const rec = Math.max(p.amountCents, cashReceived);
              out.receivedCents = rec;
              cashReceived = Math.max(0, cashReceived - rec);
            }
            return out;
          });
          const body = {
            items: this.cart.map((i) => ({ productId: i.productId, qty: i.qty })),
            payments,
            discountCents: this.discountCents || undefined,
            surchargeCents: this.surchargeCents || undefined,
            customerId: this.hasPrazo() ? this.pay.customerId || undefined : undefined,
            dueDate: this.hasPrazo() ? this.pay.dueDate || undefined : undefined,
          };
          const r = await fetch('/api/store/sales', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          this.saving = false;
          if (r.ok) {
            const d = await r.json();
            this.lastSaleId = d.id;
            this.$refs.pay.close();
            this.cart = []; this.discountCents = 0; this.surchargeCents = 0;
            this.focusSearch();
          } else {
            this.payError = (await r.json()).error ?? 'Erro ao registrar a venda.';
          }
        },
      };
    }
  </script>
</body>
</html>
