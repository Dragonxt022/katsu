    <!-- ─── MODAL: Pagamento com pontos de fidelidade ─── -->
    <dialog x-ref="fidelidadeDlg">
      <h1>Pontos de fidelidade</h1>
      <p class="muted" style="margin-top:-.3rem" x-text="'Saldo disponível: ' + (customerBalances.loyaltyPoints || 0) + ' pontos'"></p>
      <label>Quantos pontos usar</label>
      <input type="number" min="1" x-model.number="fidelidadeForm.pointsUsed" @input="fidelidadeError = ''" />
      <p class="muted" style="font-size:.85rem" x-text="'Equivale a ' + brl(Math.round((fidelidadeForm.pointsUsed || 0) * centsPerPointClient()))"></p>
      <div class="error" x-text="fidelidadeError"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.fidelidadeDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="confirmFidelidadeDlg()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Confirmar
        </button>
      </div>
    </dialog>

    <% if (user.permissions.has('finance.cash.open')) { %>
    <!-- ─── MODAL: Complementos / opcionais ─── -->
    <dialog x-ref="complementDlg" style="width:min(600px,94vw)">
      <h1 x-text="'Complementos — ' + (complementDlg.product?.name || '')"></h1>
      <p class="muted">Selecione os opcionais desejados e confirme para adicionar ao carrinho.</p>
      <template x-for="g in complementDlg.groups" :key="g.group_id">
        <div class="complement-group" style="margin:1rem 0;padding:.75rem;border:1.5px solid var(--border-light);border-radius:var(--radius)">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <strong x-text="g.group_name"></strong>
            <span class="muted text-xs" x-text="(g.min_select > 0 ? ('Min: ' + g.min_select) : 'Opcional') + (g.max_select ? (' · Max: ' + g.max_select) : '')"></span>
          </div>
          <div style="margin-top:.5rem">
            <template x-for="item in (typeof g.items === 'string' ? [] : g.items)" :key="item.id">
              <div class="complement-item" style="display:flex;align-items:center;gap:.5rem;padding:.3rem 0">
                <input type="checkbox" :checked="complementDlg.selections[g.group_id]?.some(s => s.product_id === item.product_id)"
                       @change="toggleComplement(g.group_id, item)" />
                <span x-text="item.product_name" style="flex:1"></span>
                <span class="text-sm" x-text="brl(item.price_override_cents != null ? item.price_override_cents : complementDlg.product?.price_cents)"></span>
                <template x-if="complementDlg.selections[g.group_id]?.some(s => s.product_id === item.product_id)">
                  <div style="display:flex;align-items:center;gap:.25rem">
                    <button class="btn secondary small" @click="complementQty(g.group_id, item.product_id, -1)" style="padding:.1rem .4rem">−</button>
                    <span x-text="complementDlg.selections[g.group_id]?.find(s => s.product_id === item.product_id)?.qty || 1" style="min-width:1.5rem;text-align:center"></span>
                    <button class="btn secondary small" @click="complementQty(g.group_id, item.product_id, 1)" style="padding:.1rem .4rem">+</button>
                  </div>
                </template>
              </div>
            </template>
          </div>
          <div class="error text-xs" x-show="complementDlg.errors[g.group_id]" x-text="complementDlg.errors[g.group_id]"></div>
        </div>
      </template>
      <div style="margin-bottom:.75rem">
        <label class="text-sm" style="display:block;margin-bottom:.25rem">Observação (opcional)</label>
        <input type="text" x-model="complementDlg.mainNotes" placeholder="Ex.: sem cebola, bem passado..." style="width:100%" />
      </div>
      <div class="error" x-text="complementDlg.errors._general"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.complementDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="confirmComplementSelection()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Adicionar ao carrinho
        </button>
      </div>
    </dialog>

    <!-- ─── MODAL: Aviso de caixa fechado ─── -->
    <dialog x-ref="cashClosedWarnDlg" style="width:360px">
      <div class="dialog-body-center">
        <div class="dialog-icon dialog-icon-warning">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--warning-text)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h2 class="dialog-heading-md">Caixa fechado</h2>
        <p class="dialog-muted">
          Para receber em dinheiro é preciso abrir o caixa. Deseja abrir agora?
        </p>
        <div class="actions actions-center">
          <button class="btn secondary" @click="$refs.cashClosedWarnDlg.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            Não
          </button>
          <button class="btn" @click="$refs.cashClosedWarnDlg.close(); openRegisterFromSale()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Sim
          </button>
        </div>
      </div>
    </dialog>

    <!-- ─── MODAL: Abrir caixa (sem sair da venda em andamento) ─── -->
    <dialog x-ref="openRegisterDlg" style="width:360px">
      <h1>Abrir caixa</h1>
      <p class="muted muted-sm">O carrinho e o pagamento em andamento não serão perdidos.</p>
      <label>Valor inicial da gaveta (R$)</label>
      <input type="text" x-ref="openRegisterInput" x-model="openRegisterForm.opening" placeholder="0,00"
             @input="openRegisterForm.opening = maskMoney(openRegisterForm.opening)"
             @keydown.enter.prevent="confirmOpenRegister()" />
      <div class="error" x-text="openRegisterForm.error"></div>
      <div class="actions">
        <button class="btn secondary" @click="$refs.openRegisterDlg.close()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          Cancelar
        </button>
        <button class="btn" @click="confirmOpenRegister()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Abrir caixa
        </button>
      </div>
    </dialog>
    <% } %>

    <!-- ─── MODAL: Venda concluída — imprimir cupom? ─── -->
    <dialog x-ref="postSale" @close="onPostSaleClose()">
      <div class="dialog-body-center">
        <div class="dialog-icon dialog-icon-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <h2 class="dialog-heading-sm">Venda finalizada!</h2>
        <p class="dialog-muted">Deseja imprimir o cupom desta venda?</p>
        <div class="actions actions-center">
          <button class="btn secondary" @click="$refs.postSale.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            Não (Esc)
          </button>
          <button class="btn secondary" x-show="lastSaleHasCarne" @click="printCarne()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Imprimir carnê
          </button>
          <button class="btn" autofocus @click="printLast(); $refs.postSale.close()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Imprimir (Enter)
          </button>
        </div>
      </div>
    </dialog>
  </main>

  <script src="/js/masks.js"></script>
  <script src="/js/datetime.js"></script>
  <script>
    function pdvPage() {
      return {
        // ─── Estado ───
        // Vendas simultâneas (até 4 "guichês" no mesmo PDV — atender outro cliente sem
        // perder o carrinho do anterior) + persistência em localStorage (sobrevive a
        // navegar pra outra tela e voltar, ou recarregar a página sem querer).
        slots: [{ cart: [], discountCents: 0, surchargeCents: 0, lastSaleId: null, customerId: '', comandaId: null, tableLabel: null }],
        justClosedComandaId: null,
        activeSlot: 0,
        q: '', results: [], customers: [], methods: [],
        highlightIdx: -1, searching: false,
        get cart() { return this.slots[this.activeSlot].cart; },
        set cart(v) { this.slots[this.activeSlot].cart = v; },
        get discountCents() { return this.slots[this.activeSlot].discountCents; },
        set discountCents(v) { this.slots[this.activeSlot].discountCents = v; },
        get surchargeCents() { return this.slots[this.activeSlot].surchargeCents; },
        set surchargeCents(v) { this.slots[this.activeSlot].surchargeCents = v; },
        get lastSaleId() { return this.slots[this.activeSlot].lastSaleId; },
        set lastSaleId(v) { this.slots[this.activeSlot].lastSaleId = v; },
        get customerId() { return this.slots[this.activeSlot].customerId ?? ''; },
        set customerId(v) { this.slots[this.activeSlot].customerId = v; },
        valueDlg: { kind: 'desconto', amount: '', mode: 'valor', error: '' },
        pay: { methodId: null, amount: '', list: [], split: 2, received: '', changeCents: 0, clientRequestId: '' },
        showSplit: false, showCashReceived: false,
        error: '', payError: '', saving: false, appSettings: [],
        pinInput: '', pinError: '', pendingRemoveIdx: null,
        browseQ: '', browseResults: [], browseCategories: [], browseCategoryId: '',
        openRegisterForm: { opening: '', error: '' },
        customerBalances: {}, lastSaleHasCarne: false,
        prazoForm: { customerId: '', mode: 'avista', installments: 3, firstDueDate: '', amountCents: 0 }, prazoError: '',
        fidelidadeForm: { pointsUsed: 0 }, fidelidadeError: '',
        cloudOnline: false,
        complementDlg: { product: null, groups: [], selections: {}, mainNotes: '', errors: {} },

        // ─── Complementos ───
        openComplementDlg(product, groups) {
          this.complementDlg.product = product;
          this.complementDlg.groups = groups;
          this.complementDlg.selections = {};
          this.complementDlg.mainNotes = '';
          this.complementDlg.errors = {};
          for (const g of groups) {
            this.complementDlg.selections[g.group_id] = [];
            // Parse items JSON (vem como string do json_group_array)
            if (typeof g.items === 'string') {
              try { g.items = JSON.parse(g.items); } catch { g.items = []; }
            }
          }
          this.$refs.complementDlg.showModal();
        },
        toggleComplement(groupId, item) {
          const sel = this.complementDlg.selections[groupId];
          const g = this.complementDlg.groups.find((gr) => gr.group_id === groupId);
          const idx = sel.findIndex((s) => s.product_id === item.product_id);
          if (idx >= 0) {
            sel.splice(idx, 1);
          } else {
            if (g && g.max_select === 1) {
              sel.length = 0;
            }
            sel.push({ ...item });
          }
          this.complementDlg.errors = {};
        },
        complementQty(groupId, productId, delta) {
          const sel = this.complementDlg.selections[groupId];
          const item = sel.find((s) => s.product_id === productId);
          if (item) {
            item.qty = Math.max(1, (item.qty || 1) + delta);
          }
        },
        validateComplementSelection() {
          const errors = {};
          for (const g of this.complementDlg.groups) {
            const sel = this.complementDlg.selections[g.group_id];
            const totalQty = sel.reduce((s, i) => s + (i.qty || 1), 0);
            if (g.min_select > 0 && totalQty < g.min_select) {
              errors[g.group_id] = `Selecione ao menos ${g.min_select} opcao(oes).`;
            }
            if (g.max_select != null && totalQty > g.max_select) {
              errors[g.group_id] = `Maximo de ${g.max_select} opcao(oes) excedido.`;
            }
          }
          this.complementDlg.errors = errors;
          return Object.keys(errors).length === 0;
        },
        confirmComplementSelection() {
          if (!this.validateComplementSelection()) return;
          const p = this.complementDlg.product;
          const lineGroupUuid = window.crypto?.randomUUID?.() || (Date.now() + '-' + Math.random());
          // Adiciona o produto principal
          this.addToCart(p, 1, lineGroupUuid, this.complementDlg.mainNotes || null);
          // Adiciona cada complemento selecionado
          for (const g of this.complementDlg.groups) {
            for (const sel of this.complementDlg.selections[g.group_id]) {
              const qty = sel.qty || 1;
              const complementProduct = {
                id: sel.product_id,
                name: sel.product_name,
                price_cents: sel.price_override_cents != null ? sel.price_override_cents : p.price_cents,
                sku: null,
                image_url: null,
              };
              this.addToCart(complementProduct, qty, lineGroupUuid, this.complementDlg.mainNotes || null);
            }
          }
          this.$refs.complementDlg.close();
        },

        // ─── Utilitários ───
        brl(c) { return 'R$ ' + ((c ?? 0) / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.'); },
        cents(s) { const n = parseFloat(String(s || '0').replace(/\./g, '').replace(',', '.')); return isNaN(n) ? 0 : Math.round(n * 100); },
        focusSearch() { this.$nextTick(() => { this.$refs.search?.focus(); }); },
        methodIcon(type) {
          const icons = {
            dinheiro: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>',
            debito: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>',
            credito: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>',
            pix: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="15" y="15" width="5" height="5" rx="1"/></svg>',
            prazo: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
          };
          return icons[type] ?? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>';
        },

        // ─── Vendas simultâneas + persistência ───
        persistSlots() {
          try { localStorage.setItem('katsu:pdv:slots', JSON.stringify({ slots: this.slots, activeSlot: this.activeSlot })); } catch (e) {}
        },
        restoreSlots() {
          try {
            const raw = localStorage.getItem('katsu:pdv:slots');
            if (!raw) return;
            const saved = JSON.parse(raw);
            if (Array.isArray(saved?.slots) && saved.slots.length) {
              this.slots = saved.slots;
              this.activeSlot = Math.min(saved.activeSlot ?? 0, this.slots.length - 1);
            }
          } catch (e) {}
        },
        addSlot() {
          if (this.slots.length >= 4) return;
          this.slots.push({ cart: [], discountCents: 0, surchargeCents: 0, lastSaleId: null, customerId: '', comandaId: null, tableLabel: null });
          this.activeSlot = this.slots.length - 1;
          this.persistSlots();
          this.focusSearch();
        },
        switchSlot(idx) {
          if (idx === this.activeSlot) return;
          this.activeSlot = idx;
          this.q = ''; this.results = []; this.highlightIdx = -1;
          this.persistSlots();
          this.focusSearch();
        },
        async closeSlot(idx) {
          if (this.slots.length <= 1) return;
          if (this.slots[idx].cart.length && !await window.confirmDlg('Fechar esta venda? Os itens ainda não finalizados serão perdidos.')) return;
          this.slots.splice(idx, 1);
          if (this.activeSlot >= this.slots.length) this.activeSlot = this.slots.length - 1;
          else if (this.activeSlot > idx) this.activeSlot -= 1;
          this.persistSlots();
        },

        // ─── Inicialização ───
        async init() {
          this.restoreSlots();
          const [m, s, c, p] = await Promise.all([
            fetch('/api/store/payment-methods'),
            fetch('/api/settings'),
            fetch('/api/commercial/customers'),
            fetch('/api/commercial/products'),
          ]);
          if (m.ok) { this.methods = await m.json(); if (this.methods.length) this.pay.methodId = this.methods[0].id; }
          if (s.ok) this.appSettings = await s.json();
          if (c.ok) this.customers = await c.json();
          if (p.ok) {
            // Carrinho persistido em localStorage pode referenciar produto excluído/inativado
            // desde a última sessão — sem essa limpeza, o item fica "fantasma" no carrinho e
            // quebra o checkout (o backend rejeita productId inexistente).
            const validIds = new Set((await p.json()).map((prod) => prod.id));
            this.slots.forEach((slot) => { slot.cart = slot.cart.filter((i) => validIds.has(i.productId)); });
            this.persistSlots();
          }
          const comandaIdParam = new URLSearchParams(location.search).get('comandaId');
          if (comandaIdParam) await this.loadComanda(Number(comandaIdParam));
          if (this.customerId) this.loadCustomerBalances();
          this.focusSearch();
          this.$watch('slots', () => this.persistSlots());
          this.checkOnline();
          setInterval(() => this.checkOnline(), 25000);
          document.addEventListener('keydown', (e) => {
            const dialogsOpen = document.querySelectorAll('dialog[open]').length > 0;
            if (!dialogsOpen) {
              switch (e.key) {
                case 'F2': e.preventDefault(); if (this.cart.length) this.openPay(); return;
                case 'F4': e.preventDefault(); this.openValue('desconto'); return;
                case 'F7': e.preventDefault(); this.openValue('acrescimo'); return;
                case 'F9': e.preventDefault(); this.clearCart(); return;
                case 'F11': e.preventDefault(); this.printLast(); return;
              }
            }
            if (this.$refs.pay && this.$refs.pay.open) {
              const fMatch = /^F([1-9])$/.exec(e.key);
              if (fMatch) {
                const m = this.methods[Number(fMatch[1]) - 1];
                if (m) { e.preventDefault(); this.pay.methodId = m.id; }
                return;
              }
              const inField = e.target.matches('input, select, textarea');
              if (e.key === 'Enter' && !inField && this.remaining() === 0) {
                e.preventDefault();
                this.finish();
                return;
              }
            }
            if (e.key === 'Enter') {
              const dlg = document.querySelector('dialog[open]');
              if (dlg && dlg.id === 'confirm-dlg') {
                const confirmBtn = dlg.querySelector('.btn:not(.secondary)');
                if (confirmBtn) confirmBtn.click();
              }
            }
          });
        },
        // ─── Comanda → PDV (fechar comanda pelo caixa, preço já congelado) ───
        async loadComanda(id) {
          const r = await fetch(`/api/comandas/comandas/${id}`);
          if (!r.ok) { this.error = 'Comanda não encontrada ou já fechada.'; return; }
          const c = await r.json();
          if (c.status !== 'aberta') { this.error = 'Esta comanda não está mais aberta.'; return; }
          const cart = (c.items || []).map((i) => ({
            productId: i.product_id, name: i.product_name, price_cents: i.unit_price_cents, qty: i.qty,
            sku: null, image_url: null, lineGroupUuid: i.line_group_uuid || null, notes: i.notes || null,
          }));
          const needsNewSlot = this.slots[this.activeSlot].cart.length > 0 || this.slots[this.activeSlot].comandaId;
          if (needsNewSlot) {
            this.slots.push({ cart: [], discountCents: 0, surchargeCents: 0, lastSaleId: null, customerId: '', comandaId: null, tableLabel: null });
            this.activeSlot = this.slots.length - 1;
          }
          this.slots[this.activeSlot] = {
            cart, discountCents: 0, surchargeCents: 0, lastSaleId: null,
            customerId: c.customer_id || '', comandaId: id, tableLabel: c.table_label || null,
          };
          this.persistSlots();
        },
        onPostSaleClose() {
          if (this.justClosedComandaId) {
            this.justClosedComandaId = null;
            window.location.href = '/app/comandas/mesas';
            return;
          }
          this.focusSearch();
        },
        async checkOnline() {
          try {
            const r = await fetch('/api/sync/status');
            const d = r.ok ? await r.json() : null;
            this.cloudOnline = !!(d && d.online);
          } catch {
            this.cloudOnline = false;
          }
        },

        // ─── Busca ───
        async search() {
          if (!this.q.trim()) { this.results = []; this.highlightIdx = -1; return; }
          this.searching = true;
          this.highlightIdx = -1;
          try {
            const r = await fetch('/api/commercial/products?q=' + encodeURIComponent(this.q.trim()));
            if (r.ok) this.results = await r.json();
          } finally {
            this.searching = false;
          }
        },
        // ─── Consultar produtos (modal separado, sem afetar o carrinho) ───
        async openBrowse() {
          this.browseQ = ''; this.browseResults = []; this.browseCategoryId = '';
          this.$refs.browse.showModal();
          this.$nextTick(() => this.$refs.browseInput.focus());
          if (!this.browseCategories.length) {
            const c = await fetch('/api/commercial/categories');
            if (c.ok) this.browseCategories = await c.json();
          }
          this.searchBrowse();
        },
        async searchBrowse() {
          const r = await fetch('/api/commercial/products' + (this.browseQ.trim() ? '?q=' + encodeURIComponent(this.browseQ.trim()) : ''));
          if (r.ok) this.browseResults = await r.json();
        },
        browseFiltered() {
          if (!this.browseCategoryId) return this.browseResults;
          return this.browseResults.filter((p) => p.category_id === this.browseCategoryId);
        },

        highlightNext() {
          if (!this.results.length) return;
          this.highlightIdx = (this.highlightIdx + 1) % this.results.length;
          const el = document.querySelector('.pdv-result.highlight');
          if (el) el.scrollIntoView({ block: 'nearest' });
        },
        highlightPrev() {
          if (!this.results.length) return;
          this.highlightIdx = (this.highlightIdx - 1 + this.results.length) % this.results.length;
          const el = document.querySelector('.pdv-result.highlight');
          if (el) el.scrollIntoView({ block: 'nearest' });
        },
        async quickAdd() {
          if (this.results.length === 1) { await this.add(this.results[0]); }
          else if (this.results.length > 1) {
            if (this.highlightIdx >= 0) {
              await this.add(this.results[this.highlightIdx]);
              return;
            }
            const exact = this.results.find((p) => p.barcode === this.q.trim() || p.sku === this.q.trim());
            if (exact) await this.add(exact);
          }
        },
        async add(p) {
          const existing = this.cart.find((i) => i.productId === p.id && !i.lineGroupUuid);
          if (existing) { existing.qty += 1; this.persistSlots(); this.repriceCart(); return; }
          // Checar se produto tem complementos
          const r = await fetch(`/api/commercial/products/${p.id}/complement-groups`);
          const groups = r.ok ? await r.json() : [];
          if (groups.length > 0) {
            this.openComplementDlg(p, groups);
            return;
          }
          this.addToCart(p, 1, null, null);
        },
        addToCart(p, qty, lineGroupUuid, notes) {
          this.cart.push({
            productId: p.id, name: p.name, price_cents: p.price_cents, qty,
            sku: p.sku ?? null, image_url: p.image_url ?? null,
            lineGroupUuid, notes,
          });
          this.q = ''; this.results = []; this.highlightIdx = -1;
          this.focusSearch();
          this.persistSlots();
          this.repriceCart();
        },

        // ─── Tabelas de preço (atacado/varejo/cliente) ───
        async repriceCart() {
          if (!this.cart.length) return;
          if (this.slots[this.activeSlot].comandaId) return; // preco congelado na comanda — nao re-resolver
          const r = await fetch('/api/commercial/pricing/resolve', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ customerId: this.customerId || null, items: this.cart.map((i) => ({ productId: i.productId, qty: i.qty })) }),
          });
          if (!r.ok) return;
          const { prices } = await r.json();
          for (const p of prices) {
            const line = this.cart.find((i) => i.productId === p.productId);
            if (line) line.price_cents = p.unitCents;
          }
          this.persistSlots();
        },

        // ─── Carrinho ───
        qtyPlus(idx) {
          const i = this.cart[idx];
          if (i) i.qty = Math.round((i.qty + 0.5) * 2) / 2;
          this.persistSlots();
          this.repriceCart();
        },
        qtyMinus(idx) {
          const i = this.cart[idx];
          if (i && i.qty > 0.001) {
            const dec = i.qty <= 1 ? 0.5 : 1;
            i.qty = Math.max(0.001, Math.round((i.qty - dec) * 2) / 2);
          }
          this.persistSlots();
          this.repriceCart();
        },
        removeItem(idx) {
          if (this.pinRequiredForRemove()) { this.openPinConfirm(idx); return; }
          this.cart.splice(idx, 1); this.persistSlots();
        },
        pinRequiredForRemove() {
          return this.appSettings?.find((s) => s.key === 'seguranca.pin_remover_item')?.value === '1';
        },
        openPinConfirm(idx) {
          this.pendingRemoveIdx = idx; this.pinInput = ''; this.pinError = '';
          this.$refs.pinDlg.showModal();
          this.$nextTick(() => this.$refs.pinInput.focus());
        },
        async confirmPinRemove() {
          if (!this.pinInput) return;
          const r = await fetch('/api/security/pin/verify', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ pin: this.pinInput }),
          });
          const body = r.ok ? await r.json() : { ok: false };
          if (body.ok) {
            this.cart.splice(this.pendingRemoveIdx, 1);
            this.persistSlots();
            this.$refs.pinDlg.close();
          } else {
            this.pinError = 'PIN incorreto.';
          }
        },
        subtotal() { return this.cart.reduce((a, i) => a + Math.round(i.price_cents * i.qty), 0); },
        total() { return Math.max(0, this.subtotal() - this.discountCents + this.surchargeCents); },

        // ─── Desconto / Acréscimo ───
        openValue(kind) {
          this.valueDlg = { kind, amount: '', mode: 'valor', error: '' };
          this.$refs.value.showModal();
          this.$nextTick(() => this.$refs.valueInput.focus());
        },
        setValueMode(mode) {
          if (this.valueDlg.mode === mode) return;
          this.valueDlg.mode = mode; this.valueDlg.amount = ''; this.valueDlg.error = '';
          this.$nextTick(() => this.$refs.valueInput.focus());
        },
        percentToCents(pct) {
          const p = parseFloat(String(pct || '0').replace(',', '.'));
          if (isNaN(p) || p <= 0) return 0;
          return Math.round(this.subtotal() * (p / 100));
        },
        saveValue() {
          const v = this.valueDlg.mode === 'valor' ? this.cents(this.valueDlg.amount) : this.percentToCents(this.valueDlg.amount);
          if (v < 0) { this.valueDlg.error = 'Valor inválido.'; return; }
          if (this.valueDlg.kind === 'desconto') {
            if (v > this.subtotal() + this.surchargeCents) { this.valueDlg.error = 'Desconto maior que o total.'; return; }
            this.discountCents = v;
          } else {
            this.surchargeCents = v;
          }
          this.$refs.value.close();
          this.focusSearch();
          this.persistSlots();
        },

        // ─── Limpar carrinho ───
        clearCart() {
          if (!this.cart.length) return;
          this.$refs.clearDlg.showModal();
          this.$nextTick(() => this.$refs.clearConfirm.focus());
        },
        doClear() {
          this.cart = []; this.discountCents = 0; this.surchargeCents = 0; this.customerId = ''; this.customerBalances = {};
          this.$refs.clearDlg.close();
          this.focusSearch();
          this.persistSlots();
        },

        // ─── Impressão ───
        printLast() {
          if (this.lastSaleId) window.open(`/app/store/vendas/${this.lastSaleId}/cupom`, '_blank', 'width=380,height=600');
        },
        printCarne() {
          if (this.lastSaleId) window.open(`/app/store/vendas/${this.lastSaleId}/carne`, '_blank', 'width=380,height=700');
        },

        // ─── Pagamento ───
        methodName(id) { const m = this.methods.find((x) => x.id === id); return m ? m.name : '?'; },
        methodType(id) { const m = this.methods.find((x) => x.id === id); return m ? m.type : ''; },
        paidSum() { return this.pay.list.reduce((a, p) => a + p.amountCents, 0); },
        remaining() { return this.total() - this.paidSum(); },
        needsCashReceived() { return this.pay.list.some((p) => this.methodType(p.methodId) === 'dinheiro'); },
        visibleQuickMethods() {
          return this.methods.filter((m) => {
            if (m.type === 'credito_loja') return (this.customerBalances.storeCreditCents || 0) > 0;
            if (m.type === 'fidelidade') return (this.customerBalances.loyaltyPoints || 0) > 0;
            if (m.type === 'convenio') return !!this.customerBalances.hasAgreement;
            return true;
          });
        },
        selectQuickMethod(m) {
          if (m.type === 'prazo') { this.openPrazoDlg(); return; }
          if (m.type === 'fidelidade') { this.openFidelidadeDlg(); return; }
          this.pay.methodId = m.id;
        },
        async loadCustomerBalances() {
          if (!this.customerId) { this.customerBalances = {}; return; }
          const r = await fetch(`/api/commercial/customers/${this.customerId}`);
          if (r.ok) {
            const c = await r.json();
            this.customerBalances = { storeCreditCents: c.store_credit_cents || 0, loyaltyPoints: c.loyalty_points || 0, hasAgreement: !!c.agreement_company_id };
          } else this.customerBalances = {};
        },
        centsPerPointClient() {
          const pontos = Number(this.appSettings?.find((s) => s.key === 'fidelidade.pontos_resgate')?.value ?? 100);
          const valor = Number(this.appSettings?.find((s) => s.key === 'fidelidade.valor_resgate_cents')?.value ?? 500);
          return pontos > 0 ? valor / pontos : 0;
        },
        async openPay() {
          this.payError = '';
          this.pay.list = []; this.pay.received = ''; this.pay.changeCents = 0;
          this.pay.amount = (this.total() / 100).toFixed(2).replace('.', ',');
          this.pay.clientRequestId = (window.crypto && window.crypto.randomUUID) ? window.crypto.randomUUID() : (Date.now() + '-' + Math.random());
          this.showSplit = false; this.showCashReceived = false;
          if (!this.customers.length) {
            const r = await fetch('/api/commercial/customers');
            if (r.ok) this.customers = await r.json();
          }
          this.$refs.pay.showModal();
        },
        addPayment() {
          const amount = this.cents(this.pay.amount);
          if (!this.pay.methodId || amount <= 0) { this.payError = 'Escolha a forma e o valor.'; return; }
          if (amount > this.remaining()) { this.payError = 'Valor maior que o restante.'; return; }
          const type = this.methodType(this.pay.methodId);
          if (type === 'credito_loja' && amount > (this.customerBalances.storeCreditCents || 0)) {
            this.payError = 'Saldo de crédito de loja insuficiente.'; return;
          }
          this.payError = '';
          const extra = (type === 'credito_loja' || type === 'convenio') ? { customerId: this.customerId || undefined } : {};
          this.pay.list.push({ methodId: this.pay.methodId, amountCents: amount, ...extra });
          const rest = this.remaining();
          this.pay.amount = rest > 0 ? (rest / 100).toFixed(2).replace('.', ',') : '';
          this.calcChange();
        },
        splitEqual() {
          const n = this.pay.split;
          if (!n || n < 2) return;
          this.pay.list = [];
          const base = Math.floor(this.total() / n);
          for (let i = 0; i < n; i++) {
            const amount = i === 0 ? this.total() - base * (n - 1) : base;
            if (amount > 0) this.pay.list.push({ methodId: this.pay.methodId, amountCents: amount });
          }
          this.pay.amount = '';
          this.calcChange();
        },
        calcChange() {
          const cashDue = this.pay.list.filter((p) => this.methodType(p.methodId) === 'dinheiro')
            .reduce((a, p) => a + p.amountCents, 0);
          this.pay.changeCents = Math.max(0, this.cents(this.pay.received) - cashDue);
        },

        // ─── Venda a prazo (parcelamento) ───
        openPrazoDlg() {
          const existing = this.pay.list.find((p) => this.methodType(p.methodId) === 'prazo');
          const amt = existing ? existing.amountCents : (this.remaining() > 0 ? this.remaining() : this.total());
          this.prazoForm = {
            customerId: (existing && existing.customerId) || this.customerId || '',
            mode: existing && existing.installments ? 'parcelado' : 'avista',
            installments: (existing && existing.installments && existing.installments.count) || 3,
            firstDueDate: (existing && existing.dueDate) || new Date(Date.now() + 30 * 24 * 3600e3).toISOString().slice(0, 10),
            amountCents: amt,
          };
          this.prazoError = '';
          this.$refs.prazoDlg.showModal();
        },
        prazoPreview() {
          const count = this.prazoForm.mode === 'parcelado' ? Math.max(2, Number(this.prazoForm.installments) || 2) : 1;
          const amt = this.prazoForm.amountCents || 0;
          const base = Math.floor(amt / count);
          const rem = amt - base * count;
          const out = [];
          for (let i = 0; i < count; i++) {
            const d = new Date((this.prazoForm.firstDueDate || new Date().toISOString().slice(0, 10)) + 'T00:00:00Z');
            d.setUTCDate(d.getUTCDate() + 30 * i);
            out.push({ n: i + 1, count, dueDate: d.toISOString().slice(0, 10), amountCents: i === 0 ? base + rem : base });
          }
          return out;
        },
        confirmPrazoDlg() {
          if (!this.prazoForm.customerId) { this.prazoError = 'Selecione o cliente.'; return; }
          const count = this.prazoForm.mode === 'parcelado' ? Number(this.prazoForm.installments) : 1;
          if (this.prazoForm.mode === 'parcelado' && (count < 2 || count > 12)) { this.prazoError = 'Parcelamento deve ser de 2 a 12 vezes.'; return; }
          if (!this.prazoForm.firstDueDate) { this.prazoError = 'Informe o vencimento.'; return; }
          const prazoMethod = this.methods.find((m) => m.type === 'prazo');
          if (!prazoMethod) { this.prazoError = 'Nenhuma forma de pagamento "a prazo" ativa.'; return; }
          this.pay.list = this.pay.list.filter((p) => this.methodType(p.methodId) !== 'prazo');
          this.pay.list.push({
            methodId: prazoMethod.id, amountCents: this.prazoForm.amountCents,
            customerId: this.prazoForm.customerId, dueDate: this.prazoForm.firstDueDate,
            installments: count > 1 ? { count, firstDueDate: this.prazoForm.firstDueDate } : undefined,
          });
          const rest = this.remaining();
          this.pay.amount = rest > 0 ? (rest / 100).toFixed(2).replace('.', ',') : '';
          this.$refs.prazoDlg.close();
        },

        // ─── Pagamento com pontos de fidelidade ───
        openFidelidadeDlg() {
          const maxByRemaining = this.centsPerPointClient() > 0 ? Math.ceil(this.remaining() / this.centsPerPointClient()) : 0;
          this.fidelidadeForm = { pointsUsed: Math.max(0, Math.min(this.customerBalances.loyaltyPoints || 0, maxByRemaining)) };
          this.fidelidadeError = '';
          this.$refs.fidelidadeDlg.showModal();
        },
        confirmFidelidadeDlg() {
          const pts = Number(this.fidelidadeForm.pointsUsed);
          if (!pts || pts <= 0) { this.fidelidadeError = 'Informe quantos pontos usar.'; return; }
          if (pts > (this.customerBalances.loyaltyPoints || 0)) { this.fidelidadeError = 'Saldo de pontos insuficiente.'; return; }
          const amountCents = Math.round(pts * this.centsPerPointClient());
          if (amountCents > this.remaining()) { this.fidelidadeError = 'Valor maior que o restante.'; return; }
          const method = this.methods.find((m) => m.type === 'fidelidade');
          if (!method) { this.fidelidadeError = 'Forma de pagamento "Pontos de fidelidade" não está ativa.'; return; }
          this.pay.list = this.pay.list.filter((p) => this.methodType(p.methodId) !== 'fidelidade');
          this.pay.list.push({ methodId: method.id, amountCents, pointsUsed: pts, customerId: this.customerId || undefined });
          const rest = this.remaining();
          this.pay.amount = rest > 0 ? (rest / 100).toFixed(2).replace('.', ',') : '';
          this.$refs.fidelidadeDlg.close();
        },

        async finish() {
          if (this.saving || this.remaining() !== 0) return;
          this.saving = true; this.payError = '';
          let cashReceived = this.cents(this.pay.received);
          const hasCarne = this.pay.list.some((p) => p.installments && p.installments.count > 1);
          const payments = this.pay.list.map((p) => {
            const out = { methodId: p.methodId, amountCents: p.amountCents };
            if (this.methodType(p.methodId) === 'dinheiro') {
              const rec = Math.max(p.amountCents, cashReceived);
              out.receivedCents = rec;
              cashReceived = Math.max(0, cashReceived - rec);
            }
            if (p.customerId) out.customerId = p.customerId;
            if (p.dueDate) out.dueDate = p.dueDate;
            if (p.installments) out.installments = p.installments;
            if (p.pointsUsed) out.pointsUsed = p.pointsUsed;
            return out;
          });
          const comandaId = this.slots[this.activeSlot].comandaId;
          let r;
          if (comandaId) {
            const body = {
              payments,
              discountCents: this.discountCents || undefined,
              surchargeCents: this.surchargeCents || undefined,
              customerId: this.customerId || undefined,
            };
            r = await fetch(`/api/comandas/comandas/${comandaId}/close`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          } else {
            const body = {
              items: this.cart.map((i) => ({ productId: i.productId, qty: i.qty, notes: i.notes || undefined, lineGroupUuid: i.lineGroupUuid || undefined })),
              payments,
              discountCents: this.discountCents || undefined,
              surchargeCents: this.surchargeCents || undefined,
              customerId: this.customerId || undefined,
              clientRequestId: this.pay.clientRequestId || undefined,
            };
            r = await fetch('/api/store/sales', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          }
          this.saving = false;
          if (r.ok) {
            const d = await r.json();
            this.lastSaleId = comandaId ? d.saleId : d.id;
            this.lastSaleHasCarne = hasCarne;
            this.$refs.pay.close();
            this.cart = []; this.discountCents = 0; this.surchargeCents = 0; this.customerId = ''; this.customerBalances = {};
            if (comandaId) { this.slots[this.activeSlot].comandaId = null; this.justClosedComandaId = comandaId; }
            this.persistSlots();
            const exibir = this.appSettings?.find(s => s.key === 'vendas.exibir_cupom_fiscal')?.value;
            if (exibir !== '0') this.$refs.postSale.showModal(); else this.onPostSaleClose();
          } else {
            const err = (await r.json()).error ?? 'Erro ao registrar a venda.';
            this.payError = err;
            <% if (user.permissions.has('finance.cash.open')) { %>
            if (err.includes('Abra o caixa')) this.$refs.cashClosedWarnDlg.showModal();
            <% } %>
          }
        },

        // ─── Abrir caixa sem perder a venda em andamento ───
        openRegisterFromSale() {
          this.openRegisterForm = { opening: '', error: '' };
          this.$refs.openRegisterDlg.showModal();
          this.$nextTick(() => this.$refs.openRegisterInput.focus());
        },
        async confirmOpenRegister() {
          const r = await fetch('/api/finance/cash/open', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ openingCents: this.cents(this.openRegisterForm.opening) }),
          });
          if (r.ok) {
            this.$refs.openRegisterDlg.close();
            this.payError = '';
          } else {
            this.openRegisterForm.error = (await r.json()).error ?? 'Erro ao abrir o caixa.';
          }
        },
      };
    }
  </script>
</body>
</html>
