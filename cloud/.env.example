# Porta do servidor HTTP (default: 4000)
CLOUD_PORT=4000

# Conexão com o banco MySQL
CLOUD_DB_HOST=127.0.0.1
CLOUD_DB_PORT=3307
CLOUD_DB_USER=root
CLOUD_DB_PASSWORD=kivo
CLOUD_DB_NAME=kivo_cloud

# URL de download do instalador do Kivo (opcional — usado na landing page)
# KIVO_DOWNLOAD_URL=https://example.com/kivo-setup.exe

# Versão do app exibida na landing page (opcional)
# KIVO_APP_VERSION=1.0.0
