<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Katsu Cloud — Nova empresa</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 480px; margin: 40px auto; }
    input { display: block; width: 100%; padding: 8px; margin-bottom: 12px; box-sizing: border-box; }
    label { font-weight: bold; }
  </style>
</head>
<body>
  <p><a href="/admin">&larr; Empresas</a></p>
  <h1>Nova empresa</h1>
  <form method="post" action="/admin/companies">
    <label>Nome</label>
    <input type="text" name="name" required>
    <label>Plano</label>
    <input type="text" name="plan" placeholder="ex.: basico">
    <label>Módulos (separados por vírgula — vazio = sem restrição)</label>
    <input type="text" name="modules" placeholder="ex.: commercial,finance,store">
    <button type="submit">Criar</button>
  </form>
</body>
</html>
