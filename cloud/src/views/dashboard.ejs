<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%- include('partials/theme-init') %>
  <title>Katsu Cloud — Dashboard</title>
  <link rel="icon" href="/favicon.png">
  <%- include('partials/styles') %>
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <%- include('partials/plan-icons') %>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'dashboard' }) %>
    <main class="content">
      <%- include('partials/navbar', { active: 'dashboard' }) %>

      <div class="page">
        <div class="page-header">
          <div>
            <div class="breadcrumb">Geral</div>
            <h1>Dashboard</h1>
          </div>
          <button class="btn" onclick="document.getElementById('modal-new-company').showModal()">+ Nova empresa</button>
        </div>

        <%
          var totalCompanies = Number(kpis.total_companies || 0);
          var activeCompanies = Number(kpis.active_companies || 0);
          var syncs7d = Number(kpis.syncs_7d || 0);
          var syncsPrev7d = Number(kpis.syncs_prev_7d || 0);
          var newCompanies30d = Number(kpis.new_companies_30d || 0);
          var newCompaniesPrev30d = Number(kpis.new_companies_prev_30d || 0);
          var revenueMonth = Number(kpis.revenue_month_cents || 0) / 100;
          var revenuePrevMonth = Number(kpis.revenue_prev_month_cents || 0) / 100;
          var pendingAmount = Number(kpis.pending_amount_cents || 0) / 100;
          var overdueCount = Number(kpis.overdue_count || 0);
          var activeDevices = Number(kpis.active_devices || 0);

          function brl(v) {
            return v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
          }
          /** Variação percentual; null quando não há base anterior (evita "+100%" enganoso a partir do zero). */
          function pct(cur, prev) {
            if (!prev) return null;
            return ((cur - prev) / prev) * 100;
          }
          function deltaClass(d) {
            if (d === null) return 'flat';
            if (d > 0.5) return 'up';
            if (d < -0.5) return 'down';
            return 'flat';
          }
          function deltaText(d) {
            if (d === null) return 'sem base anterior';
            return (d > 0 ? '+' : '') + d.toFixed(0) + '%';
          }

          var syncDelta = pct(syncs7d, syncsPrev7d);
          var companyDelta = pct(newCompanies30d, newCompaniesPrev30d);
          var revenueDelta = pct(revenueMonth, revenuePrevMonth);
          var activePct = totalCompanies ? Math.round((activeCompanies / totalCompanies) * 100) : 0;
        %>

        <%
          // Ícones de tendência: a seta acompanha a cor, para o sinal não depender só do matiz.
          function deltaIcon(cls) {
            if (cls === 'up') return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>';
            if (cls === 'down') return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>';
            return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>';
          }
        %>

        <div class="dash-kpi-grid">
          <div class="dash-kpi">
            <div class="dash-kpi-icon green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <div class="dash-kpi-value"><%= totalCompanies %></div>
            <div class="dash-kpi-label">Empresas cadastradas</div>
            <div class="dash-kpi-delta <%= deltaClass(companyDelta) %>">
              <%- deltaIcon(deltaClass(companyDelta)) %>
              <span><%= deltaText(companyDelta) %></span>
              <span class="delta-base"><%= newCompanies30d %> em 30 dias</span>
            </div>
          </div>

          <div class="dash-kpi">
            <div class="dash-kpi-icon blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="dash-kpi-value"><%= activeCompanies %></div>
            <div class="dash-kpi-label">Com plano ativo</div>
            <div class="dash-kpi-delta flat">
              <span class="delta-base"><%= activePct %>% da base · <%= activeDevices %> dispositivos</span>
            </div>
          </div>

          <div class="dash-kpi">
            <div class="dash-kpi-icon amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <div class="dash-kpi-value"><%= syncs7d.toLocaleString('pt-BR') %></div>
            <div class="dash-kpi-label">Syncs nos últimos 7 dias</div>
            <div class="dash-kpi-delta <%= deltaClass(syncDelta) %>">
              <%- deltaIcon(deltaClass(syncDelta)) %>
              <span><%= deltaText(syncDelta) %></span>
              <span class="delta-base">vs. 7 dias antes</span>
            </div>
          </div>

          <div class="dash-kpi">
            <div class="dash-kpi-icon red">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div class="dash-kpi-value"><%= brl(pendingAmount) %></div>
            <div class="dash-kpi-label">Cobranças pendentes</div>
            <div class="dash-kpi-delta <%= overdueCount ? 'down' : 'flat' %>">
              <% if (overdueCount) { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <span><%= overdueCount %> vencida<%= overdueCount > 1 ? 's' : '' %></span>
              <% } else { %>
                <span class="delta-base">nenhuma vencida</span>
              <% } %>
            </div>
          </div>
        </div>

        <% if (alerts.length) { %>
        <div class="card" style="margin-bottom: 24px;">
          <h2 style="margin-bottom: 14px;">Avisos</h2>
          <% alerts.forEach(function(a) { %>
          <div class="dash-alert-card <%= a.type %>">
            <div class="dash-alert-icon">
              <% if (a.icon === 'clock') { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <% } else if (a.icon === 'alert') { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <% } else { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <% } %>
            </div>
            <div>
              <div class="dash-alert-text"><strong><%= a.title %></strong> — <%= a.detail %></div>
              <% if (a.link) { %><div class="dash-alert-action"><a href="<%= a.link %>">Ver detalhes →</a></div><% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>

        <%
          // ─── Geometria do gráfico de área (sincronizações, 14 dias) ───
          // apadL acomoda o maior rótulo do eixo no celular, onde o texto sobe p/ 17 unidades.
          var AW = 560, AH = 170, apadL = 48, apadR = 10, apadT = 14, apadB = 24;
          var aPlotW = AW - apadL - apadR, aPlotH = AH - apadT - apadB;
          var counts = syncTrend.map(function (p) { return p.count; });
          var syncTotal = counts.reduce(function (s, v) { return s + v; }, 0);
          var rawMax = Math.max.apply(null, counts.concat([1]));
          // Arredonda o topo para um número redondo — o eixo fica legível.
          var mag = Math.pow(10, Math.floor(Math.log10(rawMax)));
          var aMax = Math.ceil(rawMax / (mag / 2 || 1)) * (mag / 2 || 1);
          if (!isFinite(aMax) || aMax <= 0) aMax = 1;
          // Piso de 2: abaixo disso as três marcas (0, meio, topo) arredondam para o mesmo rótulo.
          aMax = Math.max(aMax, 2);

          function ax(i) { return apadL + (counts.length > 1 ? (i * aPlotW) / (counts.length - 1) : aPlotW / 2); }
          function ay(v) { return apadT + aPlotH - (v / aMax) * aPlotH; }

          var linePts = counts.map(function (v, i) { return ax(i).toFixed(1) + ',' + ay(v).toFixed(1); });
          var linePath = 'M' + linePts.join('L');
          var areaPath = linePath + 'L' + ax(counts.length - 1).toFixed(1) + ',' + (apadT + aPlotH) + 'L' + ax(0).toFixed(1) + ',' + (apadT + aPlotH) + 'Z';

          function ddmm(iso) { var p = String(iso).split('-'); return p[2] + '/' + p[1]; }

          /** Milhares abreviados: o eixo tem largura fixa, "12,5k" cabe onde "12500" não cabe. */
          function shortNum(v) {
            if (v >= 1000) return (v / 1000).toFixed(v >= 10000 ? 0 : 1).replace('.', ',') + 'k';
            return String(Math.round(v));
          }
        %>

        <div class="dash-two-col">
          <div class="card dash-chart viz" id="viz-sync">
            <div class="viz-head">
              <h2>Sincronizações</h2>
              <span class="viz-sub" style="margin:0;">últimos 14 dias</span>
            </div>
            <div class="viz-hero"><%= syncTotal.toLocaleString('pt-BR') %></div>
            <p class="viz-sub">registros recebidos no período</p>

            <div style="position: relative;">
              <svg class="viz-svg" viewBox="0 0 <%= AW %> <%= AH %>" role="img"
                   aria-label="Sincronizações diárias nos últimos 14 dias, total de <%= syncTotal %> registros">
                <defs>
                  <linearGradient id="viz-area-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--viz-series-1)" stop-opacity="0.28"/>
                    <stop offset="100%" stop-color="var(--viz-series-1)" stop-opacity="0.02"/>
                  </linearGradient>
                </defs>

                <% for (var g = 0; g <= 2; g++) {
                     var gv = (aMax / 2) * g, gy = ay(gv); %>
                  <line class="viz-grid-line" x1="<%= apadL %>" y1="<%= gy.toFixed(1) %>" x2="<%= AW - apadR %>" y2="<%= gy.toFixed(1) %>"/>
                  <text class="viz-tick" x="<%= apadL - 7 %>" y="<%= (gy + 3.5).toFixed(1) %>" text-anchor="end"><%= shortNum(gv) %></text>
                <% } %>

                <path class="viz-area" d="<%= areaPath %>"/>
                <path class="viz-line" d="<%= linePath %>"/>

                <line class="viz-crosshair" id="sync-crosshair" x1="0" y1="<%= apadT %>" x2="0" y2="<%= apadT + aPlotH %>" style="display:none"/>
                <circle class="viz-dot" id="sync-dot" r="4.5" cx="0" cy="0" style="display:none"/>

                <%
                  // Espaça a cada 3 dias a partir do último, para o dia de hoje sempre ter rótulo.
                  // As pontas ancoram para dentro; centralizadas, elas vazariam do viewBox.
                  var lastIdx = syncTrend.length - 1;
                %>
                <% syncTrend.forEach(function (p, i) { %>
                  <% if ((lastIdx - i) % 3 === 0) { %>
                  <text class="viz-tick" x="<%= ax(i).toFixed(1) %>" y="<%= AH - 6 %>"
                        text-anchor="<%= i === 0 ? 'start' : (i === lastIdx ? 'end' : 'middle') %>"><%= ddmm(p.date) %></text>
                  <% } %>
                <% }) %>

                <% syncTrend.forEach(function (p, i) {
                     var half = counts.length > 1 ? aPlotW / (counts.length - 1) / 2 : aPlotW / 2; %>
                <rect class="viz-hit" x="<%= (ax(i) - half).toFixed(1) %>" y="<%= apadT %>"
                      width="<%= (half * 2).toFixed(1) %>" height="<%= aPlotH %>"
                      data-x="<%= ax(i).toFixed(1) %>" data-y="<%= ay(p.count).toFixed(1) %>"
                      data-label="<%= ddmm(p.date) %>" data-value="<%= p.count %>"></rect>
                <% }) %>
              </svg>
              <div class="viz-tooltip" id="sync-tooltip" style="display:none" role="status" aria-live="polite"></div>
            </div>

            <button type="button" class="viz-table-toggle" data-table="sync-table" aria-expanded="false">Ver dados em tabela</button>
            <table class="viz-table" id="sync-table" hidden>
              <thead><tr><th>Dia</th><th class="text-right">Sincronizações</th></tr></thead>
              <tbody>
                <% syncTrend.forEach(function (p) { %>
                <tr><td><%= ddmm(p.date) %></td><td class="text-right"><%= p.count %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <%
            // ─── Geometria do gráfico de barras (receita, 6 meses) ───
            var BW = 560, BH = 170, bpadL = 78, bpadR = 10, bpadT = 14, bpadB = 24;
            var bPlotW = BW - bpadL - bpadR, bPlotH = BH - bpadT - bpadB;
            var cents = revenueTrend.map(function (r) { return r.cents; });
            var revTotal = cents.reduce(function (s, v) { return s + v; }, 0);
            var rMaxRaw = Math.max.apply(null, cents.concat([1]));
            var rMag = Math.pow(10, Math.floor(Math.log10(rMaxRaw)));
            var rMax = Math.ceil(rMaxRaw / (rMag / 2 || 1)) * (rMag / 2 || 1);
            if (!isFinite(rMax) || rMax <= 0) rMax = 1;
            // Piso de R$ 100: sem isso, um mês zerado renderiza três marcas "R$ 0".
            rMax = Math.max(rMax, 10000);

            var slot = bPlotW / revenueTrend.length;
            var barW = Math.min(38, slot * 0.56);
            function by(v) { return bpadT + bPlotH - (v / rMax) * bPlotH; }

            /**
             * Barra com topo arredondado e base reta: o dado termina na linha de base.
             * Recebe números — formatar antes de entrar transforma as somas em concatenação.
             */
            function barPath(x, y, w, h, r) {
              if (h <= 0.5) return '';
              x = Number(x); y = Number(y); w = Number(w); h = Number(h);
              r = Math.min(Number(r), w / 2, h);
              var n = function (v) { return Number(v).toFixed(1); };
              var b = y + h;
              return 'M' + n(x) + ',' + n(b) +
                     'V' + n(y + r) +
                     'a' + n(r) + ',' + n(r) + ' 0 0 1 ' + n(r) + ',' + n(-r) +
                     'h' + n(w - 2 * r) +
                     'a' + n(r) + ',' + n(r) + ' 0 0 1 ' + n(r) + ',' + n(r) +
                     'V' + n(b) + 'Z';
            }
            var MONTHS = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
            function monthLabel(ym) {
              var p = String(ym).split('-');
              return MONTHS[Number(p[1]) - 1] + '/' + String(p[0]).slice(2);
            }
            function brlShort(c) {
              var v = c / 100;
              if (v >= 1000) return 'R$ ' + (v / 1000).toFixed(v >= 10000 ? 0 : 1).replace('.', ',') + 'k';
              return 'R$ ' + v.toFixed(0);
            }
          %>

          <div class="card dash-chart viz" id="viz-revenue">
            <div class="viz-head">
              <h2>Receita recebida</h2>
              <span class="viz-sub" style="margin:0;">últimos 6 meses</span>
            </div>
            <div class="viz-hero"><%= brl(revTotal / 100) %></div>
            <p class="viz-sub">
              <%= brl(revenueMonth) %> neste mês
              <% if (revenueDelta !== null) { %>
                · <%= deltaText(revenueDelta) %> vs. mês anterior
              <% } %>
            </p>

            <div style="position: relative;">
              <svg class="viz-svg" viewBox="0 0 <%= BW %> <%= BH %>" role="img"
                   aria-label="Receita recebida por mês nos últimos 6 meses, total de <%= brl(revTotal / 100) %>">
                <% for (var g2 = 0; g2 <= 2; g2++) {
                     var rv = (rMax / 2) * g2, ry = by(rv); %>
                  <line class="viz-grid-line" x1="<%= bpadL %>" y1="<%= ry.toFixed(1) %>" x2="<%= BW - bpadR %>" y2="<%= ry.toFixed(1) %>"/>
                  <text class="viz-tick" x="<%= bpadL - 7 %>" y="<%= (ry + 3.5).toFixed(1) %>" text-anchor="end"><%= brlShort(rv) %></text>
                <% } %>
                <line class="viz-axis-line" x1="<%= bpadL %>" y1="<%= bpadT + bPlotH %>" x2="<%= BW - bpadR %>" y2="<%= bpadT + bPlotH %>"/>

                <% revenueTrend.forEach(function (r, i) {
                     var cx = bpadL + slot * i + slot / 2;
                     var x = cx - barW / 2;
                     var y = by(r.cents);
                     var h = (bpadT + bPlotH) - y; %>
                <g class="viz-bar-group">
                  <% if (h > 0.5) { %>
                  <path class="viz-bar" d="<%= barPath(x, y, barW, h, 4) %>"/>
                  <% } %>
                  <rect class="viz-hit" x="<%= (cx - slot / 2).toFixed(1) %>" y="<%= bpadT %>"
                        width="<%= slot.toFixed(1) %>" height="<%= bPlotH %>"
                        data-x="<%= cx.toFixed(1) %>" data-y="<%= Math.max(y, bpadT).toFixed(1) %>"
                        data-label="<%= monthLabel(r.month) %>" data-value="<%= brl(r.cents / 100) %>"></rect>
                  <text class="viz-tick" x="<%= cx.toFixed(1) %>" y="<%= BH - 6 %>" text-anchor="middle"><%= monthLabel(r.month) %></text>
                </g>
                <% }) %>
              </svg>
              <div class="viz-tooltip" id="revenue-tooltip" style="display:none" role="status" aria-live="polite"></div>
            </div>

            <button type="button" class="viz-table-toggle" data-table="revenue-table" aria-expanded="false">Ver dados em tabela</button>
            <table class="viz-table" id="revenue-table" hidden>
              <thead><tr><th>Mês</th><th class="text-right">Recebido</th></tr></thead>
              <tbody>
                <% revenueTrend.forEach(function (r) { %>
                <tr><td><%= monthLabel(r.month) %></td><td class="text-right"><%= brl(r.cents / 100) %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <%
          // Planos são níveis ordenados: rampa de hue único, do mais claro (trial) ao mais escuro.
          var tierRank = {};
          planTiers.forEach(function (t, i) { tierRank[t] = i; });
          function planColor(label) {
            var r = tierRank[label];
            if (r === undefined) return 'var(--viz-axis)';
            return 'var(--viz-ordinal-' + Math.min(r + 1, 4) + ')';
          }
          var maxPlanCount = planDistribution.length
            ? Math.max.apply(null, planDistribution.map(function (p) { return Number(p.cnt); }))
            : 1;
        %>

        <div class="dash-two-col">
          <div class="card dash-chart">
            <div class="viz-head">
              <h2>Planos</h2>
              <span class="viz-sub" style="margin:0;"><%= activeCompanies %> de <%= totalCompanies %> com plano</span>
            </div>
            <% if (planDistribution.length) { %>
            <div class="dash-bar-list" style="margin-top: 12px;">
              <% planDistribution.forEach(function (p) {
                   var seal = planTiers.includes(p.plan_label) ? p.plan_label : 'none'; %>
              <div class="dash-bar-row">
                <div class="dash-bar-label plan-seal-label plan-seal--<%= seal %>">
                  <svg class="plan-seal-icon"><use href="#plan-icon-<%= seal %>"/></svg>
                  <span><%= planLabels[p.plan_label] || p.plan_label %></span>
                </div>
                <div class="dash-bar-track">
                  <div class="dash-bar-fill" style="width: <%= Math.max(Math.round((Number(p.cnt) / maxPlanCount) * 100), 2) %>%; background: <%= planColor(p.plan_label) %>;"></div>
                </div>
                <div class="dash-bar-count"><%= p.cnt %></div>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <div class="dash-empty">Nenhum plano atribuído ainda.</div>
            <% } %>
          </div>

          <div class="card">
            <div class="viz-head">
              <h2>Atividade recente</h2>
              <a href="/admin/companies" class="card-link">Ver empresas →</a>
            </div>
            <% if (recentActivity.length) { %>
            <div class="dash-activity-list">
              <% recentActivity.forEach(function(a) { %>
              <div class="dash-activity-item">
                <div class="dash-activity-dot green"></div>
                <div>
                  <div class="dash-activity-text">
                    <strong><%= a.name || a.company_uuid.slice(0, 8) %></strong>
                    sincronizou <strong><%= a.entity_type %></strong>
                  </div>
                  <div class="dash-activity-time"><%= a.server_received_at %></div>
                </div>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <div class="dash-empty">Nenhuma sincronização registrada ainda.</div>
            <% } %>
          </div>
        </div>

      </div>
    </main>
  </div>

  <dialog id="modal-new-company">
    <form method="post" action="/admin/companies">
      <div class="modal-header">
        <h2>Nova empresa</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-new-company').close()">&times;</button>
      </div>
      <div class="modal-body">
        <label>Nome</label>
        <input type="text" name="name" required autofocus>
        <label>Plano</label>
        <%- include('partials/plan-picker', { selectedPlan: '' }) %>
        <label>Válido até</label>
        <input type="date" name="validUntil">
        <p class="field-hint">Deixe em branco no plano Trial para usar automaticamente hoje + 15 dias.</p>
        <%- include('partials/module-toggles', { checkedModules: [] }) %>
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-new-company').close()">Cancelar</button>
          <button type="submit" class="btn">Criar empresa</button>
        </div>
      </div>
    </form>
  </dialog>

  <script>
    (function () {
      /**
       * Liga a camada de hover de um gráfico SVG. As coordenadas vêm do viewBox,
       * então convertemos para pixels pela largura renderizada — o SVG é fluido.
       */
      function attachHover(rootId, tooltipId, viewBoxWidth, opts) {
        var root = document.getElementById(rootId);
        if (!root) return;
        var svg = root.querySelector('.viz-svg');
        var tooltip = document.getElementById(tooltipId);
        var crosshair = opts.crosshair ? document.getElementById(opts.crosshair) : null;
        var dot = opts.dot ? document.getElementById(opts.dot) : null;
        var hits = root.querySelectorAll('.viz-hit');

        function show(hit) {
          var x = parseFloat(hit.dataset.x);
          var y = parseFloat(hit.dataset.y);
          var scale = svg.getBoundingClientRect().width / viewBoxWidth;

          tooltip.innerHTML =
            '<div class="tt-label">' + hit.dataset.label + '</div>' +
            '<div class="tt-value">' + hit.dataset.value + '</div>';
          tooltip.style.display = 'block';
          tooltip.style.left = (x * scale) + 'px';
          tooltip.style.top = (y * scale - 10) + 'px';

          if (crosshair) {
            crosshair.setAttribute('x1', x);
            crosshair.setAttribute('x2', x);
            crosshair.style.display = '';
          }
          if (dot) {
            dot.setAttribute('cx', x);
            dot.setAttribute('cy', y);
            dot.style.display = '';
          }
        }
        function hide() {
          tooltip.style.display = 'none';
          if (crosshair) crosshair.style.display = 'none';
          if (dot) dot.style.display = 'none';
        }

        hits.forEach(function (hit) {
          hit.addEventListener('mouseenter', function () { show(hit); });
          hit.addEventListener('focus', function () { show(hit); });
          // No toque não existe "sair"; o próprio toque alterna o ponto exibido.
          hit.addEventListener('touchstart', function (e) { e.preventDefault(); show(hit); }, { passive: false });
        });
        root.addEventListener('mouseleave', hide);
        root.addEventListener('blur', hide, true);
        window.addEventListener('resize', hide);
      }

      attachHover('viz-sync', 'sync-tooltip', <%= AW %>, { crosshair: 'sync-crosshair', dot: 'sync-dot' });
      attachHover('viz-revenue', 'revenue-tooltip', <%= BW %>, {});

      document.querySelectorAll('.viz-table-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var table = document.getElementById(btn.dataset.table);
          var open = table.hasAttribute('hidden');
          table.toggleAttribute('hidden', !open);
          btn.setAttribute('aria-expanded', String(open));
          btn.textContent = open ? 'Ocultar tabela' : 'Ver dados em tabela';
        });
      });
    })();
  </script>
</body>
</html>
