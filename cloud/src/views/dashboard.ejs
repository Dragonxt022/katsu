<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Katsu Cloud — Empresas</title>
  <%- include('partials/styles') %>
</head>
<body>
  <%- include('partials/navbar', { active: 'dashboard' }) %>

  <div class="page">
    <div class="page-header">
      <h1>Empresas</h1>
      <button class="btn" onclick="document.getElementById('modal-new-company').showModal()">+ Nova empresa</button>
    </div>

    <div class="card" style="padding: 0;">
      <table>
        <thead>
          <tr><th>Nome</th><th>Plano</th><th>Módulos</th><th>Validade</th><th>Sincronizações</th><th>Última atividade</th><th>Pendente (R$)</th></tr>
        </thead>
        <tbody>
          <% companies.forEach(function(c) { %>
          <tr>
            <td><a href="/admin/companies/<%= c.company_uuid %>"><%= c.name || c.company_uuid %></a></td>
            <td><% if (c.plan) { %><span class="badge plan"><%= planLabels[c.plan] || c.plan %></span><% } else { %>—<% } %></td>
            <td><%= c.modules ? c.modules.join(', ') : 'sem restrição' %></td>
            <td><%= c.valid_until || '—' %></td>
            <td><%= c.sync_count %></td>
            <td><%= c.last_activity || 'nunca' %></td>
            <td><% if (c.pending_cents > 0) { %><span class="badge money-pending"><%= (c.pending_cents / 100).toFixed(2) %></span><% } else { %><%= (c.pending_cents / 100).toFixed(2) %><% } %></td>
          </tr>
          <% }) %>
          <% if (!companies.length) { %>
          <tr><td colspan="7" class="empty-state">Nenhuma empresa cadastrada ainda.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <dialog id="modal-new-company">
    <form method="post" action="/admin/companies">
      <div class="modal-header">
        <h2>Nova empresa</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-new-company').close()">&times;</button>
      </div>
      <div class="modal-body">
        <label>Nome</label>
        <input type="text" name="name" required autofocus>
        <label>Plano</label>
        <select name="plan">
          <option value="">—</option>
          <% planTiers.forEach(function(tier) { %>
          <option value="<%= tier %>"><%= planLabels[tier] %></option>
          <% }) %>
        </select>
        <label>Válido até</label>
        <input type="date" name="validUntil">
        <p class="field-hint">Deixe em branco no plano Trial para usar automaticamente hoje + 15 dias.</p>
        <%- include('partials/module-toggles', { checkedModules: [] }) %>
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-new-company').close()">Cancelar</button>
          <button type="submit" class="btn">Criar empresa</button>
        </div>
      </div>
    </form>
  </dialog>
</body>
</html>
