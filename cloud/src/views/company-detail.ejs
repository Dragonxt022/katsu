<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <%- include('partials/theme-init') %>
  <title>Katsu Cloud — <%= company.name || company.company_uuid %></title>
  <link rel="icon" href="/favicon.png">
  <%- include('partials/styles') %>
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', {}) %>
    <main class="content">
      <%- include('partials/navbar', {}) %>

      <div class="page">
    <div class="breadcrumb"><a href="/admin">&larr; Empresas</a></div>

    <% if (typeof revealedLicenseKey !== 'undefined' && revealedLicenseKey) { %>
      <div class="key-reveal">
        <strong>Chave de licença (mostrada uma única vez — copie agora):</strong><br>
        <code><%= revealedLicenseKey %></code>
      </div>
    <% } %>

    <div class="page-header">
      <div>
        <h1><%= company.name || company.company_uuid %></h1>
        <div class="breadcrumb"><%= company.company_uuid %></div>
      </div>
    </div>

    <div class="card">
      <h2>Dados</h2>
      <form method="post" action="/admin/companies/<%= company.company_uuid %>">
        <label>Nome</label>
        <input type="text" name="name" value="<%= company.name || '' %>">
        <label>Plano</label>
        <select name="plan">
          <option value="">—</option>
          <% planTiers.forEach(function(tier) { %>
          <option value="<%= tier %>" <%= company.plan === tier ? 'selected' : '' %>><%= planLabels[tier] %></option>
          <% }) %>
          <% if (company.plan && !planTiers.includes(company.plan)) { %>
          <option value="<%= company.plan %>" selected><%= company.plan %> (legado)</option>
          <% } %>
        </select>
        <%- include('partials/module-toggles', { checkedModules: company.modules || [] }) %>
        <label>Validade</label>
        <input type="date" name="validUntil" value="<%= company.valid_until ? String(company.valid_until).slice(0,10) : '' %>">
        <label>Limite de dispositivos</label>
        <input type="number" name="maxDevices" min="1" value="<%= company.max_devices || 1 %>">
        <p class="field-hint">Quantos computadores podem usar esta chave ao mesmo tempo. Para trocar de máquina além do limite, remova um dispositivo abaixo.</p>
        <div class="modal-actions" style="justify-content: flex-start;">
          <button type="submit" class="btn">Salvar</button>
          <button type="button" class="btn danger" onclick="document.getElementById('modal-rotate-key').showModal()">Gerar nova chave de licença</button>
        </div>
      </form>
    </div>

    <div class="card">
      <h2>Dispositivos ativados</h2>
      <p class="field-hint" style="margin-top:0">
        Máquinas que já validaram esta licença. Remover libera a vaga e bloqueia imediatamente aquela máquina —
        use para autorizar a troca de computador de um cliente.
      </p>
      <table>
        <thead><tr><th>Machine ID</th><th>Primeira vez visto</th><th>Visto por último</th><th></th></tr></thead>
        <tbody>
          <% devices.forEach(function(d) { %>
          <tr>
            <td class="muted"><%= d.machine_id.slice(0, 16) %>…</td>
            <td><%= d.first_seen_at %></td>
            <td><%= d.last_seen_at %></td>
            <td class="text-right">
              <form method="post" action="/admin/companies/<%= company.company_uuid %>/devices/<%= d.id %>/delete"
                    onsubmit="return confirm('Remover este dispositivo? Ele será bloqueado imediatamente na próxima tentativa de uso.')">
                <button type="submit" class="btn danger small">Remover</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (!devices.length) { %><tr><td colspan="4"><%- include('partials/empty-state', { message: 'Nenhum dispositivo ativado ainda.' }) %></td></tr><% } %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2>Sincronização</h2>
      <div class="stat-row">
        <div class="stat">
          <div class="value"><%= syncStats.total %></div>
          <div class="label">Registros sincronizados</div>
        </div>
        <div class="stat">
          <div class="value"><%= syncStats.last_activity || 'nunca' %></div>
          <div class="label">Última atividade</div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Backups na nuvem</h2>
      <table>
        <thead><tr><th>UUID</th><th>Máquina</th><th>Tamanho</th><th>Quando</th></tr></thead>
        <tbody>
          <% backups.forEach(function(b) { %>
          <tr><td><%= b.uuid %></td><td><%= b.machine_id %></td><td><%= (b.size_bytes/1024).toFixed(1) %> KB</td><td><%= b.created_at %></td></tr>
          <% }) %>
          <% if (!backups.length) { %><tr><td colspan="4"><%- include('partials/empty-state', { message: 'Nenhum backup ainda.' }) %></td></tr><% } %>
        </tbody>
      </table>
    </div>

    <div class="card" x-data="chargesTable()">
      <div class="card-header">
        <h2>Cobranças</h2>
        <button class="btn" onclick="document.getElementById('modal-new-charge').showModal()">+ Nova cobrança</button>
      </div>
      <table>
        <thead><tr>
          <th class="sortable" @click="sortCycle('description')">Descrição<span class="sort-arrow" x-text="sortArrow('description')"></span></th>
          <th class="sortable" @click="sortCycle('amount_cents')">Valor<span class="sort-arrow" x-text="sortArrow('amount_cents')"></span></th>
          <th class="sortable" @click="sortCycle('due_date')">Vencimento<span class="sort-arrow" x-text="sortArrow('due_date')"></span></th>
          <th class="sortable" @click="sortCycle('status')">Status<span class="sort-arrow" x-text="sortArrow('status')"></span></th>
          <th>Pago em</th><th>Instruções</th><th></th>
        </tr></thead>
        <tbody>
          <template x-for="ch in displayRows" :key="ch.id">
            <tr>
              <td x-text="ch.description"></td>
              <td x-text="(ch.amount_cents/100).toFixed(2)"></td>
              <td x-text="ch.due_date"></td>
              <td><span class="badge" :class="ch.status" x-text="ch.status"></span></td>
              <td x-text="ch.paid_at || '—'"></td>
              <td class="instructions-cell" :title="ch.instructions || ''" x-text="ch.instructions || '—'"></td>
              <td class="text-right" @click.outside="openMenu = null">
                <div class="dropdown" x-show="ch.status === 'pendente'">
                  <button type="button" class="icon-btn" @click="openMenu = openMenu === ch.id ? null : ch.id" title="Mais ações">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                  </button>
                  <div class="dropdown-menu" x-show="openMenu === ch.id" x-cloak>
                    <form method="post" :action="'/admin/companies/<%= company.company_uuid %>/charges/' + ch.id + '/pay'"><button type="submit">Marcar paga</button></form>
                    <form method="post" :action="'/admin/companies/<%= company.company_uuid %>/charges/' + ch.id + '/cancel'"><button type="submit" class="danger">Cancelar</button></form>
                  </div>
                </div>
              </td>
            </tr>
          </template>
          <tr x-show="!displayRows.length"><td colspan="7"><%- include('partials/empty-state', { message: 'Nenhuma cobrança ainda.' }) %></td></tr>
        </tbody>
      </table>
    </div>

    <div class="card" style="border-color: color-mix(in srgb, var(--danger) 40%, transparent);">
      <h2 style="color: var(--danger);">Zona de perigo</h2>
      <p class="field-hint" style="margin-top:0;">
        Apaga a empresa e todo o histórico de sincronização, backups e cobranças associados. Imagens que ela enviou
        ao banco de imagens permanecem lá (sem vínculo). Essa ação não pode ser desfeita.
      </p>
      <button type="button" class="btn danger" onclick="document.getElementById('modal-delete-company').showModal()">Excluir empresa definitivamente</button>
    </div>
      </div>
    </main>
  </div>

  <dialog id="modal-new-charge">
    <form method="post" action="/admin/companies/<%= company.company_uuid %>/charges">
      <div class="modal-header">
        <h2>Nova cobrança</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-new-charge').close()">&times;</button>
      </div>
      <div class="modal-body">
        <label>Descrição</label>
        <input type="text" name="description" required autofocus>
        <label>Valor (R$)</label>
        <input type="number" step="0.01" name="amount" required>
        <label>Vencimento</label>
        <input type="date" name="dueDate" required>
        <label>Instruções de pagamento</label>
        <textarea name="instructions" rows="3" placeholder="ex.: chave PIX, dados bancários, como enviar o comprovante..."></textarea>
        <p class="field-hint">Aparece para o cliente na tela de Cobranças do app instalado.</p>
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-new-charge').close()">Cancelar</button>
          <button type="submit" class="btn">Registrar cobrança</button>
        </div>
      </div>
    </form>
  </dialog>

  <dialog id="modal-rotate-key">
    <form method="post" action="/admin/companies/<%= company.company_uuid %>/rotate-key">
      <div class="modal-header">
        <h2>Gerar nova chave?</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-rotate-key').close()">&times;</button>
      </div>
      <div class="modal-body">
        <p style="margin-top:0;">A chave de licença atual desta empresa deixará de funcionar imediatamente. Todas as instalações do cliente precisarão ser reconfiguradas com a nova chave.</p>
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-rotate-key').close()">Cancelar</button>
          <button type="submit" class="btn danger">Sim, gerar nova chave</button>
        </div>
      </div>
    </form>
  </dialog>

  <dialog id="modal-delete-company">
    <form method="post" action="/admin/companies/<%= company.company_uuid %>/delete">
      <div class="modal-header">
        <h2>Excluir empresa?</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-delete-company').close()">&times;</button>
      </div>
      <div class="modal-body">
        <p style="margin-top:0;">
          Isso vai apagar <strong><%= company.name || company.company_uuid %></strong> e todo o histórico de
          sincronização, backups e cobranças dela — sem volta. Digite
          <strong><%= company.name || company.company_uuid %></strong> para confirmar.
        </p>
        <input type="text" id="delete-confirm-input" placeholder="Digite o nome da empresa" autocomplete="off">
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-delete-company').close()">Cancelar</button>
          <button type="submit" class="btn danger" id="delete-confirm-submit" disabled>Sim, excluir de vez</button>
        </div>
      </div>
    </form>
  </dialog>

  <script src="/js/table-toolkit.js"></script>
  <script>
    function chargesTable() {
      return {
        ...tableToolkit(),
        rows: <%- JSON.stringify(charges.map(function (ch) {
          return { ...ch, due_date: String(ch.due_date).slice(0, 10) };
        })) %>,
        sortGetters: {
          description: (c) => c.description, amount_cents: (c) => c.amount_cents,
          due_date: (c) => c.due_date, status: (c) => c.status,
        },
        get displayRows() { return this.sortedRows(this.rows, this.sortGetters); },
      };
    }

    (function () {
      var expected = <%- JSON.stringify(company.name || company.company_uuid) %>;
      var input = document.getElementById('delete-confirm-input');
      var submitBtn = document.getElementById('delete-confirm-submit');
      input.addEventListener('input', function () {
        submitBtn.disabled = input.value !== expected;
      });
    })();
  </script>
</body>
</html>
