<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%- include('partials/theme-init') %>
  <title>Kivo Cloud — Administradores</title>
  <%- include('partials/styles') %>
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'admins' }) %>
    <main class="content">
      <%- include('partials/navbar', { active: 'admins' }) %>

      <div class="page" x-data="adminsPage()">
        <div class="page-header">
          <h1>Administradores</h1>
          <button class="btn" onclick="document.getElementById('modal-new-admin').showModal()">+ Novo administrador</button>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-banner"><%= error %></div>
        <% } %>

        <div class="toolbar" style="margin-bottom: 14px;">
          <input type="text" class="input-search" placeholder="Buscar por usuário…" x-model="q">
        </div>

        <div class="card" style="padding: 0;">
          <table>
            <thead><tr>
              <th class="sortable" @click="sortCycle('username')">Usuário<span class="sort-arrow" x-text="sortArrow('username')"></span></th>
              <th class="sortable" @click="sortCycle('created_at')">Criado em<span class="sort-arrow" x-text="sortArrow('created_at')"></span></th>
              <th></th>
            </tr></thead>
            <tbody>
              <template x-for="a in displayRows" :key="a.id">
                <tr>
                  <td x-text="a.username"></td>
                  <td x-text="a.created_at"></td>
                  <td style="text-align: right;">
                    <form method="post" :action="'/admin/admins/' + a.id + '/delete'"
                          @submit.prevent="if (confirm('Excluir o administrador \'' + a.username + '\'?')) $el.submit()">
                      <button type="submit" class="btn danger small">Excluir</button>
                    </form>
                  </td>
                </tr>
              </template>
              <tr x-show="!displayRows.length"><td colspan="3"><%- include('partials/empty-state', { message: 'Nenhum administrador cadastrado.' }) %></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <dialog id="modal-new-admin">
    <form method="post" action="/admin/admins">
      <div class="modal-header">
        <h2>Novo administrador</h2>
        <button type="button" class="modal-close" onclick="document.getElementById('modal-new-admin').close()">&times;</button>
      </div>
      <div class="modal-body">
        <label>Usuário</label>
        <input type="text" name="username" required autofocus>
        <label>Senha</label>
        <input type="password" name="password" required minlength="8">
        <p class="field-hint">Pelo menos 8 caracteres.</p>
        <div class="modal-actions">
          <button type="button" class="btn secondary" onclick="document.getElementById('modal-new-admin').close()">Cancelar</button>
          <button type="submit" class="btn">Criar</button>
        </div>
      </div>
    </form>
  </dialog>

  <script src="/js/table-toolkit.js"></script>
  <script>
    function adminsPage() {
      return {
        ...tableToolkit(),
        rows: <%- JSON.stringify(admins) %>,
        q: '',
        sortGetters: { username: (a) => a.username, created_at: (a) => a.created_at ?? '' },
        get displayRows() {
          const q = this.q.trim().toLowerCase();
          const filtered = q ? this.rows.filter((a) => a.username.toLowerCase().includes(q)) : this.rows;
          return this.sortedRows(filtered, this.sortGetters);
        },
      };
    }
  </script>
</body>
</html>
