<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%- include('partials/theme-init') %>
  <title><%= company ? `Cardápio — ${company.name ?? 'Kivo'}` : 'Cardápio não encontrado' %></title>
  <meta name="description" content="<%= company ? `Cardápio digital de ${company.name ?? 'Kivo'}` : 'Cardápio não encontrado' %>">
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg">
  <%- include('partials/styles') %>
  <link rel="stylesheet" href="/css/cardapio.css">
  <%
    // Paleta de acento por categoria — determinística (hash simples do nome), pra cada
    // categoria sempre cair na mesma cor/ícone entre visitas, sem precisar de dado extra.
    var ACCENTS = [
      { hue: '#FF8000', bg: 'color-mix(in srgb, #FF8000 12%, transparent)' },
      { hue: '#f59e0b', bg: 'color-mix(in srgb, #f59e0b 14%, transparent)' },
      { hue: '#3b82f6', bg: 'color-mix(in srgb, #3b82f6 12%, transparent)' },
      { hue: '#ec4899', bg: 'color-mix(in srgb, #ec4899 12%, transparent)' },
      { hue: '#8b5cf6', bg: 'color-mix(in srgb, #8b5cf6 12%, transparent)' },
      { hue: '#ef4444', bg: 'color-mix(in srgb, #ef4444 12%, transparent)' },
    ];
    function accentFor(name) {
      var h = 0;
      for (var i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
      return ACCENTS[h % ACCENTS.length];
    }
    // Ícone por categoria — reconhece palavras comuns de cardápio em pt-BR; sem match,
    // cai num garfo-e-faca genérico. Puramente cosmético, não depende de dado novo.
    function iconFor(name) {
      var n = name.toLowerCase();
      if (/bebida|suco|refri|drink|cerveja|chopp|vinho|caf[ée]/.test(n))
        return '<path d="M8 2h8l-1 7H9L8 2Z"/><path d="M12 9v13"/><path d="M8 22h8"/>';
      if (/sobremesa|doce|bolo|sorvete|pudim/.test(n))
        return '<path d="M20 21H4a1 1 0 0 1-1-1v-2a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v2a1 1 0 0 1-1 1Z"/><path d="M12 4a2 2 0 1 0-2-2 2 2 0 0 0 2 2Z"/><path d="M12 14V4"/>';
      if (/lanche|burger|hamb[uú]rguer|sandu[ií]che/.test(n))
        return '<path d="M3 11h18v2a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-2Z"/><path d="M4 11a8 4 0 0 1 16 0"/><path d="M3 17h18"/>';
      if (/pizza/.test(n))
        return '<path d="m12 2 9.5 8.5L12 22 2.5 10.5Z"/><circle cx="12" cy="10" r="1.2" fill="currentColor" stroke="none"/>';
      if (/salada|vegetari|vegano|legume/.test(n))
        return '<path d="M12 3c-4 0-7 3-7 7 0 6 4 10 7 11 3-1 7-5 7-11 0-4-3-7-7-7Z"/><path d="M12 3v18"/>';
      if (/massa|macarr[aã]o|lasanha|nhoque/.test(n))
        return '<circle cx="12" cy="12" r="9"/><path d="M8 9c1 2 1 4 0 6M12 8c1 2.5 1 5.5 0 8M16 9c1 2 1 4 0 6"/>';
      if (/carne|churrasco|grelhado|espeto/.test(n))
        return '<path d="M8.5 8.5 3 21l4-1.5"/><path d="M14 3a5 5 0 0 1 5 5c0 3-2 4.5-4 6.5s-3.5 4-6.5 4a5 5 0 0 1-5-5c0-3 2-4.5 4-6.5S11 3 14 3Z"/>';
      return '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>';
    }
    var DIACRITICS_RE = new RegExp('\\u0300-\\u036f'.replace(/(.+)/, '[$1]'), 'g');
    function slug(s) { return String(s).toLowerCase().normalize('NFD').replace(DIACRITICS_RE, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''); }
  %>
</head>
<body>
  <% if (!company) { %>
    <div class="menu-notfound">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
      <h1>Cardápio não encontrado</h1>
      <p>Verifique o link ou peça um novo QR code ao estabelecimento.</p>
    </div>
  <% } else { %>
    <div class="menu-page">
      <div class="menu-hero">
        <span class="menu-hero-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/></svg>
          Cardápio digital
        </span>
        <h1><%= company.name ?? 'Cardápio' %></h1>
        <% if (categories.length) { %>
        <p><%= categories.reduce((n, c) => n + c.items.length, 0) %> itens em <%= categories.length %> categoria<%= categories.length === 1 ? '' : 's' %></p>
        <% } %>
      </div>

      <% if (!categories.length) { %>
        <div class="menu-empty show">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg>
          <p>Nenhum item disponível no cardápio no momento.</p>
        </div>
      <% } else { %>
        <div class="menu-search-wrap">
          <div class="menu-search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="search" id="menuSearch" placeholder="Buscar no cardápio…" autocomplete="off">
          </div>
        </div>

        <% if (categories.length > 1) { %>
        <nav class="menu-nav" id="menuNav">
          <% categories.forEach(function(cat) { %>
          <a href="#cat-<%= slug(cat.name) %>" data-target="cat-<%= slug(cat.name) %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- iconFor(cat.name) %></svg>
            <%= cat.name %>
          </a>
          <% }); %>
        </nav>
        <% } %>

        <div class="menu-body" id="menuBody">
          <% categories.forEach(function(cat) { var a = accentFor(cat.name); %>
            <div class="menu-category" id="cat-<%= slug(cat.name) %>" data-category>
              <div class="menu-category-head">
                <span class="menu-category-icon" style="background:<%- a.bg %>;color:<%- a.hue %>">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- iconFor(cat.name) %></svg>
                </span>
                <h2><%= cat.name %></h2>
                <span class="menu-category-count">· <%= cat.items.length %></span>
              </div>
              <% cat.items.forEach(function(item, idx) { %>
                <div class="menu-item" data-item data-search="<%= (item.name + ' ' + (item.description || '')).toLowerCase() %>" style="animation-delay:<%= Math.min(idx, 6) * 0.04 %>s">
                  <div class="menu-item-main">
                    <div class="menu-item-name"><%= item.name %></div>
                    <% if (item.description) { %><div class="menu-item-desc"><%= item.description %></div><% } %>
                  </div>
                  <span class="menu-item-leader"></span>
                  <div class="menu-item-price"><%= (item.price_cents / 100).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></div>
                </div>
              <% }); %>
            </div>
          <% }); %>
        </div>

        <div class="menu-no-results">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <p>Nada encontrado. Tente outro termo.</p>
        </div>
      <% } %>

      <div class="menu-footer">
        <span class="mark">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/></svg>
          Kivo
        </span>
        <div style="margin-top:2px">Cardápio gerado pelo Kivo</div>
      </div>
    </div>

    <button type="button" class="menu-top-btn" id="menuTopBtn" aria-label="Voltar ao topo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </button>

    <script>
    (function () {
      var search = document.getElementById('menuSearch');
      var cats = [].slice.call(document.querySelectorAll('[data-category]'));
      var noResults = document.querySelector('.menu-no-results');

      if (search) {
        search.addEventListener('input', function () {
          var q = search.value.trim().toLowerCase();
          var anyVisible = false;
          cats.forEach(function (cat) {
            var catItems = [].slice.call(cat.querySelectorAll('[data-item]'));
            var visibleCount = 0;
            catItems.forEach(function (it) {
              var match = !q || it.getAttribute('data-search').indexOf(q) !== -1;
              it.style.display = match ? '' : 'none';
              if (match) visibleCount++;
            });
            cat.style.display = visibleCount ? '' : 'none';
            if (visibleCount) anyVisible = true;
          });
          noResults.classList.toggle('show', !anyVisible && q.length > 0);
        });
      }

      // realce da categoria ativa no menu de navegação, conforme a rolagem
      var navLinks = [].slice.call(document.querySelectorAll('#menuNav a'));
      if (navLinks.length && 'IntersectionObserver' in window) {
        var byId = {};
        navLinks.forEach(function (a) { byId[a.dataset.target] = a; });
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            var link = byId[entry.target.id];
            if (!link) return;
            if (entry.isIntersecting) {
              navLinks.forEach(function (a) { a.classList.remove('active'); });
              link.classList.add('active');
              // só rola a tira horizontal de categorias (nunca a página) — scrollIntoView()
              // aqui mexeria no scroll vertical também, já que o nav é sticky, e ficava
              // brigando com a rolagem natural do usuário.
              var navEl = document.getElementById('menuNav');
              if (navEl) {
                var target = link.offsetLeft - navEl.clientWidth / 2 + link.clientWidth / 2;
                navEl.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
              }
            }
          });
        }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
        cats.forEach(function (c) { observer.observe(c); });
      }

      // botão flutuante "voltar ao topo"
      var topBtn = document.getElementById('menuTopBtn');
      if (topBtn) {
        window.addEventListener('scroll', function () {
          topBtn.classList.toggle('show', window.scrollY > 480);
        }, { passive: true });
        topBtn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    })();
    </script>
  <% } %>
</body>
</html>
