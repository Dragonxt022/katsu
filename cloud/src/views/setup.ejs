<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%- include('partials/theme-init') %>
  <title>Kivo Cloud — Configuração Inicial</title>
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg">
  <%- include('partials/styles') %>
  <link rel="stylesheet" href="/css/setup.css">
</head>
<body>
  <div class="card login-card">
    <div class="brand"><img id="brand-logo" src="/logo_kivo-icon.svg" alt=""> Kivo Cloud</div>
    <p class="note">Nenhum administrador cadastrado. Crie o primeiro acesso.</p>
    <% if (error) { %><p class="error-banner"><%= error %></p><% } %>
    <form method="post" action="/admin/setup">
      <label>Usuário</label>
      <input type="text" name="username" required autofocus>
      <label>Senha</label>
      <input type="password" name="password" required>
      <label>Confirmar senha</label>
      <input type="password" name="password_confirm" required>
      <button type="submit" class="btn">Criar administrador</button>
    </form>
  </div>
  <script>
    if (document.documentElement.getAttribute('data-theme') === 'dark') {
      document.getElementById('brand-logo').src = '/logo_kivo-icon_branco.svg';
    }
  </script>
</body>
</html>
