<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%- include('partials/theme-init') %>
  <title>Kivo Cloud — Ticket #<%= ticket.id %></title>
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg">
  <%- include('partials/styles') %>
  <link rel="stylesheet" href="/css/support-detail.css">
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'support' }) %>
    <main class="content">
      <%- include('partials/navbar', { active: 'support' }) %>

      <div class="page" x-data="chatDetail()" x-init="init()">
        <div class="page-header" style="flex-wrap: wrap; gap: .75rem;">
          <h1 style="display:flex; align-items:center; gap:.6rem;">
            Ticket #<%= ticket.id %> — <span x-text="subject"><%= ticket.subject %></span>
            <span class="badge" :class="statusBadge" x-text="statusLabel"><%= ticket.status %></span>
          </h1>
          <div style="display:flex; gap:.5rem;">
            <form method="post" action="/admin/support/<%= ticket.id %>/status" x-show="status !== 'aberto'"><input type="hidden" name="status" value="aberto"><button class="btn small" type="submit">Reabrir</button></form>
            <form method="post" action="/admin/support/<%= ticket.id %>/status" x-show="status === 'aberto'"><input type="hidden" name="status" value="fechado"><button class="btn secondary small" type="submit">Fechar</button></form>
            <form method="post" action="/admin/support/<%= ticket.id %>/status" x-show="status !== 'arquivado'"><input type="hidden" name="status" value="arquivado"><button class="btn secondary small" type="submit">Arquivar</button></form>
          </div>
        </div>

        <div class="ticket-meta">
          <div class="ticket-meta-item">
            <div class="ticket-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div class="ticket-meta-body">
              <span class="label">Empresa</span>
              <span class="value"><a href="/admin/companies/<%= ticket.company_uuid %>"><%= ticket.company_name || ticket.company_uuid %></a></span>
            </div>
          </div>
          <div class="ticket-meta-item">
            <div class="ticket-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <div class="ticket-meta-body">
              <span class="label">Categoria</span>
              <span class="value"><%= ticket.category %></span>
            </div>
          </div>
          <div class="ticket-meta-item">
            <div class="ticket-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="ticket-meta-body">
              <span class="label">Aberto por</span>
              <span class="value"><%= ticket.created_by || '—' %></span>
            </div>
          </div>
          <div class="ticket-meta-item">
            <div class="ticket-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="ticket-meta-body">
              <span class="label">Criado em</span>
              <span class="value"><%= String(ticket.created_at).slice(0, 16) %></span>
            </div>
          </div>
          <a href="/admin/support" class="back-link">← Voltar para a lista</a>
        </div>

        <div class="card" style="padding: 0;">
          <div class="chat-thread" id="thread" x-ref="thread">
            <template x-for="m in messages" :key="m.id">
              <div class="chat-row" :class="m.sender === 'suporte' ? 'suporte' : 'cliente'">
                <div class="chat-avatar" :class="m.sender === 'suporte' ? 'suporte' : 'cliente'" x-text="(m.sender === 'suporte' ? 'S' : 'C')"></div>
                <div class="chat-bubble" :class="m.sender === 'suporte' ? 'suporte' : 'cliente'">
                  <div x-text="m.body" x-show="m.body"></div>
                  <div x-show="m.attachment">
                    <a :href="m.attachment" target="_blank" rel="noopener"><img :src="m.attachment" alt="Print anexado" style="max-width: 260px; max-height: 260px; border-radius: 8px; display: block; margin-top: .4rem;"></a>
                  </div>
                  <div class="meta" x-text="(m.sender === 'suporte' ? 'Suporte' : 'Cliente') + (m.sender_name ? ' · ' + m.sender_name : '') + ' · ' + (m.created_at || '').slice(0, 16)"></div>
                </div>
              </div>
            </template>
            <template x-if="!messages.length">
              <div style="text-align:center;color:var(--muted);padding:2rem;">Nenhuma mensagem ainda — aguardando resposta.</div>
            </template>
          </div>
          <form class="reply-row" method="post" action="/admin/support/<%= ticket.id %>/reply">
            <textarea name="body" required maxlength="4000"
                      placeholder="<%= ticket.status === 'arquivado' ? 'Este ticket está arquivado. Reabra para enviar uma resposta.' : 'Digite sua resposta…' %>"
                      x-bind:disabled="status === 'arquivado'"></textarea>
            <button class="btn" type="submit" x-bind:disabled="status === 'arquivado'">Responder</button>
          </form>
        </div>
      </div>
    </main>
  </div>
  <script>
    var ticketId = <%= ticket.id %>;
    var thread = document.getElementById('thread');
    thread.scrollTop = thread.scrollHeight;

    function chatDetail() {
      return {
        ticketId: ticketId,
        subject: '<%= ticket.subject.replace(/'/g, "\\'") %>',
        status: '<%= ticket.status %>',
        messages: <%- JSON.stringify(messages) %>,
        pollTimer: null,

        init() {
          this.startPolling();
        },
        get statusBadge() {
          return this.status;
        },
        get statusLabel() {
          return this.status === 'aberto' ? 'aberto' : this.status === 'fechado' ? 'fechado' : 'arquivado';
        },
        startPolling() {
          var self = this;
          this.pollTimer = setInterval(function () {
            fetch('/admin/support/api/tickets/' + self.ticketId + '/messages', { credentials: 'same-origin' })
              .then(function (r) { return r.ok ? r.json() : null; })
              .then(function (d) {
                if (!d) return;
                self.subject = d.ticket.subject;
                self.status = d.ticket.status;
                var atBottom = self.isThreadAtBottom();
                var grew = (d.messages || []).length !== self.messages.length;
                self.messages = d.messages || [];
                if (grew && atBottom) self.$nextTick(function () { self.scrollThread(); });
              })
              .catch(function () {});
          }, 5000);
        },
        isThreadAtBottom() {
          var el = this.$refs.thread;
          return !el || el.scrollHeight - el.scrollTop - el.clientHeight < 80;
        },
        scrollThread() {
          var el = this.$refs.thread;
          if (el) el.scrollTop = el.scrollHeight;
        },
        destroy() {
          if (this.pollTimer) clearInterval(this.pollTimer);
        },
      };
    }
  </script>
</body>
</html>
