<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <%- include('partials/theme-init') %>
  <title>Kivo Cloud — Banco de imagens</title>
  <link rel="icon" type="image/svg+xml" href="/logo_kivo-icon.svg">
  <%- include('partials/styles') %>
  <script defer src="/vendor/alpine.min.js"></script>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'catalog' }) %>
    <main class="content">
      <%- include('partials/navbar', { active: 'catalog' }) %>

      <%
        function formatBytes(n) {
          if (!n) return '0 KB';
          if (n < 1024 * 1024) return Math.round(n / 1024) + ' KB';
          if (n < 1024 * 1024 * 1024) return (n / (1024 * 1024)).toFixed(1) + ' MB';
          return (n / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
        }
      %>

      <div class="page">
        <div class="page-header">
          <h1>Banco de imagens</h1>
          <div style="display:flex; gap:8px;">
            <% if (images.length > 0) { %>
              <button class="btn danger" onclick="openDeleteAllModal()">Apagar todas</button>
            <% } else { %>
              <button class="btn danger" disabled title="Nenhuma imagem para apagar">Apagar todas</button>
            <% } %>
            <button class="btn" onclick="openUploadModal()">+ Adicionar imagem(ns)</button>
          </div>
        </div>

        <div class="card">
          <div class="stat-row">
            <div class="stat"><div class="value"><%= stats.pending %></div><div class="label">Pendentes</div></div>
            <div class="stat"><div class="value"><%= stats.approved %></div><div class="label">Aprovadas</div></div>
            <div class="stat"><div class="value"><%= stats.rejected %></div><div class="label">Rejeitadas (histórico)</div></div>
            <div class="stat"><div class="value"><%= formatBytes(stats.storageBytes) %></div><div class="label">Espaço em disco</div></div>
          </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-banner"><%= error %></div>
        <% } %>
        <% if (typeof deleted !== 'undefined' && deleted) { %>
          <div class="success-banner"><%= deleted %> imagem(ns) removida(s) com sucesso.</div>
        <% } %>

        <div class="catalog-tabs" style="display: flex; gap: 8px; margin-bottom: 20px;">
          <a href="/admin/catalog?status=pendente" class="btn secondary <%= activeStatus === 'pendente' ? 'active' : '' %>">Pendentes (<%= stats.pending %>)</a>
          <a href="/admin/catalog?status=aprovada" class="btn secondary <%= activeStatus === 'aprovada' ? 'active' : '' %>">Aprovadas (<%= stats.approved %>)</a>
        </div>

        <div class="card" style="padding: 0;" x-data="catalogTable()">
          <div style="padding: 16px 20px 0; display: flex; justify-content: flex-end;">
            <input type="text" class="input-search" placeholder="Buscar por produto…" x-model="q">
          </div>

          <% if (activeStatus === 'pendente') { %>
          <div class="batch-bar" x-show="selectedIds.length > 0" x-cloak style="display:flex; align-items:center; gap:8px; padding:10px 20px; background:var(--surface-hover); border-bottom:1px solid var(--border-light);">
            <span style="font-size:0.85rem; font-weight:600;" x-text="selectedIds.length + ' selecionada(s)'"></span>
            <form method="post" action="/admin/catalog/batch-approve" style="display:inline;" @submit.prevent="submitBatch($el, 'approve')">
              <input type="hidden" name="ids" x-model="JSON.stringify(selectedIds)">
              <input type="hidden" name="redirectStatus" value="pendente">
              <button type="submit" class="btn small" style="background:var(--success);color:#fff;">✓ Aprovar selecionadas</button>
            </form>
            <form method="post" action="/admin/catalog/batch-reject" style="display:inline;" @submit.prevent="if (confirm('Rejeitar ' + selectedIds.length + ' imagem(ns)?')) submitBatch($el, 'reject')">
              <input type="hidden" name="ids" x-model="JSON.stringify(selectedIds)">
              <input type="hidden" name="redirectStatus" value="pendente">
              <button type="submit" class="btn small danger">✕ Rejeitar selecionadas</button>
            </form>
          </div>
          <% } %>

          <table>
            <thead><tr>
              <% if (activeStatus === 'pendente') { %>
              <th style="width:40px;">
                <input type="checkbox" @change="toggleAll($event.target.checked)" :checked="selectedIds.length === displayRows.length && displayRows.length > 0">
              </th>
              <% } %>
              <th></th>
              <th class="sortable" @click="sortCycle('product_name')">Produto<span class="sort-arrow" x-text="sortArrow('product_name')"></span></th>
              <th class="sortable" @click="sortCycle('origin')">Origem<span class="sort-arrow" x-text="sortArrow('origin')"></span></th>
              <th class="sortable" @click="sortCycle('size_bytes')">Detalhes<span class="sort-arrow" x-text="sortArrow('size_bytes')"></span></th>
              <th class="sortable" @click="sortCycle('created_at')"><%= activeStatus === 'aprovada' ? 'Aprovada em' : 'Enviada em' %><span class="sort-arrow" x-text="sortArrow('created_at')"></span></th>
              <th style="min-width:140px;"></th>
            </tr></thead>
            <tbody>
              <template x-for="img in displayRows" :key="img.id">
                <tr :class="{ 'row-selected': selectedIds.includes(img.id) }">
                  <% if (activeStatus === 'pendente') { %>
                  <td>
                    <input type="checkbox" :checked="selectedIds.includes(img.id)" @change="toggleOne(img.id, $event.target.checked)">
                  </td>
                  <% } %>
                  <td><img style="width:56px;height:56px;border-radius:8px;object-fit:cover;border:1px solid var(--border-light);background:var(--surface-hover)" :src="'/admin/catalog/' + img.id + '/image'" :alt="img.product_name"></td>
                  <td x-text="img.product_name"></td>
                  <td style="font-size:0.78rem;color:var(--muted)" x-text="img.origin"></td>
                  <td style="font-size:0.78rem;color:var(--muted)" x-text="img.width + '×' + img.height + 'px · ' + img.sizeLabel + ' · ' + img.format"></td>
                  <td style="font-size:0.78rem;color:var(--muted)" x-text="img.created_at"></td>
                  <td class="text-right">
                    <div style="display:flex;gap:4px;justify-content:flex-end;">
                      <a :href="'/admin/catalog/' + img.id + '/image'" download class="btn small secondary" title="Baixar">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      </a>
                      <template x-if="activeStatus === 'pendente'">
                        <>
                          <form method="post" :action="'/admin/catalog/' + img.id + '/approve'" style="display:inline;">
                            <input type="hidden" name="redirectStatus" value="pendente">
                            <button type="submit" class="btn small" style="background:var(--success);color:#fff;" title="Aprovar">✓</button>
                          </form>
                          <form method="post" :action="'/admin/catalog/' + img.id + '/reject'" style="display:inline;" @submit.prevent="if (confirm('Rejeitar e excluir esta imagem?')) $el.submit()">
                            <input type="hidden" name="redirectStatus" value="pendente">
                            <button type="submit" class="btn small danger" title="Rejeitar">✕</button>
                          </form>
                        </>
                      </template>
                      <template x-if="activeStatus !== 'pendente'">
                        <form method="post" :action="'/admin/catalog/' + img.id + '/reject'" style="display:inline;" @submit.prevent="if (confirm('Remover esta imagem do catálogo aprovado?')) $el.submit()">
                          <input type="hidden" name="redirectStatus" value="aprovada">
                          <button type="submit" class="btn small danger">Remover</button>
                        </form>
                      </template>
                    </div>
                  </td>
                </tr>
              </template>
              <tr x-show="!displayRows.length">
                <td colspan="<%= activeStatus === 'pendente' ? 7 : 6 %>">
                  <%- include('partials/empty-state', { message: activeStatus === 'aprovada' ? 'Nenhuma imagem aprovada ainda.' : 'Nenhuma imagem pendente de curadoria.' }) %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <dialog id="modal-manual-upload">
    <div class="modal-header">
      <h2>Adicionar imagens ao catálogo</h2>
      <button type="button" class="modal-close" onclick="closeUploadModal()">&times;</button>
    </div>
    <div class="modal-body">
      <label>Imagens (JPEG, PNG ou WEBP — mínimo 200×200px, máximo 6MB cada)</label>
      <p class="field-hint" style="margin-top:-4px">O nome de cada produto é gerado a partir do nome do arquivo — renomeie os arquivos antes de selecionar se quiser outro nome.</p>
      <div class="drop-zone" id="drop-zone">
        <div class="drop-zone-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
        <div>Arraste imagens aqui ou clique para selecionar</div>
        <div style="font-size: 0.78rem; margin-top: 4px; color: var(--muted);">Pode selecionar várias imagens de uma vez</div>
      </div>
      <input type="file" id="manual-image-file" accept="image/jpeg,image/png,image/webp" multiple style="display:none">

      <div class="upload-preview-grid" id="upload-preview-grid"></div>
      <div class="upload-counter" id="upload-counter" style="display:none">
        <strong id="upload-count-num">0</strong> imagem(ns) selecionada(s)
      </div>

      <p style="color: var(--danger); font-size: 0.85rem; margin-top: 10px; display: none;" id="manual-upload-error"></p>

      <div id="upload-progress" style="display:none; margin-top: 12px;">
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
          <span style="font-size:0.85rem; font-weight:600;" id="upload-progress-text">Enviando...</span>
          <span style="font-size:0.82rem; color:var(--muted);" id="upload-progress-count"></span>
        </div>
        <div style="height:6px; background:var(--surface-hover); border-radius:999px; overflow:hidden;">
          <div id="upload-progress-bar" style="height:100%; background:var(--primary); border-radius:999px; transition: width .3s; width: 0;"></div>
        </div>
      </div>

      <div class="modal-actions" style="margin-top: 16px;">
        <button type="button" class="btn secondary" onclick="closeUploadModal()">Cancelar</button>
        <button type="button" class="btn" id="manual-upload-submit" onclick="submitAllUploads()">Adicionar ao catálogo</button>
      </div>
    </div>
  </dialog>

  <dialog id="modal-delete-all">
    <div class="modal-header">
      <h2>Apagar imagens do catálogo</h2>
      <button type="button" class="modal-close" onclick="closeDeleteAllModal()">&times;</button>
    </div>
    <div class="modal-body">
      <p>Tem certeza que deseja apagar <strong id="delete-all-count">0</strong> imagem(ns) da aba <strong id="delete-all-status-label">Pendentes</strong>?</p>
      <p style="color: var(--danger); font-size: 0.85rem; margin-top: 8px;">Esta ação não pode ser desfeita. Os arquivos serão removidos permanentemente do disco.</p>

      <div style="margin-top: 16px;">
        <label style="font-size: 0.85rem; font-weight: 600;">Digite <strong>APAGAR</strong> para confirmar:</label>
        <input type="text" id="delete-all-confirm-input" class="input-search" placeholder="APAGAR" style="margin-top: 6px;" oninput="validateDeleteAllInput()">
      </div>

      <div class="modal-actions" style="margin-top: 16px;">
        <button type="button" class="btn secondary" onclick="closeDeleteAllModal()">Cancelar</button>
        <form method="post" action="/admin/catalog/delete-all" id="delete-all-form" style="display:inline;">
          <input type="hidden" name="status" id="delete-all-status-field" value="">
          <button type="submit" class="btn danger" id="delete-all-submit-btn" disabled>Apagar todas</button>
        </form>
      </div>
    </div>
  </dialog>

  <script src="/js/table-toolkit.js"></script>
  <script>
    function catalogTable() {
      return {
        ...tableToolkit(),
        selectedIds: [],
        activeStatus: <%- JSON.stringify(activeStatus) %>,
        rows: <%- JSON.stringify(images.map(function (img) {
          return {
            id: img.id, product_name: img.product_name, format: img.format,
            width: img.width, height: img.height, created_at: img.created_at,
            sizeLabel: formatBytes(img.size_bytes),
            origin: img.source === 'manual' ? 'Manual' : (img.company_uuid ? img.company_uuid.slice(0, 8) + '…' : '—'),
          };
        })) %>,
        q: '',
        sortGetters: {
          product_name: (i) => i.product_name, origin: (i) => i.origin,
          size_bytes: (i) => i.width * i.height, created_at: (i) => i.created_at ?? '',
        },
        get displayRows() {
          const q = this.q.trim().toLowerCase();
          const filtered = q ? this.rows.filter((i) => i.product_name.toLowerCase().includes(q)) : this.rows;
          return this.sortedRows(filtered, this.sortGetters);
        },
        toggleAll(checked) {
          this.selectedIds = checked ? this.displayRows.map((i) => i.id) : [];
        },
        toggleOne(id, checked) {
          if (checked) {
            if (!this.selectedIds.includes(id)) this.selectedIds.push(id);
          } else {
            this.selectedIds = this.selectedIds.filter((sid) => sid !== id);
          }
        },
      };
    }

    function submitBatch(form, action) {
      var ids = JSON.parse(form.querySelector('[name="ids"]').value);
      if (!ids.length) return;
      form.querySelector('[name="ids"]').value = ids.join(',');
      form.submit();
    }

    var pendingFiles = [];

    function nameFromFilename(filename) {
      return filename.replace(/\.[^.]+$/, '').replace(/[_-]+/g, ' ').trim();
    }

    function openUploadModal() {
      pendingFiles = [];
      document.getElementById('upload-preview-grid').innerHTML = '';
      document.getElementById('upload-counter').style.display = 'none';
      document.getElementById('manual-upload-error').style.display = 'none';
      document.getElementById('upload-progress').style.display = 'none';
      document.getElementById('manual-upload-submit').disabled = false;
      document.getElementById('manual-upload-submit').textContent = 'Adicionar ao catálogo';
      document.getElementById('modal-manual-upload').showModal();
    }

    function closeUploadModal() {
      document.getElementById('modal-manual-upload').close();
      pendingFiles = [];
    }

    function renderPreviews() {
      var grid = document.getElementById('upload-preview-grid');
      var counter = document.getElementById('upload-counter');
      grid.innerHTML = '';
      if (!pendingFiles.length) {
        counter.style.display = 'none';
        return;
      }
      counter.style.display = 'block';
      document.getElementById('upload-count-num').textContent = pendingFiles.length;
      pendingFiles.forEach(function (f, i) {
        var div = document.createElement('div');
        div.className = 'upload-preview-item';
        var img = document.createElement('img');
        img.src = URL.createObjectURL(f);
        var caption = document.createElement('div');
        caption.className = 'upload-preview-name';
        caption.textContent = nameFromFilename(f.name);
        caption.title = f.name;
        var btn = document.createElement('button');
        btn.className = 'remove-btn';
        btn.type = 'button';
        btn.textContent = '×';
        btn.onclick = function () {
          pendingFiles.splice(i, 1);
          renderPreviews();
        };
        div.appendChild(img);
        div.appendChild(caption);
        div.appendChild(btn);
        grid.appendChild(div);
      });
    }

    var dropZone = document.getElementById('drop-zone');
    var fileInput = document.getElementById('manual-image-file');

    dropZone.addEventListener('click', function () { fileInput.click(); });

    dropZone.addEventListener('dragover', function (e) {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });
    dropZone.addEventListener('dragleave', function () {
      dropZone.classList.remove('dragover');
    });
    dropZone.addEventListener('drop', function (e) {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      var files = Array.from(e.dataTransfer.files).filter(function (f) {
        return ['image/jpeg', 'image/png', 'image/webp'].indexOf(f.type) !== -1;
      });
      if (files.length) {
        pendingFiles = pendingFiles.concat(files);
        renderPreviews();
      }
    });

    fileInput.addEventListener('change', function (e) {
      var files = Array.from(e.target.files);
      if (files.length) {
        pendingFiles = pendingFiles.concat(files);
        renderPreviews();
      }
      fileInput.value = '';
    });

    var uploading = false;

    async function submitAllUploads() {
      if (uploading) return;
      var errorEl = document.getElementById('manual-upload-error');
      errorEl.style.display = 'none';
      if (!pendingFiles.length) {
        errorEl.textContent = 'Selecione ao menos uma imagem.';
        errorEl.style.display = 'block';
        return;
      }

      uploading = true;
      var btn = document.getElementById('manual-upload-submit');
      btn.disabled = true;
      btn.textContent = 'Enviando...';

      var progressEl = document.getElementById('upload-progress');
      var barEl = document.getElementById('upload-progress-bar');
      var textEl = document.getElementById('upload-progress-text');
      var countEl = document.getElementById('upload-progress-count');
      progressEl.style.display = 'block';

      var total = pendingFiles.length;
      var ok = 0;
      var fail = 0;
      var errors = [];

      for (var i = 0; i < total; i++) {
        countEl.textContent = (i + 1) + '/' + total;
        textEl.textContent = 'Enviando ' + (i + 1) + ' de ' + total + '...';
        barEl.style.width = Math.round(((i) / total) * 100) + '%';

        try {
          var buf = await pendingFiles[i].arrayBuffer();
          var res = await fetch('/admin/catalog/manual', {
            method: 'POST',
            headers: { 'Content-Type': pendingFiles[i].type, 'X-Kivo-Product-Name': nameFromFilename(pendingFiles[i].name) },
            body: buf,
          });
          if (res.ok) {
            ok++;
          } else {
            var data = await res.json().catch(function () { return { error: 'HTTP ' + res.status }; });
            fail++;
            errors.push(pendingFiles[i].name + ': ' + (data.error || 'Erro ' + res.status));
          }
        } catch (e) {
          fail++;
          errors.push(pendingFiles[i].name + ': Erro de rede');
        }
      }

      barEl.style.width = '100%';
      textEl.textContent = 'Concluído!';

      if (fail > 0 && ok === 0) {
        errorEl.textContent = 'Falha em todas: ' + errors.join('; ');
        errorEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Adicionar ao catálogo';
        uploading = false;
        return;
      }

      if (fail > 0) {
        window.location.href = '/admin/catalog?upload_ok=' + ok + '&upload_fail=' + fail;
      } else {
        window.location.href = '/admin/catalog';
      }
    }

    var deleteAllCount = <%= images.length %>;
    var deleteAllStatus = '<%= activeStatus %>';

    function openDeleteAllModal() {
      document.getElementById('delete-all-count').textContent = deleteAllCount;
      document.getElementById('delete-all-status-label').textContent = deleteAllStatus === 'aprovada' ? 'Aprovadas' : 'Pendentes';
      document.getElementById('delete-all-status-field').value = deleteAllStatus;
      document.getElementById('delete-all-confirm-input').value = '';
      document.getElementById('delete-all-submit-btn').disabled = true;
      document.getElementById('modal-delete-all').showModal();
    }

    function closeDeleteAllModal() {
      document.getElementById('modal-delete-all').close();
    }

    function validateDeleteAllInput() {
      var val = document.getElementById('delete-all-confirm-input').value.trim().toUpperCase();
      document.getElementById('delete-all-submit-btn').disabled = val !== 'APAGAR';
    }
  </script>
</body>
</html>
