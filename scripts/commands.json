  "cloud:install": {
    "description": "Instalar dependências do cloud/",
    "run": "npm --prefix cloud install"
  },
  "cloud:migrate": {
    "description": "Rodar migrations do cloud/",
    "run": "npm --prefix cloud run migrate"
  },
  "cloud:dev": {
    "description": "Iniciar servidor cloud em dev",
    "run": "npm --prefix cloud run dev"
  },
  "cloud:deploy": {
    "description": "Fazer deploy do cloud/ (Linux/CI)",
    "run": "bash scripts/deploy-cloud.sh"
  },
  "postinstall": {
    "description": "Pós-instalação (copiar Alpine.js local)",
    "run": "node -e \"require('fs').cpSync(require.resolve('alpinejs/dist/cdn.min.js'), 'src/public/vendor/alpine.min.js')\""
  }
