{
  "dev": {
    "description": "Servidor Express sem Electron",
    "pre": "node scripts/ensure-native-abi.js node",
    "run": "tsx src/dev.ts"
  },
  "dev:electron": {
    "description": "App Electron completo",
    "pre": "tsc -p tsconfig.json && node scripts/copy-build-assets.js",
    "run": "electron ."
  },
  "build": {
    "description": "Compilar TypeScript + copiar assets",
    "run": "tsc -p tsconfig.json && node scripts/copy-build-assets.js"
  },
  "rebuild:electron": {
    "description": "Recompilar better-sqlite3 para Electron ABI",
    "run": "electron-rebuild -f -w better-sqlite3"
  },
  "verify:native": {
    "description": "Verificar compatibilidade ABI dos módulos nativos",
    "run": "node scripts/verify-native-abi.js"
  },
  "dist:win": {
    "description": "Gerar instalador Windows (NSIS)",
    "pre": "tsc -p tsconfig.json && node scripts/copy-build-assets.js",
    "run": "electron-rebuild -f -w better-sqlite3 && node scripts/verify-native-abi.js && electron-builder --win"
  },
  "release:win": {
    "description": "Gerar e publicar release no GitHub",
    "pre": "tsc -p tsconfig.json && node scripts/copy-build-assets.js",
    "run": "electron-rebuild -f -w better-sqlite3 && node scripts/verify-native-abi.js && electron-builder --win --publish always"
  },
  "lint": {
    "description": "ESLint — verificar código",
    "run": "eslint src"
  },
  "format": {
    "description": "Prettier — formatar código",
    "run": "prettier --write \"src/**/*.ts\""
  },
  "db:migrate": {
    "description": "Rodar migrations pendentes",
    "run": "tsx src/core/database/cli.ts up"
  },
  "db:rollback": {
    "description": "Reverter última migration",
    "run": "tsx src/core/database/cli.ts down"
  },
  "db:reset": {
    "description": "Resetar banco de dados de teste",
    "run": "tsx src/core/database/cli.ts reset"
  },
  "db:seed:demo": {
    "description": "Popular dados de demonstração (~30 dias)",
    "run": "tsx src/core/database/cli.ts seed-demo"
  },
  "db:status": {
    "description": "Exibir status das migrations",
    "run": "tsx src/core/database/cli.ts status"
  },
  "smoke": {
    "description": "Smoke test (health check + hello)",
    "run": "tsx src/dev.ts --smoke"
  },
  "test": {
    "description": "Rodar todos os testes de integração",
    "run": "katsu test:all"
  },
  "test:shared": {
    "description": "Testes de utilitários compartilhados",
    "run": "tsx src/tests/shared.ts"
  },
