{
  "name": "katsu",
  "version": "0.1.0",
  "description": "Katsu — plataforma comercial modular desktop-first",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx src/dev.ts",
    "dev:electron": "electron .",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "tsx src/core/database/cli.ts up",
    "db:rollback": "tsx src/core/database/cli.ts down",
    "db:status": "tsx src/core/database/cli.ts status",
    "smoke": "tsx src/dev.ts --smoke"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^36.0.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0"
  }
}
