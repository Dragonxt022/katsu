{
  "name": "katsu",
  "version": "0.2.0",
  "description": "Katsu — plataforma comercial modular desktop-first",
  "author": "Katsu",
  "private": true,
  "main": "dist/electron/bootstrap.js",
  "scripts": {
    "dev": "node scripts/katsu dev",
    "dev:electron": "node scripts/katsu dev:electron",
    "build": "node scripts/katsu build",
    "dist:win": "node scripts/katsu dist:win",
    "release:win": "node scripts/katsu release:win",
    "lint": "node scripts/katsu lint",
    "format": "node scripts/katsu format",
    "smoke": "node scripts/katsu smoke",
    "test": "node scripts/katsu test",
    "postinstall": "node scripts/katsu postinstall",
    "katsu": "node scripts/katsu"
  },
  "dependencies": {
    "alpinejs": "^3.14.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.44.0",
    "ejs": "^3.1.10",
    "electron-updater": "^6.8.9",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "morgan": "^1.11.0",
    "node-machine-id": "^1.1.12",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "c8": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "playwright": "^1.61.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0"
  },
  "build": {
    "appId": "com.katsu.desktop",
    "productName": "Katsu",
    "asar": false,
    "files": [
      "dist/**/*",
      "drizzle/migrations/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "Dragonxt022",
      "repo": "katsu",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    }
  }
}
